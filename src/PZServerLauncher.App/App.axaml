            <Setter Property="BorderBrush" Value="#6B8CF0CC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.pill-soft-neutral">
            <Setter Property="Background" Value="#14FFFFFF" />
            <Setter Property="BorderBrush" Value="#24FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.pill-text-light">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#EDF4FF" />
            <Setter Property="LineHeight" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.pill-text-green">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#8CF0CC" />
            <Setter Property="LineHeight" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.pill-text-neutral">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#C9D5EA" />
            <Setter Property="LineHeight" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="#A6030810" />
            <Setter Property="Foreground" Value="#EDF4FF" />
            <Setter Property="BorderBrush" Value="#2E405F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12,9" />
            <Setter Property="SelectionBrush" Value="#664FD8A9" />
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#8CF0CC" />
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="#A6030810" />
            <Setter Property="Foreground" Value="#EDF4FF" />
