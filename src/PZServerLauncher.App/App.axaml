        <Style Selector="Button.action-danger:disabled">
            <Setter Property="Background" Value="#C99E92" />
            <Setter Property="Foreground" Value="#FFF7F4" />
            <Setter Property="BorderBrush" Value="#C99E92" />
            <Setter Property="Opacity" Value="1" />
