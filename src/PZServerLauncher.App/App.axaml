        </Style>
        <Style Selector="Button.action-primary:disabled">
            <Setter Property="Background" Value="#93A99F" />
            <Setter Property="Foreground" Value="#F4F6F3" />
            <Setter Property="BorderBrush" Value="#93A99F" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Button.action-secondary:disabled">
            <Setter Property="Background" Value="#E8E2D8" />
            <Setter Property="Foreground" Value="#5A6367" />
            <Setter Property="BorderBrush" Value="#C9BEB0" />
