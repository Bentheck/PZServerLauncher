            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="CheckBox:disabled">
            <Setter Property="Foreground" Value="#6A7276" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="CheckBox:disabled /template/ ContentPresenter">
            <Setter Property="Foreground" Value="#6A7276" />
