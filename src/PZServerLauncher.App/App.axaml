<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PZServerLauncher.App.App"
             xmlns:local="using:PZServerLauncher.App"
             RequestedThemeVariant="Default">
    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <Style Selector="Window">
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#F7F4EE" Offset="0" />
                    <GradientStop Color="#EEE8DE" Offset="0.58" />
                    <GradientStop Color="#E4DDD2" Offset="1" />
                </LinearGradientBrush>
            </Setter>
        </Style>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#FFFDFC" />
            <Setter Property="BorderBrush" Value="#D7CDBF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="BoxShadow" Value="0 12 32 0 #160E0814" />
        </Style>
        <Style Selector="Border.surface-dark">
            <Setter Property="Background" Value="#243238" />
            <Setter Property="BorderBrush" Value="#38515A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="BoxShadow" Value="0 18 42 0 #1A11111A" />
        </Style>
        <Style Selector="Border.surface-soft">
            <Setter Property="Background" Value="#F5F0E7" />
            <Setter Property="BorderBrush" Value="#D9CCBA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>
        <Style Selector="Border.metric-card">
            <Setter Property="Background" Value="#FAF7F2" />
            <Setter Property="BorderBrush" Value="#DDD2C6" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
        </Style>
        <Style Selector="Border.callout-card">
            <Setter Property="Background" Value="#F2EEE7" />
            <Setter Property="BorderBrush" Value="#D8CDC1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
        </Style>
        <Style Selector="Border.command-card">
            <Setter Property="Background" Value="#2A383F" />
            <Setter Property="BorderBrush" Value="#3F565F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1F1D1B" />
        </Style>
        <Style Selector="TextBlock.panel-title">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1D2326" />
        </Style>
        <Style Selector="TextBlock.kicker">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#4C7B63" />
        </Style>
        <Style Selector="TextBlock.body">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Foreground" Value="#3A4548" />
        </Style>
        <Style Selector="TextBlock.caption">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#6B6F72" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="TextBox.code-preview">
            <Setter Property="FontFamily" Value="Cascadia Code,Consolas,monospace" />
            <Setter Property="Background" Value="#1F2428" />
            <Setter Property="Foreground" Value="#EDF2F7" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="MinHeight" Value="140" />
        </Style>
        <Style Selector="Button.action-primary">
            <Setter Property="Background" Value="#355B4C" />
            <Setter Property="Foreground" Value="#F7F8F6" />
            <Setter Property="BorderBrush" Value="#355B4C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,9" />
        </Style>
        <Style Selector="Button.action-secondary">
            <Setter Property="Background" Value="#F4F0E8" />
            <Setter Property="Foreground" Value="#2F3A3E" />
            <Setter Property="BorderBrush" Value="#CFC5B7" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,9" />
        </Style>
        <Style Selector="Button.action-danger">
            <Setter Property="Background" Value="#B55E46" />
            <Setter Property="Foreground" Value="#FFF6F1" />
            <Setter Property="BorderBrush" Value="#B55E46" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,9" />
        </Style>
    </Application.Styles>
</Application>
