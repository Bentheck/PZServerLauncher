            <Setter Property="Foreground" Value="#FFF6F1" />
            <Setter Property="BorderBrush" Value="#8A4030" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Button.action-primary:pointerover /template/ ContentPresenter">
            <Setter Property="Foreground" Value="#F7F8F6" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Button.action-secondary:pointerover /template/ ContentPresenter">
            <Setter Property="Foreground" Value="#2F3A3E" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Button.action-danger:pointerover /template/ ContentPresenter">
            <Setter Property="Foreground" Value="#FFF6F1" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Button.action-primary:pressed">
            <Setter Property="Background" Value="#315444" />
            <Setter Property="Foreground" Value="#F7F8F6" />
            <Setter Property="BorderBrush" Value="#20382D" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Button.action-secondary:pressed">
            <Setter Property="Background" Value="#D9C8B3" />
            <Setter Property="Foreground" Value="#2F3A3E" />
            <Setter Property="BorderBrush" Value="#86715B" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Button.action-danger:pressed">
            <Setter Property="Background" Value="#A14D38" />
            <Setter Property="Foreground" Value="#FFF6F1" />
            <Setter Property="BorderBrush" Value="#773424" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Button.action-primary:pressed /template/ ContentPresenter">
            <Setter Property="Foreground" Value="#F7F8F6" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Button.action-secondary:pressed /template/ ContentPresenter">
            <Setter Property="Foreground" Value="#2F3A3E" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Button.action-danger:pressed /template/ ContentPresenter">
            <Setter Property="Foreground" Value="#FFF6F1" />
