            <Setter Property="Foreground" Value="#F7F8F6" />
            <Setter Property="BorderBrush" Value="#2D4F40" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Button.action-secondary:pointerover">
