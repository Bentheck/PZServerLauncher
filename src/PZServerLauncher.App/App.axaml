            <Setter Property="Foreground" Value="#2F3A3E" />
            <Setter Property="BorderBrush" Value="#9C886F" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Button.action-danger:pointerover">
