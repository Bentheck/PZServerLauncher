            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="12,9" />
        </Style>
        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#EDF4FF" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="TextBox.code-preview">
            <Setter Property="FontFamily" Value="Cascadia Code,Consolas,monospace" />
            <Setter Property="Background" Value="#1F2428" />
            <Setter Property="Foreground" Value="#EDF2F7" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="MinHeight" Value="140" />
        </Style>
        <Style Selector="TextBox.console-stream">
            <Setter Property="FontFamily" Value="Cascadia Code,Consolas,monospace" />
            <Setter Property="Background" Value="#171310" />
            <Setter Property="Foreground" Value="#E9DED2" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextAlignment" Value="Left" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="#C9D5EA" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Background" Value="#101B2D" />
            <Setter Property="BorderBrush" Value="#4A5D7A" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="CheckBox /template/ ContentPresenter">
            <Setter Property="Foreground" Value="#C9D5EA" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="CheckBox /template/ Border">
            <Setter Property="Background" Value="#101B2D" />
            <Setter Property="BorderBrush" Value="#4A5D7A" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="CheckBox:pointerover /template/ Border">
