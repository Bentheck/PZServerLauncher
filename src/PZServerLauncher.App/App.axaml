<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PZServerLauncher.App.App"
             xmlns:local="using:PZServerLauncher.App"
             RequestedThemeVariant="Default">
    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <Style Selector="Window">
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Color="#F6EEE3" Offset="0" />
                    <GradientStop Color="#E3D8CC" Offset="0.48" />
                    <GradientStop Color="#CEC4B8" Offset="1" />
                </LinearGradientBrush>
            </Setter>
        </Style>
        <Style Selector="Border.card">
            <Setter Property="Background" Value="#FCF8F3" />
            <Setter Property="BorderBrush" Value="#D5B79A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="BoxShadow" Value="0 14 36 0 #22000000" />
        </Style>
        <Style Selector="Border.surface-dark">
            <Setter Property="Background" Value="#1F1813" />
            <Setter Property="BorderBrush" Value="#6E5039" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="20" />
            <Setter Property="BoxShadow" Value="0 18 42 0 #301F120F" />
        </Style>
        <Style Selector="Border.surface-soft">
            <Setter Property="Background" Value="#F1E4D6" />
            <Setter Property="BorderBrush" Value="#D6B08C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
        </Style>
        <Style Selector="Border.metric-card">
            <Setter Property="Background" Value="#FFF8F0" />
            <Setter Property="BorderBrush" Value="#D8B694" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
        </Style>
        <Style Selector="TextBlock.section-title">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1F1D1B" />
        </Style>
        <Style Selector="TextBlock.panel-title">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#1F1D1B" />
        </Style>
        <Style Selector="TextBlock.kicker">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#8F4A2A" />
        </Style>
        <Style Selector="TextBlock.body">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Foreground" Value="#3B3733" />
        </Style>
        <Style Selector="TextBlock.caption">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#6A5646" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="TextBox.code-preview">
            <Setter Property="FontFamily" Value="Cascadia Code,Consolas,monospace" />
            <Setter Property="Background" Value="#1F2428" />
            <Setter Property="Foreground" Value="#EDF2F7" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="MinHeight" Value="140" />
        </Style>
    </Application.Styles>
</Application>
