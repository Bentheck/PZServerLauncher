<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1120"
             d:DesignHeight="960"
             x:Class="PZServerLauncher.App.Views.NetworkAndAdminWorkspaceView"
             x:DataType="vm:NetworkAndAdminWorkspaceViewModel">
    <ScrollViewer>
        <Grid RowDefinitions="Auto,Auto,*" RowSpacing="18">
            <Grid ColumnDefinitions="1.42*,340" ColumnSpacing="18">
                <Border Classes="card" Padding="26">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="18">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="kicker" Text="Trust &amp; Access Console" />
                            <TextBlock Classes="panel-title" FontSize="30" Text="{Binding ProfileDisplayName}" />
                            <TextBlock Classes="body"
                                       FontSize="16"
                                       Foreground="#C9D5EA"
                                       Text="{Binding WorkspaceSummary}"
                                       TextWrapping="Wrap" />
                            <TextBlock Classes="caption" Text="{Binding ActionSummary}" TextWrapping="Wrap" />
                            <WrapPanel Margin="0,8,0,0" Orientation="Horizontal" ItemHeight="30">
                                <Border Background="#2A2927" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                    <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding Branch}" />
                                </Border>
                                <Border Background="#14FFFFFF" BorderBrush="#24FFFFFF" BorderThickness="1" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                    <TextBlock Foreground="#C9D5EA" FontSize="11" Text="{Binding AccessHeadline}" />
                                </Border>
                                <Border Background="#14FFFFFF" BorderBrush="#24FFFFFF" BorderThickness="1" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                    <TextBlock Foreground="#C9D5EA" FontSize="11" Text="{Binding TrustHeadline}" />
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                        <Border Grid.Column="1" Classes="metric-card" Padding="16" Width="220">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="kicker" Text="Recovery" />
                                <TextBlock Classes="body" FontWeight="SemiBold" Text="{Binding RecoveryHeadline}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Classes="surface-dark" Padding="18">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Security Watch" />
                        <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#F7F0E7" Text="{Binding OperatorSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Foreground="#C9D5EA" Text="{Binding IdentityAndSafetyHeadline}" TextWrapping="Wrap" />
                        <TextBlock Classes="caption" Foreground="#A8B6D4" Text="{Binding VoiceHeadline}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" ColumnSpacing="14">
                <Border Classes="metric-card" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Access" />
                        <TextBlock Classes="panel-title" FontSize="22" Text="{Binding AccessHeadline}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Classes="metric-card" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Trust" />
                        <TextBlock Classes="panel-title" FontSize="22" Text="{Binding TrustHeadline}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Classes="metric-card" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Identity" />
                        <TextBlock Classes="panel-title" FontSize="22" Text="{Binding IdentityAndSafetyHeadline}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Classes="metric-card" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Voice" />
                        <TextBlock Classes="panel-title" FontSize="22" Text="{Binding VoiceHeadline}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="2" ColumnDefinitions="1.22*,.78*" ColumnSpacing="18">
                <StackPanel Spacing="18">
                    <Border Classes="surface-dark" Padding="22">
                        <Grid ColumnDefinitions="1.08*,.92*" ColumnSpacing="18">
                            <StackPanel Spacing="10">
                                <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Trust Situation" />
                                <TextBlock FontSize="26" FontWeight="SemiBold" Foreground="#F7F0E7" Text="{Binding AccessHeadline}" TextWrapping="Wrap" />
                                <TextBlock Classes="body" Foreground="#C9D5EA" Text="{Binding TrustHeadline}" TextWrapping="Wrap" />
                                <TextBlock Classes="caption" Foreground="#A8B6D4" Text="{Binding RecoveryHeadline}" TextWrapping="Wrap" />
                            </StackPanel>
                            <ItemsControl Grid.Column="1" ItemsSource="{Binding NetworkChecklist}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#14FFFFFF" BorderBrush="#24FFFFFF" BorderThickness="1" CornerRadius="14" Padding="12" Margin="0,0,0,8">
                                            <TextBlock Classes="caption" Foreground="#A8B6D4" Text="{Binding .}" TextWrapping="Wrap" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>

                    <Grid ColumnDefinitions="1.05*,.95*" ColumnSpacing="16" IsEnabled="{Binding CanEdit}">
                        <StackPanel Spacing="16">
                            <Border Classes="card" Padding="18">
                                <StackPanel Spacing="14">
                                    <TextBlock Classes="kicker" Text="Access &amp; Passwords" />
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="body" Text="Bind IP" />
                                        <TextBox Text="{Binding BindIp}" />
                                        <TextBlock Classes="caption" Text="Leave empty for default binding, or set a specific IPv4/IPv6 address." />
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="body" Text="Server Password" />
                                        <TextBox PasswordChar="*" Text="{Binding ServerPassword}" />
                                        <TextBlock Classes="caption" Text="Write-only. Leave blank to keep the existing join password." />
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="body" Text="RCON Password" />
                                        <TextBox PasswordChar="*" Text="{Binding RconPassword}" />
                                        <TextBlock Classes="caption" Text="Write-only. Leave blank to keep the existing remote console password." />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Classes="card" Padding="18">
                                <StackPanel Spacing="14">
                                    <TextBlock Classes="kicker" Text="Compatibility &amp; Discovery" />
                                    <CheckBox Content="Auto Create Whitelist Users" IsChecked="{Binding AutoCreateWhitelistUsers}" />
                                    <CheckBox Content="Enforce Lua Checksum" IsChecked="{Binding DoLuaChecksum}" />
                                    <CheckBox Content="Steam VAC" IsChecked="{Binding SteamVacEnabled}" />
                                    <CheckBox Content="Kick Fast Players" IsChecked="{Binding KickFastPlayers}" />
                                    <CheckBox Content="Deny Login When Overloaded" IsChecked="{Binding DenyLoginWhenOverloaded}" />
                                    <CheckBox Content="Save Player State On Damage" IsChecked="{Binding PlayerSaveOnDamage}" />
                                    <CheckBox Content="Enable UPnP" IsChecked="{Binding UpnpEnabled}" />
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="body" Text="Client Command Filter" />
                                        <TextBox Text="{Binding ClientCommandFilter}" />
                                        <TextBlock Classes="caption" Text="Optional filter for client-issued Lua command traffic." />
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="body" Text="Ping Limit" />
                                        <TextBox Text="{Binding PingLimit}" />
                                        <TextBlock Classes="caption" Text="Players consistently above this limit can be kicked. Use 100 to disable the check." />
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="body" Text="Save World Every Minutes" />
                                        <TextBox Text="{Binding SaveWorldEveryMinutes}" />
                                        <TextBlock Classes="caption" Text="How often the world is flushed to disk. Use 0 to keep the current server default." />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Classes="card" Padding="18">
                                <StackPanel Spacing="14">
                                    <TextBlock Classes="kicker" Text="Identity &amp; PvP Safety" />
                                    <CheckBox Content="Display Username" IsChecked="{Binding DisplayUserName}" />
                                    <CheckBox Content="Show First &amp; Last Name" IsChecked="{Binding ShowFirstAndLastName}" />
                                    <CheckBox Content="Mouse Over To See Display Name" IsChecked="{Binding MouseOverDisplayName}" />
                                    <CheckBox Content="Hide Players Behind You" IsChecked="{Binding HidePlayersBehindYou}" />
                                    <CheckBox Content="Player Bump Player" IsChecked="{Binding PlayerBumpPlayer}" />
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="body" Text="Server Tag" />
                                            <TextBox Text="{Binding ServerTag}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Classes="body" Text="Reset ID" />
                                            <TextBox Text="{Binding ResetId}" />
                                        </StackPanel>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="body" Text="Remote Map Visibility" />
                                            <TextBox Text="{Binding MapRemotePlayerVisibility}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <CheckBox Margin="0,24,0,0"
                                                      Content="Use TCP For Map Traffic"
                                                      IsChecked="{Binding UseTcpForMapTraffic}" />
                                        </StackPanel>
                                    </Grid>
                                    <CheckBox Content="Enable Safety System" IsChecked="{Binding SafetySystem}" />
                                    <CheckBox Content="Show Safety Icon" IsChecked="{Binding ShowSafety}" />
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="body" Text="Safety Toggle Timer" />
                                            <TextBox Text="{Binding SafetyToggleTimer}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Classes="body" Text="Safety Cooldown Timer" />
                                            <TextBox Text="{Binding SafetyCooldownTimer}" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="16">
                            <Border Classes="card" Padding="18">
                                <StackPanel Spacing="14">
                                    <TextBlock Classes="kicker" Text="Account Policy" />
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="body" Text="Max Accounts Per User" />
                                        <TextBox Text="{Binding MaxAccountsPerUser}" />
                                        <TextBlock Classes="caption" Text="Use 0 for unlimited. Higher values allow multiple server accounts per Steam user." />
                                    </StackPanel>
                                    <CheckBox Content="Allow Non-ASCII Usernames" IsChecked="{Binding AllowNonAsciiUsername}" />
                                </StackPanel>
                            </Border>

                            <Border Classes="card" Padding="18">
                                <StackPanel Spacing="14">
                                    <TextBlock Classes="kicker" Text="Voice Chat" />
                                    <CheckBox Content="Enable Voice Chat" IsChecked="{Binding VoiceEnabled}" />
                                    <CheckBox Content="Use 3D Voice" IsChecked="{Binding Voice3d}" />
                                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="body" Text="Voice Min Distance" />
                                            <TextBox Text="{Binding VoiceMinDistance}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Classes="body" Text="Voice Max Distance" />
                                            <TextBox Text="{Binding VoiceMaxDistance}" />
                                        </StackPanel>
                                    </Grid>
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="body" Text="Minutes Per Page" />
                                        <TextBox Text="{Binding MinutesPerPage}" />
                                        <TextBlock Classes="caption" Text="Controls how fast survivors move through books and magazines." />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Classes="card" Padding="18">
                                <StackPanel Spacing="14">
                                    <TextBlock Classes="kicker" Text="Launcher Admin Bootstrap" />
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="body" Text="Admin Username" />
                                        <TextBox Text="{Binding AdminUsername}" />
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="body" Text="Admin Password" />
                                        <TextBox PasswordChar="*" Text="{Binding AdminPassword}" />
                                        <TextBlock Classes="caption" Text="Write-only. Leave blank to keep the existing bootstrap admin password." />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="#14FFFFFF" BorderBrush="#24FFFFFF" BorderThickness="1" CornerRadius="12" Padding="12" IsVisible="{Binding DraftsDisabled}">
                                <TextBlock Classes="caption" Text="Drafts are intentionally disabled on this page so passwords are never persisted in workspace draft storage." TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <Border Grid.Column="1" Classes="surface-dark" Padding="18">
                    <StackPanel Spacing="14">
                        <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Command Tower" />
                        <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="#F7F0E7" Text="{Binding OperatorSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Foreground="#C9D5EA" Text="{Binding RecoveryHeadline}" TextWrapping="Wrap" />

                        <Border Background="#14FFFFFF" BorderBrush="#24FFFFFF" BorderThickness="1" CornerRadius="16" Padding="14">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Actions" />
                                <WrapPanel Orientation="Horizontal" ItemWidth="152" ItemHeight="36">
                                    <Button Classes="action-primary" Command="{Binding SaveSettingsCommand}" Content="Apply Settings" IsEnabled="{Binding CanEdit}" />
                                    <Button Classes="action-secondary" Command="{Binding DiscardDraftCommand}" Content="Reload" />
                                    <Button Classes="action-secondary" Command="{Binding ReloadCommand}" Content="Reload From Host" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="#22FFB36B" BorderBrush="#72FFB36B" BorderThickness="1" CornerRadius="16" Padding="14">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="kicker" Text="Current Signals" />
                                <TextBlock Classes="body" Text="{Binding CatalogSummary}" TextWrapping="Wrap" />
                                <TextBlock Classes="caption" Text="{Binding LoadStatus}" TextWrapping="Wrap" />
                                <TextBlock Classes="caption" Text="{Binding ActionSummary}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Background="#22FFB36B" BorderBrush="#72FFB36B" BorderThickness="1" CornerRadius="16" Padding="14">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="kicker" Text="Validation" />
                                <StackPanel Spacing="6" IsVisible="{Binding HasFieldErrors}">
                                    <ItemsControl ItemsSource="{Binding FieldErrors}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Classes="caption" Text="{Binding .}" TextWrapping="Wrap" Margin="0,0,0,6" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <TextBlock Classes="caption" IsVisible="{Binding RequiresAdvancedFilesFallback}" Text="{Binding FallbackReason}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
