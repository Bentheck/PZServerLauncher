<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1120"
             d:DesignHeight="900"
             x:Class="PZServerLauncher.App.Views.OverviewWorkspaceView"
             x:DataType="vm:OverviewWorkspaceViewModel">
    <Border Classes="card" Padding="24">
        <StackPanel Spacing="18">
            <StackPanel Spacing="4">
                <TextBlock Classes="panel-title" FontSize="24" Text="{Binding PageTitle}" />
                <TextBlock Classes="body" Text="{Binding PageSummary}" TextWrapping="Wrap" />
            </StackPanel>

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14">
                <Border Background="#F6EFE6" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Runtime" />
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding RuntimeState}" />
                        <TextBlock Classes="body" Text="{Binding Ports}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="#F6EFE6" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Paths" />
                        <TextBlock Classes="body" FontFamily="Cascadia Code,Consolas,monospace" Text="{Binding InstallDirectory}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" FontFamily="Cascadia Code,Consolas,monospace" Text="{Binding CacheDirectory}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="#F6EFE6" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Backup" />
                        <TextBlock Classes="body" Text="{Binding LatestBackup}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="#1F1D1B" CornerRadius="14" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Latest Log" />
                    <TextBlock Classes="body" Foreground="#E7DED4" Text="{Binding LatestLogLine}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <StackPanel Spacing="8">
                <TextBlock Classes="kicker" Text="Quick Actions" />
                <WrapPanel Orientation="Horizontal" ItemWidth="132" ItemHeight="36">
                    <Button Command="{Binding InstallCommand}" Content="Install" />
                    <Button Command="{Binding UpdateCommand}" Content="Update" />
                    <Button Command="{Binding StartCommand}" Content="Start" />
                    <Button Command="{Binding StopCommand}" Content="Stop" />
                    <Button Command="{Binding RestartCommand}" Content="Restart" />
                    <Button Command="{Binding BackupCommand}" Content="Backup" />
                    <Button Command="{Binding RestoreCommand}" Content="Restore Latest" IsEnabled="{Binding CanRestore}" />
                </WrapPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
