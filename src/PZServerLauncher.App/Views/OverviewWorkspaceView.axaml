<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1120"
             d:DesignHeight="900"
             x:Class="PZServerLauncher.App.Views.OverviewWorkspaceView"
             x:DataType="vm:OverviewWorkspaceViewModel">
    <Border Classes="card" Padding="24">
        <Grid RowDefinitions="Auto,Auto,*" RowSpacing="18">
            <Grid ColumnDefinitions="1.28*,.72*" ColumnSpacing="18">
                <Border Classes="surface-dark" Padding="26">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="18">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Active Operations Board" />
                            <TextBlock Classes="panel-title" FontSize="30" Foreground="#F7F0E7" Text="{Binding PageTitle}" />
                            <TextBlock Classes="body"
                                       Foreground="#D3C8BA"
                                       Text="{Binding PageSummary}"
                                       TextWrapping="Wrap" />
                            <TextBlock Classes="body"
                                       Foreground="#D3C8BA"
                                       Text="{Binding OperatorGuidance}"
                                       TextWrapping="Wrap" />
                            <TextBlock Classes="body"
                                       Foreground="#D3C8BA"
                                       Text="{Binding InstallPostureSummary}"
                                       TextWrapping="Wrap" />

                            <WrapPanel Margin="0,6,0,0" Orientation="Horizontal">
                                <Border Background="#2B221C" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                    <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding Branch}" />
                                </Border>
                                <Border Background="#2B221C" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                    <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding InstallHealth}" TextWrapping="Wrap" />
                                </Border>
                                <Border Background="#2B221C" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                    <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding BackupHealth}" TextWrapping="Wrap" />
                                </Border>
                                <Border Background="#2B221C" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                    <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding NamedPresetSummary}" TextWrapping="Wrap" />
                                </Border>
                            </WrapPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="12">
                            <Border Background="#2B221C" CornerRadius="18" Padding="14">
                                <StackPanel Spacing="6">
                                    <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Runtime Status" />
                                    <TextBlock FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="#F7F0E7"
                                               Text="{Binding RuntimeState}" />
                                    <TextBlock Classes="body"
                                               Foreground="#D3C8BA"
                                               Text="{Binding Ports}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Background="#2B221C" CornerRadius="18" Padding="14">
                                <StackPanel Spacing="6">
                                    <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Latest Log" />
                                    <TextBlock Classes="body"
                                               Foreground="#F0E7DC"
                                               Text="{Binding LatestLogLine}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Classes="caption"
                                               Foreground="#CBB9A8"
                                               Text="{Binding CacheHealth}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" Spacing="18">
                    <Border Classes="surface-dark" Padding="18">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Quick Actions" />
                            <TextBlock Classes="panel-title" FontSize="24" Foreground="#F7F0E7" Text="Command Rail" />
                            <TextBlock Classes="body"
                                       Foreground="#D3C8BA"
                                       Text="Use the high-friction actions from here. Install, update, start, stop, backup, and restore stay within one reach of the live board."
                                       TextWrapping="Wrap" />

                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                                <Button Command="{Binding InstallCommand}" Content="Install" />
                                <Button Grid.Column="1" Command="{Binding UpdateCommand}" Content="Update" />
                                <Button Grid.Row="1" Command="{Binding StartCommand}" Content="Start" />
                                <Button Grid.Row="1" Grid.Column="1" Command="{Binding StopCommand}" Content="Stop" />
                                <Button Grid.Row="2" Command="{Binding RestartCommand}" Content="Restart" />
                                <Button Grid.Row="2" Grid.Column="1" Command="{Binding BackupCommand}" Content="Backup" />
                                <Button Grid.Row="3"
                                        Grid.ColumnSpan="2"
                                        Command="{Binding RestoreCommand}"
                                        Content="Restore Latest"
                                        IsEnabled="{Binding CanRestore}" />
                            </Grid>

                            <TextBlock Classes="caption"
                                       Foreground="#CBB9A8"
                                       Text="{Binding LatestBackup}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Classes="metric-card" Padding="16">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="kicker" Text="Operational Health" />
                            <TextBlock Classes="panel-title" FontSize="22" Text="{Binding InstallHealth}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="{Binding BackupHealth}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*,*" ColumnSpacing="14">
                <Border Classes="metric-card" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Runtime" />
                        <TextBlock Classes="panel-title" FontSize="24" Text="{Binding RuntimeState}" />
                        <TextBlock Classes="caption" Text="{Binding Ports}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Classes="metric-card" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Install" />
                        <TextBlock Classes="panel-title" FontSize="24" Text="{Binding InstallHealth}" TextWrapping="Wrap" />
                        <TextBlock Classes="caption" Text="{Binding InstallPostureSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Classes="metric-card" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Recovery" />
                        <TextBlock Classes="panel-title" FontSize="24" Text="{Binding BackupHealth}" TextWrapping="Wrap" />
                        <TextBlock Classes="caption" Text="{Binding NamedPresetSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Classes="metric-card" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Community" />
                        <TextBlock Classes="panel-title" FontSize="24" Text="{Binding CommunitySummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="caption" Text="{Binding WelcomeMessageSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="4" Classes="metric-card" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Players" />
                        <TextBlock Classes="panel-title" FontSize="24" Text="{Binding LivePlayerSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="caption" Text="{Binding PlayerActivitySummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="2" ColumnDefinitions="1.1*,.9*" ColumnSpacing="18">
                <StackPanel Spacing="18">
                    <Border Classes="card" Padding="18">
                        <StackPanel Spacing="12">
                            <TextBlock Classes="kicker" Text="World Control" />
                            <TextBlock Classes="panel-title" FontSize="22" Text="Rules, sandbox, and save-state posture" />
                            <TextBlock Classes="body"
                                       Text="{Binding ServerRulesSummary}"
                                       TextWrapping="Wrap" />

                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                                <Border Background="#F6EFE6" CornerRadius="14" Padding="14">
                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="kicker" Text="Sandbox Tuning" />
                                        <TextBlock Classes="body" Text="{Binding SandboxTuningSummary}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="#F6EFE6" CornerRadius="14" Padding="14">
                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="kicker" Text="World Snapshot" />
                                        <TextBlock Classes="body" Text="{Binding WorldSnapshotSummary}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Background="#F6EFE6" CornerRadius="14" Padding="14">
                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="kicker" Text="Workshop" />
                                        <TextBlock Classes="body" Text="{Binding WorkshopSummary}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Grid.Column="1" Background="#F6EFE6" CornerRadius="14" Padding="14">
                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="kicker" Text="Memory" />
                                        <TextBlock Classes="body" Text="{Binding MemorySummary}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Classes="card" Padding="18">
                        <StackPanel Spacing="12">
                            <TextBlock Classes="kicker" Text="Community Board" />
                            <TextBlock Classes="panel-title" FontSize="22" Text="Players, message, and operator posture" />
                            <TextBlock Classes="body"
                                       Text="{Binding CommunitySummary}"
                                       TextWrapping="Wrap" />
                            <TextBlock Classes="body"
                                       Text="{Binding WelcomeMessageSummary}"
                                       TextWrapping="Wrap" />
                            <TextBlock Classes="body"
                                       Text="{Binding LivePlayerRosterSummary}"
                                       TextWrapping="Wrap" />

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                <Border Background="#FFF8F1" CornerRadius="14" Padding="14">
                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="kicker" Text="Players Online" />
                                        <TextBlock Classes="body" Text="{Binding LivePlayerSummary}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="#FFF8F1" CornerRadius="14" Padding="14">
                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="kicker" Text="Operator Action" />
                                        <TextBlock Classes="body" Text="{Binding OperatorActionSummary}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="18">
                    <Border Classes="card" Padding="18">
                        <StackPanel Spacing="12">
                            <TextBlock Classes="kicker" Text="Network Control" />
                            <TextBlock Classes="panel-title" FontSize="22" Text="{Binding NetworkAccessHeadline}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="{Binding NetworkTrustHeadline}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="{Binding IdentityAndSafetyHeadline}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="{Binding NetworkRecoveryHeadline}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="{Binding VoicePostureHeadline}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="{Binding NetworkOperatorSummary}" TextWrapping="Wrap" />

                            <Border Background="#F6EFE6" CornerRadius="14" Padding="14">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="kicker" Text="Operator Checklist" />
                                    <ItemsControl ItemsSource="{Binding NetworkChecklist}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Classes="body"
                                                           Margin="0,0,0,6"
                                                           Text="{Binding .}"
                                                           TextWrapping="Wrap" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Classes="card" Padding="18">
                        <StackPanel Spacing="12">
                            <TextBlock Classes="kicker" Text="Recovery Board" />
                            <TextBlock Classes="panel-title" FontSize="22" Text="{Binding BackupHealth}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="{Binding NamedPresetSummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="{Binding LatestBackup}" TextWrapping="Wrap" />
                            <TextBlock Classes="body"
                                       Text="Restore Latest stays in the command rail above, while this card keeps the recovery posture and saved preset context visible."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
