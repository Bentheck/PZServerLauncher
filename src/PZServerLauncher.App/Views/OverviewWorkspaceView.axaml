<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1120"
             d:DesignHeight="900"
             x:Class="PZServerLauncher.App.Views.OverviewWorkspaceView"
             x:DataType="vm:OverviewWorkspaceViewModel">
    <Border Classes="card" Padding="24">
        <StackPanel Spacing="18">
            <StackPanel Spacing="4">
                <TextBlock Classes="panel-title" FontSize="24" Text="{Binding PageTitle}" />
                <TextBlock Classes="body" Text="{Binding PageSummary}" TextWrapping="Wrap" />
            </StackPanel>

            <Border Background="#1F1D1B" CornerRadius="16" Padding="18">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Profile Overview" />
                        <TextBlock FontSize="28" FontWeight="SemiBold" Foreground="#F7F0E7" Text="{Binding ProfileDisplayName}" />
                        <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding OperatorGuidance}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding InstallPostureSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Border Grid.Column="1" Background="#2A2927" CornerRadius="999" Padding="14,8" VerticalAlignment="Top">
                        <TextBlock Foreground="#F7F0E7" FontWeight="SemiBold" Text="{Binding Branch}" />
                    </Border>
                </Grid>
            </Border>

            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="14">
                <Border Background="#F6EFE6" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Runtime" />
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding RuntimeState}" />
                        <TextBlock Classes="body" Text="{Binding Ports}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="#F6EFE6" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Install Health" />
                        <TextBlock Classes="body" Text="{Binding InstallHealth}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="#F6EFE6" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Backup Posture" />
                        <TextBlock Classes="body" Text="{Binding BackupHealth}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding NamedPresetSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Background="#F6EFE6" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Community Snapshot" />
                        <TextBlock Classes="body" Text="{Binding CommunitySummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding WelcomeMessageSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="14">
                <Border Background="#FFF8F1" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="kicker" Text="Server Rules" />
                        <TextBlock Classes="body" Text="{Binding ServerRulesSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding WelcomeMessageSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="#FFF8F1" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="kicker" Text="Network Posture" />
                        <TextBlock Classes="body" Text="{Binding NetworkPostureSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding Ports}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="#FFF8F1" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="kicker" Text="Sandbox Tuning" />
                        <TextBlock Classes="body" Text="{Binding SandboxTuningSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding WorldSnapshotSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding WorkshopSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding MemorySummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Background="#FFF8F1" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="kicker" Text="Players &amp; Ops" />
                        <TextBlock Classes="body" Text="{Binding LivePlayerSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding LivePlayerRosterSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding OperatorActionSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding PlayerActivitySummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="*,340" ColumnSpacing="16">
                <Border Background="#1F1D1B" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Latest Log" />
                        <TextBlock Classes="body" Foreground="#E7DED4" Text="{Binding LatestLogLine}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding CacheHealth}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#FFF8F1" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="kicker" Text="Quick Actions" />
                        <WrapPanel Orientation="Horizontal" ItemWidth="148" ItemHeight="36">
                            <Button Command="{Binding InstallCommand}" Content="Install" />
                            <Button Command="{Binding UpdateCommand}" Content="Update" />
                            <Button Command="{Binding StartCommand}" Content="Start" />
                            <Button Command="{Binding StopCommand}" Content="Stop" />
                            <Button Command="{Binding RestartCommand}" Content="Restart" />
                            <Button Command="{Binding BackupCommand}" Content="Backup" />
                            <Button Command="{Binding RestoreCommand}" Content="Restore Latest" IsEnabled="{Binding CanRestore}" />
                        </WrapPanel>
                        <TextBlock Classes="body" Text="{Binding LatestBackup}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
