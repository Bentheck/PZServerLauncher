<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1120"
             d:DesignHeight="900"
             x:Class="PZServerLauncher.App.Views.OverviewWorkspaceView"
             x:DataType="vm:OverviewWorkspaceViewModel">
    <Grid RowDefinitions="Auto,*" RowSpacing="18">
        <Border Classes="card" Padding="26">
            <Grid ColumnDefinitions="*,280" ColumnSpacing="18">
                <StackPanel Spacing="8">
                    <TextBlock Classes="kicker" Text="Server Operations Board" />
                    <TextBlock Classes="panel-title" FontSize="30" Text="{Binding ProfileDisplayName}" />
                    <TextBlock Classes="body"
                               FontSize="16"
                               Foreground="#45382E"
                               Text="{Binding OperatorGuidance}"
                               TextWrapping="Wrap" />
                    <TextBlock Classes="caption"
                               Text="{Binding InstallPostureSummary}"
                               TextWrapping="Wrap" />

                    <WrapPanel Margin="0,8,0,0" Orientation="Horizontal" ItemHeight="30">
                        <Border Background="#2A2927" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                            <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding Branch}" />
                        </Border>
                        <Border Background="#EAD6BF" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                            <TextBlock Foreground="#5A4330" FontSize="11" Text="{Binding RuntimeState}" />
                        </Border>
                        <Border Background="#EAD6BF" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                            <TextBlock Foreground="#5A4330" FontSize="11" Text="{Binding Ports}" />
                        </Border>
                    </WrapPanel>
                </StackPanel>

                <Border Grid.Column="1" Classes="metric-card" Padding="18">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="kicker" Text="Snapshot" />
                        <TextBlock Classes="panel-title" FontSize="22" Text="{Binding RuntimeState}" TextWrapping="Wrap" />
                        <TextBlock Classes="caption" Text="{Binding LivePlayerSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="caption" Text="{Binding LatestBackup}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="1.02*,.98*" ColumnSpacing="18">
            <Border Classes="card" Padding="22">
                <StackPanel Spacing="12">
                    <TextBlock Classes="kicker" Text="Status Snapshot" />
                    <TextBlock Classes="body" Text="{Binding InstallHealth}" TextWrapping="Wrap" />
                    <TextBlock Classes="caption" Text="{Binding BackupHealth}" TextWrapping="Wrap" />
                    <TextBlock Classes="caption" Text="{Binding LatestLogLine}" TextWrapping="Wrap" />

                    <Border Background="#F5E8DA" CornerRadius="14" Padding="14">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="caption" Foreground="#5E4735" Text="{Binding OperatorActionSummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="caption" Foreground="#5E4735" Text="{Binding NetworkRecoveryHeadline}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Classes="surface-dark" Padding="18">
                <StackPanel Spacing="14">
                    <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Quick Actions" />
                    <TextBlock FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#F7F0E7"
                               Text="Operate the active server"
                               TextWrapping="Wrap" />
                    <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding NetworkPostureSummary}" TextWrapping="Wrap" />

                    <WrapPanel Orientation="Horizontal" ItemWidth="138" ItemHeight="36">
                        <Button Classes="action-secondary" Command="{Binding InstallCommand}" Content="Install" IsEnabled="{Binding CanQueueInstall}" />
                        <Button Classes="action-secondary" Command="{Binding UpdateCommand}" Content="Update" IsEnabled="{Binding CanQueueUpdate}" />
                        <Button Classes="action-primary" Command="{Binding StartCommand}" Content="Start" />
                        <Button Classes="action-danger" Command="{Binding StopCommand}" Content="Stop" />
                        <Button Classes="action-secondary" Command="{Binding RestartCommand}" Content="Restart" />
                        <Button Classes="action-secondary" Command="{Binding BackupCommand}" Content="Backup" />
                        <Button Classes="action-secondary" Command="{Binding RestoreCommand}" Content="Restore Latest" IsEnabled="{Binding CanRestore}" />
                    </WrapPanel>
                    <TextBlock Classes="caption" Foreground="#CCBBA8" Text="{Binding MaintenanceQueueSummary}" TextWrapping="Wrap" />

                    <Border Background="#2B221C" CornerRadius="16" Padding="14">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Current Signals" />
                            <TextBlock Classes="body" Foreground="#F0E7DC" Text="{Binding LivePlayerRosterSummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="caption" Foreground="#CCBBA8" Text="{Binding PlayerActivitySummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="caption" Foreground="#CCBBA8" Text="{Binding CommunitySummary}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
