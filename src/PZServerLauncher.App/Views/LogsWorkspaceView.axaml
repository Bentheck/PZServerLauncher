<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1320"
             d:DesignHeight="920"
             x:Class="PZServerLauncher.App.Views.LogsWorkspaceView"
             x:Name="LogsRoot"
             x:DataType="vm:LogsWorkspaceViewModel">
    <Grid RowDefinitions="Auto,*" RowSpacing="16">
        <Border Classes="card" Padding="22">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="18">
                <StackPanel Spacing="8">
                    <TextBlock Classes="kicker" Text="Live Operations Console" />
                    <TextBlock Classes="panel-title" FontSize="28" Text="{Binding ConsoleHeroTitle}" />
                    <TextBlock Classes="body" Text="{Binding ConsoleHeroCopy}" TextWrapping="Wrap" />
                    <WrapPanel Orientation="Horizontal" ItemHeight="30">
                        <Border Background="#2A2927" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                            <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding Branch}" />
                        </Border>
                        <Border Background="#14FFFFFF" BorderBrush="#24FFFFFF" BorderThickness="1" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                            <TextBlock Foreground="#C9D5EA" FontSize="11" Text="{Binding ConsoleStatusSummary}" />
                        </Border>
                        <Border Background="#14FFFFFF" BorderBrush="#24FFFFFF" BorderThickness="1" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                            <TextBlock Foreground="#C9D5EA" FontSize="11" Text="{Binding ActivePlayerCountSummary}" />
                        </Border>
                    </WrapPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="8" HorizontalAlignment="Right">
                    <Button Classes="action-secondary"
                            Command="{Binding ReloadCommand}"
                            Content="Reload" />
                    <TextBlock Classes="caption"
                               HorizontalAlignment="Right"
                               Text="{Binding LoadStatus}"
                               TextAlignment="Right"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="310,*" ColumnSpacing="16">
            <StackPanel Spacing="16">
                <Border Classes="card" Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="kicker" Text="Live Controls" />
                        <TextBlock Classes="body" Text="{Binding BroadcastGuidance}" TextWrapping="Wrap" />
                        <TextBlock Classes="caption" Text="{Binding PlayerModerationSummary}" TextWrapping="Wrap" />

                        <StackPanel Spacing="6">
                            <TextBlock FontWeight="SemiBold" Text="Broadcast Message" />
                            <TextBox Text="{Binding BroadcastMessage}" PlaceholderText="servermsg text" />
                            <Button Classes="action-primary"
                                    Command="{Binding SendBroadcastCommand}"
                                    Content="Send Broadcast"
                                    IsEnabled="{Binding CanSendCommands}" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock FontWeight="SemiBold" Text="Raw Console Command" />
                            <TextBox Text="{Binding RawConsoleCommand}" PlaceholderText="adduser / kickuser / save" />
                            <Button Classes="action-secondary"
                                    Command="{Binding SendConsoleCommand}"
                                    Content="Send Console Command"
                                    IsEnabled="{Binding CanSendCommands}" />
                        </StackPanel>

                        <WrapPanel Orientation="Horizontal" ItemHeight="34">
                            <Button Classes="action-secondary"
                                    Command="{Binding ListPlayersCommand}"
                                    Content="Request Player List"
                                    IsEnabled="{Binding CanSendCommands}"
                                    Margin="0,0,8,8" />
                            <Button Classes="action-secondary"
                                    Command="{Binding SaveWorldCommand}"
                                    Content="Save World"
                                    IsEnabled="{Binding CanSendCommands}"
                                    Margin="0,0,8,8" />
                            <Button Classes="action-secondary"
                                    Command="{Binding ReloadOptionsCommand}"
                                    Content="Reload Options"
                                    IsEnabled="{Binding CanSendCommands}"
                                    Margin="0,0,8,8" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Classes="card" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="kicker" Text="Connected Players" />
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto"
                                      MaxHeight="300">
                            <ItemsControl ItemsSource="{Binding ConnectedPlayers}" IsVisible="{Binding HasConnectedPlayers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:LogsWorkspaceViewModel+ConnectedPlayerRowViewModel">
                                        <Border Background="#14FFFFFF" BorderBrush="#24FFFFFF" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,8">
                                            <StackPanel Spacing="8">
                                                <StackPanel Spacing="4">
                                                    <TextBlock FontSize="16" FontWeight="SemiBold" Text="{Binding UserName}" />
                                                    <TextBlock Classes="caption" Text="{Binding JoinedSummary}" TextWrapping="Wrap" />
                                                    <TextBlock Classes="caption" Text="{Binding LastSeenSummary}" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <WrapPanel Orientation="Horizontal" ItemHeight="34">
                                                    <Button Classes="action-danger" Command="{Binding #LogsRoot.DataContext.KickPlayerCommand}" CommandParameter="{Binding .}" Content="Kick" IsEnabled="{Binding #LogsRoot.DataContext.CanSendCommands}" Margin="0,0,8,0" />
                                                    <Button Classes="action-danger" Command="{Binding #LogsRoot.DataContext.BanPlayerCommand}" CommandParameter="{Binding .}" Content="Ban" IsEnabled="{Binding #LogsRoot.DataContext.CanSendCommands}" Margin="0,0,8,0" />
                                                    <Button Classes="action-secondary" Command="{Binding #LogsRoot.DataContext.WhitelistPlayerCommand}" CommandParameter="{Binding .}" Content="Whitelist" IsEnabled="{Binding #LogsRoot.DataContext.CanSendCommands}" />
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <TextBlock Classes="caption"
                                   IsVisible="{Binding HasNoConnectedPlayers}"
                                   Text="No connected players have been inferred yet. Keep the console open during joins or request the player list while the server is live."
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Classes="surface-dark" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Live Ops Briefing" />
                        <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#F7F0E7" Text="{Binding FeedHealthHeadline}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Foreground="#C9D5EA" Text="{Binding LiveOpsTriageSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="caption" Foreground="#A8B6D4" Text="{Binding RosterPostureSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="16">
                <Border Classes="surface-dark" Padding="16">
                    <Grid RowDefinitions="Auto,*" RowSpacing="12">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Live Stream" />
                                <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#F7F0E7" Text="{Binding LogStreamSummary}" TextWrapping="Wrap" />
                                <TextBlock Classes="caption" Foreground="#A8B6D4" Text="{Binding FriendlyFeedSummary}" TextWrapping="Wrap" />
                                <TextBlock Classes="caption" Foreground="#A8B6D4" Text="{Binding SignalCountSummary}" TextWrapping="Wrap" />
                            </StackPanel>
                            <Border Grid.Column="1" Background="#2A2927" CornerRadius="999" Padding="10,5" VerticalAlignment="Top">
                                <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding ConsoleModeSummary}" />
                            </Border>
                        </Grid>

                        <Border Grid.Row="1" Background="#171310" CornerRadius="16" Padding="14">
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto"
                                          MaxHeight="460">
                                <ItemsControl ItemsSource="{Binding FriendlyLogLines}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Classes="body"
                                                       FontFamily="Cascadia Code,Consolas,monospace"
                                                       Foreground="#E9DED2"
                                                       TextAlignment="Left"
                                                       Text="{Binding .}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,6" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="14" IsVisible="{Binding HasLogs}">
                    <Border Classes="card" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="kicker" Text="Recent Player Signals" />
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto"
                                          MaxHeight="220">
                                <ItemsControl ItemsSource="{Binding RecentPlayerSignals}" IsVisible="{Binding HasPlayerSignals}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Classes="caption" Text="{Binding .}" TextWrapping="Wrap" Margin="0,0,0,6" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <TextBlock Classes="caption" IsVisible="{Binding HasNoPlayerSignals}" Text="Player join and leave signals will appear here when the host can infer them from runtime logs or launcher-issued roster commands." TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Classes="card" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="kicker" Text="Recent Operator Actions" />
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto"
                                          MaxHeight="220">
                                <ItemsControl ItemsSource="{Binding RecentOperatorActions}" IsVisible="{Binding HasOperatorActions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Classes="caption" Text="{Binding .}" TextWrapping="Wrap" Margin="0,0,0,6" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <TextBlock Classes="caption" IsVisible="{Binding HasNoOperatorActions}" Text="Broadcasts and raw console commands sent from the launcher will appear here as soon as the runtime is live." TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Classes="card" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="kicker" Text="Live Ops Checklist" />
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto"
                                          MaxHeight="220">
                                <ItemsControl ItemsSource="{Binding LiveOpsChecklist}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#14FFFFFF" BorderBrush="#24FFFFFF" BorderThickness="1" CornerRadius="12" Padding="10" Margin="0,0,0,8">
                                                <TextBlock Classes="caption" Text="{Binding .}" TextWrapping="Wrap" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Grid.Row="2"
                        Classes="card"
                        Padding="16"
                        IsVisible="{Binding HasLogs}">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="kicker" Text="Raw Buffer" />
                        <TextBlock Classes="caption" Text="{Binding RawBufferSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="caption"
                                   Text="This buffer keeps the uncollapsed runtime output so you can inspect the exact lines behind the launcher-friendly feed."
                                   TextWrapping="Wrap" />

                        <Border Background="#171310" CornerRadius="16" Padding="14">
                            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Auto"
                                          MaxHeight="280">
                                <ItemsControl ItemsSource="{Binding LogLines}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Classes="caption"
                                                       FontFamily="Cascadia Code,Consolas,monospace"
                                                       Foreground="#E9DED2"
                                                       Text="{Binding .}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,6" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="3"
                        Background="#14FFFFFF"
                        BorderBrush="#24FFFFFF"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="16"
                        IsVisible="{Binding HasNoLogs}">
                    <TextBlock Classes="body" Text="No buffered logs are available yet. Start or reload the profile, then return here to watch the live console fill with runtime output, roster changes, and operator commands." TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
