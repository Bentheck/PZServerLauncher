<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PZServerLauncher.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1560"
        d:DesignHeight="1120"
        x:Class="PZServerLauncher.App.Views.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:WorkspaceShellViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="PZ Server Launcher"
        Width="1560"
        Height="1120"
        MinWidth="1260"
        MinHeight="900">

    <Design.DataContext>
        <vm:WorkspaceShellViewModel />
    </Design.DataContext>

    <Grid>
        <Border Background="#F4EDE4" />
        <Border Height="240" VerticalAlignment="Top">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#2A211B" Offset="0" />
                    <GradientStop Color="#6F4A31" Offset="0.58" />
                    <GradientStop Color="#D4A479" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Grid RowDefinitions="Auto,Auto,*" RowSpacing="18" Margin="24">
            <Border Background="#FCF7F1" CornerRadius="22" Padding="24" BoxShadow="0 18 46 0 #2D241B22">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="20">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="kicker" Foreground="#A76A3D" Text="Project Zomboid Workspace" />
                        <TextBlock FontSize="40" FontWeight="Bold" Foreground="#1D1A17" Text="{Binding CurrentPageTitle}" />
                        <TextBlock Classes="body" FontSize="17" Text="{Binding WorkspaceGuidance}" TextWrapping="Wrap" />
                        <WrapPanel Margin="0,6,0,0" Orientation="Horizontal" ItemWidth="220" ItemHeight="40">
                            <Border Background="#F0E1D1" CornerRadius="999" Padding="14,8">
                                <TextBlock Foreground="#5A4331" FontWeight="SemiBold" Text="{Binding ProfileCountSummary}" />
                            </Border>
                            <Border Background="#F0E1D1" CornerRadius="999" Padding="14,8">
                                <TextBlock Foreground="#5A4331" FontWeight="SemiBold" Text="{Binding RecentActivitySummary}" />
                            </Border>
                            <Border Background="#F0E1D1" CornerRadius="999" Padding="14,8">
                                <TextBlock Foreground="#5A4331" FontWeight="SemiBold" Text="{Binding RemotePostureSummary}" />
                            </Border>
                        </WrapPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="10" HorizontalAlignment="Right" Width="360">
                        <Border Background="#1F1D1B" CornerRadius="18" Padding="18,14">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Local Host" />
                                <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="#F7F0E7" Text="{Binding Legacy.HostSummary}" />
                                <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding ActorSummary}" TextWrapping="Wrap" />
                                <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding Legacy.StatusMessage}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <WrapPanel HorizontalAlignment="Right" ItemWidth="168" ItemHeight="38">
                            <Button Background="#F4E2CE"
                                    Foreground="#2A211B"
                                    Command="{Binding RefreshLegacyCommand}"
                                    Content="Refresh Host State" />
                            <Button Background="#2A211B"
                                    Foreground="#F7F0E7"
                                    Command="{Binding ExitDesktopCommand}"
                                    Content="Exit Desktop" />
                        </WrapPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="#FCF1E7"
                    BorderBrush="#D9B18A"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="18,16"
                    IsVisible="{Binding HasPendingNavigation}">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="panel-title" Text="Unsaved Changes" />
                        <TextBlock Classes="body" Text="{Binding PendingNavigationMessage}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding ConfirmNavigationSaveCommand}" Content="Save" />
                    <Button Grid.Column="2" Command="{Binding ConfirmNavigationDiscardCommand}" Content="Discard" />
                    <Button Grid.Column="3" Command="{Binding CancelNavigationCommand}" Content="Cancel" />
                </Grid>
            </Border>

            <Grid Grid.Row="2" ColumnDefinitions="320,*" ColumnSpacing="18">
                <Border Background="#221C17" CornerRadius="22" Padding="16" BoxShadow="0 18 42 0 #1E171110">
                    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="16">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Navigation" />
                            <TextBlock Classes="panel-title" FontSize="24" Foreground="#F7F0E7" Text="Workspace" />
                            <TextBlock Classes="body"
                                       Foreground="#D3C8BA"
                                       Text="Global pages handle host-wide control. Profiles opens the full server workspace with install, config, mods, backups, and logs."
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <ItemsControl Grid.Row="1" ItemsSource="{Binding GlobalNavigation}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:WorkspaceNavigationItemViewModel">
                                    <Button HorizontalAlignment="Stretch"
                                            Margin="0,0,0,10"
                                            Padding="16,14"
                                            Background="#F8F1E8"
                                            Command="{Binding #RootWindow.DataContext.SelectGlobalPageCommand}"
                                            CommandParameter="{Binding .}"
                                            IsEnabled="{Binding IsEnabled}">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                            <StackPanel Spacing="3">
                                                <TextBlock FontSize="15" FontWeight="SemiBold" Text="{Binding Title}" />
                                                <TextBlock Classes="body" FontSize="12" Text="{Binding Summary}" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <Border Grid.Column="1"
                                                    Background="#2A2927"
                                                    CornerRadius="999"
                                                    Padding="10,4"
                                                    VerticalAlignment="Top"
                                                    IsVisible="{Binding IsSelected}">
                                                <TextBlock Foreground="#F7F0E7" Text="Active" />
                                            </Border>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Grid.Row="2" Background="#2E2823" CornerRadius="16" Padding="14">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Current Focus" />
                                <TextBlock Classes="body" Foreground="#F1E8DE" Text="{Binding CurrentPageSummary}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled">
                    <ContentControl Content="{Binding CurrentPage}" />
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
