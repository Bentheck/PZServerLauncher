<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PZServerLauncher.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1920"
        d:DesignHeight="1080"
        x:Class="PZServerLauncher.App.Views.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:WorkspaceShellViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="PZ Server Launcher"
        Width="1680"
        Height="1000"
        MinWidth="1280"
        MinHeight="820">

    <Design.DataContext>
        <vm:WorkspaceShellViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*" ColumnDefinitions="260,*" RowSpacing="14" ColumnSpacing="16" Margin="18">
        <Border Grid.ColumnSpan="2"
                Classes="card"
                Padding="18">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="12">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="20">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="kicker" Text="Workspace" />
                        <TextBlock FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="#172024"
                                   Text="{Binding CurrentPageTitle}" />
                        <TextBlock Classes="caption"
                                   FontSize="13"
                                   Foreground="#6A7477"
                                   Text="{Binding CurrentPageSummary}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Width="320"
                                Spacing="8"
                                HorizontalAlignment="Right">
                        <TextBlock Classes="kicker"
                                   HorizontalAlignment="Right"
                                   Text="Signed In As" />
                        <TextBlock Classes="body"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right"
                                   TextAlignment="Right"
                                   Foreground="#1E2A2E"
                                   Text="{Binding ActorSummary}"
                                   TextWrapping="Wrap" />
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Right" ItemHeight="38">
                            <Button Classes="action-secondary"
                                    Command="{Binding RefreshLegacyCommand}"
                                    Content="Refresh" />
                            <Button Classes="action-danger"
                                    Command="{Binding ExitDesktopCommand}"
                                    Content="Exit Desktop" />
                        </WrapPanel>
                    </StackPanel>
                </Grid>

                <WrapPanel Grid.Row="1" Orientation="Horizontal">
                    <Border Classes="pill-dark" Margin="0,0,8,8">
                        <TextBlock Classes="pill-text-light" Text="{Binding ProfileCountSummary}" />
                    </Border>
                    <Border Classes="pill-soft-green" Margin="0,0,8,8">
                        <TextBlock Classes="pill-text-green" Text="{Binding RecentActivitySummary}" />
                    </Border>
                    <Border Classes="pill-soft-neutral" Margin="0,0,8,8">
                        <TextBlock Classes="pill-text-neutral" Text="{Binding RemotePostureSummary}" />
                    </Border>
                    <Border Classes="pill-soft-neutral" Margin="0,0,8,8">
                        <TextBlock Classes="pill-text-neutral" Text="{Binding WorkspaceGuidance}" />
                    </Border>
                </WrapPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.ColumnSpan="2"
                Background="#FFF4E9"
                BorderBrush="#E2C39E"
                BorderThickness="1"
                CornerRadius="16"
                Padding="16,14"
                IsVisible="{Binding HasPendingNavigation}">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="12">
                <StackPanel Spacing="4">
                    <TextBlock Classes="panel-title" Text="Unsaved Changes" />
                    <TextBlock Classes="body" Text="{Binding PendingNavigationMessage}" TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="1" Classes="action-primary" Command="{Binding ConfirmNavigationSaveCommand}" Content="Save" />
                <Button Grid.Column="2" Classes="action-secondary" Command="{Binding ConfirmNavigationDiscardCommand}" Content="Discard" />
                <Button Grid.Column="3" Classes="action-secondary" Command="{Binding CancelNavigationCommand}" Content="Cancel" />
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Classes="card"
                Padding="14">
            <Grid RowDefinitions="Auto,*" RowSpacing="12">
                <StackPanel Spacing="4">
                    <TextBlock Classes="kicker" Text="Navigation" />
                    <TextBlock Classes="panel-title" FontSize="22" Text="Workspaces" />
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="8">
                    <ItemsControl ItemsSource="{Binding GlobalNavigation}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:WorkspaceNavigationItemViewModel">
                                <Button HorizontalAlignment="Stretch"
                                        Padding="0"
                                        Margin="0,0,0,8"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding #RootWindow.DataContext.SelectGlobalPageCommand}"
                                        CommandParameter="{Binding .}"
                                        IsEnabled="{Binding IsEnabled}">
                                    <Grid ColumnDefinitions="6,*" ColumnSpacing="0">
                                        <Border Background="#355B4C"
                                                CornerRadius="16,0,0,16"
                                                IsVisible="{Binding IsSelected}" />
                                        <Border Grid.Column="1"
                                                Background="#F7F3EC"
                                                BorderBrush="#D9D0C4"
                                                BorderThickness="1"
                                                CornerRadius="0,16,16,0"
                                                Padding="14,12">
                                            <StackPanel Spacing="3">
                                                <TextBlock FontSize="16"
                                                           FontWeight="SemiBold"
                                                           Foreground="#1B2326"
                                                           Text="{Binding Title}" />
                                                <TextBlock Classes="caption"
                                                           Foreground="#697075"
                                                           Text="{Binding Summary}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Grid.Column="1">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                <ContentControl Content="{Binding CurrentPage}" />
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
