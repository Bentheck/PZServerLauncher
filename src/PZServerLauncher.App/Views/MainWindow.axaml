<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PZServerLauncher.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1920"
        d:DesignHeight="1080"
        x:Class="PZServerLauncher.App.Views.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:WorkspaceShellViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="PZ Server Launcher"
        Width="1680"
        Height="1000"
        MinWidth="1280"
        MinHeight="820">

    <Design.DataContext>
        <vm:WorkspaceShellViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="14" Margin="18">
        <Border Classes="card"
                Padding="18">
            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="14">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="24">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="kicker" Text="Workspaces" />
                        <TextBlock FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="#172024"
                                   Text="{Binding CurrentPageTitle}" />
                        <TextBlock Classes="caption"
                                   FontSize="13"
                                   Foreground="#6A7477"
                                   Text="{Binding CurrentPageSummary}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Width="320"
                                Spacing="8"
                                HorizontalAlignment="Right">
                        <TextBlock Classes="kicker"
                                   HorizontalAlignment="Right"
                                   Text="Workspace Mode" />
                        <TextBlock Classes="body"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right"
                                   TextAlignment="Right"
                                   Foreground="#1E2A2E"
                                   Text="{Binding ActorSummary}"
                                   TextWrapping="Wrap" />
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Right" ItemHeight="38">
                            <Button Classes="action-secondary"
                                    Command="{Binding RefreshLegacyCommand}"
                                    Content="Refresh" />
                            <Button Classes="action-danger"
                                    Command="{Binding ExitDesktopCommand}"
                                    Content="Close App" />
                        </WrapPanel>
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="1" Spacing="8">
                    <TextBlock Classes="kicker" Text="Jump To" />
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  HorizontalAlignment="Stretch">
                        <ItemsControl ItemsSource="{Binding GlobalNavigation}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:WorkspaceNavigationItemViewModel">
                                    <Button Classes="chrome-free"
                                            Width="216"
                                            Height="132"
                                            Margin="0,0,12,0"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            HorizontalContentAlignment="Stretch"
                                            VerticalContentAlignment="Stretch"
                                            Command="{Binding #RootWindow.DataContext.SelectGlobalPageCommand}"
                                            CommandParameter="{Binding .}"
                                            IsEnabled="{Binding IsEnabled}">
                                        <Grid RowDefinitions="6,*">
                                            <Border Background="#355B4C"
                                                    CornerRadius="16,16,0,0"
                                                    IsVisible="{Binding IsSelected}" />
                                            <Border Grid.Row="1"
                                                    Background="#F7F3EC"
                                                    BorderBrush="#D9D0C4"
                                                    BorderThickness="1"
                                                    CornerRadius="0,16,16,16"
                                                    Padding="14,12">
                                                <Grid RowDefinitions="Auto,*"
                                                      RowSpacing="3">
                                                    <TextBlock FontSize="16"
                                                               FontWeight="SemiBold"
                                                               Foreground="#1B2326"
                                                               Text="{Binding Title}" />
                                                    <TextBlock Grid.Row="1"
                                                               Classes="caption"
                                                               Foreground="#697075"
                                                               Text="{Binding Summary}"
                                                               TextWrapping="Wrap"
                                                               MaxLines="4"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>

                <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="18">
                    <WrapPanel Orientation="Horizontal">
                        <Border Classes="pill-dark" Margin="0,0,8,8">
                            <TextBlock Classes="pill-text-light" Text="{Binding ProfileCountSummary}" />
                        </Border>
                        <Border Classes="pill-soft-green" Margin="0,0,8,8">
                            <TextBlock Classes="pill-text-green" Text="{Binding RecentActivitySummary}" />
                        </Border>
                        <Border Classes="pill-soft-neutral" Margin="0,0,8,8">
                            <TextBlock Classes="pill-text-neutral" Text="{Binding RuntimePostureSummary}" />
                        </Border>
                        <Border Classes="pill-soft-neutral" Margin="0,0,8,8">
                            <TextBlock Classes="pill-text-neutral" Text="{Binding WorkspaceGuidance}" />
                        </Border>
                    </WrapPanel>

                    <StackPanel Grid.Column="1"
                                Spacing="6"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom">
                        <TextBlock Classes="caption"
                                   HorizontalAlignment="Right"
                                   Foreground="#7A5A43"
                                   FontWeight="SemiBold"
                                   Text="Like what I'm doing?" />
                        <Button Classes="action-primary"
                                HorizontalAlignment="Right"
                                MinWidth="182"
                                Command="{Binding OpenSupportCommand}"
                                Content="☕ Buy me a coffee" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#FFF4E9"
                BorderBrush="#E2C39E"
                BorderThickness="1"
                CornerRadius="16"
                Padding="16,14"
                IsVisible="{Binding HasPendingNavigation}">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="12">
                <StackPanel Spacing="4">
                    <TextBlock Classes="panel-title" Text="Unsaved Changes" />
                    <TextBlock Classes="body" Text="{Binding PendingNavigationMessage}" TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="1" Classes="action-primary" Command="{Binding ConfirmNavigationSaveCommand}" Content="Save" />
                <Button Grid.Column="2" Classes="action-secondary" Command="{Binding ConfirmNavigationDiscardCommand}" Content="Discard" />
                <Button Grid.Column="3" Classes="action-secondary" Command="{Binding CancelNavigationCommand}" Content="Cancel" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                <ContentControl Content="{Binding CurrentPage}" />
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
