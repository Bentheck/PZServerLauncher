<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PZServerLauncher.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1560"
        d:DesignHeight="1120"
        x:Class="PZServerLauncher.App.Views.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:WorkspaceShellViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="PZ Server Launcher"
        Width="1560"
        Height="1120"
        MinWidth="1260"
        MinHeight="900">

    <Design.DataContext>
        <vm:WorkspaceShellViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="18" Margin="24">
        <Border Classes="card" Padding="24">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="20">
                <StackPanel Spacing="8">
                    <TextBlock Classes="kicker" Text="Project Zomboid Workspace" />
                    <TextBlock FontSize="38" FontWeight="Bold" Foreground="#1D1A17" Text="{Binding CurrentPageTitle}" />
                    <TextBlock Classes="body" FontSize="17" Text="{Binding CurrentPageSummary}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="8" HorizontalAlignment="Right">
                    <Border Background="#1F1D1B" CornerRadius="14" Padding="16,12">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Local Host" />
                            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#F7F0E7" Text="{Binding Legacy.HostSummary}" />
                            <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding ActorSummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding Legacy.StatusMessage}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <WrapPanel HorizontalAlignment="Right" ItemWidth="132" ItemHeight="36">
                        <Button Command="{Binding RefreshLegacyCommand}" Content="Refresh" />
                        <Button Command="{Binding OpenClassicCommand}" Content="Open Classic" />
                        <Button Command="{Binding ExitDesktopCommand}" Content="Exit Desktop" />
                    </WrapPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Classes="card" IsVisible="{Binding HasPendingNavigation}">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="12">
                <StackPanel Spacing="4">
                    <TextBlock Classes="panel-title" Text="Unsaved Changes" />
                    <TextBlock Classes="body" Text="{Binding PendingNavigationMessage}" TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding ConfirmNavigationSaveCommand}" Content="Save" />
                <Button Grid.Column="2" Command="{Binding ConfirmNavigationDiscardCommand}" Content="Discard" />
                <Button Grid.Column="3" Command="{Binding CancelNavigationCommand}" Content="Cancel" />
            </Grid>
        </Border>

        <Grid Grid.Row="2" ColumnDefinitions="300,*" ColumnSpacing="18">
            <Border Classes="card" Padding="14">
                <StackPanel Spacing="12">
                    <TextBlock Classes="panel-title" FontSize="22" Text="Workspace" />
                    <TextBlock Classes="body" Text="Global navigation switches between product areas. Profiles contains the per-profile workspace and the temporary Classic surface." TextWrapping="Wrap" />

                    <ItemsControl ItemsSource="{Binding GlobalNavigation}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:WorkspaceNavigationItemViewModel">
                                <Button HorizontalAlignment="Stretch"
                                        Margin="0,0,0,8"
                                        Command="{Binding #RootWindow.DataContext.SelectGlobalPageCommand}"
                                        CommandParameter="{Binding .}"
                                        IsEnabled="{Binding IsEnabled}">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Spacing="2">
                                            <TextBlock FontSize="15" FontWeight="SemiBold" Text="{Binding Title}" />
                                            <TextBlock Classes="body" FontSize="12" Text="{Binding Summary}" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                Background="#2A2927"
                                                CornerRadius="999"
                                                Padding="10,4"
                                                VerticalAlignment="Center"
                                                IsVisible="{Binding IsSelected}">
                                            <TextBlock Foreground="#F7F0E7" Text="Active" />
                                        </Border>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Background="#F1E6D7" CornerRadius="14" Padding="14">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="kicker" Text="Migration Note" />
                            <TextBlock Classes="body" Text="All per-profile workspace pages are now live. Classic remains only for the remaining global host-level surfaces while the final shell cutover lands." TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled">
                <ContentControl Content="{Binding CurrentPage}" />
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
