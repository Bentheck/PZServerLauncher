<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PZServerLauncher.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1920"
        d:DesignHeight="1080"
        x:Class="PZServerLauncher.App.Views.MainWindow"
        x:Name="RootWindow"
        x:DataType="vm:WorkspaceShellViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="PZ Server Launcher"
        Width="1680"
        Height="1000"
        MinWidth="1280"
        MinHeight="820">

    <Design.DataContext>
        <vm:WorkspaceShellViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" RowSpacing="14" Margin="24">
        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="18">
            <StackPanel Spacing="4">
                <TextBlock Classes="kicker" Text="Windows Desktop Control" />
                <TextBlock FontSize="34"
                           FontWeight="Bold"
                           Foreground="#EDF4FF"
                           Text="PZ Server Launcher" />
                <TextBlock Classes="caption"
                           FontSize="13"
                           Text="{Binding CurrentPageSummary}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Spacing="6"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <TextBlock HorizontalAlignment="Right"
                           Foreground="#FFD2A0"
                           FontSize="12"
                           FontWeight="Bold"
                           Text="Like what I'm doing?" />
                <Button Classes="action-warm"
                        HorizontalAlignment="Right"
                        MinWidth="182"
                        Command="{Binding OpenSupportCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="&#x2615;" />
                        <TextBlock Text="Buy me a coffee" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="2"
                        Width="330"
                        Spacing="8"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <TextBlock Classes="caption"
                           HorizontalAlignment="Right"
                           TextAlignment="Right"
                           Text="{Binding ActorSummary}"
                           TextWrapping="Wrap" />
                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Right" ItemHeight="38">
                    <Button Classes="action-secondary"
                            Command="{Binding RefreshLegacyCommand}"
                            Content="Refresh"
                            Margin="0,0,8,0" />
                    <Button Classes="action-danger"
                            Command="{Binding ExitDesktopCommand}"
                            Content="Close App" />
                </WrapPanel>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      HorizontalAlignment="Stretch">
            <ItemsControl ItemsSource="{Binding GlobalNavigation}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:WorkspaceNavigationItemViewModel">
                        <Button Classes="chrome-free"
                                Margin="0,0,8,0"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding #RootWindow.DataContext.SelectGlobalPageCommand}"
                                CommandParameter="{Binding .}"
                                IsEnabled="{Binding IsEnabled}">
                            <Border Background="#0AFFFFFF"
                                    BorderBrush="#2E405F"
                                    BorderThickness="1"
                                    CornerRadius="999"
                                    Padding="16,10">
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="9">
                                    <Border Width="8"
                                            Height="8"
                                            CornerRadius="999"
                                            Background="#8CF0CC"
                                            VerticalAlignment="Center"
                                            IsVisible="{Binding IsSelected}" />
                                    <TextBlock Grid.Column="1"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#DCE8FA"
                                               Text="{Binding Title}" />
                                </Grid>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="18">
            <WrapPanel Orientation="Horizontal">
                <Border Classes="pill-dark" Margin="0,0,8,8">
                    <TextBlock Classes="pill-text-light" Text="{Binding ProfileCountSummary}" />
                </Border>
                <Border Classes="pill-soft-green" Margin="0,0,8,8">
                    <TextBlock Classes="pill-text-green" Text="{Binding RecentActivitySummary}" />
                </Border>
                <Border Classes="pill-soft-neutral" Margin="0,0,8,8">
                    <TextBlock Classes="pill-text-neutral" Text="{Binding RuntimePostureSummary}" />
                </Border>
                <Border Classes="pill-soft-neutral" Margin="0,0,8,8">
                    <TextBlock Classes="pill-text-neutral" Text="{Binding WorkspaceGuidance}" />
                </Border>
            </WrapPanel>

            <TextBlock Grid.Column="1"
                       Classes="kicker"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Text="{Binding CurrentPageTitle}" />
        </Grid>

        <Border Grid.Row="3"
                Background="#22FFB36B"
                BorderBrush="#72FFB36B"
                BorderThickness="1"
                CornerRadius="16"
                Padding="16,14"
                IsVisible="{Binding HasPendingNavigation}">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="12">
                <StackPanel Spacing="4">
                    <TextBlock Classes="panel-title" Text="Unsaved Changes" />
                    <TextBlock Classes="body" Text="{Binding PendingNavigationMessage}" TextWrapping="Wrap" />
                </StackPanel>
                <Button Grid.Column="1" Classes="action-primary" Command="{Binding ConfirmNavigationSaveCommand}" Content="Save" />
                <Button Grid.Column="2" Classes="action-secondary" Command="{Binding ConfirmNavigationDiscardCommand}" Content="Discard" />
                <Button Grid.Column="3" Classes="action-secondary" Command="{Binding CancelNavigationCommand}" Content="Cancel" />
            </Grid>
        </Border>

        <Grid Grid.Row="4">
            <ContentControl Content="{Binding CurrentPage}" />
        </Grid>
    </Grid>
</Window>
