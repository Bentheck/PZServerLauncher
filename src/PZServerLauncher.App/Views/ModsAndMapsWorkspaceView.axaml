<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1120"
             d:DesignHeight="960"
             x:Class="PZServerLauncher.App.Views.ModsAndMapsWorkspaceView"
             x:DataType="vm:ModsAndMapsWorkspaceViewModel">
    <Border Classes="card" Padding="24">
        <StackPanel Spacing="18">
            <StackPanel Spacing="4">
                <TextBlock Classes="panel-title" FontSize="24" Text="{Binding PageTitle}" />
                <TextBlock Classes="body" Text="{Binding PageSummary}" TextWrapping="Wrap" />
            </StackPanel>

            <Border Background="#F6EFE6" CornerRadius="14" Padding="16">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Catalog" />
                        <TextBlock Classes="body" Text="{Binding CatalogSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding LoadStatus}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Background="#2A2927"
                            CornerRadius="14"
                            Padding="12,8"
                            VerticalAlignment="Top">
                        <TextBlock Foreground="#F7F0E7" Text="{Binding DirtyStateMessage}" />
                    </Border>
                </Grid>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                <Border Classes="card" Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="kicker" Text="Workshop Item IDs Or URLs" />
                        <TextBlock Classes="body" Text="Paste one Steam Workshop ID or URL per line. Apply settings to save the ordered preset, then scan to validate local content." TextWrapping="Wrap" />
                        <TextBox MinHeight="220"
                                 AcceptsReturn="True"
                                 Text="{Binding WorkshopItemIdsText}"
                                 VerticalContentAlignment="Top"
                                 TextWrapping="NoWrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Classes="card" Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="kicker" Text="Enabled Mods" />
                        <TextBlock Classes="body" Text="List one mod ID per line in the exact order the server should enable them." TextWrapping="Wrap" />
                        <TextBox MinHeight="220"
                                 AcceptsReturn="True"
                                 Text="{Binding EnabledModIdsText}"
                                 VerticalContentAlignment="Top"
                                 TextWrapping="NoWrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Classes="card" Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock Classes="kicker" Text="Map Folders" />
                    <TextBlock Classes="body" Text="List one map folder per line to control map load order. These values are validated against locally discovered workshop content after a scan." TextWrapping="Wrap" />
                    <TextBox MinHeight="160"
                             AcceptsReturn="True"
                             Text="{Binding MapFoldersText}"
                             VerticalContentAlignment="Top"
                             TextWrapping="NoWrap" />
                </StackPanel>
            </Border>

            <WrapPanel Orientation="Horizontal" ItemWidth="152" ItemHeight="36">
                <Button Command="{Binding SaveSettingsCommand}" Content="Apply Settings" />
                <Button Command="{Binding SaveDraftCommand}" Content="Save Draft" />
                <Button Command="{Binding DiscardDraftCommand}" Content="Discard Draft" />
                <Button Command="{Binding ScanCommand}" Content="Run Scan" IsEnabled="{Binding CanScan}" />
                <Button Command="{Binding ReloadCommand}" Content="Reload From Host" />
            </WrapPanel>

            <Border Background="#FBF7F1" CornerRadius="14" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Classes="kicker" Text="Diagnostics" />
                    <ItemsControl ItemsSource="{Binding Diagnostics}" IsVisible="{Binding HasDiagnostics}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Classes="body" Text="{Binding .}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Classes="body"
                               IsVisible="{Binding HasNoDiagnostics}"
                               Text="No workshop diagnostics yet. Apply settings and run a scan to validate local workshop content." 
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
