<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:settings="using:PZServerLauncher.Contracts.Profiles"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1120"
             d:DesignHeight="980"
             x:Class="PZServerLauncher.App.Views.ModsAndMapsWorkspaceView"
             x:Name="ModsRoot"
             x:DataType="vm:ModsAndMapsWorkspaceViewModel">
    <Grid>
        <ScrollViewer>
            <Grid RowDefinitions="Auto,Auto,*" RowSpacing="18">
            <Grid ColumnDefinitions="1.4*,340" ColumnSpacing="18">
                <Border Classes="card" Padding="26">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="18">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="kicker" Text="Loadout Control Deck" />
                            <TextBlock Classes="panel-title" FontSize="30" Text="{Binding ProfileDisplayName}" />
                            <TextBlock Classes="body" FontSize="16" Foreground="#45382E" Text="{Binding WorkspaceSummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="caption" Text="{Binding ModsNextStepSummary}" TextWrapping="Wrap" />
                            <WrapPanel Margin="0,8,0,0" Orientation="Horizontal" ItemHeight="30">
                                <Border Background="#2A2927" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                    <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding Branch}" />
                                </Border>
                                <Border Background="#EAD6BF" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                    <TextBlock Foreground="#5A4330" FontSize="11" Text="{Binding LoadoutHeadline}" />
                                </Border>
                                <Border Background="#EAD6BF" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                    <TextBlock Foreground="#5A4330" FontSize="11" Text="{Binding ValidationHeadline}" />
                                </Border>
                            </WrapPanel>
                        </StackPanel>
                        <Border Grid.Column="1" Classes="metric-card" Padding="16" Width="220">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="kicker" Text="Rollback" />
                                <TextBlock Classes="body" FontWeight="SemiBold" Text="{Binding RecoverySummary}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Classes="surface-dark" Padding="18">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Scanner Watch" />
                        <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="#F7F0E7" Text="{Binding ScannerSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding ScanReadinessSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="caption" Foreground="#CCB9A8" Text="{Binding QueueIntegritySummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" ColumnSpacing="14">
                <Border Classes="metric-card" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Live Stack" />
                        <TextBlock Classes="panel-title" FontSize="22" Text="{Binding LoadoutHeadline}" TextWrapping="Wrap" />
                        <TextBlock Classes="caption" Text="{Binding WorkshopSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Classes="metric-card" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Validation" />
                        <TextBlock Classes="panel-title" FontSize="22" Text="{Binding ValidationHeadline}" TextWrapping="Wrap" />
                        <TextBlock Classes="caption" Text="{Binding ScannerSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Classes="metric-card" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Preset Library" />
                        <TextBlock Classes="panel-title" FontSize="22" Text="{Binding PresetLibraryHeadline}" TextWrapping="Wrap" />
                        <TextBlock Classes="caption" Text="{Binding SavedPresetSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Classes="metric-card" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Map Chain" />
                        <TextBlock Classes="panel-title" FontSize="22" Text="{Binding MapChainHeadline}" TextWrapping="Wrap" />
                        <TextBlock Classes="caption" Text="{Binding MapOrderSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="2" ColumnDefinitions="1.22*,.78*" ColumnSpacing="18">
                <StackPanel Spacing="18">
                    <Border Classes="surface-dark" Padding="22">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Loadout Situation" />
                            <TextBlock FontSize="26" FontWeight="SemiBold" Foreground="#F7F0E7" Text="{Binding QueueIntegritySummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding MapOrderSummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="caption" Foreground="#CCB9A8" Text="{Binding RecoverySummary}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Classes="card" Padding="18">
                        <StackPanel Spacing="12">
                            <TextBlock Classes="panel-title" FontSize="22" Text="Workshop browser" />
                            <TextBlock Classes="body" Text="{Binding WorkshopBrowserSummary}" TextWrapping="Wrap" />
                            <Border Background="#FFF7EC" CornerRadius="12" Padding="12">
                                <StackPanel Spacing="6">
                                    <TextBlock Classes="kicker" Text="Collection Import" />
                                    <TextBlock Classes="caption"
                                               Text="{Binding WorkshopCollectionImportSummary}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Grid ColumnDefinitions="*,180,180,Auto" ColumnSpacing="8">
                                <TextBox Text="{Binding SearchQuery}" PlaceholderText="Search mod / collection name, or paste a Workshop item / collection URL / ID" />
                                <ComboBox Grid.Column="1" ItemsSource="{Binding AvailableSearchModes}" SelectedItem="{Binding SearchMode}" />
                                <ComboBox Grid.Column="2" ItemsSource="{Binding AvailableSearchFilters}" SelectedItem="{Binding SearchFilter}" />
                                <Button Grid.Column="3"
                                        Classes="action-primary"
                                        MinWidth="104"
                                        Content="Search"
                                        Command="{Binding SearchWorkshopCatalogCommand}" />
                            </Grid>

                            <TextBlock Classes="caption" Text="{Binding WorkshopBrowserModeSummary}" />

                            <Border Background="#FFF7EC" CornerRadius="12" Padding="12" IsVisible="{Binding ShowSteamApiKeyHelper}">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="kicker" Text="Steam Search Helper" />
                                    <TextBlock Classes="caption" Text="Steam search needs a Steam Web API user key. You can still search the local cache or paste a Workshop ID manually without it." TextWrapping="Wrap" />
                                    <TextBlock Classes="caption" Text="1. Sign in on steamcommunity.com" TextWrapping="Wrap" />
                                    <TextBlock Classes="caption" Text="2. Open steamcommunity.com/dev/apikey" TextWrapping="Wrap" />
                                    <TextBlock Classes="caption" Text="3. Register a key for a domain name" TextWrapping="Wrap" />
                                    <TextBlock Classes="caption" Text="4. Paste the generated key here" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <ItemsControl ItemsSource="{Binding WorkshopSearchDiagnostics}" IsVisible="{Binding HasWorkshopSearchDiagnostics}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Classes="caption" Text="{Binding .}" TextWrapping="Wrap" Margin="0,0,0,4" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <ItemsControl ItemsSource="{Binding WorkshopSearchResults}" IsVisible="{Binding HasWorkshopSearchResults}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ModsAndMapsWorkspaceViewModel+WorkshopCatalogItemViewModel">
                                        <Border Background="#F6EFE6" CornerRadius="14" Padding="12" Margin="0,0,0,10">
                                            <Grid ColumnDefinitions="96,*,Auto" ColumnSpacing="12">
                                                <Border Width="96" Height="58" Background="#E9DDCF" CornerRadius="10">
                                                    <Image Source="{Binding PreviewImage}" Stretch="UniformToFill" IsVisible="{Binding HasPreviewImage}" />
                                                </Border>
                                                <StackPanel Grid.Column="1" Spacing="4">
                                                    <TextBlock FontWeight="SemiBold" Foreground="#1F1A14" Text="{Binding Title}" TextWrapping="Wrap" />
                                                    <TextBlock Classes="caption" Text="{Binding WorkshopId}" />
                                                    <WrapPanel Orientation="Horizontal">
                                                        <Border Background="#D8C1A4" CornerRadius="999" Padding="8,3" Margin="0,0,6,6" IsVisible="{Binding IsCollection}">
                                                            <TextBlock Classes="kicker" Foreground="#5A3922" Text="{Binding KindLabel}" />
                                                        </Border>
                                                        <Border Background="#EAD6BF" CornerRadius="999" Padding="8,3" Margin="0,0,6,6" IsVisible="{Binding IsCollection}">
                                                            <TextBlock Classes="kicker" Text="{Binding CollectionItemCount, StringFormat='Child items: {0}'}" />
                                                        </Border>
                                                        <Border Background="#EAD6BF" CornerRadius="999" Padding="8,3" Margin="0,0,6,6">
                                                            <TextBlock Classes="kicker" Text="{Binding SourceLabel}" />
                                                        </Border>
                                                        <Border Background="#EAD6BF" CornerRadius="999" Padding="8,3" Margin="0,0,6,6">
                                                            <TextBlock Classes="kicker" Text="{Binding IsInstalledLocally, StringFormat='Installed locally: {0}'}" />
                                                        </Border>
                                                        <Border Background="#EAD6BF" CornerRadius="999" Padding="8,3" Margin="0,0,6,6">
                                                            <TextBlock Classes="kicker" Text="{Binding IsQueued, StringFormat='Queued: {0}'}" />
                                                        </Border>
                                                    </WrapPanel>
                                                    <TextBlock Classes="caption" Text="{Binding Description}" MaxLines="3" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <Button Grid.Column="2"
                                                        Classes="action-secondary"
                                                        MinWidth="104"
                                                        Content="{Binding PreviewLabel}"
                                                        Command="{Binding #ModsRoot.DataContext.PreviewWorkshopItemCommand}"
                                                        CommandParameter="{Binding .}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Classes="caption" IsVisible="{Binding HasNoWorkshopSearchResults}" Text="No Workshop results yet. Search by mod or collection name, or paste a Workshop item / collection ID or URL to resolve it." TextWrapping="Wrap" />

                            <Border Background="#FFF7EC" CornerRadius="12" Padding="12">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="kicker" Text="Steam API Key" />
                                    <TextBlock Classes="caption"
                                               Text="Save a Steam Web API user key here to enable Steam Workshop search. Local cache search and manual Workshop ID lookup stay available even without it."
                                               IsVisible="{Binding ShowSteamApiKeyEditor}"
                                               TextWrapping="Wrap" />
                                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8"
                                          IsVisible="{Binding ShowSteamApiKeyEditor}">
                                        <TextBox Text="{Binding SteamWebApiKey, UpdateSourceTrigger=PropertyChanged}"
                                                 PasswordChar="*"
                                                 PlaceholderText="Paste Steam Web API user key" />
                                        <Button Grid.Column="1"
                                                Classes="action-primary"
                                                MinWidth="132"
                                                Content="Save API Key"
                                                Command="{Binding SaveSteamWebApiKeyCommand}" />
                                        <Button Grid.Column="2"
                                                Classes="action-danger"
                                                MinWidth="116"
                                                Content="Remove Key"
                                                Command="{Binding RemoveSteamWebApiKeyCommand}"
                                                IsVisible="{Binding HasSteamWebApiKeyConfigured}" />
                                    </Grid>
                                    <Button Classes="action-danger"
                                            HorizontalAlignment="Left"
                                            MinWidth="132"
                                            Content="Remove API Key"
                                            Command="{Binding RemoveSteamWebApiKeyCommand}"
                                            IsVisible="{Binding ShowSteamApiKeyRemoveOnly}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Classes="card" Padding="18">
                        <StackPanel Spacing="12">
                            <TextBlock Classes="panel-title" FontSize="22" Text="Ordered preset manager" />
                            <TextBlock Classes="body" Text="Shape the live enabled-mod and map order here. Workshop items are resolved behind the scenes from the server mods you keep in this stack." TextWrapping="Wrap" />

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                <Border Background="#FBF7F1" CornerRadius="14" Padding="14">
                                    <StackPanel Spacing="10">
                                        <TextBlock Classes="kicker" Text="Enabled Mods" />
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <TextBox Text="{Binding NewEnabledModEntry}" PlaceholderText="Paste a mod ID" />
                                            <Button Grid.Column="1"
                                                    Classes="action-secondary"
                                                    Command="{Binding AddEnabledModEntryCommand}"
                                                    Content="Add"
                                                    IsEnabled="{Binding CanAddEnabledModEntry}" />
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding EnabledModEntries}" IsVisible="{Binding HasEnabledModEntries}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ModsAndMapsWorkspaceViewModel+PresetEntryViewModel">
                                                    <Border Background="#F6EFE6" CornerRadius="12" Padding="10" Margin="0,0,0,8">
                                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="8">
                                                            <Border Background="#E9DDCF" CornerRadius="999" Padding="8,4"><TextBlock Classes="kicker" Text="{Binding OrderLabel}" /></Border>
                                                            <TextBlock Grid.Column="1" Classes="body" Text="{Binding Value}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                                            <Button Grid.Column="2" Classes="action-secondary" Command="{Binding #ModsRoot.DataContext.MoveEntryUpCommand}" CommandParameter="{Binding .}" Content="Up" />
                                                            <Button Grid.Column="3" Classes="action-secondary" Command="{Binding #ModsRoot.DataContext.MoveEntryDownCommand}" CommandParameter="{Binding .}" Content="Down" />
                                                            <Button Grid.Column="4" Classes="action-danger" Command="{Binding #ModsRoot.DataContext.RemoveEntryCommand}" CommandParameter="{Binding .}" Content="Remove" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Classes="caption" IsVisible="{Binding HasNoEnabledModEntries}" Text="No mod IDs yet." />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Background="#FBF7F1" CornerRadius="14" Padding="14">
                                    <StackPanel Spacing="10">
                                        <TextBlock Classes="kicker" Text="Map Chain" />
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <TextBox Text="{Binding NewMapEntry}" PlaceholderText="Paste a map folder" />
                                            <Button Grid.Column="1"
                                                    Classes="action-secondary"
                                                    Command="{Binding AddMapEntryCommand}"
                                                    Content="Add"
                                                    IsEnabled="{Binding CanAddMapEntry}" />
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding MapEntries}" IsVisible="{Binding HasMapEntries}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ModsAndMapsWorkspaceViewModel+PresetEntryViewModel">
                                                    <Border Background="#F6EFE6" CornerRadius="12" Padding="10" Margin="0,0,0,8">
                                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto" ColumnSpacing="8">
                                                            <Border Background="#E9DDCF" CornerRadius="999" Padding="8,4"><TextBlock Classes="kicker" Text="{Binding OrderLabel}" /></Border>
                                                            <TextBlock Grid.Column="1" Classes="body" Text="{Binding Value}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                                            <Button Grid.Column="2" Classes="action-secondary" Command="{Binding #ModsRoot.DataContext.MoveEntryUpCommand}" CommandParameter="{Binding .}" Content="Up" />
                                                            <Button Grid.Column="3" Classes="action-secondary" Command="{Binding #ModsRoot.DataContext.MoveEntryDownCommand}" CommandParameter="{Binding .}" Content="Down" />
                                                            <Button Grid.Column="4" Classes="action-danger" Command="{Binding #ModsRoot.DataContext.RemoveEntryCommand}" CommandParameter="{Binding .}" Content="Remove" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Classes="caption" IsVisible="{Binding HasNoMapEntries}" Text="No custom map folders yet." />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Classes="card" Padding="18">
                        <StackPanel Spacing="12">
                            <TextBlock Classes="kicker" Text="Bulk Paste &amp; Export" />
                            <StackPanel Spacing="8">
                                <TextBlock Classes="kicker" Text="Enabled Mod IDs" />
                                <TextBlock Classes="caption" Text="Paste only mod IDs here. The launcher resolves Workshop items from the installed server content when it writes the live preset." TextWrapping="Wrap" />
                                <TextBox MinHeight="180" AcceptsReturn="True" Text="{Binding EnabledModIdsText}" VerticalContentAlignment="Top" TextWrapping="NoWrap" />
                            </StackPanel>
                            <StackPanel Spacing="8">
                                <TextBlock Classes="kicker" Text="Map Folders" />
                                <TextBox MinHeight="120" AcceptsReturn="True" Text="{Binding MapFoldersText}" VerticalContentAlignment="Top" TextWrapping="NoWrap" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border Grid.Column="1" Classes="surface-dark" Padding="18">
                    <StackPanel Spacing="14">
                        <Border Background="#F0E2D0" CornerRadius="16" Padding="14">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="kicker" Text="Preview Modal" />
                                <TextBlock Classes="body"
                                           FontWeight="SemiBold"
                                           Text="{Binding SelectedWorkshopPreview.Title}"
                                           IsVisible="{Binding HasSelectedWorkshopPreview}"
                                           TextWrapping="Wrap" />
                                <TextBlock Classes="caption"
                                           Text="Preview opens in a modal now so the image, collection contents, and queue impact all fit without crowding the workspace."
                                           TextWrapping="Wrap" />
                                <TextBlock Classes="caption"
                                           IsVisible="{Binding HasSelectedWorkshopPreview}"
                                           Text="{Binding SelectedWorkshopPreview.WorkshopId, StringFormat='Last previewed: {0}'}"
                                           TextWrapping="Wrap" />
                                <TextBlock Classes="caption"
                                           IsVisible="{Binding SelectedWorkshopPreview.Item.IsCollection}"
                                           Text="{Binding SelectedWorkshopPreview.Item.CollectionItemCount, StringFormat='Child items: {0}'}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Command Tower" />
                        <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="#F7F0E7" Text="{Binding ValidationHeadline}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding QueueIntegritySummary}" TextWrapping="Wrap" />

                        <Border Background="#2B221C" CornerRadius="16" Padding="14">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Actions" />
                                <WrapPanel Orientation="Horizontal" ItemWidth="152" ItemHeight="36">
                                    <Button Classes="action-primary" Command="{Binding SaveSettingsCommand}" Content="Apply Settings" />
                                    <Button Classes="action-secondary" Command="{Binding SaveDraftCommand}" Content="Save Draft" />
                                    <Button Classes="action-secondary" Command="{Binding DiscardDraftCommand}" Content="Discard Draft" />
                                    <Button Classes="action-secondary" Command="{Binding ScanCommand}" Content="Run Scan" IsEnabled="{Binding CanScan}" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="#2B221C" CornerRadius="16" Padding="14">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Named Presets" />
                                <TextBlock Classes="body" Foreground="#F0E7DC" Text="{Binding SavedPresetSummary}" TextWrapping="Wrap" />
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <TextBox Text="{Binding NewPresetName}" PlaceholderText="Preset name" />
                                    <Button Grid.Column="1"
                                            Classes="action-primary"
                                            Command="{Binding SaveNamedPresetCommand}"
                                            Content="Capture"
                                            IsEnabled="{Binding CanSaveNamedPreset}" />
                                </Grid>
                                <ItemsControl ItemsSource="{Binding SavedPresets}" IsVisible="{Binding HasSavedPresets}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ModsAndMapsWorkspaceViewModel+SavedPresetViewModel">
                                            <Border Background="#F0E2D0" CornerRadius="12" Padding="10" Margin="0,0,0,8">
                                                <StackPanel Spacing="6">
                                                    <TextBlock FontWeight="SemiBold" Foreground="#1C1713" Text="{Binding Name}" />
                                                    <TextBlock Classes="caption" Foreground="#5C4838" Text="{Binding CompositionSummary}" TextWrapping="Wrap" />
                                                    <TextBlock Classes="caption" Foreground="#5C4838" Text="{Binding UpdatedLabel}" />
                                                    <WrapPanel Orientation="Horizontal" ItemWidth="116" ItemHeight="34">
                                                        <Button Classes="action-secondary" Command="{Binding #ModsRoot.DataContext.LoadNamedPresetCommand}" CommandParameter="{Binding .}" Content="Load" />
                                                        <Button Classes="action-danger" Command="{Binding #ModsRoot.DataContext.DeleteNamedPresetCommand}" CommandParameter="{Binding .}" Content="Delete" />
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Classes="caption" IsVisible="{Binding HasNoSavedPresets}" Foreground="#CCBBA8" Text="Capture the current loadout once it looks right." TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Background="#F0E2D0" CornerRadius="16" Padding="14">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="kicker" Text="Diagnostics" />
                                <ItemsControl ItemsSource="{Binding DiagnosticBuckets}" IsVisible="{Binding HasDiagnosticBuckets}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="settings:ProjectZomboidModsAndMapsDiagnosticBucket">
                                            <Border Background="#FFF8F0" CornerRadius="12" Padding="10" Margin="0,0,0,8">
                                                <StackPanel Spacing="4">
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                                    <TextBlock Classes="caption" Text="{Binding Summary}" TextWrapping="Wrap" />
                                                    <TextBlock Classes="kicker" Text="{Binding Count, StringFormat='{}{0} issue(s)'}" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <ItemsControl ItemsSource="{Binding Diagnostics}" IsVisible="{Binding HasDiagnostics}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Classes="caption" Text="{Binding .}" TextWrapping="Wrap" Margin="0,0,0,6" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Classes="caption" IsVisible="{Binding HasNoDiagnosticBuckets}" Text="No categorized scan issues yet. Apply settings and run a scan to validate the local cache." TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
            </Grid>
        </ScrollViewer>

        <Border Background="#AA16110C"
                IsVisible="{Binding IsWorkshopPreviewModalOpen}">
            <Border Classes="card"
                    MaxWidth="860"
                    MaxHeight="760"
                    Margin="24"
                    Padding="22"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <Grid RowDefinitions="Auto,*,Auto" RowSpacing="16">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="kicker" Text="Workshop Preview" />
                            <TextBlock Classes="panel-title"
                                       FontSize="26"
                                       Text="{Binding SelectedWorkshopPreview.Title}"
                                       TextWrapping="Wrap" />
                            <TextBlock Classes="caption"
                                       Text="{Binding SelectedWorkshopPreview.WorkshopId, StringFormat='Workshop ID: {0}'}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Classes="action-secondary"
                                MinWidth="100"
                                Content="Close"
                                Command="{Binding CloseWorkshopPreviewCommand}" />
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="14">
                            <Image Source="{Binding SelectedWorkshopPreview.PreviewImage}"
                                   Height="260"
                                   Stretch="UniformToFill"
                                   IsVisible="{Binding SelectedWorkshopPreview.HasPreviewImage}" />

                            <WrapPanel Orientation="Horizontal" ItemHeight="30">
                                <Border Background="#EAD6BF" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                    <TextBlock Classes="kicker" Text="{Binding SelectedWorkshopPreview.Item.KindLabel}" />
                                </Border>
                                <Border Background="#EAD6BF" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                    <TextBlock Classes="kicker" Text="{Binding SelectedWorkshopPreview.SourceLabel}" />
                                </Border>
                                <Border Background="#EAD6BF" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                    <TextBlock Classes="kicker" Text="{Binding SelectedWorkshopPreview.Item.IsInstalledLocally, StringFormat='Installed locally: {0}'}" />
                                </Border>
                                <Border Background="#EAD6BF" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                    <TextBlock Classes="kicker" Text="{Binding SelectedWorkshopPreview.Item.IsQueued, StringFormat='Queued: {0}'}" />
                                </Border>
                                <Border Background="#EAD6BF"
                                        CornerRadius="999"
                                        Padding="10,5"
                                        Margin="0,0,8,8"
                                        IsVisible="{Binding SelectedWorkshopPreview.Item.IsCollection}">
                                    <TextBlock Classes="kicker" Text="{Binding SelectedWorkshopPreview.Item.CollectionItemCount, StringFormat='Child items: {0}'}" />
                                </Border>
                            </WrapPanel>

                            <TextBlock Classes="body"
                                       Text="{Binding SelectedWorkshopPreview.Description}"
                                       TextWrapping="Wrap" />

                            <Border Background="#FFF7EC" CornerRadius="14" Padding="14">
                                <StackPanel Spacing="6">
                                    <TextBlock Classes="kicker" Text="Queue Impact" />
                                    <TextBlock Classes="caption"
                                               Text="{Binding SelectedWorkshopPreview.WorkshopItemIdsToAdd.Count, StringFormat='Workshop IDs to add: {0}'}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Classes="caption"
                                               Text="{Binding SelectedWorkshopPreview.ModIdsToAdd.Count, StringFormat='Mod IDs to add: {0}'}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Classes="caption"
                                               Text="{Binding SelectedWorkshopPreview.MapFoldersToAdd.Count, StringFormat='Map folders to add: {0}'}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Background="#FFF7EC" CornerRadius="14" Padding="14" IsVisible="{Binding SelectedWorkshopPreview.HasCollectionChildren}">
                                <StackPanel Spacing="10">
                                    <TextBlock Classes="kicker" Text="Collection Contents" />
                                    <ItemsControl ItemsSource="{Binding SelectedWorkshopPreview.CollectionChildren}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="settings:WorkshopCatalogPreviewChildDto">
                                                <Border Background="#FFFDF8" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                                                    <StackPanel Spacing="2">
                                                        <TextBlock FontWeight="SemiBold" Foreground="#1F1A14" Text="{Binding Title}" TextWrapping="Wrap" />
                                                        <TextBlock Classes="caption" Text="{Binding WorkshopId}" TextWrapping="Wrap" />
                                                        <TextBlock Classes="caption" Text="{Binding IsInstalledLocally, StringFormat='Installed locally: {0}'}" TextWrapping="Wrap" />
                                                        <TextBlock Classes="caption" Text="{Binding IsQueued, StringFormat='Queued: {0}'}" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                        <Border Background="Transparent" />
                        <Button Grid.Column="1"
                                Classes="action-secondary"
                                MinWidth="104"
                                Content="Close"
                                Command="{Binding CloseWorkshopPreviewCommand}" />
                        <Button Grid.Column="2"
                                Classes="action-primary"
                                MinWidth="156"
                                Content="{Binding SelectedWorkshopApplyLabel}"
                                Command="{Binding ApplyWorkshopPreviewCommand}"
                                IsEnabled="{Binding CanApplyWorkshopPreview}" />
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</UserControl>
