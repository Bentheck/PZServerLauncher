<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:profiles="using:PZServerLauncher.Contracts.Profiles"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1120"
             d:DesignHeight="900"
             x:Class="PZServerLauncher.App.Views.UsersWorkspaceView"
             x:Name="UsersRoot"
             x:DataType="vm:UsersWorkspaceViewModel">
    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="18">
        <Grid ColumnDefinitions="1.42*,340" ColumnSpacing="18">
            <Border Classes="card" Padding="26">
                <Grid ColumnDefinitions="*,220" ColumnSpacing="18">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="kicker" Text="Identity Command" />
                        <TextBlock Classes="panel-title" FontSize="30" Text="{Binding PageTitle}" />
                        <TextBlock Classes="body"
                                   FontSize="16"
                                   Foreground="#45382E"
                                   Text="{Binding UsersPageSummary}"
                                   TextWrapping="Wrap" />
                        <TextBlock Classes="caption" Text="{Binding UserNextStepSummary}" TextWrapping="Wrap" />

                        <WrapPanel Margin="0,8,0,0" Orientation="Horizontal" ItemHeight="30">
                            <Border Background="#2A2927" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding OwnerBootstrapLabel}" />
                            </Border>
                            <Border Background="#EAD6BF" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                <TextBlock Foreground="#5A4330" FontSize="11" Text="{Binding UserCountSummary}" />
                            </Border>
                            <Border Background="#EAD6BF" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                <TextBlock Foreground="#5A4330" FontSize="11" Text="{Binding PendingChangeSummary}" />
                            </Border>
                        </WrapPanel>
                    </StackPanel>

                    <Border Grid.Column="1" Classes="metric-card" Padding="16">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="kicker" Text="Access Watch" />
                            <TextBlock Classes="body" FontWeight="SemiBold" Text="{Binding SecurityPostureSummary}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" Classes="surface-dark" Padding="18">
                <StackPanel Spacing="10">
                    <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Access Watch" />
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#F7F0E7"
                               Text="{Binding OwnerProtectionSummary}"
                               TextWrapping="Wrap" />
                    <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding RoleCoverageSummary}" TextWrapping="Wrap" />
                    <TextBlock Classes="caption" Foreground="#CCB9A8" Text="{Binding TwoFactorSummary}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*,*" ColumnSpacing="14">
            <Border Classes="metric-card" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Classes="kicker" Text="Owners" />
                    <TextBlock Classes="panel-title" FontSize="22" Text="{Binding OwnerCount, StringFormat='{}{0}'}" />
                    <TextBlock Classes="caption" Text="{Binding OwnerSummary}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Classes="metric-card" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Classes="kicker" Text="Managed Users" />
                    <TextBlock Classes="panel-title" FontSize="22" Text="{Binding UserCount, StringFormat='{}{0}'}" />
                    <TextBlock Classes="caption" Text="{Binding RosterSummary}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Classes="metric-card" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Classes="kicker" Text="Privileged" />
                    <TextBlock Classes="panel-title" FontSize="22" Text="{Binding PrivilegedAccountCount, StringFormat='{}{0}'}" />
                    <TextBlock Classes="caption" Text="{Binding RoleCoverageSummary}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Classes="metric-card" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Classes="kicker" Text="2FA Ready" />
                    <TextBlock Classes="panel-title" FontSize="22" Text="{Binding TwoFactorEnabledCount, StringFormat='{}{0}'}" />
                    <TextBlock Classes="caption" Text="{Binding TwoFactorSummary}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Classes="metric-card" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Classes="kicker" Text="Pending 2FA" />
                    <TextBlock Classes="panel-title" FontSize="22" Text="{Binding PendingTwoFactorCount, StringFormat='{}{0}'}" />
                    <TextBlock Classes="caption" Text="{Binding UserNextStepSummary}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="1.18*,.82*" ColumnSpacing="18">
            <StackPanel Spacing="18">
                <Border Classes="surface-dark" Padding="18">
                    <Grid ColumnDefinitions="1.05*,.95*" ColumnSpacing="16">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Access Posture" />
                            <TextBlock FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="#F7F0E7"
                                       Text="{Binding SecurityPostureSummary}"
                                       TextWrapping="Wrap" />
                            <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding OwnerProtectionSummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="caption" Foreground="#CCB9A8" Text="{Binding ReviewSummary}" TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="8">
                            <Border Background="#2B221C" CornerRadius="16" Padding="14">
                                <StackPanel Spacing="6">
                                    <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Roster Signal" />
                                    <TextBlock Classes="body" Foreground="#F0E7DC" Text="{Binding RosterSummary}" TextWrapping="Wrap" />
                                    <TextBlock Classes="caption" Foreground="#CCBBA8" Text="{Binding PendingChangeSummary}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <ItemsControl ItemsSource="{Binding AccessChecklist}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="profiles:ProjectZomboidOperatorChecklistItem">
                                        <Border Background="#F0E2D0" CornerRadius="12" Padding="12" Margin="0,0,0,8">
                                            <StackPanel Spacing="4">
                                                <TextBlock Classes="kicker" Text="{Binding StatusLabel}" />
                                                <TextBlock Classes="caption" Foreground="#5A4636" Text="{Binding Message}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="#FFF8F1"
                        CornerRadius="16"
                        Padding="18"
                        IsVisible="{Binding Legacy.OwnerBootstrapRequired}">
                    <Grid ColumnDefinitions="1.05*,.95*" ColumnSpacing="16">
                        <StackPanel Spacing="14">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="kicker" Text="Owner Bootstrap" />
                                <TextBlock Classes="panel-title" FontSize="22" Text="Create the first control-plane owner" />
                                <TextBlock Classes="body"
                                           Text="Bootstrap the initial local owner account now so the optional web admin can be enabled later without leaving the desktop app."
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="kicker" Text="Username" />
                                    <TextBox Text="{Binding Legacy.OwnerUserName}" PlaceholderText="owner" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Classes="kicker" Text="Password" />
                                    <TextBox Text="{Binding Legacy.OwnerPassword}" PasswordChar="*" PlaceholderText="Choose a password" />
                                </StackPanel>
                            </Grid>

                            <Button HorizontalAlignment="Left"
                                    Command="{Binding Legacy.BootstrapOwnerCommand}"
                                    Content="Create Owner Account" />
                        </StackPanel>

                        <Border Grid.Column="1" Background="#F5E8DA" CornerRadius="14" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="kicker" Text="Bootstrap Guardrails" />
                                <TextBlock Classes="body" Text="{Binding OwnerProtectionSummary}" TextWrapping="Wrap" />
                                <TextBlock Classes="caption" Text="{Binding UserNextStepSummary}" TextWrapping="Wrap" />
                                <TextBlock Classes="caption" Text="{Binding TwoFactorSummary}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <StackPanel Spacing="18" IsVisible="{Binding OwnerBootstrapConfigured}">
                    <Grid ColumnDefinitions="1.02*,.98*" ColumnSpacing="16">
                        <Border Classes="card" Padding="18">
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="kicker" Text="Create User" />
                                        <TextBlock Classes="panel-title" FontSize="22" Text="{Binding CreateRoleSummary}" TextWrapping="Wrap" />
                                        <TextBlock Classes="body" Text="{Binding CreateFormSummary}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            VerticalAlignment="Top"
                                            Command="{Binding ReloadUsersCommand}"
                                            Content="Refresh Roster"
                                            IsEnabled="{Binding CanManageUsers}" />
                                </Grid>

                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="kicker" Text="Username" />
                                        <TextBox Text="{Binding CreateUserName}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Classes="kicker" Text="Temporary Password" />
                                        <TextBox Text="{Binding CreatePassword}" PasswordChar="*" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Spacing="4">
                                        <TextBlock Classes="kicker" Text="Role" />
                                        <ComboBox ItemsSource="{Binding RoleOptions}"
                                                  SelectedItem="{Binding CreateRoleName}" />
                                        <TextBlock Classes="caption" Text="{Binding CreateRoleGuardrailSummary}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>

                                <Button HorizontalAlignment="Left"
                                        Command="{Binding CreateUserCommand}"
                                        Content="Create User"
                                        IsEnabled="{Binding CanCreateUser}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Classes="surface-dark" Padding="18">
                            <StackPanel Spacing="12">
                                <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Access Tower" />
                                <TextBlock FontSize="24"
                                           FontWeight="SemiBold"
                                           Foreground="#F7F0E7"
                                           Text="{Binding StatusMessage}"
                                           TextWrapping="Wrap" />
                                <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding SecurityPostureSummary}" TextWrapping="Wrap" />
                                <TextBlock Classes="caption" Foreground="#CCB9A8" Text="{Binding UserNextStepSummary}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Classes="card" Padding="18">
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="kicker" Text="Current Users" />
                                    <TextBlock Classes="panel-title" FontSize="22" Text="Desktop roster and role control" />
                                    <TextBlock Classes="body"
                                               Text="Desktop now mirrors the core account-management workflows. Save only the rows you changed, and keep privileged roles paired with TOTP before the optional web admin is exposed."
                                               TextWrapping="Wrap" />
                                </StackPanel>
                                <Border Background="#2A2927" CornerRadius="999" Padding="10,5" VerticalAlignment="Top">
                                    <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding UserCount, StringFormat='{}{0} account(s)'}" />
                                </Border>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Users}" IsVisible="{Binding HasUsers}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:UsersWorkspaceViewModel+EditableUserRowViewModel">
                                        <Border Background="#F6EFE6" CornerRadius="14" Padding="14" Margin="0,0,0,10">
                                            <Grid ColumnDefinitions="*,*,220,260,Auto,Auto,Auto" ColumnSpacing="12">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Classes="kicker" Text="Username" />
                                                    <TextBox Text="{Binding UserName}" />
                                                    <TextBlock Classes="caption" Text="{Binding DirtySummary}" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Spacing="4">
                                                    <TextBlock Classes="kicker" Text="Role" />
                                                    <ComboBox ItemsSource="{Binding #UsersRoot.DataContext.RoleOptions}"
                                                              SelectedItem="{Binding RoleName}" />
                                                    <TextBlock Classes="caption" Text="{Binding RoleSummary}" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <Border Grid.Column="2" Background="#FFF8F0" BorderBrush="#E0C1A2" BorderThickness="1" CornerRadius="12" Padding="12">
                                                    <StackPanel Spacing="4">
                                                        <TextBlock Classes="kicker" Text="Security" />
                                                        <TextBlock Classes="caption" Text="{Binding SecuritySummary}" TextWrapping="Wrap" />
                                                        <TextBlock Classes="caption" Text="{Binding TwoFactorEnabled, StringFormat='2FA enabled: {0}'}" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Grid.Column="3" Background="#FFF8F0" BorderBrush="#E0C1A2" BorderThickness="1" CornerRadius="12" Padding="12">
                                                    <StackPanel Spacing="6">
                                                        <TextBlock Classes="kicker" Text="Password Reset" />
                                                        <TextBlock Classes="caption" Text="{Binding PasswordResetSummary}" TextWrapping="Wrap" />
                                                        <TextBox Text="{Binding TemporaryPassword}" PasswordChar="*" PlaceholderText="Set a temporary password" />
                                                    </StackPanel>
                                                </Border>
                                                <Button Grid.Column="4"
                                                        VerticalAlignment="Bottom"
                                                        Command="{Binding #UsersRoot.DataContext.ResetUserPasswordCommand}"
                                                        CommandParameter="{Binding .}"
                                                        Content="Reset Password"
                                                        IsEnabled="{Binding CanResetPassword}" />
                                                <Button Grid.Column="5"
                                                        VerticalAlignment="Bottom"
                                                        Command="{Binding #UsersRoot.DataContext.SaveUserCommand}"
                                                        CommandParameter="{Binding .}"
                                                        Content="Save Changes"
                                                        IsEnabled="{Binding IsDirty}" />
                                                <Button Grid.Column="6"
                                                        VerticalAlignment="Bottom"
                                                        Command="{Binding #UsersRoot.DataContext.DeleteUserCommand}"
                                                        CommandParameter="{Binding .}"
                                                        Content="Remove Account" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Background="#1F1D1B"
                                    CornerRadius="16"
                                    Padding="18"
                                    IsVisible="{Binding HasNoUsers}">
                                <StackPanel Spacing="10">
                                    <TextBlock Classes="kicker" Foreground="#E5A26B" Text="No Managed Users Yet" />
                                    <TextBlock Classes="panel-title" FontSize="22" Foreground="#F7F0E7" Text="Bootstrap is done, but the roster is still empty" />
                                    <TextBlock Classes="body"
                                               Foreground="#D3C8BA"
                                               Text="Add operators or viewers here before exposing the optional web surface so you are not running remote admin with a single account."
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="16">
                <Border Classes="card" Padding="18">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="kicker" Text="Operator Checklist" />
                        <TextBlock Classes="body" Text="{Binding ReviewSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="caption" Text="{Binding PendingChangeSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Classes="card" Padding="18">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="kicker" Text="Access Coverage" />
                        <TextBlock Classes="body" Text="{Binding RoleCoverageSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="caption" Text="{Binding TwoFactorSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="caption" Text="{Binding UserNextStepSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
