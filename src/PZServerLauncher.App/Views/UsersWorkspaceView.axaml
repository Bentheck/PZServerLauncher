<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="980"
             d:DesignHeight="760"
             x:Class="PZServerLauncher.App.Views.UsersWorkspaceView"
             x:Name="UsersRoot"
             x:DataType="vm:UsersWorkspaceViewModel">
    <Border Classes="card" Padding="24">
        <StackPanel Spacing="18">
            <Border Background="#1F1D1B" CornerRadius="16" Padding="18">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="18">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Identity And Access" />
                        <TextBlock FontSize="28" FontWeight="SemiBold" Foreground="#F7F0E7" Text="{Binding PageTitle}" />
                        <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding UsersPageSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Border Grid.Column="1" Background="#2A2927" CornerRadius="999" Padding="14,8" VerticalAlignment="Top">
                        <TextBlock Foreground="#F7F0E7" FontWeight="SemiBold" Text="{Binding OwnerBootstrapLabel}" />
                    </Border>
                </Grid>
            </Border>

            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="14">
                <Border Background="#F6EFE6" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Owner" />
                        <TextBlock Classes="body" Text="{Binding OwnerSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="#F6EFE6" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Managed Users" />
                        <TextBlock Classes="body" Text="{Binding UserCountSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="#F6EFE6" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="2FA Policy" />
                        <TextBlock Classes="body" Text="{Binding TwoFactorSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Background="#F6EFE6" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Role Coverage" />
                        <TextBlock Classes="body" Text="{Binding RoleCoverageSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                <Border Background="#FFF8F1" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="kicker" Text="Security Posture" />
                        <TextBlock Classes="body" Text="{Binding SecurityPostureSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="#FFF8F1" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="kicker" Text="Next Step" />
                        <TextBlock Classes="body" Text="{Binding UserNextStepSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="#FFF8F1"
                    CornerRadius="14"
                    Padding="18"
                    IsVisible="{Binding Legacy.OwnerBootstrapRequired}">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="panel-title" FontSize="20" Text="Owner Bootstrap" />
                        <TextBlock Classes="body" Text="Create the initial local owner account now so the optional web admin surface can be enabled later without leaving the desktop app." TextWrapping="Wrap" />
                    </StackPanel>

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="kicker" Text="Username" />
                            <TextBox Text="{Binding Legacy.OwnerUserName}" PlaceholderText="owner" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Classes="kicker" Text="Email" />
                            <TextBox Text="{Binding Legacy.OwnerEmail}" PlaceholderText="owner@localhost" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Classes="kicker" Text="Password" />
                            <TextBox Text="{Binding Legacy.OwnerPassword}" PasswordChar="*" PlaceholderText="Choose a password" />
                        </StackPanel>
                    </Grid>

                    <Button HorizontalAlignment="Left"
                            Command="{Binding Legacy.BootstrapOwnerCommand}"
                            Content="Create Owner Account" />
                </StackPanel>
            </Border>

            <StackPanel Spacing="18" IsVisible="{Binding OwnerBootstrapConfigured}">
                <Grid ColumnDefinitions="*,320" ColumnSpacing="16">
                    <Border Classes="card" Padding="18">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="panel-title" FontSize="20" Text="Create User" />
                                <TextBlock Classes="body" Text="{Binding ActionSummary}" TextWrapping="Wrap" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                        VerticalAlignment="Top"
                                        Command="{Binding ReloadUsersCommand}"
                                        Content="Reload Users"
                                        IsEnabled="{Binding CanManageUsers}" />
                            </Grid>

                            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="kicker" Text="Username" />
                                    <TextBox Text="{Binding CreateUserName}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Classes="kicker" Text="Email" />
                                    <TextBox Text="{Binding CreateEmail}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" Spacing="4">
                                    <TextBlock Classes="kicker" Text="Temporary Password" />
                                    <TextBox Text="{Binding CreatePassword}" PasswordChar="*" />
                                </StackPanel>
                                <StackPanel Grid.Column="3" Spacing="4">
                                    <TextBlock Classes="kicker" Text="Role" />
                                    <ComboBox ItemsSource="{Binding RoleOptions}"
                                              SelectedItem="{Binding CreateRoleName}" />
                                </StackPanel>
                            </Grid>

                            <Button HorizontalAlignment="Left"
                                    Command="{Binding CreateUserCommand}"
                                    Content="Create User"
                                    IsEnabled="{Binding CanCreateUser}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Classes="card" Padding="18">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="kicker" Text="Current Snapshot" />
                            <TextBlock Classes="body" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="{Binding SecurityPostureSummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="{Binding UserNextStepSummary}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Classes="card" Padding="18">
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="panel-title" FontSize="20" Text="Current Users" />
                            <TextBlock Classes="body" Text="Desktop now mirrors the core account-management workflows. Use Save on each edited row, or use page-level save/discard if you navigate away mid-edit." TextWrapping="Wrap" />
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding Users}" IsVisible="{Binding HasUsers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:UsersWorkspaceViewModel+EditableUserRowViewModel">
                                    <Border Background="#F6EFE6" CornerRadius="14" Padding="14" Margin="0,0,0,10">
                                        <Grid ColumnDefinitions="*,*,200,220,Auto,Auto" ColumnSpacing="12">
                                            <StackPanel Spacing="4">
                                                <TextBlock Classes="kicker" Text="Username" />
                                                <TextBox Text="{Binding UserName}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Spacing="4">
                                                <TextBlock Classes="kicker" Text="Email" />
                                                <TextBox Text="{Binding Email}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Spacing="4">
                                                <TextBlock Classes="kicker" Text="Role" />
                                                <ComboBox ItemsSource="{Binding #UsersRoot.DataContext.RoleOptions}"
                                                          SelectedItem="{Binding RoleName}" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="3" Spacing="4">
                                                <TextBlock Classes="kicker" Text="2FA" />
                                                <TextBlock Classes="body"
                                                           Text="{Binding TwoFactorEnabled, StringFormat='Enabled: {0}'}" />
                                                <TextBlock Classes="body"
                                                           Text="{Binding RequiresTwoFactor, StringFormat='Required for web sign-in: {0}'}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <Button Grid.Column="4"
                                                    VerticalAlignment="Bottom"
                                                    Command="{Binding #UsersRoot.DataContext.SaveUserCommand}"
                                                    CommandParameter="{Binding .}"
                                                    Content="Save" />
                                            <Button Grid.Column="5"
                                                    VerticalAlignment="Bottom"
                                                    Command="{Binding #UsersRoot.DataContext.DeleteUserCommand}"
                                                    CommandParameter="{Binding .}"
                                                    Content="Delete" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Classes="body"
                                   IsVisible="{Binding HasNoUsers}"
                                   Text="No local user accounts exist yet beyond owner bootstrap."
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
