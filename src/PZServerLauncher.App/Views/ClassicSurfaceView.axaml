<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1460"
             d:DesignHeight="1080"
             x:Class="PZServerLauncher.App.Views.ClassicSurfaceView"
             x:Name="ClassicRoot"
             x:DataType="vm:MainWindowViewModel">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" Margin="0" RowSpacing="20">
            <Border Classes="card" Padding="28">
                <Grid ColumnDefinitions="*,360" ColumnSpacing="20">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="kicker" Text="Classic Surface" />
                        <TextBlock FontSize="40" FontWeight="Bold" Foreground="#1D1A17" Text="{Binding Title}" />
                        <TextBlock Classes="body" FontSize="18" Text="{Binding Subtitle}" />
                    </StackPanel>
                    <Border Background="#1F1D1B" CornerRadius="16" Padding="18">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Host Summary" />
                            <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="#F7F0E7" Text="{Binding HostSummary}" />
                            <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding RemoteSummary}" />
                            <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding OwnerSummary}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1" Classes="card">
                <Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="12">
                    <Button Command="{Binding RefreshCommand}" Content="Refresh" />
                    <Button Grid.Column="1" Command="{Binding CreateStarterProfileCommand}" Content="Create Starter Profile" />
                    <Button Grid.Column="2" Command="{Binding DiscoverImportsCommand}" Content="Discover Local Imports" />
                    <TextBlock Grid.Column="3" Classes="body" VerticalAlignment="Center" Text="{Binding StatusMessage}" />
                </Grid>
            </Border>

            <Border Grid.Row="2" Classes="card">
                <Grid ColumnDefinitions="340,*" ColumnSpacing="20">
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="panel-title" FontSize="22" Text="Host Settings" />
                            <TextBlock Classes="body" Text="Closing this window minimizes to tray. Use Exit Desktop when you want to close the UI but leave the local host running." TextWrapping="Wrap" />
                        </StackPanel>

                        <CheckBox Content="Start Host With Windows" IsChecked="{Binding HostStartWithWindows}" />

                        <WrapPanel Orientation="Horizontal" ItemHeight="36" ItemWidth="148">
                            <Button Command="{Binding SaveHostSettingsCommand}" Content="Save Host Settings" />
                            <Button Command="{Binding StopHostCommand}" Content="Stop Host" />
                            <Button Command="{Binding StopAllAndHostCommand}" Content="Stop All + Host" />
                            <Button Command="{Binding ExitDesktopCommand}" Content="Exit Desktop" />
                        </WrapPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="panel-title" FontSize="22" Text="Remote Access Setup" />
                            <TextBlock Classes="body" Text="Desktop-driven HTTPS setup for the optional web admin. Router forwarding is still manual in v1, but you can save, self-test, and apply a Windows Firewall rule from here." TextWrapping="Wrap" />
                        </StackPanel>

                        <Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="10" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
                            <CheckBox Grid.ColumnSpan="4"
                                      Content="Enable Remote Access"
                                      IsChecked="{Binding RemoteAccessEnabled}" />

                            <TextBlock Grid.Row="1" Classes="body" Text="Bind Address" VerticalAlignment="Center" />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding RemoteBindAddress}" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Classes="body" Text="HTTPS Port" VerticalAlignment="Center" />
                            <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding RemoteHttpsPort}" />

                            <TextBlock Grid.Row="2" Classes="body" Text="Public Hostname" VerticalAlignment="Center" />
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding RemotePublicHostname}" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Classes="body" Text="PFX Password" VerticalAlignment="Center" />
                            <TextBox Grid.Row="2" Grid.Column="3" PasswordChar="*" Text="{Binding RemoteCertificatePassword}" />

                            <TextBlock Grid.Row="3" Classes="body" Text="PFX Certificate Path" VerticalAlignment="Center" />
                            <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding RemoteCertificatePath}" />
                        </Grid>

                        <CheckBox Content="Create Or Update The Windows Firewall Rule"
                                  IsChecked="{Binding RemoteCreateFirewallRule}" />

                        <WrapPanel Orientation="Horizontal" ItemHeight="36" ItemWidth="162">
                            <Button Command="{Binding SaveRemoteAccessCommand}" Content="Save Remote Settings" />
                            <Button Command="{Binding RemoteSelfTestCommand}" Content="Run Local Self-Test" />
                            <Button Command="{Binding ApplyFirewallRuleCommand}" Content="Apply Firewall Rule" />
                        </WrapPanel>

                        <TextBlock Classes="body" Text="{Binding RemoteWizardStatus}" TextWrapping="Wrap" />
                        <TextBlock Classes="body"
                                   FontFamily="Cascadia Code,Consolas,monospace"
                                   Text="{Binding RemoteSelfTestChecks}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="3" Classes="card">
                <TextBlock Classes="body" Text="The classic experience remains functional while the new workspace shell is introduced around it. Use the workspace navigation to move into the new structure, or stay here for the full legacy flow." TextWrapping="Wrap" />
            </Border>

            <Border Grid.Row="4" Classes="card" IsVisible="{Binding OwnerBootstrapRequired}">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="panel-title" FontSize="24" Text="Owner Bootstrap" />
                        <TextBlock Classes="body" Text="Create the initial local owner account now so the optional web admin surface can be enabled later without leaving the desktop app." TextWrapping="Wrap" />
                    </StackPanel>

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="kicker" Text="Username" />
                            <TextBox Text="{Binding OwnerUserName}" PlaceholderText="owner" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Classes="kicker" Text="Email" />
                            <TextBox Text="{Binding OwnerEmail}" PlaceholderText="owner@localhost" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Classes="kicker" Text="Password" />
                            <TextBox Text="{Binding OwnerPassword}" PasswordChar="*" PlaceholderText="Choose a password" />
                        </StackPanel>
                    </Grid>

                    <Button HorizontalAlignment="Left" Command="{Binding BootstrapOwnerCommand}" Content="Create Owner Account" />
                </StackPanel>
            </Border>

            <Border Grid.Row="5" Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Classes="panel-title" FontSize="22" Text="Import Candidates" />
                    <ItemsControl ItemsSource="{Binding ImportCandidates}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ImportCandidateViewModel">
                                <Border Background="#F6EFE6" CornerRadius="14" Padding="14" Margin="0,0,0,10">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="panel-title" FontSize="20" Text="{Binding DisplayName}" />
                                            <TextBlock Classes="body" Text="{Binding ServerName}" />
                                            <TextBlock Classes="body" FontFamily="Cascadia Code,Consolas,monospace" Text="{Binding CacheDirectory}" />
                                            <TextBlock Classes="body" FontFamily="Cascadia Code,Consolas,monospace" Text="{Binding InstallDirectory}" />
                                            <TextBlock Classes="body" Text="{Binding Branch}" />
                                            <TextBlock Classes="body" Text="{Binding Notes}" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <Button Command="{Binding #ClassicRoot.DataContext.ImportCandidateCommand}"
                                                CommandParameter="{Binding .}"
                                                Content="{Binding ImportActionLabel}"
                                                IsEnabled="{Binding CanImport}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Row="6" Classes="card">
                <StackPanel Spacing="10">
                    <TextBlock Classes="panel-title" FontSize="22" Text="Recent Jobs" />
                    <ItemsControl ItemsSource="{Binding RecentJobs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ShellItemViewModel">
                                <Border Background="#F6EFE6" CornerRadius="14" Padding="14" Margin="0,0,0,8">
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="kicker" Text="{Binding Title}" />
                                        <TextBlock Classes="body" Text="{Binding Detail}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <ItemsControl Grid.Row="7" ItemsSource="{Binding Profiles}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:ProfileCardViewModel">
                        <Border Classes="card" Margin="0,0,0,16">
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="14">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="panel-title" FontSize="22" Text="{Binding DisplayName}" />
                                        <TextBlock Classes="body" Text="{Binding Branch}" />
                                    </StackPanel>
                                    <Border Background="#2A2927" CornerRadius="14" Padding="12,8" HorizontalAlignment="Right">
                                        <TextBlock Foreground="#F7F0E7" Text="{Binding RuntimeState}" />
                                    </Border>
                                </Grid>

                                <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="18">
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="kicker" Text="Paths" />
                                        <TextBlock Classes="body" FontFamily="Cascadia Code,Consolas,monospace" Text="{Binding InstallDirectory}" />
                                        <TextBlock Classes="body" FontFamily="Cascadia Code,Consolas,monospace" Text="{Binding CacheDirectory}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="4">
                                        <TextBlock Classes="kicker" Text="Ports And Backups" />
                                        <TextBlock Classes="body" Text="{Binding Ports}" />
                                        <TextBlock Classes="body" Text="{Binding LastBackup}" />
                                        <TextBlock Classes="body" Text="{Binding WorkshopSummary}" />
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="18">
                                    <StackPanel Spacing="8">
                                        <TextBlock Classes="kicker" Text="Workspace Pages Live" />
                                        <Border Background="#F1E6D7" CornerRadius="14" Padding="16">
                                            <StackPanel Spacing="8">
                                                <TextBlock Classes="body" Text="Structured General and Sandbox settings now live in the workspace pages." TextWrapping="Wrap" />
                                                <TextBlock Classes="body" Text="Use the new workspace for server identity, primary ports, memory, startup behavior, and first-pass sandbox gameplay/world settings. Classic remains focused on raw files and the still-migrating areas." TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Spacing="8">
                                        <TextBlock Classes="kicker" Text="Validation" />
                                        <TextBlock Classes="body" Text="{Binding WorkshopDiagnostics}" TextWrapping="Wrap" />
                                        <TextBlock Classes="kicker" Text="Latest Log" />
                                        <TextBlock Classes="body" Text="{Binding LatestLogLine}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="3" ColumnDefinitions="*,320" ColumnSpacing="18">
                                    <StackPanel Spacing="8">
                                        <Grid ColumnDefinitions="240,Auto,Auto,*" ColumnSpacing="10">
                                            <StackPanel Spacing="4">
                                                <TextBlock Classes="kicker" Text="Raw Config Editor" />
                                                <ComboBox ItemsSource="{Binding RawConfigKinds}"
                                                          SelectedItem="{Binding SelectedRawConfigKind}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:ConfigFileOptionViewModel">
                                                            <TextBlock Text="{Binding Label}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    VerticalAlignment="Bottom"
                                                    Command="{Binding #ClassicRoot.DataContext.LoadRawConfigCommand}"
                                                    CommandParameter="{Binding .}"
                                                    Content="Load File" />
                                            <Button Grid.Column="2"
                                                    VerticalAlignment="Bottom"
                                                    Command="{Binding #ClassicRoot.DataContext.SaveRawConfigCommand}"
                                                    CommandParameter="{Binding .}"
                                                    Content="Save File"
                                                    IsEnabled="{Binding IsRawConfigLoaded}" />
                                            <TextBlock Grid.Column="3"
                                                       VerticalAlignment="Bottom"
                                                       Classes="body"
                                                       Text="{Binding RawConfigStatus}"
                                                       TextWrapping="Wrap" />
                                        </Grid>

                                        <TextBox MinHeight="240"
                                                 AcceptsReturn="True"
                                                 AcceptsTab="True"
                                                 FontFamily="Cascadia Code,Consolas,monospace"
                                                 HorizontalAlignment="Stretch"
                                                 Text="{Binding RawConfigContent}"
                                                 TextWrapping="NoWrap"
                                                 VerticalContentAlignment="Top" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Spacing="8">
                                        <TextBlock Classes="kicker" Text="Raw Diagnostics" />
                                        <TextBlock Classes="body"
                                                   Text="{Binding RawConfigDiagnostics}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>

                                <WrapPanel Grid.Row="4" ItemHeight="36" ItemWidth="132" Orientation="Horizontal">
                                    <Button Command="{Binding #ClassicRoot.DataContext.ScanWorkshopCommand}" CommandParameter="{Binding .}" Content="Scan Workshop" />
                                    <Button Command="{Binding #ClassicRoot.DataContext.InstallCommand}" CommandParameter="{Binding .}" Content="Install" />
                                    <Button Command="{Binding #ClassicRoot.DataContext.UpdateCommand}" CommandParameter="{Binding .}" Content="Update" />
                                    <Button Command="{Binding #ClassicRoot.DataContext.StartCommand}" CommandParameter="{Binding .}" Content="Start" />
                                    <Button Command="{Binding #ClassicRoot.DataContext.StopCommand}" CommandParameter="{Binding .}" Content="Stop" />
                                    <Button Command="{Binding #ClassicRoot.DataContext.RestartCommand}" CommandParameter="{Binding .}" Content="Restart" />
                                    <Button Command="{Binding #ClassicRoot.DataContext.BackupCommand}" CommandParameter="{Binding .}" Content="Backup" />
                                    <Button Command="{Binding #ClassicRoot.DataContext.RestoreCommand}" CommandParameter="{Binding .}" Content="Restore Latest" IsEnabled="{Binding HasBackup}" />
                                </WrapPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </ScrollViewer>
</UserControl>
