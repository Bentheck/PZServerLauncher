<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1600"
             d:DesignHeight="980"
             x:Class="PZServerLauncher.App.Views.ConsolesWorkspaceView"
             x:Name="ConsolesRoot"
             x:DataType="vm:ConsolesWorkspaceViewModel">
    <Grid ColumnDefinitions="320,*" ColumnSpacing="18">
        <Border Classes="card" Padding="18">
            <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="14">
                <StackPanel Spacing="6">
                    <TextBlock Classes="kicker" Text="Console Picker" />
                    <TextBlock Classes="panel-title" FontSize="26" Text="{Binding PageTitle}" />
                    <TextBlock Classes="body" Text="{Binding PickerSummary}" TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="10">
                    <Border Background="#F6EFE6" CornerRadius="14" Padding="14">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="kicker" Text="Target Slot" />
                            <TextBlock Classes="body" FontWeight="SemiBold" Text="{Binding SelectionSummary}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding ConsoleSlots}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2" Rows="2" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ConsolesWorkspaceViewModel+ConsoleTileViewModel">
                                <Button Classes="chrome-free"
                                        Margin="0,0,8,8"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Command="{Binding #ConsolesRoot.DataContext.SelectSlotCommand}"
                                        CommandParameter="{Binding .}">
                                    <Border Background="#F8F0E6"
                                            BorderBrush="{Binding TileBorderBrush}"
                                            BorderThickness="2"
                                            CornerRadius="14"
                                            Padding="12">
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="kicker" Text="{Binding SlotLabel}" />
                                            <TextBlock FontWeight="SemiBold"
                                                       Foreground="#1D2326"
                                                       Text="{Binding ProfileDisplayName}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Classes="caption"
                                                       Foreground="#5E4D3F"
                                                       Text="{Binding StatusSummary}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <ScrollViewer Grid.Row="2"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="kicker" Text="Servers" />
                        <ItemsControl ItemsSource="{Binding ProfilePickerItems}" IsVisible="{Binding HasProfiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ConsolesWorkspaceViewModel+ConsoleProfilePickerItemViewModel">
                                    <Border Background="#FBF7F1"
                                            BorderBrush="#DDD2C6"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="14"
                                            Margin="0,0,0,10">
                                        <StackPanel Spacing="10">
                                            <StackPanel Spacing="4">
                                                <TextBlock Classes="panel-title" FontSize="18" Text="{Binding DisplayName}" />
                                                <TextBlock Classes="caption" Text="{Binding Branch}" />
                                                <TextBlock Classes="caption" Text="{Binding RuntimeState}" />
                                                <TextBlock Classes="caption"
                                                           FontFamily="Cascadia Code,Consolas,monospace"
                                                           Text="{Binding LatestLogLine}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>

                                            <Button Classes="action-secondary"
                                                    Command="{Binding #ConsolesRoot.DataContext.AssignProfileCommand}"
                                                    CommandParameter="{Binding .}"
                                                    Content="{Binding AssignmentLabel}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Background="#FBF7F1"
                                BorderBrush="#DDD2C6"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14"
                                IsVisible="{Binding HasNoProfiles}">
                            <TextBlock Classes="body"
                                       Text="No managed servers are available yet. Create or import one from Home or Servers, then come back here to pin its console."
                                       TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="3" ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Button Classes="action-secondary"
                            Command="{Binding ClearSelectedSlotCommand}"
                            Content="Clear Slot" />
                    <Button Grid.Column="1"
                            Classes="action-secondary"
                            Command="{Binding RefreshSelectedSlotCommand}"
                            Content="Reload Now" />
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="16">
            <Border Classes="card" Padding="20">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="18">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Live Console Board" />
                        <TextBlock Classes="panel-title" FontSize="28" Text="Watch the active servers without drilling through profile pages" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding RunningServersSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="caption" Text="{Binding AutoRefreshSummary}" TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="8" HorizontalAlignment="Right">
                        <Border Classes="pill-dark">
                            <TextBlock Classes="pill-text-light" Text="{Binding VisibleConsoleSummary}" />
                        </Border>
                        <Border Classes="pill-soft-neutral">
                            <TextBlock Classes="pill-text-neutral" Text="{Binding RunningServersSummary}" />
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding ConsoleSlots}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2" Rows="2" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ConsolesWorkspaceViewModel+ConsoleTileViewModel">
                            <Border Margin="0,0,14,14"
                                    Background="#243238"
                                    BorderBrush="{Binding TileBorderBrush}"
                                    BorderThickness="2"
                                    CornerRadius="20"
                                    Padding="16">
                                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <StackPanel Spacing="5">
                                            <TextBlock Classes="kicker" Foreground="#E5A26B" Text="{Binding SlotLabel}" />
                                            <TextBlock FontSize="22"
                                                       FontWeight="SemiBold"
                                                       Foreground="#F7F0E7"
                                                       Text="{Binding ProfileDisplayName}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Classes="caption"
                                                       Foreground="#CCB9A8"
                                                       Text="{Binding Branch}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Classes="body"
                                                       Foreground="#D3C8BA"
                                                       Text="{Binding StatusSummary}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Classes="caption"
                                                       Foreground="#CCB9A8"
                                                       Text="{Binding ActivitySummary}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Spacing="8" HorizontalAlignment="Right">
                                            <Button Classes="action-secondary"
                                                    Command="{Binding #ConsolesRoot.DataContext.SelectSlotCommand}"
                                                    CommandParameter="{Binding .}"
                                                    Content="Target Slot" />
                                            <Button Classes="action-secondary"
                                                    Command="{Binding ReloadCommand}"
                                                    Content="Reload Now"
                                                    IsEnabled="{Binding HasPinnedProfile}" />
                                        </StackPanel>
                                    </Grid>

                                    <Border Grid.Row="1"
                                            Height="220"
                                            Background="#171310"
                                            BorderBrush="#3F565F"
                                            BorderThickness="1"
                                            CornerRadius="16"
                                            Padding="0"
                                            ClipToBounds="True">
                                        <TextBox Classes="console-stream"
                                                 Text="{Binding LogText}"
                                                 CaretIndex="{Binding ConsoleCaretIndex}" />
                                    </Border>

                                    <Grid Grid.Row="2" RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                                        <WrapPanel Orientation="Horizontal" ItemHeight="34">
                                            <Button Classes="action-primary"
                                                    Command="{Binding PrimaryRuntimeCommand}"
                                                    Content="Start"
                                                    IsVisible="{Binding ShowStartAction}" />
                                            <Button Classes="action-danger"
                                                    Command="{Binding PrimaryRuntimeCommand}"
                                                    Content="Stop"
                                                    IsVisible="{Binding ShowStopAction}" />
                                            <Button Classes="action-secondary"
                                                    Command="{Binding RestartRuntimeCommand}"
                                                    Content="Restart"
                                                    IsEnabled="{Binding HasPinnedProfile}"
                                                    Margin="8,0,0,0" />
                                            <Button Classes="action-secondary"
                                                    Command="{Binding RequestPlayersCommand}"
                                                    Content="Players"
                                                    IsEnabled="{Binding CanSendCommands}"
                                                    Margin="8,0,0,0" />
                                            <Button Classes="action-secondary"
                                                    Command="{Binding SaveWorldCommand}"
                                                    Content="Save World"
                                                    IsEnabled="{Binding CanSendCommands}"
                                                    Margin="8,0,0,0" />
                                        </WrapPanel>

                                        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                            <TextBox Text="{Binding RawConsoleCommand}"
                                                     IsEnabled="{Binding CanSendCommands}"
                                                     PlaceholderText="save / players / custom console command" />
                                            <Button Grid.Column="1"
                                                    Classes="action-secondary"
                                                    Command="{Binding SendRawCommand}"
                                                    Content="Send"
                                                    IsEnabled="{Binding CanSendCommands}" />
                                        </Grid>

                                        <Grid Grid.Row="2" ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                            <CheckBox Content="Follow Tail"
                                                      IsChecked="{Binding FollowTail}"
                                                      Foreground="#F7F0E7" />
                                            <TextBlock Grid.Column="1"
                                                       Classes="caption"
                                                       Foreground="#CCB9A8"
                                                       Text="{Binding LoadStatus}"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
