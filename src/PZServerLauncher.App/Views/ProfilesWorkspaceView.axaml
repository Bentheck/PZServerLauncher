<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1320"
             d:DesignHeight="980"
             x:Class="PZServerLauncher.App.Views.ProfilesWorkspaceView"
             x:Name="ProfilesRoot"
             x:DataType="vm:ProfilesWorkspaceViewModel">
    <Grid ColumnDefinitions="340,*" ColumnSpacing="18">
        <Border Classes="card" Padding="20">
            <StackPanel Spacing="14">
                <StackPanel Spacing="4">
                    <TextBlock Classes="kicker" Text="Profile Workspace" />
                    <TextBlock Classes="panel-title" FontSize="26" Text="{Binding PageTitle}" />
                    <TextBlock Classes="body" Text="{Binding PageSummary}" TextWrapping="Wrap" />
                </StackPanel>

                <Border Background="#1F1D1B" CornerRadius="16" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Foreground="#E5A26B" Text="{Binding ProfileCountSummary}" />
                        <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding WorkspaceGuidance}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Background="#F1E6D7" CornerRadius="14" Padding="14">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Selected Profile" />
                        <TextBlock Classes="panel-title" FontSize="18" Text="{Binding SelectedProfileSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding SelectedProfilePathSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding SelectedProfilePortsSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding SelectedCommunitySummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding SelectedNetworkSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding SelectedProfile.InstallPreflightSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding SelectedProfile.LaunchReadinessSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding SelectedProfile.BackupSafetySummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <TextBlock Classes="kicker" Text="Profiles" />
                <ListBox ItemsSource="{Binding Profiles}"
                         SelectedItem="{Binding SelectedProfile}"
                         MinHeight="240">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ProfileCardViewModel">
                            <Border Background="#F6EFE6" CornerRadius="12" Padding="12" Margin="4">
                                <StackPanel Spacing="6">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                        <StackPanel Spacing="2">
                                            <TextBlock FontSize="15" FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                            <TextBlock Classes="body" FontSize="12" Text="{Binding Branch}" />
                                        </StackPanel>
                                        <Border Grid.Column="1"
                                                Background="#2A2927"
                                                CornerRadius="999"
                                                Padding="10,4"
                                                VerticalAlignment="Top">
                                            <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding RuntimeState}" />
                                        </Border>
                                    </Grid>
                                    <TextBlock Classes="body" FontSize="12" Text="{Binding CommunitySummary}" TextWrapping="Wrap" />
                                    <TextBlock Classes="body" FontSize="12" Text="{Binding NetworkSummary}" TextWrapping="Wrap" />
                                    <TextBlock Classes="body" FontSize="12" Text="{Binding InstallPreflightSummary}" TextWrapping="Wrap" />
                                    <TextBlock Classes="body" FontSize="12" Text="{Binding BackupSafetySummary}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Background="#1F1D1B" CornerRadius="14" Padding="14">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Workspace Ready" />
                        <TextBlock Classes="body" Foreground="#D3C8BA" Text="Every profile-specific server task now lives in the workspace rail on the right. Use this column to switch targets and inspect the active server at a glance." TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="16">
            <Border Classes="card" Padding="18">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="panel-title" FontSize="24" Text="{Binding WorkspaceHeadline}" />
                        <TextBlock Classes="body" Text="{Binding WorkspaceGuidance}" TextWrapping="Wrap" />
                    </StackPanel>

                    <WrapPanel Grid.Column="1" Orientation="Horizontal" ItemWidth="126" ItemHeight="32">
                        <Border Background="#F1E6D7" CornerRadius="999" Padding="10,6">
                            <TextBlock Classes="body" Text="{Binding SelectedProfileBranchSummary}" TextWrapping="Wrap" />
                        </Border>
                        <Border Background="#F1E6D7" CornerRadius="999" Padding="10,6">
                            <TextBlock Classes="body" Text="{Binding SelectedProfileRuntimeSummary}" TextWrapping="Wrap" />
                        </Border>
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" ColumnSpacing="14">
                <Border Classes="card" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Profile Focus" />
                        <TextBlock Classes="panel-title" FontSize="20" Text="{Binding SelectedProfileSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Classes="card" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Community Posture" />
                        <TextBlock Classes="body" Text="{Binding SelectedCommunitySummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Classes="card" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Network Posture" />
                        <TextBlock Classes="body" Text="{Binding SelectedNetworkSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Classes="card" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="World Snapshot" />
                        <TextBlock Classes="body" Text="{Binding SelectedWorldSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Classes="card" IsVisible="{Binding HasPendingSectionNavigation}">
                <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="panel-title" Text="Unsaved Section Changes" />
                        <TextBlock Classes="body" Text="{Binding PendingSectionNavigationMessage}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding ConfirmSectionNavigationSaveCommand}" Content="Save" />
                    <Button Grid.Column="2" Command="{Binding ConfirmSectionNavigationDiscardCommand}" Content="Discard" />
                    <Button Grid.Column="3" Command="{Binding CancelSectionNavigationCommand}" Content="Cancel" />
                </Grid>
            </Border>

            <Grid Grid.Row="3" RowDefinitions="Auto,*" RowSpacing="16">
                <Border Classes="card" Padding="12">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
                            <Border Background="#F1E6D7" CornerRadius="12" Padding="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="kicker" Text="Installed" />
                                    <TextBlock Classes="panel-title" FontSize="20" Text="{Binding InstalledProfileCount}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Background="#F1E6D7" CornerRadius="12" Padding="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="kicker" Text="Public Listing" />
                                    <TextBlock Classes="panel-title" FontSize="20" Text="{Binding PublicProfileCount}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="#F1E6D7" CornerRadius="12" Padding="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="kicker" Text="Voice Enabled" />
                                    <TextBlock Classes="panel-title" FontSize="20" Text="{Binding VoiceEnabledProfileCount}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="3" Background="#F1E6D7" CornerRadius="12" Padding="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="kicker" Text="Running" />
                                    <TextBlock Classes="panel-title" FontSize="20" Text="{Binding RunningProfileCount}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <TextBlock Classes="body" Text="{Binding SelectedWelcomeSummary}" TextWrapping="Wrap" />

                        <ItemsControl ItemsSource="{Binding SectionItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:WorkspaceNavigationItemViewModel">
                                    <Button Margin="0,0,10,10"
                                            Command="{Binding #ProfilesRoot.DataContext.SelectSectionCommand}"
                                            CommandParameter="{Binding .}"
                                            IsEnabled="{Binding IsEnabled}">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <TextBlock Text="{Binding Title}" />
                                            <Border Grid.Column="1"
                                                    Background="#2A2927"
                                                    CornerRadius="999"
                                                    Padding="8,2"
                                                    VerticalAlignment="Center"
                                                    IsVisible="{Binding IsSelected}">
                                                <TextBlock Foreground="#F7F0E7" FontSize="11" Text="Active" />
                                            </Border>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Classes="card" Padding="0">
                    <ContentControl Content="{Binding CurrentSection}" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
