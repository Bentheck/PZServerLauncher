<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1120"
             d:DesignHeight="960"
             x:Class="PZServerLauncher.App.Views.GeneralWorkspaceView"
             x:DataType="vm:GeneralWorkspaceViewModel">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" RowSpacing="16">
            <Border Classes="card" Padding="22">
                <Grid ColumnDefinitions="*,300" ColumnSpacing="18">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="kicker" Text="Settings" />
                        <TextBlock Classes="panel-title" FontSize="30" Text="{Binding ProfileDisplayName}" />
                        <TextBlock Classes="body"
                                   FontSize="16"
                                   Foreground="#C9D5EA"
                                   Text="{Binding WorkspaceSummary}"
                                   TextWrapping="Wrap" />
                        <WrapPanel Margin="0,8,0,0" Orientation="Horizontal" ItemHeight="28">
                            <Border Background="#233238" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                <TextBlock Foreground="#F7F8F6" FontSize="11" Text="{Binding Branch}" />
                            </Border>
                            <Border Background="#224FD8A9" BorderBrush="#6B8CF0CC" BorderThickness="1" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                <TextBlock Foreground="#8CF0CC" FontSize="11" Text="{Binding CatalogSummary}" />
                            </Border>
                            <Border Background="#14FFFFFF" BorderBrush="#24FFFFFF" BorderThickness="1" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                <TextBlock Foreground="#C9D5EA" FontSize="11" Text="{Binding ProfileNamespace}" />
                            </Border>
                        </WrapPanel>
                    </StackPanel>

                    <Border Grid.Column="1" Classes="surface-soft" Padding="16">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="kicker" Text="Editor Status" />
                            <TextBlock Classes="body"
                                       FontWeight="SemiBold"
                                       Foreground="#EDF4FF"
                                       Text="{Binding LoadStatus}"
                                       TextWrapping="Wrap" />
                            <TextBlock Classes="caption" Text="{Binding ActionSummary}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Classes="callout-card"
                    Padding="16"
                    IsVisible="{Binding RequiresAdvancedFilesFallback}">
                <StackPanel Spacing="6">
                    <TextBlock Classes="kicker" Text="Use Advanced Files Instead" />
                    <TextBlock Classes="body" Text="{Binding FallbackReason}" TextWrapping="Wrap" />
                    <TextBlock Classes="caption"
                               Text="The structured editor stays safe on purpose. If the file is unusual or unsupported, edit it from Advanced Files instead of forcing a risky rewrite."
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="2" ColumnDefinitions="1.05*,.95*" ColumnSpacing="16" IsEnabled="{Binding CanEdit}">
                <StackPanel Spacing="16">
                    <Border Classes="card" Padding="18">
                        <StackPanel Spacing="12">
                            <TextBlock Classes="kicker" Text="Basic Server Info" />
                            <TextBlock Classes="caption"
                                       Text="These are the main things most hosts want to change first."
                                       TextWrapping="Wrap" />

                            <StackPanel Spacing="4">
                                <TextBlock Classes="body" Text="Public server name" />
                                <TextBox Text="{Binding PublicName}" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Classes="body" Text="Public description" />
                                <TextBox Text="{Binding PublicDescription}" />
                            </StackPanel>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                <CheckBox Content="Show in the public server browser" IsChecked="{Binding IsPublic}" />
                                <CheckBox Grid.Column="1" Content="Allow open sign-ups" IsChecked="{Binding IsOpen}" />
                            </Grid>

                            <StackPanel Spacing="4">
                                <TextBlock Classes="body" Text="Max players" />
                                <TextBox Text="{Binding MaxPlayers}" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Classes="body" Text="Welcome message" />
                                <TextBox Text="{Binding WelcomeMessage}" AcceptsReturn="True" Height="120" TextWrapping="Wrap" />
                                <TextBlock Classes="caption" Text="Line breaks are saved back using Project Zomboid's &lt;LINE&gt; format." TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Classes="card" Padding="18">
                        <StackPanel Spacing="12">
                            <TextBlock Classes="kicker" Text="Gameplay Basics" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
                                <CheckBox Content="Enable PvP" IsChecked="{Binding PvpEnabled}" />
                                <CheckBox Grid.Column="1" Content="Pause when empty" IsChecked="{Binding PauseWhenEmpty}" />
                                <CheckBox Grid.Row="1" Content="Enable global chat" IsChecked="{Binding GlobalChatEnabled}" />
                                <CheckBox Grid.Row="1" Grid.Column="1" Content="Allow sleep" IsChecked="{Binding SleepAllowed}" />
                                <CheckBox Grid.Row="2" Content="Require sleep" IsChecked="{Binding SleepNeeded}" />
                                <CheckBox Grid.Row="2" Grid.Column="1" Content="Disable fire spread" IsChecked="{Binding NoFire}" />
                                <CheckBox Grid.Row="3" Content="Announce player deaths" IsChecked="{Binding AnnounceDeath}" />
                                <CheckBox Grid.Row="3" Grid.Column="1" Content="Allow sledge destruction" IsChecked="{Binding AllowSledgehammerDestruction}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Classes="card" Padding="18">
                        <StackPanel Spacing="12">
                            <TextBlock Classes="kicker" Text="Spawn, Loot, and Cleanup" />

                            <StackPanel Spacing="4">
                                <TextBlock Classes="body" Text="Spawn items" />
                                <TextBox Text="{Binding SpawnItems}" AcceptsReturn="True" Height="104" TextWrapping="Wrap" />
                                <TextBlock Classes="caption" Text="Use one item per line. The launcher saves them back as a comma-separated list." TextWrapping="Wrap" />
                            </StackPanel>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="body" Text="Loot respawn hours" />
                                    <TextBox Text="{Binding LootRespawnHours}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Classes="body" Text="Loot respawn max items" />
                                    <TextBox Text="{Binding LootRespawnMaxItems}" />
                                </StackPanel>
                            </Grid>

                            <CheckBox Content="Buildings prevent loot respawn" IsChecked="{Binding ConstructionPreventsLootRespawn}" />

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                <CheckBox Content="Respawn at death location" IsChecked="{Binding RespawnWithSelf}" />
                                <CheckBox Grid.Column="1" Content="Respawn with split-screen partner" IsChecked="{Binding RespawnWithOther}" />
                            </Grid>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="body" Text="Ground item cleanup hours" />
                                    <TextBox Text="{Binding WorldItemRemovalHours}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Classes="body" Text="Ground item cleanup list" />
                                    <TextBox Text="{Binding WorldItemRemovalList}" AcceptsReturn="True" Height="104" TextWrapping="Wrap" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="16">
                    <Border Classes="card" Padding="18">
                        <StackPanel Spacing="12">
                            <TextBlock Classes="kicker" Text="Safehouses" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="10">
                                <CheckBox Content="Allow player safehouses" IsChecked="{Binding PlayerSafehouse}" />
                                <CheckBox Grid.Column="1" Content="Allow admin safehouses" IsChecked="{Binding AdminSafehouse}" />
                                <CheckBox Grid.Row="1" Content="Allow trespass" IsChecked="{Binding SafehouseAllowTrespass}" />
                                <CheckBox Grid.Row="1" Grid.Column="1" Content="Allow fire damage" IsChecked="{Binding SafehouseAllowFire}" />
                                <CheckBox Grid.Row="2" Content="Allow looting" IsChecked="{Binding SafehouseAllowLoot}" />
                                <CheckBox Grid.Row="2" Grid.Column="1" Content="Allow respawn" IsChecked="{Binding SafehouseAllowRespawn}" />
                                <CheckBox Grid.Row="3" Content="Allow non-residential claiming" IsChecked="{Binding SafehouseAllowNonResidential}" />
                                <CheckBox Grid.Row="3" Grid.Column="1" Content="Disable while owner is online" IsChecked="{Binding DisableSafehouseWhenPlayerConnected}" />
                                <CheckBox Grid.Row="4" Content="Disable while owner is offline" IsChecked="{Binding DisableSafehouseWhenPlayerDisconnected}" />
                                <CheckBox Grid.Row="4" Grid.Column="1" Content="Drop whitelist on death" IsChecked="{Binding DropWhitelistOnDeath}" />
                                <StackPanel Grid.Row="5" Spacing="4">
                                    <TextBlock Classes="body" Text="Days before claim is allowed" />
                                    <TextBox Text="{Binding SafehouseDaysToClaim}" />
                                </StackPanel>
                                <StackPanel Grid.Row="5" Grid.Column="1" Spacing="4">
                                    <TextBlock Classes="body" Text="Removal time (hours)" />
                                    <TextBox Text="{Binding SafehouseRemovalHours}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Classes="card" Padding="18">
                        <StackPanel Spacing="12">
                            <TextBlock Classes="kicker" Text="Factions and Trade" />
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                                <CheckBox Content="Enable factions" IsChecked="{Binding FactionEnabled}" />
                                <CheckBox Grid.Column="1" Content="Allow trade UI" IsChecked="{Binding AllowTradeUi}" />
                                <StackPanel Grid.Row="1" Spacing="4">
                                    <TextBlock Classes="body" Text="Days before a faction can be created" />
                                    <TextBox Text="{Binding FactionDaysToCreate}" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                                    <TextBlock Classes="body" Text="Players required for a faction tag" />
                                    <TextBox Text="{Binding FactionPlayersForTag}" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Classes="card" Padding="18">
                        <StackPanel Spacing="12">
                            <TextBlock Classes="kicker" Text="Ports and Launcher" />

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="body" Text="Default port" />
                                    <TextBox Text="{Binding DefaultPort}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Classes="body" Text="UDP port" />
                                    <TextBox Text="{Binding UdpPort}" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Spacing="4">
                                <TextBlock Classes="body" Text="RCON port" />
                                <TextBox Text="{Binding RconPort}" />
                            </StackPanel>

                            <StackPanel Spacing="4">
                                <TextBlock Classes="body" Text="Preferred memory (GB)" />
                                <TextBox Text="{Binding MemoryInGigabytes}" />
                            </StackPanel>

                            <CheckBox Content="Start this server when the host starts" IsChecked="{Binding StartWithHost}" />
                            <CheckBox Content="Auto restart on crash" IsChecked="{Binding AutoRestartOnCrash}" />
                        </StackPanel>
                    </Border>

                    <Border Classes="surface-soft" Padding="18">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="kicker" Text="Before You Save" />
                            <TextBlock Classes="body" Text="{Binding ActionSummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="caption"
                                       Text="Apply Settings writes to the real server files. Save Draft keeps a local work-in-progress copy. Reload pulls fresh values from the host."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <Border Grid.Row="3"
                    Background="#22FFB36B"
                    BorderBrush="#72FFB36B"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="16"
                    IsVisible="{Binding HasFieldErrors}">
                <StackPanel Spacing="8">
                    <TextBlock Classes="kicker" Text="Please Fix These Before Saving" />
                    <ItemsControl ItemsSource="{Binding FieldErrors}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Classes="body" Text="{Binding .}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Classes="card" Padding="18">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Save Options" />
                        <TextBlock Classes="body"
                                   FontWeight="SemiBold"
                                   Text="{Binding LoadStatus}"
                                   TextWrapping="Wrap" />
                        <TextBlock Classes="caption" Text="{Binding CatalogSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                    <WrapPanel Grid.Column="1" Orientation="Horizontal" ItemWidth="152" ItemHeight="36">
                        <Button Classes="action-primary" Command="{Binding SaveSettingsCommand}" Content="Apply Settings" IsEnabled="{Binding CanEdit}" />
                        <Button Classes="action-secondary" Command="{Binding SaveDraftCommand}" Content="Save Draft" IsEnabled="{Binding CanEdit}" />
                        <Button Classes="action-secondary" Command="{Binding DiscardDraftCommand}" Content="Discard Draft" />
                        <Button Classes="action-secondary" Command="{Binding ReloadCommand}" Content="Reload" />
                    </WrapPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
