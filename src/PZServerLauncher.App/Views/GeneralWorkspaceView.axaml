<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1120"
             d:DesignHeight="960"
             x:Class="PZServerLauncher.App.Views.GeneralWorkspaceView"
             x:DataType="vm:GeneralWorkspaceViewModel">
    <ScrollViewer>
        <Border Classes="card" Padding="24">
            <StackPanel Spacing="18">
                <Border Background="#201D1A" CornerRadius="18" Padding="22">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="18">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="kicker" Foreground="#E5A26B" Text="General Settings" />
                            <TextBlock FontSize="30"
                                       FontWeight="SemiBold"
                                       Foreground="#F7F0E7"
                                       Text="{Binding ProfileDisplayName}" />
                            <TextBlock Classes="body"
                                       Foreground="#D7CCBE"
                                       Text="{Binding WorkspaceSummary}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="10" HorizontalAlignment="Right">
                            <Border Background="#2C2926"
                                    CornerRadius="999"
                                    Padding="14,8"
                                    HorizontalAlignment="Right">
                                <TextBlock Foreground="#F7F0E7"
                                           FontWeight="SemiBold"
                                           Text="{Binding Branch}" />
                            </Border>
                            <Border Background="#2C2926"
                                    CornerRadius="14"
                                    Padding="14,10"
                                    HorizontalAlignment="Right">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Namespace" />
                                    <TextBlock Foreground="#F7F0E7" Text="{Binding ProfileNamespace}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14">
                    <Border Background="#F6EFE6" CornerRadius="14" Padding="16">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="kicker" Text="Catalog" />
                            <TextBlock Classes="body" Text="{Binding CatalogSummary}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="#F6EFE6" CornerRadius="14" Padding="16">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="kicker" Text="Status" />
                            <TextBlock Classes="body" Text="{Binding LoadStatus}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="#F6EFE6" CornerRadius="14" Padding="16">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="kicker" Text="Operator Guidance" />
                            <TextBlock Classes="body" Text="{Binding ActionSummary}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Background="#FFF8F1"
                        CornerRadius="14"
                        Padding="16"
                        IsVisible="{Binding RequiresAdvancedFilesFallback}">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Fallback Required" />
                        <TextBlock Classes="body" Text="{Binding FallbackReason}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Grid ColumnDefinitions="1.15*,.85*" ColumnSpacing="16" IsEnabled="{Binding CanEdit}">
                    <StackPanel Spacing="16">
                        <Border Classes="card" Padding="18">
                            <StackPanel Spacing="12">
                                <TextBlock Classes="kicker" Text="Server Browser Identity" />
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="body" Text="Public Server Name" />
                                    <TextBox Text="{Binding PublicName}" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="body" Text="Public Description" />
                                    <TextBox Text="{Binding PublicDescription}" />
                                </StackPanel>
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                    <CheckBox Content="Public Listing Enabled" IsChecked="{Binding IsPublic}" />
                                    <CheckBox Grid.Column="1" Content="Open To New Accounts" IsChecked="{Binding IsOpen}" />
                                </Grid>
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="body" Text="Max Players" />
                                    <TextBox Text="{Binding MaxPlayers}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Classes="card" Padding="18">
                            <StackPanel Spacing="12">
                                <TextBlock Classes="kicker" Text="World Access" />
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                    <CheckBox Content="PvP Enabled" IsChecked="{Binding PvpEnabled}" />
                                    <CheckBox Grid.Column="1" Content="Pause When Empty" IsChecked="{Binding PauseWhenEmpty}" />
                                </Grid>
                                <CheckBox Content="Global Chat Enabled" IsChecked="{Binding GlobalChatEnabled}" />
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="body" Text="Welcome Message" />
                                    <TextBox Text="{Binding WelcomeMessage}" AcceptsReturn="True" Height="120" TextWrapping="Wrap" />
                                    <TextBlock Classes="body" FontSize="12" Text="Line breaks will be converted to &lt;LINE&gt; markers for Project Zomboid." TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="16">
                        <Border Classes="card" Padding="18">
                            <StackPanel Spacing="12">
                                <TextBlock Classes="kicker" Text="Ports" />
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="body" Text="Default Port" />
                                    <TextBox Text="{Binding DefaultPort}" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="body" Text="UDP Port Override" />
                                    <TextBox Text="{Binding UdpPort}" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="body" Text="RCON Port" />
                                    <TextBox Text="{Binding RconPort}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Classes="card" Padding="18">
                            <StackPanel Spacing="12">
                                <TextBlock Classes="kicker" Text="Launcher Runtime" />
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="body" Text="Preferred Memory (GB)" />
                                    <TextBox Text="{Binding MemoryInGigabytes}" />
                                </StackPanel>
                                <CheckBox Content="Start With Host" IsChecked="{Binding StartWithHost}" />
                                <CheckBox Content="Auto Restart On Crash" IsChecked="{Binding AutoRestartOnCrash}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Border Background="#F1E6D7" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="kicker" Text="Operator Guidance" />
                        <TextBlock Classes="body" Text="{Binding ActionSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <WrapPanel Orientation="Horizontal" ItemWidth="152" ItemHeight="36">
                    <Button Command="{Binding SaveSettingsCommand}" Content="Apply Settings" IsEnabled="{Binding CanEdit}" />
                    <Button Command="{Binding SaveDraftCommand}" Content="Save Draft" IsEnabled="{Binding CanEdit}" />
                    <Button Command="{Binding DiscardDraftCommand}" Content="Discard Draft" />
                    <Button Command="{Binding ReloadCommand}" Content="Reload From Host" />
                </WrapPanel>

                <Border Background="#FBF7F1" CornerRadius="14" Padding="16" IsVisible="{Binding HasFieldErrors}">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="kicker" Text="Validation" />
                        <ItemsControl ItemsSource="{Binding FieldErrors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Classes="body" Text="{Binding .}" TextWrapping="Wrap" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
