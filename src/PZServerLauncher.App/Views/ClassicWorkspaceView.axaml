<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:views="using:PZServerLauncher.App.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1460"
             d:DesignHeight="1080"
             x:Class="PZServerLauncher.App.Views.ClassicWorkspaceView"
             x:DataType="vm:ClassicWorkspaceViewModel">
    <Grid RowDefinitions="Auto,*" RowSpacing="16">
        <Border Classes="card" Padding="18">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                <StackPanel Spacing="4">
                    <TextBlock Classes="panel-title" FontSize="24" Text="{Binding PageTitle}" />
                    <TextBlock Classes="body" Text="{Binding PageSummary}" TextWrapping="Wrap" />
                </StackPanel>
                <Border Grid.Column="1" Background="#2A2927" CornerRadius="14" Padding="12,8">
                    <TextBlock Foreground="#F7F0E7" Text="Temporary migration surface" />
                </Border>
            </Grid>
        </Border>

        <views:ClassicSurfaceView Grid.Row="1" DataContext="{Binding Legacy}" />
    </Grid>
</UserControl>
