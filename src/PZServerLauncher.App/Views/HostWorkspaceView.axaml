<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:profiles="using:PZServerLauncher.Contracts.Profiles"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1200"
             d:DesignHeight="900"
             x:Class="PZServerLauncher.App.Views.HostWorkspaceView"
             x:DataType="vm:HostWorkspaceViewModel">
    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="16">
        <Border Classes="card" Padding="24">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="18">
                <StackPanel Spacing="8">
                    <TextBlock Classes="kicker" Text="App Control" />
                    <TextBlock Classes="panel-title" FontSize="30" Text="{Binding PageTitle}" />
                    <TextBlock Classes="body" FontSize="16" Text="{Binding PageSummary}" TextWrapping="Wrap" />
                    <TextBlock Classes="caption" Text="{Binding HostNextStepSummary}" TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Column="1" Spacing="10" MinWidth="210" HorizontalAlignment="Right">
                    <Border Classes="pill-soft-green" HorizontalAlignment="Right">
                        <TextBlock Classes="pill-text-green" Text="{Binding HostStartupLabel}" />
                    </Border>
                    <Button Classes="action-primary"
                            Command="{Binding Legacy.SaveHostSettingsCommand}"
                            Content="Save App Settings" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" ColumnSpacing="14">
            <Border Classes="metric-card" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Classes="kicker" Text="Runtime" />
                    <TextBlock Classes="panel-title" FontSize="20" Text="{Binding HostStatusSummary}" TextWrapping="Wrap" />
                    <TextBlock Classes="caption" Text="{Binding HostLifecycleSummary}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Classes="metric-card" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Classes="kicker" Text="Startup" />
                    <TextBlock Classes="panel-title" FontSize="24" Text="{Binding StartupRosterCount}" />
                    <TextBlock Classes="caption" Text="{Binding HostStartupCoverageSummary}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Classes="metric-card" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Classes="kicker" Text="Backups" />
                    <TextBlock Classes="panel-title" FontSize="24" Text="{Binding BackupCoverageCount}" />
                    <TextBlock Classes="caption" Text="{Binding HostRecoveryCoverageSummary}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Classes="metric-card" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Classes="kicker" Text="Running" />
                    <TextBlock Classes="panel-title" FontSize="24" Text="{Binding RunningProfileCount}" />
                    <TextBlock Classes="caption" Text="{Binding HostRuntimeCoverageSummary}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="1.25*,.75*" ColumnSpacing="16">
            <Border Classes="card" Padding="20">
                <Grid RowDefinitions="Auto,*" RowSpacing="14">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <StackPanel Spacing="5">
                            <TextBlock Classes="kicker" Text="Managed Servers" />
                            <TextBlock Classes="panel-title" FontSize="24" Text="{Binding HostStartupFleetSummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="{Binding HostFleetSummary}" TextWrapping="Wrap" />
                        </StackPanel>
                        <Border Grid.Column="1" Classes="pill-dark" VerticalAlignment="Top">
                            <TextBlock Classes="pill-text-light" Text="{Binding ManagedProfileCount}" />
                        </Border>
                    </Grid>

                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="10">
                            <ItemsControl ItemsSource="{Binding ManagedProfiles}" IsVisible="{Binding HasManagedProfiles}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:HostWorkspaceViewModel+HostManagedProfileRowViewModel">
                                        <Border Background="#14FFFFFF"
                                                BorderBrush="#24FFFFFF"
                                                BorderThickness="1"
                                                CornerRadius="18"
                                                Padding="14"
                                                Margin="0,0,0,10">
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                <StackPanel Spacing="5">
                                                    <TextBlock Classes="panel-title" FontSize="18" Text="{Binding DisplayName}" />
                                                    <TextBlock Classes="caption" Text="{Binding Ports}" TextWrapping="Wrap" />
                                                    <TextBlock Classes="body" Text="{Binding RosterSummary}" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <WrapPanel Grid.Column="1" Orientation="Horizontal" ItemHeight="28" VerticalAlignment="Top">
                                                    <Border Classes="pill-soft-neutral" Margin="0,0,8,8">
                                                        <TextBlock Classes="pill-text-neutral" Text="{Binding Branch}" />
                                                    </Border>
                                                    <Border Classes="pill-soft-neutral" Margin="0,0,8,8">
                                                        <TextBlock Classes="pill-text-neutral" Text="{Binding RuntimeState}" />
                                                    </Border>
                                                    <Border Classes="pill-soft-green" Margin="0,0,8,8">
                                                        <TextBlock Classes="pill-text-green" Text="{Binding StartWithHost, StringFormat='Start: {0}'}" />
                                                    </Border>
                                                </WrapPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Classes="callout-card" Padding="18" IsVisible="{Binding HasNoManagedProfiles}">
                                <StackPanel Spacing="8">
                                    <TextBlock Classes="kicker" Text="No Servers Yet" />
                                    <TextBlock Classes="panel-title" FontSize="22" Text="Nothing is under app supervision" />
                                    <TextBlock Classes="body"
                                               Text="Create or import a profile first. Once profiles exist, this page becomes the machine-wide control point."
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="1" Classes="surface-dark" Padding="20">
                <StackPanel Spacing="14">
                    <TextBlock Classes="kicker" Foreground="#FFB36B" Text="Operations" />
                    <TextBlock Classes="panel-title" FontSize="24" Text="{Binding HostOperatorSummary}" TextWrapping="Wrap" />
                    <TextBlock Classes="body" Text="{Binding HostShutdownSummary}" TextWrapping="Wrap" />

                    <CheckBox Content="Start Launcher With Windows"
                              IsChecked="{Binding Legacy.HostStartWithWindows}" />

                    <WrapPanel Orientation="Horizontal" ItemHeight="38">
                        <Button Classes="action-primary" Command="{Binding Legacy.SaveHostSettingsCommand}" Content="Save" Margin="0,0,8,8" />
                        <Button Classes="action-secondary" Command="{Binding Legacy.StopHostCommand}" Content="Stop Runtime" Margin="0,0,8,8" />
                        <Button Classes="action-danger" Command="{Binding Legacy.StopAllAndHostCommand}" Content="Stop Servers + Runtime" Margin="0,0,8,8" />
                        <Button Classes="action-secondary" Command="{Binding Legacy.ExitDesktopCommand}" Content="Close App" Margin="0,0,8,8" />
                    </WrapPanel>

                    <Border Classes="command-card" Padding="14">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="kicker" Foreground="#FFB36B" Text="Guidance" />
                            <TextBlock Classes="caption" Text="{Binding HostActionSummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="caption" Text="{Binding HostRecoverySummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="caption" Text="{Binding HostRiskSummary}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <ItemsControl ItemsSource="{Binding HostChecklist}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="profiles:ProjectZomboidOperatorChecklistItem">
                                <Border Classes="command-card" Padding="12" Margin="0,0,0,8">
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="kicker" Text="{Binding StatusLabel}" />
                                        <TextBlock Classes="caption" Text="{Binding Message}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
