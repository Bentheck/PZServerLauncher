<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:profiles="using:PZServerLauncher.Contracts.Profiles"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="980"
             d:DesignHeight="760"
             x:Class="PZServerLauncher.App.Views.HostWorkspaceView"
             x:DataType="vm:HostWorkspaceViewModel">
    <Border Classes="card" Padding="24">
        <StackPanel Spacing="18">
            <Border Background="#1F1D1B" CornerRadius="16" Padding="20">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="18">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Global Host Control" />
                        <TextBlock FontSize="30" FontWeight="SemiBold" Foreground="#F7F0E7" Text="{Binding PageTitle}" />
                        <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding PageSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Border Grid.Column="1" Background="#2A2927" CornerRadius="999" Padding="14,8" VerticalAlignment="Top">
                        <TextBlock Foreground="#F7F0E7" FontWeight="SemiBold" Text="{Binding HostStartupLabel}" />
                    </Border>
                </Grid>
            </Border>

            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="14">
                <Border Background="#F6EFE6" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Lifecycle" />
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding HostStatusSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding HostLifecycleSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="#F6EFE6" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Fleet" />
                        <TextBlock Classes="body" Text="{Binding HostFleetSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="#F6EFE6" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Exposure" />
                        <TextBlock Classes="body" Text="{Binding HostExposureSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Background="#F6EFE6" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Security" />
                        <TextBlock Classes="body" Text="{Binding HostSecuritySummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="14">
                <Border Background="#FFF8F1" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Startup Roster" />
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding StartupRosterCount, StringFormat='{}{0} profile(s)'}" />
                        <TextBlock Classes="body" Text="{Binding HostStartupCoverageSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="#FFF8F1" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Crash Recovery" />
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding AutoRestartCoverageCount, StringFormat='{}{0} profile(s)'}" />
                        <TextBlock Classes="body" Text="{Binding HostAutomationSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="#FFF8F1" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Recovery Coverage" />
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding BackupCoverageCount, StringFormat='{}{0} profile(s)'}" />
                        <TextBlock Classes="body" Text="{Binding HostRecoveryCoverageSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Background="#FFF8F1" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Live Runtime" />
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding RunningProfileCount, StringFormat='{}{0} profile(s)'}" />
                        <TextBlock Classes="body" Text="{Binding HostRuntimeCoverageSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="#FFF8F1" CornerRadius="14" Padding="16">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="kicker" Text="Managed Profiles" />
                        <TextBlock Classes="panel-title" FontSize="22" Text="{Binding HostStartupFleetSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="These are the Project Zomboid servers the local host is expected to supervise, restart, and optionally bring online at startup." TextWrapping="Wrap" />
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding ManagedProfiles}" IsVisible="{Binding HasManagedProfiles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:HostWorkspaceViewModel+HostManagedProfileRowViewModel">
                                <Border Background="#F1E6D7" CornerRadius="14" Padding="14" Margin="0,0,0,10">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                        <StackPanel Spacing="4">
                                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                            <TextBlock Classes="body" Text="{Binding Ports}" TextWrapping="Wrap" />
                                            <TextBlock Classes="body" Text="{Binding RuntimeState, StringFormat='Runtime: {0}'}" TextWrapping="Wrap" />
                                            <TextBlock Classes="body" Text="{Binding RosterSummary}" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <WrapPanel Grid.Column="1" Orientation="Horizontal" ItemHeight="28" VerticalAlignment="Top">
                                            <Border Background="#2A2927" CornerRadius="999" Padding="10,4" Margin="0,0,8,8">
                                                <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding Branch}" />
                                            </Border>
                                            <Border Background="#2A2927" CornerRadius="999" Padding="10,4" Margin="0,0,8,8">
                                                <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding StartWithHost, StringFormat='Start with host: {0}'}" />
                                            </Border>
                                            <Border Background="#2A2927" CornerRadius="999" Padding="10,4" Margin="0,0,8,8">
                                                <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding AutoRestartOnCrash, StringFormat='Auto-restart: {0}'}" />
                                            </Border>
                                            <Border Background="#2A2927" CornerRadius="999" Padding="10,4" Margin="0,0,8,8">
                                                <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding HasBackup, StringFormat='Backups: {0}'}" />
                                            </Border>
                                            <Border Background="#2A2927" CornerRadius="999" Padding="10,4" Margin="0,0,0,8">
                                                <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding InstallDetected, StringFormat='Install detected: {0}'}" />
                                            </Border>
                                        </WrapPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Classes="body"
                               IsVisible="{Binding HasNoManagedProfiles}"
                               Text="No profiles are loaded yet, so the host has nothing to supervise."
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Grid ColumnDefinitions="*,360" ColumnSpacing="16">
                <Border Background="#FFF8F1" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="kicker" Text="Host Status" />
                            <TextBlock Classes="panel-title" FontSize="22" Text="{Binding Legacy.HostSummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="{Binding Legacy.StatusMessage}" TextWrapping="Wrap" />
                        </StackPanel>
                        <Border Background="#F7EFE4" CornerRadius="12" Padding="14">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="body" Text="{Binding HostActionSummary}" TextWrapping="Wrap" />
                                <TextBlock Classes="body" Text="{Binding HostRecoverySummary}" TextWrapping="Wrap" />
                                <TextBlock Classes="body" Text="{Binding HostRiskSummary}" TextWrapping="Wrap" />
                                <TextBlock Classes="body" Text="{Binding HostNextStepSummary}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#F1E6D7" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="kicker" Text="Actions" />
                            <TextBlock Classes="body" Text="{Binding HostOperatorSummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="{Binding HostShutdownSummary}" TextWrapping="Wrap" />
                        </StackPanel>
                        <CheckBox Content="Start Host With Windows"
                                  IsChecked="{Binding Legacy.HostStartWithWindows}" />
                        <WrapPanel Orientation="Horizontal" ItemWidth="156" ItemHeight="36">
                            <Button Command="{Binding Legacy.SaveHostSettingsCommand}" Content="Save Host Settings" />
                            <Button Command="{Binding Legacy.StopHostCommand}" Content="Stop Host" />
                            <Button Command="{Binding Legacy.StopAllAndHostCommand}" Content="Stop All + Host" />
                            <Button Command="{Binding Legacy.ExitDesktopCommand}" Content="Exit Desktop" />
                        </WrapPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Classes="kicker" Text="Host Checklist" />
                            <ItemsControl ItemsSource="{Binding HostChecklist}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="profiles:ProjectZomboidOperatorChecklistItem">
                                        <Border Background="#FFF8F1" CornerRadius="12" Padding="12" Margin="0,0,0,8">
                                            <StackPanel Spacing="4">
                                                <Border Background="#2A2927" CornerRadius="999" Padding="8,3" HorizontalAlignment="Left">
                                                    <TextBlock Foreground="#F7F0E7" FontSize="11" FontWeight="SemiBold" Text="{Binding StatusLabel}" />
                                                </Border>
                                                <TextBlock Classes="body" Text="{Binding Message}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="#F6EFE6" CornerRadius="14" Padding="16">
                <TextBlock Classes="body" Text="Closing the window still minimizes to tray. Exit Desktop closes only the UI and leaves the local host running until you explicitly stop it." TextWrapping="Wrap" />
            </Border>
        </StackPanel>
    </Border>
</UserControl>
