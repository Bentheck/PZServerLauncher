<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:profiles="using:PZServerLauncher.Contracts.Profiles"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="980"
             d:DesignHeight="760"
             x:Class="PZServerLauncher.App.Views.HostWorkspaceView"
             x:DataType="vm:HostWorkspaceViewModel">
    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="18">
        <Grid ColumnDefinitions="1.42*,340" ColumnSpacing="18">
            <Border Classes="card" Padding="26">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="18">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="kicker" Text="Machine Control Console" />
                        <TextBlock Classes="panel-title" FontSize="30" Text="{Binding PageTitle}" />
                        <TextBlock Classes="body"
                                   FontSize="16"
                                   Foreground="#45382E"
                                   Text="{Binding PageSummary}"
                                   TextWrapping="Wrap" />
                        <TextBlock Classes="caption"
                                   Text="{Binding HostNextStepSummary}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="10" Width="184">
                        <Border Background="#2A2927" CornerRadius="999" Padding="14,8">
                            <TextBlock Foreground="#F7F0E7" FontWeight="SemiBold" Text="{Binding HostStartupLabel}" />
                        </Border>
                        <Button Classes="action-secondary"
                                Command="{Binding Legacy.SaveHostSettingsCommand}"
                                Content="Save Host Settings" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Classes="surface-dark" Padding="18">
                <StackPanel Spacing="10">
                    <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Lifecycle Watch" />
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#F7F0E7"
                               Text="{Binding HostStatusSummary}"
                               TextWrapping="Wrap" />
                    <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding HostLifecycleSummary}" TextWrapping="Wrap" />
                    <Border Classes="command-card" Padding="14">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Risk" />
                            <TextBlock Classes="caption" Foreground="#D2C3B6" Text="{Binding HostRiskSummary}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" ColumnSpacing="14">
            <Border Classes="metric-card" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Classes="kicker" Text="Lifecycle" />
                    <TextBlock Classes="panel-title" FontSize="20" Text="{Binding HostStatusSummary}" TextWrapping="Wrap" />
                    <TextBlock Classes="caption" Text="{Binding HostLifecycleSummary}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Classes="metric-card" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Classes="kicker" Text="Startup Roster" />
                    <TextBlock Classes="panel-title" FontSize="20" Text="{Binding StartupRosterCount, StringFormat='{}{0} profile(s)'}" />
                    <TextBlock Classes="caption" Text="{Binding HostStartupCoverageSummary}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Classes="metric-card" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Classes="kicker" Text="Recovery" />
                    <TextBlock Classes="panel-title" FontSize="20" Text="{Binding BackupCoverageCount, StringFormat='{}{0} profile(s)'}" />
                    <TextBlock Classes="caption" Text="{Binding HostRecoveryCoverageSummary}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Classes="metric-card" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Classes="kicker" Text="Live Runtime" />
                    <TextBlock Classes="panel-title" FontSize="20" Text="{Binding RunningProfileCount, StringFormat='{}{0} profile(s)'}" />
                    <TextBlock Classes="caption" Text="{Binding HostRuntimeCoverageSummary}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="1.16*,.84*" ColumnSpacing="18">
            <StackPanel Spacing="18">
                <Border Classes="card" Padding="20">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="kicker" Text="Managed Profiles" />
                                <TextBlock Classes="panel-title" FontSize="24" Text="{Binding HostStartupFleetSummary}" TextWrapping="Wrap" />
                                <TextBlock Classes="body"
                                           Text="These are the server profiles the local host supervises for startup, crash recovery, and stop-all operations."
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <Border Background="#2A2927" CornerRadius="999" Padding="10,5" VerticalAlignment="Top">
                                <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding ManagedProfileCount}" />
                            </Border>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding ManagedProfiles}" IsVisible="{Binding HasManagedProfiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:HostWorkspaceViewModel+HostManagedProfileRowViewModel">
                                    <Border Background="#F6EFE6" CornerRadius="14" Padding="14" Margin="0,0,0,10">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                            <StackPanel Spacing="4">
                                                <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding DisplayName}" />
                                                <TextBlock Classes="body" Text="{Binding Ports}" TextWrapping="Wrap" />
                                                <TextBlock Classes="body" Text="{Binding RuntimeState, StringFormat='Runtime: {0}'}" TextWrapping="Wrap" />
                                                <TextBlock Classes="caption" Text="{Binding RosterSummary}" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <WrapPanel Grid.Column="1" Orientation="Horizontal" ItemHeight="28" VerticalAlignment="Top">
                                                <Border Background="#2A2927" CornerRadius="999" Padding="10,4" Margin="0,0,8,8">
                                                    <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding Branch}" />
                                                </Border>
                                                <Border Background="#2A2927" CornerRadius="999" Padding="10,4" Margin="0,0,8,8">
                                                    <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding StartWithHost, StringFormat='Start with host: {0}'}" />
                                                </Border>
                                                <Border Background="#2A2927" CornerRadius="999" Padding="10,4" Margin="0,0,8,8">
                                                    <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding AutoRestartOnCrash, StringFormat='Auto-restart: {0}'}" />
                                                </Border>
                                                <Border Background="#2A2927" CornerRadius="999" Padding="10,4" Margin="0,0,8,8">
                                                    <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding HasBackup, StringFormat='Backups: {0}'}" />
                                                </Border>
                                                <Border Background="#2A2927" CornerRadius="999" Padding="10,4" Margin="0,0,0,8">
                                                    <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding InstallDetected, StringFormat='Install detected: {0}'}" />
                                                </Border>
                                            </WrapPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Classes="callout-card" Padding="18" IsVisible="{Binding HasNoManagedProfiles}">
                            <StackPanel Spacing="8">
                                <TextBlock Classes="kicker" Text="Host Empty" />
                                <TextBlock Classes="panel-title" FontSize="22" Text="Nothing is under host supervision yet" />
                                <TextBlock Classes="body"
                                           Text="Create or import a profile first. Once the roster exists, this page becomes the machine-wide control point for startup, crash recovery, and coordinated shutdown."
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Classes="card" Padding="20">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="kicker" Text="Machine Posture" />
                        <TextBlock Classes="panel-title" FontSize="22" Text="{Binding Legacy.HostSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding Legacy.StatusMessage}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding HostFleetSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding HostExposureSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding HostSecuritySummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Column="1" Classes="surface-dark" Padding="18">
                <StackPanel Spacing="14">
                    <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Operations Rail" />
                    <TextBlock FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#F7F0E7"
                               Text="{Binding HostOperatorSummary}"
                               TextWrapping="Wrap" />
                    <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding HostShutdownSummary}" TextWrapping="Wrap" />

                    <CheckBox Content="Start Host With Windows"
                              Foreground="#F1E8DE"
                              IsChecked="{Binding Legacy.HostStartWithWindows}" />

                    <WrapPanel Orientation="Horizontal" ItemWidth="154" ItemHeight="38">
                        <Button Classes="action-secondary"
                                Command="{Binding Legacy.SaveHostSettingsCommand}"
                                Content="Save Host Settings" />
                        <Button Classes="action-secondary"
                                Command="{Binding Legacy.StopHostCommand}"
                                Content="Stop Host" />
                        <Button Classes="action-danger"
                                Command="{Binding Legacy.StopAllAndHostCommand}"
                                Content="Stop All + Host" />
                        <Button Classes="action-secondary"
                                Command="{Binding Legacy.ExitDesktopCommand}"
                                Content="Exit Desktop" />
                    </WrapPanel>

                    <Border Classes="command-card" Padding="14">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Action Guidance" />
                            <TextBlock Classes="caption" Foreground="#D2C3B6" Text="{Binding HostActionSummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="caption" Foreground="#D2C3B6" Text="{Binding HostRecoverySummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="caption" Foreground="#D2C3B6" Text="{Binding HostNextStepSummary}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <StackPanel Spacing="8">
                        <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Host Checklist" />
                        <ItemsControl ItemsSource="{Binding HostChecklist}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="profiles:ProjectZomboidOperatorChecklistItem">
                                    <Border Classes="command-card" Padding="12" Margin="0,0,0,8">
                                        <StackPanel Spacing="4">
                                            <Border Background="#F0E2D0" CornerRadius="999" Padding="8,3" HorizontalAlignment="Left">
                                                <TextBlock Foreground="#5E4735" FontSize="11" FontWeight="SemiBold" Text="{Binding StatusLabel}" />
                                            </Border>
                                            <TextBlock Classes="caption" Foreground="#D9C8B6" Text="{Binding Message}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Border Background="#2B221C" CornerRadius="16" Padding="14">
                        <TextBlock Classes="caption"
                                   Foreground="#CCBBA8"
                                   Text="Closing the window still minimizes to tray. Exit Desktop closes only the UI and leaves the local host running until you explicitly stop it."
                                   TextWrapping="Wrap" />
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
