<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1120"
             d:DesignHeight="900"
             x:Class="PZServerLauncher.App.Views.WorkspaceSectionView"
             x:Name="SectionRoot"
             x:DataType="vm:WorkspaceSectionViewModel">
    <Border Classes="card" Padding="24">
        <StackPanel Spacing="16">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                <StackPanel Spacing="4">
                    <TextBlock Classes="panel-title" FontSize="24" Text="{Binding PageTitle}" />
                    <TextBlock Classes="body" Text="{Binding PageSummary}" TextWrapping="Wrap" />
                </StackPanel>
                <Border Grid.Column="1" Background="#2A2927" CornerRadius="14" Padding="12,8" VerticalAlignment="Top">
                    <TextBlock Foreground="#F7F0E7" Text="{Binding DirtyStateMessage}" />
                </Border>
            </Grid>

            <Border Background="#F1E6D7" CornerRadius="14" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Classes="kicker" Text="Workspace Scaffold" />
                    <TextBlock Classes="body" Text="This page is a shell placeholder for the workspace migration. Structured editing and real controls will land here in later milestones." TextWrapping="Wrap" />
                    <TextBlock Classes="body" Text="Use the draft box to exercise the navigation guard scaffold." TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <StackPanel Spacing="8">
                <TextBlock Classes="kicker" Text="Highlights" />
                <ItemsControl ItemsSource="{Binding Highlights}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Classes="body" Text="{Binding .}" TextWrapping="Wrap" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock Classes="kicker" Text="Draft Note" />
                <TextBox AcceptsReturn="True"
                         Height="140"
                         Text="{Binding DraftNote}"
                         TextWrapping="Wrap"
                         VerticalContentAlignment="Top" />
                <WrapPanel Orientation="Horizontal" ItemWidth="128" ItemHeight="36">
                    <Button Command="{Binding SaveDraftCommand}" Content="Save Draft" />
                    <Button Command="{Binding DiscardDraftCommand}" Content="Discard Draft" />
                </WrapPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
