<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1120"
             d:DesignHeight="900"
             x:Class="PZServerLauncher.App.Views.InstallUpdateWorkspaceView"
             x:DataType="vm:InstallUpdateWorkspaceViewModel">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="16">
            <Border Classes="card" Padding="22">
                <Grid ColumnDefinitions="*,260" ColumnSpacing="18">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="kicker" Text="Install" />
                        <TextBlock Classes="panel-title"
                                   FontSize="30"
                                   Text="{Binding ProfileDisplayName}"
                                   TextWrapping="Wrap" />
                        <TextBlock Classes="body"
                                   FontSize="16"
                                   Foreground="#C9D5EA"
                                   Text="{Binding DeploymentPosture}"
                                   TextWrapping="Wrap" />
                        <WrapPanel Margin="0,8,0,0" Orientation="Horizontal" ItemHeight="28">
                            <Border Background="#233238" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                <TextBlock Foreground="#F7F8F6" FontSize="11" Text="{Binding Branch}" />
                            </Border>
                            <Border Background="#224FD8A9" BorderBrush="#6B8CF0CC" BorderThickness="1" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                <TextBlock Foreground="#8CF0CC" FontSize="11" Text="{Binding InstallSignal}" />
                            </Border>
                            <Border Background="#14FFFFFF" BorderBrush="#24FFFFFF" BorderThickness="1" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                <TextBlock Foreground="#C9D5EA" FontSize="11" Text="{Binding LaunchModeSignal}" />
                            </Border>
                            <Border Background="#14FFFFFF" BorderBrush="#24FFFFFF" BorderThickness="1" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                <TextBlock Foreground="#C9D5EA" FontSize="11" Text="{Binding BackupSignal}" />
                            </Border>
                        </WrapPanel>
                    </StackPanel>

                    <Border Grid.Column="1" Classes="surface-soft" Padding="16">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="kicker" Text="Recommended Next Step" />
                            <TextBlock Classes="body"
                                       FontWeight="SemiBold"
                                       Foreground="#EDF4FF"
                                       Text="{Binding NextRecommendedAction}"
                                       TextWrapping="Wrap" />
                            <TextBlock Classes="caption" Text="{Binding RuntimeActionSummary}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="16">
                <Border Classes="card" Padding="18">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="kicker" Text="Step 1" />
                        <TextBlock Classes="panel-title" FontSize="22" Text="Choose where this server lives" />
                        <TextBlock Classes="caption"
                                   Text="By default the launcher creates PZServers\\Installs and PZServers\\Profiles inside its own install folder. Override either path only if you need a custom layout."
                                   TextWrapping="Wrap" />

                        <StackPanel Spacing="4">
                            <TextBlock Classes="body" Text="Install folder" />
                            <TextBox Text="{Binding EditableInstallDirectory}" />
                        </StackPanel>
                        <WrapPanel Orientation="Horizontal" ItemHeight="34">
                            <Button Classes="action-secondary" Command="{Binding BrowseInstallDirectoryCommand}" Content="Browse Install Folder" />
                            <Button Classes="action-secondary" Command="{Binding ResetPathOverridesCommand}" Content="Reset" />
                        </WrapPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Classes="body" Text="Profile data folder" />
                            <TextBox Text="{Binding EditableCacheDirectory}" />
                        </StackPanel>
                        <WrapPanel Orientation="Horizontal" ItemHeight="34">
                            <Button Classes="action-secondary" Command="{Binding BrowseCacheDirectoryCommand}" Content="Browse Cache Folder" />
                            <Button Classes="action-primary" Command="{Binding SavePathOverridesCommand}" Content="Save Folders" />
                        </WrapPanel>

                        <TextBlock Classes="caption" Text="{Binding PathOverrideSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Classes="card" Padding="18">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="kicker" Text="Step 2" />
                        <TextBlock Classes="panel-title" FontSize="22" Text="Install or update the server" />
                        <TextBlock Classes="caption"
                                   Text="{Binding BranchInstallStatus}"
                                   TextWrapping="Wrap" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Border Classes="metric-card" Padding="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="kicker" Text="Install" />
                                    <TextBlock Classes="body" FontWeight="SemiBold" Text="{Binding InstallSignal}" />
                                    <TextBlock Classes="caption" Text="{Binding InstallSignalSummary}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Classes="metric-card" Padding="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="kicker" Text="Config" />
                                    <TextBlock Classes="body" FontWeight="SemiBold" Text="{Binding ConfigSignal}" />
                                    <TextBlock Classes="caption" Text="{Binding ConfigSignalSummary}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <WrapPanel Orientation="Horizontal" ItemHeight="36">
                            <Button Classes="action-primary" Command="{Binding InstallCommand}" Content="Install Server" IsEnabled="{Binding CanQueueInstall}" />
                            <Button Classes="action-secondary" Command="{Binding UpdateCommand}" Content="Update Server" IsEnabled="{Binding CanQueueUpdate}" />
                            <Button Classes="action-secondary" Command="{Binding BackupCommand}" Content="Create Backup" />
                        </WrapPanel>

                        <TextBlock Classes="body" Text="{Binding BackupSafety}" TextWrapping="Wrap" />
                        <TextBlock Classes="caption" Text="{Binding MaintenanceQueueSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="caption" Text="{Binding PreflightSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Classes="card" Padding="18">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="kicker" Text="Step 3" />
                        <TextBlock Classes="panel-title" FontSize="22" Text="Run the server" />
                        <TextBlock Classes="caption"
                                   Text="{Binding RuntimeActionHeadline}"
                                   TextWrapping="Wrap" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Border Classes="metric-card" Padding="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="kicker" Text="Runtime" />
                                    <TextBlock Classes="body" FontWeight="SemiBold" Text="{Binding RuntimeState}" />
                                    <TextBlock Classes="caption" Text="{Binding RuntimeActionSummary}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Classes="metric-card" Padding="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="kicker" Text="Launch Path" />
                                    <TextBlock Classes="body" FontWeight="SemiBold" Text="{Binding LaunchModeLabel}" />
                                    <TextBlock Classes="caption" Text="{Binding LaunchModeSummary}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <WrapPanel Orientation="Horizontal" ItemHeight="36">
                            <Button Classes="action-primary" Command="{Binding StartCommand}" Content="Start" />
                            <Button Classes="action-secondary" Command="{Binding StopCommand}" Content="Stop" />
                            <Button Classes="action-secondary" Command="{Binding RestartCommand}" Content="Restart" />
                            <Button Classes="action-secondary" Command="{Binding RefreshCommand}" Content="Refresh" />
                        </WrapPanel>

                        <TextBlock Classes="caption" Text="{Binding LastJobSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="16">
                <Border Classes="card" Padding="18">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="kicker" Text="Recent Install Jobs" />
                        <TextBlock Classes="caption" Text="{Binding InstallJobHistorySummary}" TextWrapping="Wrap" />
                        <ItemsControl ItemsSource="{Binding RecentInstallJobs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#14FFFFFF" BorderBrush="#24FFFFFF" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,8">
                                        <StackPanel Spacing="4">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Status}" />
                                            <TextBlock Classes="caption" Text="{Binding Detail}" TextWrapping="Wrap" />
                                            <TextBlock Classes="caption" Text="{Binding Summary}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Classes="caption" Text="{Binding LastInstallJobSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Classes="card" Padding="18">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="kicker" Text="Recent Update Jobs" />
                        <TextBlock Classes="caption" Text="{Binding UpdateJobHistorySummary}" TextWrapping="Wrap" />
                        <ItemsControl ItemsSource="{Binding RecentUpdateJobs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#14FFFFFF" BorderBrush="#24FFFFFF" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,0,0,8">
                                        <StackPanel Spacing="4">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Status}" />
                                            <TextBlock Classes="caption" Text="{Binding Detail}" TextWrapping="Wrap" />
                                            <TextBlock Classes="caption" Text="{Binding Summary}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Classes="caption" Text="{Binding LastUpdateJobSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="3" Classes="card" Padding="18">
                <StackPanel Spacing="14">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Danger Zone" />
                        <TextBlock Classes="panel-title" FontSize="24" Text="Uninstall or delete this server" />
                        <TextBlock Classes="body"
                                   Foreground="#FFB36B"
                                   Text="{Binding RetirementGuardrailSummary}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                        <Border Background="#22FFB36B" BorderBrush="#72FFB36B" BorderThickness="1" CornerRadius="16" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock Classes="kicker" Text="Uninstall Server" />
                                <TextBlock Classes="body" FontWeight="SemiBold" Text="Remove the dedicated-server files only" />
                                <TextBlock Classes="caption" Text="{Binding UninstallServerSummary}" TextWrapping="Wrap" />

                                <Button Classes="action-secondary"
                                        Command="{Binding ArmUninstallServerCommand}"
                                        Content="Uninstall Server"
                                        IsEnabled="{Binding CanArmUninstallServer}"
                                        IsVisible="{Binding ShowUninstallServerArmButton}" />

                                <Border Background="#1EFF8F8F"
                                        BorderBrush="#D48A6D"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="12"
                                        IsVisible="{Binding ShowUninstallServerConfirmation}">
                                    <StackPanel Spacing="8">
                                        <TextBlock Classes="body"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FFF3F3"
                                                   Text="Confirm uninstall. This keeps the profile, backups, and cache so you can reinstall later."
                                                   TextWrapping="Wrap" />
                                        <WrapPanel Orientation="Horizontal" ItemHeight="36">
                                            <Button Classes="action-danger"
                                                    Command="{Binding UninstallServerCommand}"
                                                    Content="Confirm Uninstall"
                                                    IsEnabled="{Binding CanArmUninstallServer}" />
                                            <Button Classes="action-secondary"
                                                    Command="{Binding CancelRetirementCommand}"
                                                    Content="Cancel" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="#22FF8F8F" BorderBrush="#72FF8F8F" BorderThickness="1" CornerRadius="16" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock Classes="kicker" Text="Delete Profile" />
                                <TextBlock Classes="body" FontWeight="SemiBold" Text="Remove this server from the launcher" />
                                <TextBlock Classes="caption" Text="{Binding DeleteProfileSummary}" TextWrapping="Wrap" />

                                <Button Classes="action-danger"
                                        Command="{Binding ArmDeleteProfileCommand}"
                                        Content="Delete Profile"
                                        IsEnabled="{Binding CanArmDeleteProfile}"
                                        IsVisible="{Binding ShowDeleteProfileArmButton}" />

                                <Border Background="#1EFF8F8F"
                                        BorderBrush="#D48A6D"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="12"
                                        IsVisible="{Binding ShowDeleteProfileConfirmation}">
                                    <StackPanel Spacing="8">
                                        <TextBlock Classes="body"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FFF3F3"
                                                   Text="Confirm delete. The launcher will remove this profile and clean up launcher-managed folders, backups, logs, and runtime artifacts."
                                                   TextWrapping="Wrap" />
                                        <WrapPanel Orientation="Horizontal" ItemHeight="36">
                                            <Button Classes="action-danger"
                                                    Command="{Binding DeleteProfileCommand}"
                                                    Content="Confirm Delete"
                                                    IsEnabled="{Binding CanArmDeleteProfile}" />
                                            <Button Classes="action-secondary"
                                                    Command="{Binding CancelRetirementCommand}"
                                                    Content="Cancel" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
