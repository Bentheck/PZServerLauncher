<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1120"
             d:DesignHeight="900"
             x:Class="PZServerLauncher.App.Views.InstallUpdateWorkspaceView"
             x:DataType="vm:InstallUpdateWorkspaceViewModel">
    <Border Classes="card" Padding="24">
        <StackPanel Spacing="18">
            <StackPanel Spacing="4">
                <TextBlock Classes="panel-title" FontSize="24" Text="{Binding PageTitle}" />
                <TextBlock Classes="body" Text="{Binding PageSummary}" TextWrapping="Wrap" />
            </StackPanel>

            <Border Background="#1F1D1B" CornerRadius="16" Padding="18">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Install &amp; Update Flow" />
                        <TextBlock FontSize="28" FontWeight="SemiBold" Foreground="#F7F0E7" Text="{Binding ProfileDisplayName}" />
                        <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding DeploymentPosture}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding BranchInstallStatus}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Border Grid.Column="1" Background="#2A2927" CornerRadius="999" Padding="14,8" VerticalAlignment="Top">
                        <TextBlock Foreground="#F7F0E7" FontWeight="SemiBold" Text="{Binding Branch}" />
                    </Border>
                </Grid>
            </Border>

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14">
                <Border Background="#F6EFE6" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Runtime" />
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding RuntimeState}" />
                        <TextBlock Classes="body" Text="{Binding LifecycleGuidance}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="#F6EFE6" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Branch And Install" />
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding Branch}" />
                        <TextBlock Classes="body" Text="{Binding BranchChannelSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="#F6EFE6" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Update Posture" />
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding UpdatePostureSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding MaintenanceWindowSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14">
                <Border Background="#FFF8F1" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Install Root" />
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding InstallSignal}" />
                        <TextBlock Classes="body" Text="{Binding InstallSignalSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="#FFF8F1" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Cache Layer" />
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding CacheSignal}" />
                        <TextBlock Classes="body" Text="{Binding CacheSignalSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="#FFF8F1" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Config Layer" />
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding ConfigSignal}" />
                        <TextBlock Classes="body" Text="{Binding ConfigSignalSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14">
                <Border Background="#FFF8F1" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Backup Posture" />
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding BackupSignal}" />
                        <TextBlock Classes="body" Text="{Binding BackupSignalSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="#FFF8F1" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Launch Mode" />
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding LaunchModeSignal}" />
                        <TextBlock Classes="body" Text="{Binding LaunchModeSignalSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="#FFF8F1" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Maintenance Window" />
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding MaintenanceSignal}" />
                        <TextBlock Classes="body" Text="{Binding MaintenanceSignalSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Background="#FBF7F1" CornerRadius="14" Padding="16">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="kicker" Text="Deployment Readiness" />
                        <TextBlock Classes="body"
                                   Text="These checkpoints condense the install, cache, launcher, config, and recovery posture into one maintenance pass before you queue work."
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding FootprintCheckpoints}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:InstallReadinessCheckpointViewModel">
                                <Border Background="#F1E6D7"
                                        CornerRadius="12"
                                        Padding="14"
                                        Width="208"
                                        Margin="0,0,12,12">
                                    <StackPanel Spacing="6">
                                        <TextBlock Classes="kicker" Text="{Binding Title}" />
                                        <TextBlock FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Status}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Classes="body"
                                                   Text="{Binding Summary}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Grid ColumnDefinitions="*,320" ColumnSpacing="16">
                <StackPanel Spacing="14">
                    <Border Background="#FFF8F1" CornerRadius="14" Padding="16">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="kicker" Text="Install Posture" />
                            <TextBlock Classes="body" Text="{Binding InstallPostureSummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="{Binding InstallJobHistorySummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="{Binding LastInstallJobSummary}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Background="#FFF8F1" CornerRadius="14" Padding="16">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="kicker" Text="Update Posture" />
                            <TextBlock Classes="body" Text="{Binding UpdatePostureSummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="{Binding UpdateJobHistorySummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="{Binding LastUpdateJobSummary}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Background="#FFF8F1" CornerRadius="14" Padding="16">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="kicker" Text="Install Directory" />
                            <TextBlock Classes="body" FontFamily="Cascadia Code,Consolas,monospace" Text="{Binding InstallDirectory}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="{Binding InstallReadiness}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Background="#FFF8F1" CornerRadius="14" Padding="16">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="kicker" Text="Cache Directory" />
                            <TextBlock Classes="body" FontFamily="Cascadia Code,Consolas,monospace" Text="{Binding CacheDirectory}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="{Binding CacheReadiness}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Background="#FFF8F1" CornerRadius="14" Padding="16">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="kicker" Text="Launcher Path" />
                            <TextBlock Classes="body" FontFamily="Cascadia Code,Consolas,monospace" Text="{Binding ExpectedLauncherPath}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="{Binding SteamCmdCommandSummary}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                        <Border Background="#FFF8F1" CornerRadius="14" Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="kicker" Text="SteamCMD Script Preview" />
                                <SelectableTextBlock Classes="body"
                                                     FontFamily="Cascadia Code,Consolas,monospace"
                                                     Text="{Binding SteamCmdScriptPreview}"
                                                     TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="#FFF8F1" CornerRadius="14" Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="kicker" Text="Launch Preview" />
                                <SelectableTextBlock Classes="body"
                                                     FontFamily="Cascadia Code,Consolas,monospace"
                                                     Text="{Binding LaunchCommandPreview}"
                                                     TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Background="#F1E6D7" CornerRadius="14" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="kicker" Text="Preflight Briefing" />
                            <TextBlock Classes="body" Text="{Binding BackupSafety}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="{Binding PreflightSummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="{Binding ConfigFootprintSummary}" TextWrapping="Wrap" />
                            <ItemsControl ItemsSource="{Binding PreflightChecks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Classes="body"
                                                   Text="{Binding .}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                        <Border Background="#FFF8F1" CornerRadius="14" Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="kicker" Text="Install History" />
                                <TextBlock Classes="body" Text="{Binding InstallJobHistorySummary}" TextWrapping="Wrap" />
                                <ItemsControl ItemsSource="{Binding RecentInstallJobs}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#F1E6D7" CornerRadius="10" Padding="10" Margin="0,4,0,0">
                                                <StackPanel Spacing="4">
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Status}" />
                                                    <TextBlock Classes="body" Text="{Binding Detail}" TextWrapping="Wrap" />
                                                    <TextBlock Classes="body" Text="{Binding Summary}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="#FFF8F1" CornerRadius="14" Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="kicker" Text="Update History" />
                                <TextBlock Classes="body" Text="{Binding UpdateJobHistorySummary}" TextWrapping="Wrap" />
                                <ItemsControl ItemsSource="{Binding RecentUpdateJobs}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#F1E6D7" CornerRadius="10" Padding="10" Margin="0,4,0,0">
                                                <StackPanel Spacing="4">
                                                    <TextBlock FontWeight="SemiBold" Text="{Binding Status}" />
                                                    <TextBlock Classes="body" Text="{Binding Detail}" TextWrapping="Wrap" />
                                                    <TextBlock Classes="body" Text="{Binding Summary}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>

                <Border Grid.Column="1" Background="#FFF8F1" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="kicker" Text="Operator Actions" />
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="{Binding RuntimeActionHeadline}"
                                   TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding NextRecommendedAction}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding RuntimeActionSummary}" TextWrapping="Wrap" />

                        <StackPanel Spacing="8">
                            <TextBlock FontWeight="SemiBold" Text="Deploy" />
                            <WrapPanel Orientation="Horizontal" ItemWidth="136" ItemHeight="36">
                                <Button Command="{Binding InstallCommand}" Content="Install" />
                                <Button Command="{Binding UpdateCommand}" Content="Update" />
                            </WrapPanel>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock FontWeight="SemiBold" Text="Safeguards" />
                            <WrapPanel Orientation="Horizontal" ItemWidth="136" ItemHeight="36">
                                <Button Command="{Binding BackupCommand}" Content="Manual Backup" />
                            </WrapPanel>
                            <TextBlock Classes="body" Text="{Binding LatestBackupLabel}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="{Binding BackupSignalSummary}" TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock FontWeight="SemiBold" Text="Runtime" />
                            <WrapPanel Orientation="Horizontal" ItemWidth="136" ItemHeight="36">
                                <Button Command="{Binding StartCommand}" Content="Start" />
                                <Button Command="{Binding StopCommand}" Content="Stop" />
                                <Button Command="{Binding RestartCommand}" Content="Restart" />
                            </WrapPanel>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock FontWeight="SemiBold" Text="Refresh" />
                            <WrapPanel Orientation="Horizontal" ItemWidth="136" ItemHeight="36">
                                <Button Command="{Binding RefreshCommand}" Content="Refresh" />
                            </WrapPanel>
                        </StackPanel>

                        <Border Background="#F1E6D7" CornerRadius="12" Padding="12">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="kicker" Text="Maintenance Gate" />
                                <TextBlock Classes="body" Text="{Binding LaunchModeSummary}" TextWrapping="Wrap" />
                                <TextBlock Classes="body" Text="{Binding OperatorSequenceSummary}" TextWrapping="Wrap" />
                                <TextBlock Classes="body" Text="{Binding JobHistorySummary}" TextWrapping="Wrap" />
                                <TextBlock Classes="body" Text="{Binding LastJobSummary}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Background="#F1E6D7" CornerRadius="12" Padding="12">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="kicker" Text="Current Signals" />
                                <TextBlock Classes="body" Text="{Binding BranchInstallStatus}" TextWrapping="Wrap" />
                                <TextBlock Classes="body" Text="{Binding ConfigStateHeadline}" TextWrapping="Wrap" />
                                <TextBlock Classes="body" Text="{Binding RecoveryStateHeadline}" TextWrapping="Wrap" />
                                <TextBlock Classes="body" Text="{Binding LaunchReadiness}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
