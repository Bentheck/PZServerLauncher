<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1120"
             d:DesignHeight="860"
             x:Class="PZServerLauncher.App.Views.RemoteAccessWorkspaceView"
             x:DataType="vm:RemoteAccessWorkspaceViewModel">
    <Border Classes="card" Padding="24">
        <StackPanel Spacing="18">
            <Border Background="#1F1D1B" CornerRadius="16" Padding="20">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="18">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Optional Remote Admin" />
                        <TextBlock FontSize="30" FontWeight="SemiBold" Foreground="#F7F0E7" Text="{Binding PageTitle}" />
                        <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding PageSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Border Grid.Column="1" Background="#2A2927" CornerRadius="999" Padding="14,8" VerticalAlignment="Top">
                        <TextBlock Foreground="#F7F0E7" FontWeight="SemiBold" Text="{Binding RemoteEnabledLabel}" />
                    </Border>
                </Grid>
            </Border>

            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="14">
                <Border Background="#F6EFE6" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Readiness" />
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding RemoteStatusSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding RemoteReadinessSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="#F6EFE6" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Endpoint" />
                        <TextBlock Classes="body" Text="{Binding RemoteEndpointSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="#F6EFE6" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Identity" />
                        <TextBlock Classes="body" Text="{Binding RemoteIdentitySummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Background="#F6EFE6" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Self-Test" />
                        <TextBlock Classes="body" Text="{Binding RemoteSelfTestHeadline}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding RemoteSelfTestStats}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="*,360" ColumnSpacing="16">
                <Border Background="#FFF8F1" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="kicker" Text="Remote Setup" />
                                <TextBlock Classes="panel-title" FontSize="22" Text="{Binding RemoteHostSummary}" TextWrapping="Wrap" />
                                <TextBlock Classes="body" Text="{Binding RemoteBindingSummary}" TextWrapping="Wrap" />
                                <TextBlock Classes="body" Text="{Binding RemoteCertificateSummary}" TextWrapping="Wrap" />
                            </StackPanel>
                            <Border Background="#2A2927" CornerRadius="999" Padding="10,6" VerticalAlignment="Top">
                                <TextBlock Foreground="#F7F0E7" FontSize="12" Text="Desktop-managed" />
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="12" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
                            <CheckBox Grid.ColumnSpan="4"
                                      Content="Enable Remote Access"
                                      IsChecked="{Binding Legacy.RemoteAccessEnabled}" />

                            <TextBlock Grid.Row="1" Classes="body" Text="Bind Address" VerticalAlignment="Center" />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Legacy.RemoteBindAddress}" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Classes="body" Text="HTTPS Port" VerticalAlignment="Center" />
                            <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding Legacy.RemoteHttpsPort}" />

                            <TextBlock Grid.Row="2" Classes="body" Text="Public Hostname" VerticalAlignment="Center" />
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Legacy.RemotePublicHostname}" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Classes="body" Text="PFX Password" VerticalAlignment="Center" />
                            <TextBox Grid.Row="2" Grid.Column="3" PasswordChar="*" Text="{Binding Legacy.RemoteCertificatePassword}" />

                            <TextBlock Grid.Row="3" Classes="body" Text="PFX Certificate Path" VerticalAlignment="Center" />
                            <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding Legacy.RemoteCertificatePath}" />
                        </Grid>

                        <CheckBox Content="Create Or Update The Windows Firewall Rule"
                                  IsChecked="{Binding Legacy.RemoteCreateFirewallRule}" />

                        <WrapPanel Orientation="Horizontal" ItemWidth="176" ItemHeight="36">
                            <Button Command="{Binding Legacy.SaveRemoteAccessCommand}" Content="Save Remote Settings" />
                            <Button Command="{Binding Legacy.RemoteSelfTestCommand}" Content="Run Local Self-Test" />
                            <Button Command="{Binding Legacy.ApplyFirewallRuleCommand}" Content="Apply Firewall Rule" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#F1E6D7" CornerRadius="14" Padding="16">
                        <StackPanel Spacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="kicker" Text="Operator Checklist" />
                                <TextBlock Classes="body" Text="{Binding RemoteActionSummary}" TextWrapping="Wrap" />
                                <TextBlock Classes="body" Text="{Binding RemoteFirewallIntentSummary}" TextWrapping="Wrap" />
                                <TextBlock Classes="body" Text="{Binding RemoteNextStepSummary}" TextWrapping="Wrap" />
                            </StackPanel>
                            <TextBlock Classes="body"
                                   FontFamily="Cascadia Code,Consolas,monospace"
                                   Text="{Binding Legacy.RemoteSelfTestChecks}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
