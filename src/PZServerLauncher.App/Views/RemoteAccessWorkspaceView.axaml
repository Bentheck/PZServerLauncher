<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:profiles="using:PZServerLauncher.Contracts.Profiles"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1120"
             d:DesignHeight="900"
             x:Class="PZServerLauncher.App.Views.RemoteAccessWorkspaceView"
             x:DataType="vm:RemoteAccessWorkspaceViewModel">
    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="18">
        <Grid ColumnDefinitions="1.42*,340" ColumnSpacing="18">
            <Border Classes="card" Padding="26">
                <Grid ColumnDefinitions="*,220" ColumnSpacing="18">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="kicker" Text="Optional Remote Admin" />
                        <TextBlock Classes="panel-title" FontSize="30" Text="{Binding PageTitle}" />
                        <TextBlock Classes="body"
                                   FontSize="16"
                                   Foreground="#45382E"
                                   Text="{Binding RemoteActionSummary}"
                                   TextWrapping="Wrap" />
                        <TextBlock Classes="caption" Text="{Binding RemoteNextStepSummary}" TextWrapping="Wrap" />

                        <WrapPanel Margin="0,8,0,0" Orientation="Horizontal" ItemHeight="30">
                            <Border Background="#2A2927" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding RemoteEnabledLabel}" />
                            </Border>
                            <Border Background="#EAD6BF" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                <TextBlock Foreground="#5A4330" FontSize="11" Text="{Binding RemoteStatusSummary}" />
                            </Border>
                            <Border Background="#EAD6BF" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                <TextBlock Foreground="#5A4330" FontSize="11" Text="{Binding RemoteSelfTestCheckCount, StringFormat='Checks: {0}'}" />
                            </Border>
                        </WrapPanel>
                    </StackPanel>

                    <Border Grid.Column="1" Classes="metric-card" Padding="16">
                        <StackPanel Spacing="6">
                            <TextBlock Classes="kicker" Text="Next Move" />
                            <TextBlock Classes="body" FontWeight="SemiBold" Text="{Binding RemoteChecklistHeadline}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" Classes="surface-dark" Padding="18">
                <StackPanel Spacing="10">
                    <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Rollout Tower" />
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#F7F0E7"
                               Text="{Binding RemoteReadinessSummary}"
                               TextWrapping="Wrap" />
                    <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding RemoteEndpointSummary}" TextWrapping="Wrap" />
                    <TextBlock Classes="caption" Foreground="#CCB9A8" Text="{Binding RemoteCertificateStatusSummary}" TextWrapping="Wrap" />
                    <WrapPanel Orientation="Horizontal" ItemWidth="154" ItemHeight="36">
                        <Button Command="{Binding Legacy.SaveRemoteAccessCommand}" Content="Save Remote" />
                        <Button Command="{Binding Legacy.RemoteSelfTestCommand}" Content="Run Self-Test" />
                        <Button Command="{Binding Legacy.ApplyFirewallRuleCommand}" Content="Apply Firewall" />
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*" ColumnSpacing="14">
            <Border Classes="metric-card" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Classes="kicker" Text="Readiness" />
                    <TextBlock Classes="panel-title" FontSize="22" Text="{Binding RemoteStatusSummary}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Classes="metric-card" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Classes="kicker" Text="Endpoint" />
                    <TextBlock Classes="panel-title" FontSize="22" Text="{Binding RemoteEndpointSummary}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Classes="metric-card" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Classes="kicker" Text="Healthy Checks" />
                    <TextBlock Classes="panel-title" FontSize="22" Text="{Binding RemoteHealthyCheckCount, StringFormat='{}{0}'}" />
                    <TextBlock Classes="caption" Text="{Binding RemoteChecklistSummary}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Classes="metric-card" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Classes="kicker" Text="Blocking Checks" />
                    <TextBlock Classes="panel-title" FontSize="22" Text="{Binding RemoteBlockingCheckCount, StringFormat='{}{0}'}" />
                    <TextBlock Classes="caption" Text="{Binding RemoteFirewallIntentSummary}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="1.18*,.82*" ColumnSpacing="18">
            <StackPanel Spacing="18">
                <Border Classes="card" Padding="20">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="kicker" Text="HTTPS Footprint" />
                                <TextBlock Classes="panel-title" FontSize="24" Text="{Binding RemoteHostSummary}" TextWrapping="Wrap" />
                                <TextBlock Classes="body" Text="{Binding RemoteBindingSummary}" TextWrapping="Wrap" />
                                <TextBlock Classes="caption" Text="{Binding RemoteExposureSummary}" TextWrapping="Wrap" />
                            </StackPanel>
                            <Border Grid.Column="1" Background="#2A2927" CornerRadius="999" Padding="10,5" VerticalAlignment="Top">
                                <TextBlock Foreground="#F7F0E7" FontSize="11" Text="Desktop-managed" />
                            </Border>
                        </Grid>

                        <Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="12" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
                            <CheckBox Grid.ColumnSpan="4"
                                      Content="Enable Remote Access"
                                      IsChecked="{Binding Legacy.RemoteAccessEnabled}" />

                            <TextBlock Grid.Row="1" Classes="body" Text="Bind Address" VerticalAlignment="Center" />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Legacy.RemoteBindAddress}" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Classes="body" Text="HTTPS Port" VerticalAlignment="Center" />
                            <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding Legacy.RemoteHttpsPort}" />

                            <TextBlock Grid.Row="2" Classes="body" Text="Public Hostname" VerticalAlignment="Center" />
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Legacy.RemotePublicHostname}" />
                            <TextBlock Grid.Row="2" Grid.Column="2" Classes="body" Text="PFX Password" VerticalAlignment="Center" />
                            <TextBox Grid.Row="2" Grid.Column="3" PasswordChar="*" Text="{Binding Legacy.RemoteCertificatePassword}" />

                            <TextBlock Grid.Row="3" Classes="body" Text="PFX Certificate Path" VerticalAlignment="Center" />
                            <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding Legacy.RemoteCertificatePath}" />
                        </Grid>

                        <Border Background="#F5E8DA" CornerRadius="14" Padding="14">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="kicker" Text="Firewall Intent" />
                                <CheckBox Content="Create Or Update The Windows Firewall Rule"
                                          IsChecked="{Binding Legacy.RemoteCreateFirewallRule}" />
                                <TextBlock Classes="caption" Text="{Binding RemoteFirewallIntentSummary}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                    <Border Classes="surface-dark" Padding="18">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Rollout Guidance" />
                            <TextBlock FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="#F7F0E7"
                                       Text="{Binding RemoteModeSummary}"
                                       TextWrapping="Wrap" />
                            <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding RemoteLocalOnlyGuidance}" TextWrapping="Wrap" />
                            <TextBlock Classes="caption" Foreground="#CCB9A8" Text="{Binding RemoteOperatorChecklistSummary}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Classes="card" Padding="18">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="kicker" Text="Identity And Certs" />
                            <TextBlock Classes="panel-title" FontSize="22" Text="{Binding RemoteIdentitySummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="caption" Text="{Binding RemoteCertificateStatusSummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="caption" Text="{Binding RemoteFirewallActionSummary}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Column="1" Spacing="16">
                <Border Classes="card" Padding="18">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="kicker" Text="Latest Self-Test Checks" />
                        <ItemsControl ItemsSource="{Binding RemoteSelfTestChecks}" IsVisible="{Binding HasRemoteSelfTestChecks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="profiles:ProjectZomboidOperatorChecklistItem">
                                    <Border Background="#F5E8DA" CornerRadius="12" Padding="12" Margin="0,0,0,8">
                                        <StackPanel Spacing="4">
                                            <Border Background="#26201A" CornerRadius="999" Padding="8,3" HorizontalAlignment="Left">
                                                <TextBlock Foreground="#F7F0E7" FontSize="11" FontWeight="SemiBold" Text="{Binding StatusLabel}" />
                                            </Border>
                                            <TextBlock Classes="caption" Text="{Binding Message}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Background="#1F1D1B"
                                CornerRadius="16"
                                Padding="18"
                                IsVisible="{Binding HasNoRemoteSelfTestChecks}">
                            <StackPanel Spacing="10">
                                <TextBlock Classes="kicker" Foreground="#E5A26B" Text="No Self-Test Data Yet" />
                                <TextBlock Classes="panel-title" FontSize="22" Foreground="#F7F0E7" Text="{Binding RemoteChecklistHeadline}" />
                                <TextBlock Classes="body"
                                           Foreground="#D3C8BA"
                                           Text="Run the local self-test after saving the HTTPS footprint so this page can shift from setup into a real rollout checklist."
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Classes="card" Padding="18">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="kicker" Text="Operator Note" />
                        <TextBlock Classes="body" Text="{Binding RemoteNextStepSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
