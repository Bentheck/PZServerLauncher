<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1180"
             d:DesignHeight="940"
             x:Class="PZServerLauncher.App.Views.DashboardWorkspaceView"
             x:Name="DashboardRoot"
             x:DataType="vm:DashboardWorkspaceViewModel">
    <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="18">
        <Grid ColumnDefinitions="1.45*,360" ColumnSpacing="18">
            <Border Classes="card" Padding="26">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="18">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="kicker" Text="Fleet Command" />
                        <TextBlock Classes="panel-title" FontSize="30" Text="{Binding PageTitle}" />
                        <TextBlock Classes="body"
                                   FontSize="16"
                                   Foreground="#45382E"
                                   Text="{Binding PageSummary}"
                                   TextWrapping="Wrap" />
                        <TextBlock Classes="caption"
                                   Text="{Binding NextActionSummary}"
                                   TextWrapping="Wrap" />

                        <WrapPanel Margin="0,8,0,0" Orientation="Horizontal" ItemHeight="32">
                            <Border Background="#2A2927" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding FleetRiskSummary}" TextWrapping="Wrap" />
                            </Border>
                            <Border Background="#EAD6BF" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                <TextBlock Foreground="#5A4330" FontSize="11" Text="{Binding FleetNextStepSummary}" TextWrapping="Wrap" />
                            </Border>
                        </WrapPanel>
                    </StackPanel>

                    <WrapPanel Grid.Column="1" Orientation="Horizontal" ItemWidth="154" ItemHeight="38">
                        <Button Command="{Binding Legacy.RefreshCommand}" Content="Refresh Host" />
                        <Button Command="{Binding Legacy.CreateStarterProfileCommand}" Content="Create Profile" />
                        <Button Command="{Binding Legacy.DiscoverImportsCommand}" Content="Scan Imports" />
                    </WrapPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Classes="surface-dark" Padding="18">
                <StackPanel Spacing="10">
                    <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Host Watch" />
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#F7F0E7"
                               Text="{Binding HostStateSummary}" />
                    <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding RemoteAccessSummary}" TextWrapping="Wrap" />
                    <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding OwnerSummary}" TextWrapping="Wrap" />
                    <TextBlock Classes="caption" Foreground="#C5B29E" Text="{Binding StatusSummary}" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="*,*,*,*,*" ColumnSpacing="14">
            <Border Classes="metric-card" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Classes="kicker" Text="Installed" />
                    <TextBlock Classes="panel-title" FontSize="24" Text="{Binding InstalledProfileCount}" />
                    <TextBlock Classes="caption" Text="Detected dedicated-server footprints." />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Classes="metric-card" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Classes="kicker" Text="Launch Ready" />
                    <TextBlock Classes="panel-title" FontSize="24" Text="{Binding LaunchReadyProfileCount}" />
                    <TextBlock Classes="caption" Text="Ready to boot without extra cache/config work." />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Classes="metric-card" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Classes="kicker" Text="Recovery Ready" />
                    <TextBlock Classes="panel-title" FontSize="24" Text="{Binding BackupCoverageCount}" />
                    <TextBlock Classes="caption"
                               Text="{Binding ProfilesMissingBackupCount, StringFormat='Missing archives: {0}'}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Classes="metric-card" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Classes="kicker" Text="Direct Java" />
                    <TextBlock Classes="panel-title" FontSize="24" Text="{Binding DirectJavaReadyProfileCount}" />
                    <TextBlock Classes="caption"
                               Text="{Binding FallbackLaunchProfileCount, StringFormat='Fallback launchers: {0}'}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <Border Grid.Column="4" Classes="metric-card" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Classes="kicker" Text="Modded" />
                    <TextBlock Classes="panel-title" FontSize="24" Text="{Binding ModdedProfileCount}" />
                    <TextBlock Classes="caption" Text="Profiles carrying workshop, mods, or custom maps." />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="1.35*,.95*" ColumnSpacing="18">
            <Border Classes="surface-dark" Padding="22">
                <Grid ColumnDefinitions="1.1*,.9*" ColumnSpacing="18">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Fleet Situation" />
                        <TextBlock FontSize="26"
                                   FontWeight="SemiBold"
                                   Foreground="#F7F0E7"
                                   Text="{Binding FleetAccessHeadline}"
                                   TextWrapping="Wrap" />
                        <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding FleetTrustHeadline}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding FleetCommunicationHeadline}" TextWrapping="Wrap" />
                        <TextBlock Classes="caption" Foreground="#CCBBA8" Text="{Binding FleetSummary}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="10">
                        <Border Background="#2B221C" CornerRadius="18" Padding="14">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Operator Focus" />
                                <TextBlock Classes="body" Foreground="#F0E7DC" Text="{Binding FleetAccessOperatorSummary}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <WrapPanel Orientation="Horizontal" ItemHeight="28">
                            <Border Background="#F0E2D0" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                <TextBlock Foreground="#5E4735"
                                           FontSize="11"
                                           Text="{Binding PublicProfileCount, StringFormat='Public listed: {0}'}" />
                            </Border>
                            <Border Background="#F0E2D0" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                <TextBlock Foreground="#5E4735"
                                           FontSize="11"
                                           Text="{Binding OpenAccessCount, StringFormat='Open access: {0}'}" />
                            </Border>
                            <Border Background="#F0E2D0" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                <TextBlock Foreground="#5E4735"
                                           FontSize="11"
                                           Text="{Binding SafetyEnabledCount, StringFormat='Safety enabled: {0}'}" />
                            </Border>
                            <Border Background="#F0E2D0" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                <TextBlock Foreground="#5E4735"
                                           FontSize="11"
                                           Text="{Binding VoiceEnabledCount, StringFormat='Voice enabled: {0}'}" />
                            </Border>
                        </WrapPanel>

                        <ItemsControl ItemsSource="{Binding FleetAccessChecklist}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#2B221C" CornerRadius="14" Padding="12" Margin="0,0,0,8">
                                        <TextBlock Classes="caption"
                                                   Foreground="#D9C8B6"
                                                   Text="{Binding .}"
                                                   TextWrapping="Wrap" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Classes="caption"
                                   Foreground="#CCBBA8"
                                   Text="{Binding PublicOpenWithoutSafetyCount, StringFormat='Public + open without safety: {0}'}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1" RowDefinitions="Auto,*" RowSpacing="18">
                <Border Classes="card" Padding="18">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="kicker" Text="Import Intake" />
                        <TextBlock Classes="panel-title" FontSize="22" Text="{Binding ImportSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="caption" Text="Use discovery to turn existing local Zomboid servers into managed profiles." />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Classes="card" Padding="18">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="kicker" Text="Recent Jobs" />
                                <TextBlock Classes="panel-title" FontSize="22" Text="{Binding RecentJobSummary}" TextWrapping="Wrap" />
                            </StackPanel>
                            <Border Background="#2A2927" CornerRadius="999" Padding="10,5" VerticalAlignment="Top">
                                <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding RecentJobCount}" />
                            </Border>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding Legacy.RecentJobs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ShellItemViewModel">
                                    <Border Background="#F6EFE6" CornerRadius="14" Padding="14" Margin="0,0,0,8">
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="kicker" Text="{Binding Title}" />
                                            <TextBlock Classes="body" Text="{Binding Detail}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Classes="body"
                                   IsVisible="{Binding HasNoRecentJobs}"
                                   Text="No recent host jobs have been recorded yet."
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.Row="3" ColumnDefinitions="1.35*,.95*" ColumnSpacing="18">
            <Border Classes="card" Padding="20">
                <StackPanel Spacing="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="kicker" Text="Server Roster" />
                            <TextBlock Classes="panel-title" FontSize="24" Text="Fleet posture by profile" />
                            <TextBlock Classes="body" Text="{Binding FleetSummary}" TextWrapping="Wrap" />
                        </StackPanel>
                        <Border Background="#2A2927" CornerRadius="999" Padding="10,5" VerticalAlignment="Top">
                            <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding ProfileCount}" />
                        </Border>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Legacy.Profiles}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ProfileCardViewModel">
                                <Border Background="#F6EFE6" CornerRadius="16" Padding="16" Margin="0,0,0,10">
                                    <Grid ColumnDefinitions="*,220" ColumnSpacing="16">
                                        <StackPanel Spacing="8">
                                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                                <TextBlock Classes="panel-title" FontSize="18" Text="{Binding DisplayName}" />
                                                <Border Grid.Column="1" Background="#2A2927" CornerRadius="999" Padding="10,4">
                                                    <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding Branch}" />
                                                </Border>
                                                <Border Grid.Column="2" Background="#2A2927" CornerRadius="999" Padding="10,4">
                                                    <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding RuntimeState}" />
                                                </Border>
                                            </Grid>

                                            <WrapPanel Orientation="Horizontal" ItemHeight="24">
                                                <Border Background="#2A2927" CornerRadius="999" Padding="8,3" Margin="0,0,6,6">
                                                    <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding InstallSignal}" />
                                                </Border>
                                                <Border Background="#2A2927" CornerRadius="999" Padding="8,3" Margin="0,0,6,6">
                                                    <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding LaunchModeLabel}" />
                                                </Border>
                                                <Border Background="#2A2927" CornerRadius="999" Padding="8,3" Margin="0,0,6,6">
                                                    <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding RecoveryStateHeadline}" />
                                                </Border>
                                            </WrapPanel>

                                            <TextBlock Classes="body" Text="{Binding CommunitySummary}" TextWrapping="Wrap" />
                                            <TextBlock Classes="caption" Text="{Binding InstallPreflightSummary}" TextWrapping="Wrap" />
                                            <TextBlock Classes="caption" Text="{Binding LaunchReadinessSummary}" TextWrapping="Wrap" />
                                        </StackPanel>

                                        <Border Grid.Column="1" Background="#FFF8F0" BorderBrush="#E0C1A2" BorderThickness="1" CornerRadius="14" Padding="14">
                                            <StackPanel Spacing="8">
                                                <TextBlock Classes="kicker" Text="Watchboard" />
                                                <TextBlock Classes="caption" Text="{Binding WorkshopSummary}" TextWrapping="Wrap" />
                                                <TextBlock Classes="caption" Text="{Binding LastBackup}" TextWrapping="Wrap" />
                                                <TextBlock Classes="caption" Text="{Binding BackupSafetySummary}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Classes="body"
                               IsVisible="{Binding HasNoProfiles}"
                               Text="No profiles are available yet. Create or import a server to start building the fleet."
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Classes="card" Padding="20">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="kicker" Text="Import Candidates" />
                            <TextBlock Classes="panel-title" FontSize="22" Text="Local servers waiting for intake" />
                            <TextBlock Classes="body" Text="Scan local Zomboid directories and turn existing installs into managed profiles." TextWrapping="Wrap" />
                        </StackPanel>
                        <Border Background="#2A2927" CornerRadius="999" Padding="10,5" VerticalAlignment="Top">
                            <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding ImportCandidateCount}" />
                        </Border>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Legacy.ImportCandidates}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ImportCandidateViewModel">
                                <Border Background="#F6EFE6" CornerRadius="14" Padding="14" Margin="0,0,0,10">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="panel-title" FontSize="18" Text="{Binding DisplayName}" />
                                            <TextBlock Classes="caption" Text="{Binding ServerName}" />
                                            <TextBlock Classes="caption" FontFamily="Cascadia Code,Consolas,monospace" Text="{Binding CacheDirectory}" />
                                            <TextBlock Classes="caption" FontFamily="Cascadia Code,Consolas,monospace" Text="{Binding InstallDirectory}" />
                                            <TextBlock Classes="body" Text="{Binding Notes}" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <Button Command="{Binding #DashboardRoot.DataContext.Legacy.ImportCandidateCommand}"
                                                CommandParameter="{Binding .}"
                                                Content="{Binding ImportActionLabel}"
                                                IsEnabled="{Binding CanImport}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Classes="body"
                               IsVisible="{Binding HasNoImportCandidates}"
                               Text="No local import candidates are currently loaded. Run discovery to scan the local Zomboid directories."
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
