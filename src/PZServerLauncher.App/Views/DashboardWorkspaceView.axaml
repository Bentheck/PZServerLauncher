<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1180"
             d:DesignHeight="940"
             x:Class="PZServerLauncher.App.Views.DashboardWorkspaceView"
             x:Name="DashboardRoot"
             x:DataType="vm:DashboardWorkspaceViewModel">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="18">
            <Border Classes="card" Padding="28">
                <Grid ColumnDefinitions="1.2*,.8*" ColumnSpacing="20">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="kicker" Text="Dashboard" />
                        <TextBlock Classes="panel-title" FontSize="34" Text="{Binding PageTitle}" />
                        <TextBlock Classes="body"
                                   FontSize="16"
                                   Text="{Binding PageSummary}"
                                   TextWrapping="Wrap" />
                        <TextBlock Classes="caption"
                                   Text="{Binding LaunchPadSummary}"
                                   TextWrapping="Wrap" />

                        <WrapPanel Orientation="Horizontal" ItemHeight="38">
                            <Button Classes="action-primary"
                                    Command="{Binding Legacy.CreateStarterProfileCommand}"
                                    Content="{Binding SetupPrimaryActionLabel}"
                                    Margin="0,0,10,10" />
                            <Button Classes="action-secondary"
                                    Command="{Binding Legacy.DiscoverImportsCommand}"
                                    Content="{Binding SetupSecondaryActionLabel}"
                                    Margin="0,0,10,10" />
                            <Button Classes="action-secondary"
                                    Command="{Binding OpenProfilesWorkspaceCommand}"
                                    Content="Open Profiles"
                                    Margin="0,0,10,10" />
                            <Button Classes="action-secondary"
                                    Command="{Binding OpenUsersWorkspaceCommand}"
                                    Content="Open Users"
                                    IsVisible="{Binding ShowOwnerSetupAction}"
                                    Margin="0,0,10,10" />
                        </WrapPanel>
                    </StackPanel>

                    <Border Grid.Column="1" Background="#F6EFE6" CornerRadius="18" Padding="18">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="kicker" Text="Next Step" />
                            <TextBlock Classes="panel-title" FontSize="22" Text="{Binding LaunchPadHeadline}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="{Binding FirstRunActionPlan}" TextWrapping="Wrap" />
                            <TextBlock Classes="caption" Text="{Binding LaunchPadActionHint}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid ColumnDefinitions="1.1*,.9*" ColumnSpacing="18">
                <Border Classes="card" Padding="22">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="kicker" Text="Getting Started" />
                                <TextBlock Classes="panel-title" FontSize="24" Text="{Binding SetupModeHeadline}" TextWrapping="Wrap" />
                                <TextBlock Classes="body" Text="{Binding SetupModeSummary}" TextWrapping="Wrap" />
                            </StackPanel>
                            <Border Grid.Column="1" Background="#EAD6BF" CornerRadius="999" Padding="10,6" VerticalAlignment="Top">
                                <TextBlock Foreground="#5A4330" FontSize="11" Text="{Binding ProfileCount, StringFormat='Profiles: {0}'}" />
                            </Border>
                        </Grid>

                        <StackPanel Spacing="10">
                            <Border Background="#FBF7F1" CornerRadius="14" Padding="14">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="kicker" Text="Step 1" />
                                    <TextBlock Classes="body" Text="{Binding LaunchPadStepOne}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Background="#FBF7F1" CornerRadius="14" Padding="14">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="kicker" Text="Step 2" />
                                    <TextBlock Classes="body" Text="{Binding LaunchPadStepTwo}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Background="#FBF7F1" CornerRadius="14" Padding="14">
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="kicker" Text="Step 3" />
                                    <TextBlock Classes="body" Text="{Binding LaunchPadStepThree}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Classes="card" Padding="22">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="kicker" Text="Host Snapshot" />
                        <TextBlock Classes="panel-title" FontSize="24" Text="{Binding HostStateSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding RemoteAccessSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding OwnerSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="caption" Text="{Binding StatusSummary}" TextWrapping="Wrap" />

                        <Border Background="#F6EFE6" CornerRadius="14" Padding="14">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="kicker" Text="Fleet Summary" />
                                <TextBlock Classes="body" Text="{Binding FleetSummary}" TextWrapping="Wrap" />
                                <TextBlock Classes="body" Text="{Binding FleetRiskSummary}" TextWrapping="Wrap" />
                                <TextBlock Classes="body" Text="{Binding FleetNextStepSummary}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="18" IsVisible="{Binding HasGuidedLaunchPad}">
                <Border Classes="card" Padding="22">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="kicker" Text="Import Intake" />
                                <TextBlock Classes="panel-title" FontSize="24" Text="{Binding ImportSummary}" TextWrapping="Wrap" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Classes="action-secondary"
                                    Command="{Binding Legacy.DiscoverImportsCommand}"
                                    Content="Scan Again" />
                        </Grid>

                        <TextBlock Classes="body"
                                   Text="If this machine already hosts Project Zomboid, import it so the launcher adopts the existing files instead of rebuilding everything."
                                   TextWrapping="Wrap" />

                        <ItemsControl ItemsSource="{Binding Legacy.ImportCandidates}" IsVisible="{Binding HasImportCandidates}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ImportCandidateViewModel">
                                    <Border Background="#F6EFE6" CornerRadius="14" Padding="14" Margin="0,0,0,10">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                                            <StackPanel Spacing="4">
                                                <TextBlock Classes="panel-title" FontSize="18" Text="{Binding DisplayName}" />
                                                <TextBlock Classes="caption" Text="{Binding ServerName}" />
                                                <TextBlock Classes="caption"
                                                           FontFamily="Cascadia Code,Consolas,monospace"
                                                           Text="{Binding CacheDirectory}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Classes="action-primary"
                                                    Command="{Binding #DashboardRoot.DataContext.Legacy.ImportCandidateCommand}"
                                                    CommandParameter="{Binding .}"
                                                    Content="{Binding ImportActionLabel}"
                                                    IsEnabled="{Binding CanImport}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Background="#FBF7F1"
                                CornerRadius="14"
                                Padding="14"
                                IsVisible="{Binding HasNoImportCandidates}">
                            <TextBlock Classes="body"
                                       Text="No local server candidates are loaded yet. Use the scan action to look through the standard Project Zomboid locations on this machine."
                                       TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </Border>

                <Border Classes="card" Padding="22">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="kicker" Text="Quick Actions" />
                        <TextBlock Classes="panel-title" FontSize="24" Text="Open the next workspace" />
                        <TextBlock Classes="body" Text="Use Profiles to choose a server, or jump straight to the first-run actions below." TextWrapping="Wrap" />

                        <WrapPanel Orientation="Horizontal" ItemHeight="38">
                            <Button Classes="action-primary" Command="{Binding OpenProfilesWorkspaceCommand}" Content="Open Profiles" Margin="0,0,10,10" />
                            <Button Classes="action-secondary" Command="{Binding Legacy.RefreshCommand}" Content="Refresh Host" Margin="0,0,10,10" />
                            <Button Classes="action-secondary" Command="{Binding Legacy.CreateStarterProfileCommand}" Content="Create Profile" Margin="0,0,10,10" />
                        </WrapPanel>

                        <Border Background="#F6EFE6" CornerRadius="14" Padding="14">
                            <StackPanel Spacing="4">
                                <TextBlock Classes="kicker" Text="Recent Jobs" />
                                <TextBlock Classes="body" Text="{Binding RecentJobSummary}" TextWrapping="Wrap" />
                                <TextBlock Classes="caption" Text="{Binding NextActionSummary}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <ItemsControl ItemsSource="{Binding Legacy.RecentJobs}" IsVisible="{Binding HasRecentJobs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ShellItemViewModel">
                                    <Border Background="#FBF7F1" CornerRadius="12" Padding="12" Margin="0,0,0,8">
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="kicker" Text="{Binding Title}" />
                                            <TextBlock Classes="body" Text="{Binding Detail}" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Background="#FBF7F1"
                                CornerRadius="14"
                                Padding="14"
                                IsVisible="{Binding HasNoRecentJobs}">
                            <TextBlock Classes="body"
                                       Text="No recent host jobs have been recorded yet. Install, update, start, or back up a server to populate this feed."
                                       TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Classes="card" Padding="22">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="kicker" Text="Managed Servers" />
                            <TextBlock Classes="panel-title" FontSize="24" Text="Fleet Overview" />
                            <TextBlock Classes="body" Text="Desktop and web converge on the same profile workspaces. Pick a profile above to jump straight into the next task." TextWrapping="Wrap" />
                        </StackPanel>
                        <Border Grid.Column="1" Background="#2A2927" CornerRadius="999" Padding="10,6" VerticalAlignment="Top">
                            <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding ProfileCount}" />
                        </Border>
                    </Grid>

                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="14">
                        <Border Classes="metric-card" Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="kicker" Text="Installed" />
                                <TextBlock Classes="panel-title" FontSize="24" Text="{Binding InstalledProfileCount}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Classes="metric-card" Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="kicker" Text="Launch Ready" />
                                <TextBlock Classes="panel-title" FontSize="24" Text="{Binding LaunchReadyProfileCount}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Classes="metric-card" Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="kicker" Text="Recovery Ready" />
                                <TextBlock Classes="panel-title" FontSize="24" Text="{Binding BackupCoverageCount}" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" Classes="metric-card" Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Classes="kicker" Text="Modded" />
                                <TextBlock Classes="panel-title" FontSize="24" Text="{Binding ModdedProfileCount}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
