<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1180"
             d:DesignHeight="940"
             x:Class="PZServerLauncher.App.Views.DashboardWorkspaceView"
             x:Name="DashboardRoot"
             x:DataType="vm:DashboardWorkspaceViewModel">
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" RowSpacing="18">
        <Border Classes="card" Padding="24">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                <StackPanel Spacing="6">
                    <TextBlock Classes="kicker" Text="Host Dashboard" />
                    <TextBlock Classes="panel-title" FontSize="28" Text="{Binding PageTitle}" />
                    <TextBlock Classes="body" Text="{Binding PageSummary}" TextWrapping="Wrap" />
                </StackPanel>

                <WrapPanel Grid.Column="1" Orientation="Horizontal" ItemWidth="164" ItemHeight="36">
                    <Button Command="{Binding Legacy.RefreshCommand}" Content="Refresh Host" />
                    <Button Command="{Binding Legacy.CreateStarterProfileCommand}" Content="Create Starter Profile" />
                    <Button Command="{Binding Legacy.DiscoverImportsCommand}" Content="Discover Imports" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="2*,*" ColumnSpacing="18">
            <Border Classes="card" Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Classes="kicker" Text="Operator Snapshot" />
                    <TextBlock Classes="panel-title" FontSize="22" Text="{Binding HostStateSummary}" />
                    <TextBlock Classes="body" Text="{Binding RemoteAccessSummary}" TextWrapping="Wrap" />
                    <TextBlock Classes="body" Text="{Binding OwnerSummary}" TextWrapping="Wrap" />
                    <TextBlock Classes="body" Text="{Binding StatusSummary}" TextWrapping="Wrap" />
                    <WrapPanel Orientation="Horizontal" ItemWidth="148" ItemHeight="32">
                        <Border Background="#F1E6D7" CornerRadius="999" Padding="10,6">
                            <TextBlock Classes="body" Text="{Binding ImportSummary}" TextWrapping="Wrap" />
                        </Border>
                        <Border Background="#F1E6D7" CornerRadius="999" Padding="10,6">
                            <TextBlock Classes="body" Text="{Binding RecentJobSummary}" TextWrapping="Wrap" />
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Classes="card" Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Classes="kicker" Text="Workspace State" />
                    <TextBlock Classes="panel-title" FontSize="20" Text="{Binding NextActionSummary}" TextWrapping="Wrap" />
                    <TextBlock Classes="body" Text="{Binding FleetRiskSummary}" TextWrapping="Wrap" />
                    <TextBlock Classes="body" Text="{Binding FleetNextStepSummary}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="1.2*,.8*" ColumnSpacing="18">
            <Border Classes="card" Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Classes="kicker" Text="Fleet Access &amp; Trust" />
                    <TextBlock Classes="panel-title" FontSize="22" Text="{Binding FleetAccessHeadline}" TextWrapping="Wrap" />
                    <TextBlock Classes="body" Text="{Binding FleetTrustHeadline}" TextWrapping="Wrap" />
                    <TextBlock Classes="body" Text="{Binding FleetCommunicationHeadline}" TextWrapping="Wrap" />
                    <WrapPanel Orientation="Horizontal" ItemHeight="28">
                        <Border Background="#F1E6D7" CornerRadius="999" Padding="10,6" Margin="0,0,8,8">
                            <TextBlock Classes="body" Text="{Binding PublicProfileCount, StringFormat='Public listed: {0}'}" TextWrapping="Wrap" />
                        </Border>
                        <Border Background="#F1E6D7" CornerRadius="999" Padding="10,6" Margin="0,0,8,8">
                            <TextBlock Classes="body" Text="{Binding OpenAccessCount, StringFormat='Open access: {0}'}" TextWrapping="Wrap" />
                        </Border>
                        <Border Background="#F1E6D7" CornerRadius="999" Padding="10,6" Margin="0,0,8,8">
                            <TextBlock Classes="body" Text="{Binding SafetyEnabledCount, StringFormat='Safety enabled: {0}'}" TextWrapping="Wrap" />
                        </Border>
                        <Border Background="#F1E6D7" CornerRadius="999" Padding="10,6" Margin="0,0,8,8">
                            <TextBlock Classes="body" Text="{Binding VoiceEnabledCount, StringFormat='Voice enabled: {0}'}" TextWrapping="Wrap" />
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Classes="card" Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Classes="kicker" Text="Operator Focus" />
                    <TextBlock Classes="panel-title" FontSize="20" Text="{Binding FleetAccessOperatorSummary}" TextWrapping="Wrap" />
                    <ItemsControl ItemsSource="{Binding FleetAccessChecklist}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Classes="body"
                                           Margin="0,0,0,6"
                                           Text="{Binding .}"
                                           TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Classes="body"
                               Text="{Binding PublicOpenWithoutSafetyCount, StringFormat='Public + open without safety: {0}'}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="3" Spacing="14">
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14">
                <Border Classes="card" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Installed" />
                        <TextBlock Classes="panel-title" FontSize="22" Text="{Binding InstalledProfileCount}" />
                        <TextBlock Classes="body" Text="Profiles with a detected dedicated-server install." TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Classes="card" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Recovery Ready" />
                        <TextBlock Classes="panel-title" FontSize="22" Text="{Binding BackupCoverageCount}" />
                        <TextBlock Classes="body" Text="{Binding ProfilesMissingBackupCount, StringFormat='Profiles still missing backups: {0}'}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Classes="card" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Direct Java" />
                        <TextBlock Classes="panel-title" FontSize="22" Text="{Binding DirectJavaReadyProfileCount}" />
                        <TextBlock Classes="body" Text="{Binding FallbackLaunchProfileCount, StringFormat='Profiles still on batch fallback: {0}'}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14">
                <Border Classes="card" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Launch Ready" />
                        <TextBlock Classes="panel-title" FontSize="22" Text="{Binding LaunchReadyProfileCount}" />
                        <TextBlock Classes="body" Text="Installed profiles whose cache and config footprint look ready for launch." TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Classes="card" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Install Missing" />
                        <TextBlock Classes="panel-title" FontSize="22" Text="{Binding ProfilesMissingInstallCount}" />
                        <TextBlock Classes="body" Text="Profiles that still need a detected server install before deployment work can begin." TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Classes="card" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Modded" />
                        <TextBlock Classes="panel-title" FontSize="22" Text="{Binding ModdedProfileCount}" />
                        <TextBlock Classes="body" Text="Profiles currently carrying workshop, mod, or custom map content." TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>

        <Border Grid.Row="4" Classes="card" Padding="20">
            <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock Classes="panel-title" FontSize="22" Text="Fleet Posture" />
                        <TextBlock Classes="body" Text="{Binding FleetSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Border Background="#2A2927" CornerRadius="999" Padding="10,6" VerticalAlignment="Top">
                        <TextBlock Foreground="#F7F0E7" FontSize="12" Text="{Binding ProfileCount}" />
                    </Border>
                </Grid>

                <ItemsControl ItemsSource="{Binding Legacy.Profiles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ProfileCardViewModel">
                            <Border Background="#F6EFE6" CornerRadius="14" Padding="14" Margin="0,0,0,10">
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                                    <StackPanel Spacing="6">
                                       <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                            <TextBlock Classes="panel-title" FontSize="18" Text="{Binding DisplayName}" />
                                            <Border Grid.Column="1" Background="#2A2927" CornerRadius="999" Padding="10,4">
                                                <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding Branch}" />
                                            </Border>
                                            <Border Grid.Column="2" Background="#2A2927" CornerRadius="999" Padding="10,4">
                                                <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding RuntimeState}" />
                                            </Border>
                                        </Grid>
                                        <WrapPanel Orientation="Horizontal" ItemHeight="24">
                                            <Border Background="#2A2927"
                                                    CornerRadius="999"
                                                    Padding="8,3"
                                                    Margin="0,0,6,6">
                                                <TextBlock Foreground="#F7F0E7"
                                                           FontSize="11"
                                                           Text="{Binding InstallSignal}" />
                                            </Border>
                                            <Border Background="#2A2927"
                                                    CornerRadius="999"
                                                    Padding="8,3"
                                                    Margin="0,0,6,6">
                                                <TextBlock Foreground="#F7F0E7"
                                                           FontSize="11"
                                                           Text="{Binding LaunchModeLabel}" />
                                            </Border>
                                            <Border Background="#2A2927"
                                                    CornerRadius="999"
                                                    Padding="8,3"
                                                    Margin="0,0,6,6">
                                                <TextBlock Foreground="#F7F0E7"
                                                           FontSize="11"
                                                           Text="{Binding RecoveryStateHeadline}" />
                                            </Border>
                                        </WrapPanel>
                                       <TextBlock Classes="body" Text="{Binding CommunitySummary}" TextWrapping="Wrap" />
                                       <TextBlock Classes="body" Text="{Binding InstallPreflightSummary}" TextWrapping="Wrap" />
                                        <TextBlock Classes="body" Text="{Binding LaunchReadinessSummary}" TextWrapping="Wrap" />
                                        <TextBlock Classes="body" Text="{Binding BackupSafetySummary}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Top">
                                        <Border Background="#FFF8F1" CornerRadius="999" Padding="10,4">
                                            <TextBlock Classes="body" FontSize="11" Text="{Binding WorkshopSummary}" TextWrapping="Wrap" />
                                        </Border>
                                        <Border Background="#FFF8F1" CornerRadius="999" Padding="10,4">
                                            <TextBlock Classes="body" FontSize="11" Text="{Binding LastBackup}" TextWrapping="Wrap" />
                                        </Border>
                                        <TextBlock Classes="body" FontSize="11" Text="{Binding BackupSafetySummary}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Classes="body"
                           IsVisible="{Binding HasNoProfiles}"
                           Text="No profiles are available yet. Create or import a server to start building the operator fleet view."
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="5" ColumnDefinitions="*,*" ColumnSpacing="18">
            <Border Classes="card" Padding="20">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="panel-title" FontSize="22" Text="Import Candidates" />
                            <TextBlock Classes="body" Text="Scan local Zomboid directories and turn existing installs into managed profiles." TextWrapping="Wrap" />
                        </StackPanel>
                        <Border Background="#2A2927" CornerRadius="999" Padding="10,6" VerticalAlignment="Top">
                            <TextBlock Foreground="#F7F0E7" FontSize="12" Text="{Binding ImportCandidateCount}" />
                        </Border>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Legacy.ImportCandidates}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ImportCandidateViewModel">
                                <Border Background="#F6EFE6" CornerRadius="14" Padding="14" Margin="0,0,0,10">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="panel-title" FontSize="18" Text="{Binding DisplayName}" />
                                            <TextBlock Classes="body" Text="{Binding ServerName}" />
                                            <TextBlock Classes="body" FontFamily="Cascadia Code,Consolas,monospace" Text="{Binding CacheDirectory}" />
                                            <TextBlock Classes="body" FontFamily="Cascadia Code,Consolas,monospace" Text="{Binding InstallDirectory}" />
                                            <TextBlock Classes="body" Text="{Binding Notes}" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <Button Command="{Binding #DashboardRoot.DataContext.Legacy.ImportCandidateCommand}"
                                                CommandParameter="{Binding .}"
                                                Content="{Binding ImportActionLabel}"
                                                IsEnabled="{Binding CanImport}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Classes="body"
                               IsVisible="{Binding HasNoImportCandidates}"
                               Text="No local import candidates are currently loaded. Run discovery to scan the local Zomboid directories."
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Classes="card" Padding="20">
                <StackPanel Spacing="10">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <StackPanel Spacing="4">
                            <TextBlock Classes="panel-title" FontSize="22" Text="Recent Jobs" />
                            <TextBlock Classes="body" Text="Deployments, backups, and import work appear here so the operator can see what happened most recently." TextWrapping="Wrap" />
                        </StackPanel>
                        <Border Background="#2A2927" CornerRadius="999" Padding="10,6" VerticalAlignment="Top">
                            <TextBlock Foreground="#F7F0E7" FontSize="12" Text="{Binding RecentJobCount}" />
                        </Border>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Legacy.RecentJobs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ShellItemViewModel">
                                <Border Background="#F6EFE6" CornerRadius="14" Padding="14" Margin="0,0,0,8">
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="kicker" Text="{Binding Title}" />
                                        <TextBlock Classes="body" Text="{Binding Detail}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Classes="body"
                               IsVisible="{Binding HasNoRecentJobs}"
                               Text="No recent host jobs have been recorded yet."
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
