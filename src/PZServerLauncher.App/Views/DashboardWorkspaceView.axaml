<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1180"
             d:DesignHeight="940"
             x:Class="PZServerLauncher.App.Views.DashboardWorkspaceView"
             x:Name="DashboardRoot"
             x:DataType="vm:DashboardWorkspaceViewModel">
    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="18">
        <Border Classes="card" Padding="24">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                <StackPanel Spacing="4">
                    <TextBlock Classes="panel-title" FontSize="24" Text="{Binding PageTitle}" />
                    <TextBlock Classes="body" Text="{Binding PageSummary}" TextWrapping="Wrap" />
                </StackPanel>

                <WrapPanel Grid.Column="1" Orientation="Horizontal" ItemWidth="164" ItemHeight="36">
                    <Button Command="{Binding Legacy.RefreshCommand}" Content="Refresh Host" />
                    <Button Command="{Binding Legacy.CreateStarterProfileCommand}" Content="Create Starter Profile" />
                    <Button Command="{Binding Legacy.DiscoverImportsCommand}" Content="Discover Imports" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="18">
            <Border Classes="card" Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Classes="kicker" Text="Local Host" />
                    <TextBlock Classes="panel-title" FontSize="20" Text="{Binding Legacy.HostSummary}" />
                    <TextBlock Classes="body" Text="{Binding Legacy.RemoteSummary}" TextWrapping="Wrap" />
                    <TextBlock Classes="body" Text="{Binding Legacy.OwnerSummary}" TextWrapping="Wrap" />
                    <TextBlock Classes="body" Text="{Binding Legacy.StatusMessage}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Classes="card" Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Classes="kicker" Text="Workspace State" />
                    <TextBlock Classes="body" Text="Per-profile pages are fully live. Use this dashboard for imports, recent jobs, and global host context while the final Classic retirement wraps up." TextWrapping="Wrap" />
                    <TextBlock Classes="body" Text="The optional web admin mirrors the same structure once remote access is enabled." TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="18">
            <Border Classes="card" Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Classes="panel-title" FontSize="22" Text="Import Candidates" />
                    <ItemsControl ItemsSource="{Binding Legacy.ImportCandidates}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ImportCandidateViewModel">
                                <Border Background="#F6EFE6" CornerRadius="14" Padding="14" Margin="0,0,0,10">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                                        <StackPanel Spacing="4">
                                            <TextBlock Classes="panel-title" FontSize="18" Text="{Binding DisplayName}" />
                                            <TextBlock Classes="body" Text="{Binding ServerName}" />
                                            <TextBlock Classes="body" FontFamily="Cascadia Code,Consolas,monospace" Text="{Binding CacheDirectory}" />
                                            <TextBlock Classes="body" FontFamily="Cascadia Code,Consolas,monospace" Text="{Binding InstallDirectory}" />
                                            <TextBlock Classes="body" Text="{Binding Notes}" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <Button Command="{Binding #DashboardRoot.DataContext.Legacy.ImportCandidateCommand}"
                                                CommandParameter="{Binding .}"
                                                Content="{Binding ImportActionLabel}"
                                                IsEnabled="{Binding CanImport}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Classes="body"
                               IsVisible="{Binding HasNoImportCandidates}"
                               Text="No local import candidates are currently loaded. Run discovery to scan the local Zomboid directories."
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Classes="card" Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Classes="panel-title" FontSize="22" Text="Recent Jobs" />
                    <ItemsControl ItemsSource="{Binding Legacy.RecentJobs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ShellItemViewModel">
                                <Border Background="#F6EFE6" CornerRadius="14" Padding="14" Margin="0,0,0,8">
                                    <StackPanel Spacing="4">
                                        <TextBlock Classes="kicker" Text="{Binding Title}" />
                                        <TextBlock Classes="body" Text="{Binding Detail}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Classes="body"
                               IsVisible="{Binding HasNoRecentJobs}"
                               Text="No recent host jobs have been recorded yet."
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
