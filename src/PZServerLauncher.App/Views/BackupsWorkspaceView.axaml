<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1120"
             d:DesignHeight="900"
             x:Class="PZServerLauncher.App.Views.BackupsWorkspaceView"
             x:DataType="vm:BackupsWorkspaceViewModel">
    <Border Classes="card" Padding="24">
        <StackPanel Spacing="18">
            <StackPanel Spacing="4">
                <TextBlock Classes="panel-title" FontSize="24" Text="{Binding PageTitle}" />
                <TextBlock Classes="body" Text="{Binding PageSummary}" TextWrapping="Wrap" />
            </StackPanel>

            <Border Background="#1F1D1B" CornerRadius="16" Padding="18">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Recovery Center" />
                        <TextBlock FontSize="28" FontWeight="SemiBold" Foreground="#F7F0E7" Text="{Binding RecoveryHeroTitle}" />
                        <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding RecoveryHeroCopy}" TextWrapping="Wrap" />
                    </StackPanel>
                    <WrapPanel Orientation="Horizontal">
                        <Border Background="#2A2927" CornerRadius="999" Padding="14,8" Margin="0,0,10,0">
                            <TextBlock Foreground="#F7F0E7" FontWeight="SemiBold" Text="{Binding Branch}" />
                        </Border>
                        <Border Background="#2A2927" CornerRadius="999" Padding="14,8" Margin="0,0,10,0">
                            <TextBlock Foreground="#F7F0E7" Text="{Binding BackupInventorySummary}" />
                        </Border>
                        <Border Background="#2A2927" CornerRadius="999" Padding="14,8">
                            <TextBlock Foreground="#F7F0E7" Text="{Binding LatestBackupSummary}" />
                        </Border>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="14">
                <Border Background="#F6EFE6" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Coverage" />
                        <TextBlock Classes="body" Text="{Binding BackupPosture}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="#F6EFE6" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Retention" />
                        <TextBlock Classes="body" Text="{Binding PolicySummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="#F6EFE6" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Restore Safety" />
                        <TextBlock Classes="body" Text="{Binding RecoveryGuidance}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Background="#F6EFE6" CornerRadius="14" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Classes="kicker" Text="Continuity" />
                        <TextBlock Classes="body" Text="{Binding OperatorNextStep}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="340,*" ColumnSpacing="16">
                <Border Classes="card" Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="kicker" Text="Available Backups" />
                        <ListBox ItemsSource="{Binding Backups}"
                                 SelectedItem="{Binding SelectedBackup}"
                                 MinHeight="360">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Classes="body" Text="{Binding .}" TextWrapping="Wrap" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock Classes="body"
                                   Text="No backups yet. Create the first manual archive from this page."
                                   IsVisible="{Binding HasNoBackups}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1" Spacing="14">
                    <Border Classes="card" Padding="16">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="kicker" Text="Selected Backup" />
                            <TextBlock Classes="body" Text="{Binding SelectedBackupDetails}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="{Binding LatestBackupSummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="Backups are ZIP archives produced by the host service. Restore stops the server, unpacks the selected archive, and optionally requests a restart afterward." TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="Use this page for standard recovery workflows. Advanced file-level recovery still belongs in filesystem tooling and Advanced Files." TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Background="#FFF8F1" CornerRadius="14" Padding="16">
                        <StackPanel Spacing="10">
                            <TextBlock Classes="kicker" Text="Operator Actions" />
                            <WrapPanel Orientation="Horizontal" ItemWidth="168" ItemHeight="36">
                                <Button Command="{Binding CreateBackupCommand}" Content="Create Backup" IsEnabled="{Binding CanCreateBackup}" />
                                <Button Command="{Binding RestoreSelectedCommand}" Content="Restore Selected" IsEnabled="{Binding CanRestore}" />
                                <Button Command="{Binding ReloadCommand}" Content="Reload" />
                            </WrapPanel>

                            <CheckBox Content="Restart server after restore"
                                      IsChecked="{Binding RestartAfterRestore}"
                                      IsEnabled="{Binding CanRestore}" />
                            <TextBlock Classes="body" Text="{Binding RestoreModeSummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="{Binding LoadStatus}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
