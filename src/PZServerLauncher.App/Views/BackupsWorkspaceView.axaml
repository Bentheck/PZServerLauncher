<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PZServerLauncher.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1120"
             d:DesignHeight="900"
             x:Class="PZServerLauncher.App.Views.BackupsWorkspaceView"
             x:DataType="vm:BackupsWorkspaceViewModel">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <Grid RowDefinitions="Auto,*" RowSpacing="16">
            <Grid ColumnDefinitions="1.08*,.92*" ColumnSpacing="16">
                <Border Classes="card" Padding="24">
                    <StackPanel Spacing="8">
                        <TextBlock Classes="kicker" Text="Recovery Console" />
                        <TextBlock Classes="panel-title" FontSize="30" Text="{Binding RecoveryHeroTitle}" />
                        <TextBlock Classes="body"
                                   FontSize="16"
                                   Foreground="#45382E"
                                   Text="{Binding RecoveryHeroCopy}"
                                   TextWrapping="Wrap" />
                        <TextBlock Classes="caption"
                                   Text="{Binding BackupPosture}"
                                   TextWrapping="Wrap" />

                        <WrapPanel Margin="0,8,0,0" Orientation="Horizontal" ItemHeight="30">
                            <Border Background="#2A2927" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding Branch}" />
                            </Border>
                            <Border Background="#EAD6BF" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                <TextBlock Foreground="#5A4330" FontSize="11" Text="{Binding BackupCountSummary}" />
                            </Border>
                            <Border Background="#EAD6BF" CornerRadius="999" Padding="10,5" Margin="0,0,8,8">
                                <TextBlock Foreground="#5A4330" FontSize="11" Text="{Binding LatestBackupSummary}" />
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Classes="card" Padding="20">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="kicker" Text="Recovery Policy" />
                        <TextBlock Classes="panel-title" FontSize="24" Text="Set retention before you need it" TextWrapping="Wrap" />
                        <TextBlock Classes="body" Text="{Binding PolicyEditorSummary}" TextWrapping="Wrap" />
                        <TextBlock Classes="caption" Text="{Binding PolicySummary}" TextWrapping="Wrap" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <StackPanel Spacing="6">
                                <CheckBox Content="Enable scheduled backups"
                                          IsChecked="{Binding ScheduledBackupsEnabled}" />
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="body" Text="Scheduled start time" />
                                    <TextBox Text="{Binding ScheduledBackupStartLocalTime}" PlaceholderText="03:00" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="body" Text="Repeat every (hours)" />
                                    <TextBox Text="{Binding ScheduledBackupIntervalHours}" />
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="body" Text="Scheduled retention count" />
                                    <TextBox Text="{Binding ScheduledBackupRetentionCount}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="6">
                                <CheckBox Content="Create pre-update safety archives"
                                          IsChecked="{Binding PreUpdateBackupEnabled}" />
                                <StackPanel Spacing="4">
                                    <TextBlock Classes="body" Text="Pre-update retention count" />
                                    <TextBox Text="{Binding PreUpdateBackupRetentionCount}" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <TextBlock Classes="caption" Text="{Binding ScheduledCadenceSummary}" TextWrapping="Wrap" />

                        <CheckBox Content="Keep manual backups forever"
                                  IsChecked="{Binding KeepManualBackupsForever}" />

                        <WrapPanel Orientation="Horizontal" ItemWidth="170" ItemHeight="36">
                            <Button Classes="action-primary"
                                    Command="{Binding SavePolicyCommand}"
                                    Content="Save Policy"
                                    IsEnabled="{Binding CanSavePolicy}" />
                            <Button Classes="action-secondary"
                                    Command="{Binding ReloadCommand}"
                                    Content="Reload Recovery"
                                    IsEnabled="{Binding HasSelectedProfile}" />
                        </WrapPanel>

                        <TextBlock Classes="caption" Text="{Binding PolicyValidationSummary}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="1" ColumnDefinitions="360,*" ColumnSpacing="16">
                <Border Classes="surface-dark" Padding="18">
                    <StackPanel Spacing="10">
                        <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Archive Inventory" />
                        <TextBlock FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="#F7F0E7"
                                   Text="{Binding BackupInventorySummary}"
                                   TextWrapping="Wrap" />
                        <TextBlock Classes="caption"
                                   Foreground="#CCB9A8"
                                   Text="Manual, pre-update, and scheduled archives appear newest-first."
                                   TextWrapping="Wrap" />

                        <ListBox ItemsSource="{Binding BackupEntries}"
                                 SelectedItem="{Binding SelectedBackupArchive}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 MinHeight="420">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8F0E6" CornerRadius="14" Padding="12" Margin="0,0,0,8">
                                        <StackPanel Spacing="4">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock FontWeight="SemiBold" Foreground="#191512" Text="{Binding Title}" />
                                                <Border Background="#E5A26B" CornerRadius="999" Padding="8,2" IsVisible="{Binding IsLatest}">
                                                    <TextBlock Foreground="#1F1D1B" FontSize="11" FontWeight="SemiBold" Text="Latest" />
                                                </Border>
                                                <Border Background="#26201A" CornerRadius="999" Padding="8,2">
                                                    <TextBlock Foreground="#F7F0E7" FontSize="11" Text="{Binding KindLabel}" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Classes="caption" Text="{Binding TimestampLabel}" TextWrapping="Wrap" />
                                            <TextBlock Classes="caption"
                                                       FontFamily="Cascadia Code,Consolas,monospace"
                                                       Text="{Binding FileLabel}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <TextBlock Classes="body"
                                   Text="No backups yet. Create the first manual archive from this page."
                                   IsVisible="{Binding HasNoBackups}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1" Spacing="16">
                    <Border Classes="surface-dark" Padding="18">
                        <StackPanel Spacing="14">
                            <TextBlock Classes="kicker" Foreground="#E5A26B" Text="Restore Actions" />
                            <TextBlock FontSize="24"
                                       FontWeight="SemiBold"
                                       Foreground="#F7F0E7"
                                       Text="{Binding RecoveryModeHeadline}"
                                       TextWrapping="Wrap" />
                            <TextBlock Classes="body" Foreground="#D3C8BA" Text="{Binding RestoreRiskHeadline}" TextWrapping="Wrap" />
                            <TextBlock Classes="caption" Foreground="#CCBBA8" Text="{Binding RestoreModeSummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="caption" Foreground="#CCBBA8" Text="{Binding RecoveryGuidance}" TextWrapping="Wrap" />

                            <WrapPanel Orientation="Horizontal" ItemWidth="168" ItemHeight="36">
                                <Button Classes="action-primary" Command="{Binding CreateBackupCommand}" Content="Create Backup" IsEnabled="{Binding CanCreateBackup}" />
                                <Button Classes="action-danger" Command="{Binding RestoreSelectedCommand}" Content="Restore Selected" IsEnabled="{Binding CanRestore}" />
                                <Button Classes="action-secondary" Command="{Binding ReloadCommand}" Content="Reload" />
                            </WrapPanel>

                            <CheckBox Content="Restart server after restore"
                                      IsChecked="{Binding RestartAfterRestore}"
                                      IsEnabled="{Binding CanRestore}" />

                            <TextBlock Classes="caption" Foreground="#CCBBA8" Text="{Binding LoadStatus}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Classes="card" Padding="20">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="kicker" Text="Selected Recovery Point" />
                            <TextBlock Classes="panel-title" FontSize="24" Text="{Binding SelectedBackupHeadline}" TextWrapping="Wrap" />
                            <TextBlock Classes="body" Text="{Binding SelectedBackupKindSummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="caption" Text="{Binding RecoverySelectionSummary}" TextWrapping="Wrap" />
                            <TextBlock Classes="caption" Text="{Binding SelectedBackupDetails}" TextWrapping="Wrap" />
                            <TextBlock Classes="caption" Text="{Binding OperatorNextStep}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Classes="card" Padding="18">
                        <StackPanel Spacing="8">
                            <TextBlock Classes="kicker" Text="Recovery Checklist" />
                            <TextBlock Classes="body" Text="{Binding RecoveryOperatorSummary}" TextWrapping="Wrap" />
                            <ItemsControl ItemsSource="{Binding RecoveryChecklist}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F5E8DA" CornerRadius="12" Padding="10" Margin="0,0,0,8">
                                            <TextBlock Classes="caption" Text="{Binding .}" TextWrapping="Wrap" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
