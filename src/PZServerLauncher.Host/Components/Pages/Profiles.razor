@page "/profiles"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using PZServerLauncher.Core.Settings
@using PZServerLauncher.Host.Services
@inject ProfileStore ProfileStore
@inject RuntimeStateStore RuntimeStateStore
@inject StructuredSettingsService StructuredSettingsService

<PageTitle>Profiles</PageTitle>

<div class="home-shell">
    <section class="workspace-panel hero-panel">
        <div class="workspace-panel__copy">
            <p class="eyebrow">Workspace</p>
            <h1>Profiles</h1>
            <p class="muted-text">Profile selection is now a first-class workspace area. Every per-profile page is live, and you can jump directly into each server workspace from here.</p>
        </div>

        <div class="workspace-actions">
            <span class="pill">@(_rows.Count == 0 ? "No profiles loaded" : $"{_rows.Count} profiles")</span>
            <span class="pill">Overview</span>
            <span class="pill">Install &amp; Update</span>
            <span class="pill">Advanced Files</span>
        </div>
    </section>

    <section class="metric-grid metric-grid--host">
        <article class="metric-card">
            <span class="metric-label">Profiles</span>
            <strong class="metric-value">@(_rows.Count)</strong>
            <span class="metric-note">Known server workspaces</span>
        </article>
        <article class="metric-card">
            <span class="metric-label">Branches</span>
            <strong class="metric-value">@(_rows.Select(row => row.Profile.Branch).Distinct().Count())</strong>
            <span class="metric-note">Build 41 / Build 42 mix</span>
        </article>
        <article class="metric-card">
            <span class="metric-label">Running</span>
            <strong class="metric-value">@(_rows.Count(row => string.Equals(row.Runtime.State.ToString(), "Running", StringComparison.OrdinalIgnoreCase)))</strong>
            <span class="metric-note">Active server processes</span>
        </article>
        <article class="metric-card">
            <span class="metric-label">Public / Voice</span>
            <strong class="metric-value">@(_rows.Count(row => row.Posture.IsPubliclyListed)) / @(_rows.Count(row => row.Posture.IsVoiceEnabled))</strong>
            <span class="metric-note">Publicly listed and voice-enabled profiles</span>
        </article>
    </section>

    <section class="profiles card">
        <div class="card-heading">
            <div>
                <p class="eyebrow">Known Profiles</p>
                <h2>Server Index</h2>
            </div>
            <span class="pill">@(_rows.Count == 0 ? "Waiting for a profile" : "Workspace ready")</span>
        </div>

        @if (_rows.Count == 0)
        {
            <div class="empty-state">
                <p>No profiles have been created yet. Use the desktop app to create or import the first server profile.</p>
            </div>
        }
        else
        {
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Branch</th>
                        <th>Ports</th>
                        <th>Runtime</th>
                        <th>Posture</th>
                        <th>Workspace</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in _rows)
                    {
                        var profile = row.Profile;
                        var runtime = row.Runtime;
                        <tr>
                            <td>@profile.DisplayName</td>
                            <td>@profile.Branch</td>
                            <td>@profile.DefaultPort / @profile.UdpPort / @profile.RconPort</td>
                            <td>@runtime.State</td>
                            <td>
                                <div class="stack-list">
                                    <div>@row.Posture.CommunitySummary</div>
                                    <div>@row.Posture.NetworkSummary</div>
                                    <div>@row.Posture.WorldSummary</div>
                                </div>
                            </td>
                            <td>
                                <div class="actions-cell">
                                    <a class="nav-button secondary-button" href="@BuildProfileHref(profile.ProfileId, "overview")">Overview</a>
                                    <a class="nav-button secondary-button" href="@BuildProfileHref(profile.ProfileId, "install-update")">Install</a>
                                    <a class="nav-button secondary-button" href="@BuildProfileHref(profile.ProfileId, "general")">General</a>
                                    <a class="nav-button secondary-button" href="@BuildProfileHref(profile.ProfileId, "sandbox")">Sandbox</a>
                                    <a class="nav-button secondary-button" href="@BuildProfileHref(profile.ProfileId, "mods-maps")">Mods &amp; Maps</a>
                                    <a class="nav-button secondary-button" href="@BuildProfileHref(profile.ProfileId, "network-admin")">Network &amp; Admin</a>
                                    <a class="nav-button secondary-button" href="@BuildProfileHref(profile.ProfileId, "backups")">Backups</a>
                                    <a class="nav-button secondary-button" href="@BuildProfileHref(profile.ProfileId, "logs")">Logs</a>
                                    <a class="nav-button secondary-button" href="@BuildProfileHref(profile.ProfileId, "advanced-files")">Advanced Files</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <section class="card callout-card">
        <div class="card-heading">
            <div>
                <p class="eyebrow">Next Milestone</p>
                <h2>Fleet Posture</h2>
            </div>
        </div>
        <p>@(_rows.Count == 0 ? "Desktop and web now converge on the same workspace map. Add the first profile to start seeing real server posture here." : $"{_rows.Count(row => row.InstallDetected)}/{_rows.Count} installs detected, {_rows.Count(row => row.Posture.IsPvpEnabled)} PvP-enabled, {_rows.Count(row => row.Posture.IsSafetyEnabled)} safety-enabled, {_rows.Count(row => row.Posture.IsVoiceEnabled)} with voice chat.")</p>
    </section>
</div>

@code {
    private IReadOnlyList<ProfileIndexRow> _rows = [];

    protected override async Task OnInitializedAsync()
    {
        var profiles = await ProfileStore.ListAsync();
        _rows = profiles
            .Select(profile =>
            {
                var generalValues = StructuredSettingsService.GetPage(profile, "general").Values;
                var networkValues = StructuredSettingsService.GetPage(profile, "network-admin").Values;
                var sandboxValues = StructuredSettingsService.GetPage(profile, "sandbox").Values;

                return new ProfileIndexRow(
                    profile,
                    RuntimeStateStore.GetOrDefault(profile.ProfileId),
                    ProjectZomboidProfilePostureSummaryBuilder.Build(profile.DisplayName, generalValues, networkValues, sandboxValues),
                    Directory.Exists(profile.InstallDirectory) || Directory.Exists(Path.Combine(profile.InstallDirectory, "server")));
            })
            .ToList();
    }

    private static string BuildProfileHref(string profileId, string page) =>
        $"/profiles/{Uri.EscapeDataString(profileId)}/{page}";

    private sealed record ProfileIndexRow(
        PZServerLauncher.Core.Profiles.ServerProfile Profile,
        PZServerLauncher.Core.Runtime.ServerRuntimeStatus Runtime,
        ProjectZomboidProfilePostureSummary Posture,
        bool InstallDetected);
}
