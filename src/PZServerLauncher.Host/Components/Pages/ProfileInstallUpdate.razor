@page "/profiles/{ProfileId}/install-update"
@attribute [Authorize(Roles="Owner,Admin,Operator")]
@using PZServerLauncher.Core.Planning
@using PZServerLauncher.Infrastructure.Planning
@inject ProfileStore ProfileStore
@inject RuntimeStateStore RuntimeStateStore
@inject ServerInstallService InstallService
@inject ServerBackupService BackupService
@inject BackgroundJobDispatcher JobDispatcher
@inject JobStore JobStore

<PageTitle>Install &amp; Update</PageTitle>

@if (_profile is null)
{
    <div class="home-shell">
        <div class="card">
            <p class="eyebrow">Profile Workspace</p>
            <h1>Profile not found</h1>
            <p class="muted-text">The selected profile could not be loaded.</p>
            <a class="nav-button" href="/profiles">Back to profiles</a>
        </div>
    </div>
}
else
{
    <ProfileWorkspaceShell Profile="@_profile"
                           ActivePage="install-update"
                           RuntimeStatus="@_runtimeStatus"
                           InstallDetected="@_installDetected"
                           CacheDetected="@_cacheDetected">
        <Actions>
            <a class="nav-button secondary-button" href="@OverviewHref">Overview</a>
            <button class="nav-button" @onclick="InstallAsync" disabled="@_busy">Install</button>
            <button class="nav-button secondary-button" @onclick="UpdateAsync" disabled="@_busy">Update</button>
        </Actions>
        <ChildContent>
            <section class="workspace-panel hero-panel">
                <div class="workspace-panel__copy">
                    <p class="eyebrow">Install &amp; Update</p>
                    <h2>@_profile.DisplayName</h2>
                    <p class="muted-text">Install first, then update with confidence. This page surfaces the branch channel, launcher footprint, cache/config readiness, and runtime posture before you queue a new deployment cycle.</p>
                </div>

                <div class="workspace-actions">
                    <span class="pill">@_profile.Branch</span>
                    <span class="pill">@(_installDetected ? "Install detected" : "Install missing")</span>
                    <span class="pill">@(_cacheDetected ? "Cache ready" : "Cache missing")</span>
                    <span class="pill">@(_installPosture?.UsesDirectJavaTemplate == true ? "Direct Java ready" : "Batch fallback")</span>
                </div>
            </section>

            <section class="metric-grid">
                <article class="metric-card">
                    <span class="metric-label">Runtime</span>
                    <strong class="metric-value">@(_runtimeStatus?.State.ToString() ?? "Unknown")</strong>
                    <span class="metric-note">@(_runtimeStatus?.LatestLogLine ?? "No recent log line.")</span>
                </article>
                <article class="metric-card">
                    <span class="metric-label">Branch Channel</span>
                    <strong class="metric-value">@_profile.Branch</strong>
                    <span class="metric-note">@(_installPosture?.BranchChannelSummary ?? "No branch channel summary.")</span>
                </article>
                <article class="metric-card">
                    <span class="metric-label">Launch</span>
                    <strong class="metric-value">@(_installPosture?.UsesDirectJavaTemplate == true ? "Direct Java" : "Fallback")</strong>
                    <span class="metric-note">@(_installPosture?.LaunchReadinessSummary ?? "No launch summary.")</span>
                </article>
                <article class="metric-card">
                    <span class="metric-label">Queued Jobs</span>
                    <strong class="metric-value">@(_jobs.Count == 0 ? "0" : _jobs.Count.ToString())</strong>
                    <span class="metric-note">Recent install and update activity</span>
                </article>
            </section>

            <div class="cards cards--wide">
                <section class="card">
                    <div class="card-heading">
                        <div>
                            <p class="eyebrow">Install State</p>
                            <h2>Directories And Branch</h2>
                        </div>
                        <span class="pill">@(_installPosture?.InstallDetected == true ? "Detected" : "Pending")</span>
                    </div>

                    <div class="info-grid">
                        <div class="info-item">
                            <span class="info-label">Install directory</span>
                            <span class="info-value">@_profile.InstallDirectory</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Cache directory</span>
                            <span class="info-value">@_profile.CacheDirectory</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Branch</span>
                            <span class="info-value">@_profile.Branch</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Auto restart</span>
                            <span class="info-value">@(_profile.AutoRestartOnCrash ? "On" : "Off")</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Launcher path</span>
                            <span class="info-value">@(_installPosture?.ExpectedLauncherPath ?? "Unavailable")</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">SteamCMD</span>
                            <span class="info-value">@(_installPosture?.SteamCmdCommandSummary ?? "Unavailable")</span>
                        </div>
                    </div>
                </section>

                <section class="card">
                    <div class="card-heading">
                        <div>
                            <p class="eyebrow">Preflight</p>
                            <h2>Update Flow</h2>
                        </div>
                    </div>

                    <div class="status-banner">
                        <strong>Before you update</strong>
                        <p>@(_installPosture?.BackupSafetySummary ?? "Backup safety summary unavailable.")</p>
                        <p>@(_installPosture?.PreflightSummary ?? "Preflight summary unavailable.")</p>
                    </div>

                    <ul class="check-list">
                        <li>Install directory exists: <strong>@(_installPosture?.InstallDetected == true ? "Yes" : "No")</strong></li>
                        <li>Cache directory exists: <strong>@(_installPosture?.CacheDetected == true ? "Yes" : "No")</strong></li>
                        <li>Launcher script exists: <strong>@(_installPosture?.LauncherDetected == true ? "Yes" : "No")</strong></li>
                        <li>Config directory exists: <strong>@(_installPosture?.ConfigDirectoryDetected == true ? "Yes" : "No")</strong></li>
                        <li>INI and sandbox files exist: <strong>@(_installPosture?.IniDetected == true && _installPosture?.SandboxDetected == true ? "Yes" : "No")</strong></li>
                        <li>World save exists: <strong>@(_installPosture?.WorldDetected == true ? "Yes" : "No")</strong></li>
                        <li>Runtime state: <strong>@(_runtimeStatus?.State.ToString() ?? "Unknown")</strong></li>
                    </ul>
                </section>
            </div>

            <div class="cards cards--wide">
                <section class="card">
                    <div class="card-heading">
                        <div>
                            <p class="eyebrow">SteamCMD</p>
                            <h2>Install Script Preview</h2>
                        </div>
                    </div>

                    <p class="muted-text">This is the exact SteamCMD script shape the launcher will hand to the host for install or update work.</p>
                    <pre class="raw-editor">@(_installPosture?.SteamCmdScriptPreview ?? "No SteamCMD script preview available.")</pre>
                </section>

                <section class="card">
                    <div class="card-heading">
                        <div>
                            <p class="eyebrow">Launch</p>
                            <h2>Effective Command Preview</h2>
                        </div>
                    </div>

                    <p class="muted-text">This preview reflects whether the host can launch via direct Java template extraction or has to fall back to the vendor batch file.</p>
                    <pre class="raw-editor">@(_installPosture?.LaunchCommandPreview ?? "No launch command preview available.")</pre>
                </section>
            </div>

            <div class="cards cards--wide">
                <section class="card">
                    <div class="card-heading">
                        <div>
                            <p class="eyebrow">Queue</p>
                            <h2>Recent Jobs</h2>
                        </div>
                        <span class="pill">@(_jobs.Count == 0 ? "Empty" : "Active history")</span>
                    </div>

                    @if (_jobs.Count == 0)
                    {
                        <div class="empty-state">
                            <p class="muted-text">No recent install/update jobs. Queue an install or update to populate this history.</p>
                        </div>
                    }
                    else
                    {
                        <ul class="job-list">
                            @foreach (var job in _jobs.Take(5))
                            {
                                <li class="job-list__item">
                                    <div class="job-list__title">
                                        <strong>@job.Kind</strong>
                                        <span>@job.Status</span>
                                    </div>
                                    <div class="muted-text">@job.Detail ?? job.Summary</div>
                                </li>
                            }
                        </ul>
                    }
                </section>

                <section class="card">
                    <div class="card-heading">
                        <div>
                            <p class="eyebrow">Operator Flow</p>
                            <h2>Actions</h2>
                        </div>
                    </div>

                    <p class="muted-text">@(_installPosture?.RuntimePolicySummary ?? "Runtime policy summary unavailable.")</p>

                    <div class="workspace-actions">
                        <button class="nav-button" @onclick="InstallAsync" disabled="@_busy">Install</button>
                        <button class="nav-button secondary-button" @onclick="UpdateAsync" disabled="@_busy">Update</button>
                        <a class="nav-button secondary-button" href="@OverviewHref">Overview</a>
                    </div>
                </section>
            </div>

            <p class="status-line">@_statusMessage</p>
        </ChildContent>
    </ProfileWorkspaceShell>
}

@code {
    [Parameter]
    public string ProfileId { get; set; } = string.Empty;

    private ServerProfile? _profile;
    private ServerRuntimeStatus? _runtimeStatus;
    private IReadOnlyList<OperationJob> _jobs = [];
    private ProjectZomboidInstallPostureSummary? _installPosture;
    private bool _busy;
    private string? _statusMessage;
    private bool _installDetected;
    private bool _cacheDetected;

    protected override async Task OnParametersSetAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _profile = await ProfileStore.GetAsync(ProfileId);
        if (_profile is null)
        {
            return;
        }

        _runtimeStatus = RuntimeStateStore.GetOrDefault(ProfileId);
        _jobs = (await JobStore.ListRecentAsync(20)).Where(job => string.Equals(job.ProfileId, ProfileId, StringComparison.OrdinalIgnoreCase) && (job.Kind is Core.Runtime.OperationJobKind.Install or Core.Runtime.OperationJobKind.Update)).ToList();
        var backups = BackupService.ListBackups(ProfileId);
        _installPosture = ProjectZomboidInstallPostureSummaryBuilder.Build(
            _profile,
            _runtimeStatus?.State.ToString() ?? "Unknown",
            backups.Count > 0,
            backups.FirstOrDefault() ?? "No backups");
        _installDetected = _installPosture.InstallDetected;
        _cacheDetected = _installPosture.CacheDetected;
    }

    private async Task InstallAsync() => await QueueInstallAsync(Core.Runtime.OperationJobKind.Install, "Install");

    private async Task UpdateAsync() => await QueueUpdateAsync();

    private async Task QueueInstallAsync(Core.Runtime.OperationJobKind kind, string actionName)
    {
        if (_profile is null)
        {
            return;
        }

        _busy = true;
        try
        {
            var job = await JobDispatcher.QueueAsync(
                kind,
                _profile.ProfileId,
                $"{actionName} {_profile.DisplayName}",
                async (services, runningJob, token) =>
                {
                    var installer = services.GetRequiredService<ServerInstallService>();
                    var jobStore = services.GetRequiredService<JobStore>();
                    var runtimeStateStore = services.GetRequiredService<RuntimeStateStore>();
                    await installer.ExecuteInstallAsync(_profile.ProfileId, runningJob, jobStore, runtimeStateStore, token);
                });

            _statusMessage = $"{actionName} queued. Job {job.JobId:N}.";
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _statusMessage = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task QueueUpdateAsync()
    {
        if (_profile is null)
        {
            return;
        }

        _busy = true;
        try
        {
            var job = await JobDispatcher.QueueAsync(
                Core.Runtime.OperationJobKind.Update,
                _profile.ProfileId,
                $"Update {_profile.DisplayName}",
                async (services, runningJob, token) =>
                {
                    var installer = services.GetRequiredService<ServerInstallService>();
                    var jobStore = services.GetRequiredService<JobStore>();
                    var runtimeStateStore = services.GetRequiredService<RuntimeStateStore>();
                    var backupService = services.GetRequiredService<ServerBackupService>();
                    await backupService.CreateBackupAsync(_profile.ProfileId, BackupTrigger.PreUpdate, token);
                    await installer.ExecuteInstallAsync(_profile.ProfileId, runningJob, jobStore, runtimeStateStore, token);
                });

            _statusMessage = $"Update queued. Job {job.JobId:N}.";
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _statusMessage = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private string OverviewHref => $"/profiles/{Uri.EscapeDataString(ProfileId)}/overview";
}
