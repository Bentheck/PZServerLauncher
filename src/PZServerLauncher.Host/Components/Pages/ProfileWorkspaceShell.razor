@using Microsoft.AspNetCore.Components.Authorization

<div class="profile-shell">
    <div class="profile-hero card">
        <div class="profile-hero__title">
            <p class="eyebrow">Profile Workspace</p>
            <h1>@Profile?.DisplayName</h1>
            <p class="muted-text">@ProfileSummary</p>
        </div>

        <div class="profile-hero__stats">
            <div>
                <span class="stat-label">Branch</span>
                <strong>@(Profile?.Branch.ToString() ?? "Unknown")</strong>
            </div>
            <div>
                <span class="stat-label">Runtime</span>
                <strong>@RuntimeStateText</strong>
            </div>
            <div>
                <span class="stat-label">Install</span>
                <strong>@InstallStateText</strong>
            </div>
            <div>
                <span class="stat-label">Cache</span>
                <strong>@CacheStateText</strong>
            </div>
        </div>
    </div>

    <div class="profile-workspace-grid">
        <aside class="profile-nav card">
            <p class="eyebrow">Sections</p>
            <NavLink class="profile-nav__link" href="@OverviewHref" Match="NavLinkMatch.All">Overview</NavLink>
            <NavLink class="profile-nav__link" href="@InstallHref">Install &amp; Update</NavLink>
            <NavLink class="profile-nav__link" href="@GeneralHref">General</NavLink>
            <NavLink class="profile-nav__link" href="@SandboxHref">Sandbox</NavLink>
            <NavLink class="profile-nav__link" href="@AdvancedFilesHref">Advanced Files</NavLink>

            <div class="profile-nav__coming-soon">Backups and Logs will return in the next milestone.</div>

            @if (Actions is not null)
            {
                <div class="profile-nav__actions">
                    @Actions
                </div>
            }
        </aside>

        <section class="profile-content">
            @ChildContent
        </section>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public ServerProfile? Profile { get; set; }

    [Parameter, EditorRequired]
    public string ActivePage { get; set; } = string.Empty;

    [Parameter]
    public ServerRuntimeStatus? RuntimeStatus { get; set; }

    [Parameter]
    public bool InstallDetected { get; set; }

    [Parameter]
    public bool CacheDetected { get; set; }

    [Parameter]
    public RenderFragment? Actions { get; set; }

    [Parameter, EditorRequired]
    public RenderFragment ChildContent { get; set; } = default!;

    private string ProfileSummary => Profile is null
        ? "Loading profile..."
        : $"{Profile.ServerName} | {Profile.InstallDirectory}";

    private string RuntimeStateText => RuntimeStatus?.State.ToString() ?? "Unknown";

    private string InstallStateText => InstallDetected ? "Detected" : "Missing";

    private string CacheStateText => CacheDetected ? "Detected" : "Missing";

    private string OverviewHref => BuildHref("overview");

    private string InstallHref => BuildHref("install-update");

    private string GeneralHref => BuildHref("general");

    private string SandboxHref => BuildHref("sandbox");

    private string AdvancedFilesHref => BuildHref("advanced-files");

    private string BuildHref(string page) =>
        Profile is null ? "#" : $"/profiles/{Uri.EscapeDataString(Profile.ProfileId)}/{page}";
}
