    private void LoadPreset(PZServerLauncher.Core.Profiles.WorkshopPreset preset)
    {
        _suppressChangeTracking = true;
        try
        {
            WorkshopItemIdsText = string.Join(Environment.NewLine, preset.WorkshopItemIds);
            EnabledModIdsText = string.Join(Environment.NewLine, preset.EnabledModIds);
            MapFoldersText = string.Join(Environment.NewLine, preset.MapFolders);
        }
        finally
        {
            _suppressChangeTracking = false;
        }

        _presetHash = BuildPresetHash(BuildPresetForNamedPreset());
        _hasChanges = false;
        RefreshWorkshopBrowserState();
    }

    private PZServerLauncher.Core.Profiles.WorkshopPreset BuildPresetForSave() =>
        new()
        {
            WorkshopItemIds = ParseLines(WorkshopItemIdsText),
            EnabledModIds = ParseLines(EnabledModIdsText),
            MapFolders = ParseLines(MapFoldersText),
        };

    private PZServerLauncher.Core.Profiles.WorkshopPreset BuildPresetForNamedPreset() =>
        new()
        {
            WorkshopItemIds = [],
            EnabledModIds = ParseLines(EnabledModIdsText),
            MapFolders = ParseLines(MapFoldersText),
        };

    private PZServerLauncher.Core.Profiles.WorkshopPreset BuildPresetForWorkshopOperations() =>
        new()
        {
            WorkshopItemIds = ParseLines(WorkshopItemIdsText),
            EnabledModIds = ParseLines(EnabledModIdsText),
            MapFolders = ParseLines(MapFoldersText),
        };

    private static IReadOnlyList<string> ParseLines(string text)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            return [];
        }

        return text
            .ReplaceLineEndings("\n")
            .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .SelectMany(line => line.Split(';', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries))
            .Select(value => value.Trim())
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private static string BuildPresetHash(PZServerLauncher.Core.Profiles.WorkshopPreset preset)
    {
        var source = string.Join("|",
            string.Join(",", preset.EnabledModIds),
            string.Join(",", preset.MapFolders));
        return Convert.ToHexString(System.Security.Cryptography.SHA256.HashData(System.Text.Encoding.UTF8.GetBytes(source)));
    }

    private static string BuildPresetCompositionSummary(PZServerLauncher.Core.Profiles.WorkshopPreset preset) =>
        $"{preset.EnabledModIds.Count} mods | {preset.MapFolders.Count} maps";

