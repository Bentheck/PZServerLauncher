    private async Task LoadDraftIfAvailableAsync()
    {
        if (_profile is null || _catalog is null || _page is null || !_pageSupportsDrafts || _requiresAdvancedFilesFallback)
        {
            return;
        }

        var draft = await SettingsDraftStore.GetAsync(
            _profile.ProfileId,
            _profile.Branch,
            _catalog.CatalogId,
            _catalog.CatalogVersion,
            _page.PageId);
        if (draft is null)
        {
            return;
        }

        ApplyDraftValues(draft.Values);
        _statusMessage = $"Loaded saved Mods & Maps draft from {draft.UpdatedAtUtc.ToLocalTime():g}.";
    }

    private Dictionary<string, string?> BuildDraftValues()
    {
        const string branchPrefix = "b42";
        return new Dictionary<string, string?>(StringComparer.Ordinal)
        {
            [$"{branchPrefix}.mods.enabled-mods"] = EnabledModIdsText,
            [$"{branchPrefix}.mods.map-folders"] = MapFoldersText,
        };
    }

    private void ApplyDraftValues(IReadOnlyDictionary<string, string?> draftValues)
    {
        _suppressChangeTracking = true;
        try
        {
            EnabledModIdsText = ResolveDraftValue(draftValues, ".mods.enabled-mods");
            MapFoldersText = ResolveDraftValue(draftValues, ".mods.map-folders");
        }
        finally
        {
            _suppressChangeTracking = false;
        }

        _presetHash = BuildPresetHash(BuildPresetForNamedPreset());
        _hasChanges = true;
        RefreshWorkshopBrowserState();
    }

    private static string ResolveDraftValue(IReadOnlyDictionary<string, string?> draftValues, string suffix)
    {
        var key = draftValues.Keys.FirstOrDefault(candidate => candidate.EndsWith(suffix, StringComparison.Ordinal));
        if (key is null || !draftValues.TryGetValue(key, out var value))
        {
            return string.Empty;
        }

        return value ?? string.Empty;
    }

    private void RefreshWorkshopBrowserState()
    {
        var preset = BuildPresetForWorkshopOperations();

        if (_workshopSearchResult is not null)
        {
            _workshopSearchResult = _workshopSearchResult with
            {
                Results = _workshopSearchResult.Results
                    .Select(item => item with
                    {
                        IsQueued = IsWorkshopCatalogItemQueued(preset, item),
                    })
                    .ToArray(),
            };
        }

        if (_selectedWorkshopPreview is not null)
        {
            _selectedWorkshopPreview = RebuildPreviewForPreset(_selectedWorkshopPreview, preset);
        }
    }

    private static WorkshopCatalogPreviewDto RebuildPreviewForPreset(WorkshopCatalogPreviewDto preview, WorkshopPreset preset)
    {
        var item = preview.Item;
        var collectionChildWorkshopIds = item.CollectionChildWorkshopIds?
            .Where(id => !string.IsNullOrWhiteSpace(id))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray()
            ?? [];
        var workshopItemsToAdd = item.Kind is WorkshopCatalogItemKind.Collection
            ? collectionChildWorkshopIds
                .Where(id => !preset.WorkshopItemIds.Any(value => string.Equals(value, id, StringComparison.OrdinalIgnoreCase)))
                .ToArray()
            : preset.WorkshopItemIds.Any(value => string.Equals(value, item.WorkshopId, StringComparison.OrdinalIgnoreCase))
                ? Array.Empty<string>()
                : [item.WorkshopId];
        var modIdsToAdd = item.ModIds
            .Where(value => !preset.EnabledModIds.Any(existing => string.Equals(existing, value, StringComparison.OrdinalIgnoreCase)))
            .ToArray();
        var mapFoldersToAdd = item.MapFolders
            .Where(value => !preset.MapFolders.Any(existing => string.Equals(existing, value, StringComparison.OrdinalIgnoreCase)))
            .ToArray();
        var collectionChildren = item.CollectionChildWorkshopIds is { Count: > 0 } && preview.CollectionChildren is { Count: > 0 }
            ? preview.CollectionChildren
                .Select(child => child with
                {
                    IsQueued = preset.WorkshopItemIds.Any(value => string.Equals(value, child.WorkshopId, StringComparison.OrdinalIgnoreCase)),
                })
                .ToArray()
            : preview.CollectionChildren;

        var dependencyChildren = preview.DependencyChildren is { Count: > 0 }
            ? preview.DependencyChildren
                .Select(child => child with
                {
                    IsQueued = preset.WorkshopItemIds.Any(value => string.Equals(value, child.WorkshopId, StringComparison.OrdinalIgnoreCase)),
                })
                .ToArray()
            : preview.DependencyChildren;
        var dependencyWorkshopItemsToAdd = (preview.DependencyWorkshopItemIdsToAdd ?? [])
            .Where(value => !preset.WorkshopItemIds.Any(existing => string.Equals(existing, value, StringComparison.OrdinalIgnoreCase)))
            .ToArray();
        var dependencyModIdsToAdd = (preview.DependencyModIdsToAdd ?? [])
            .Where(value => !preset.EnabledModIds.Any(existing => string.Equals(existing, value, StringComparison.OrdinalIgnoreCase)))
            .ToArray();
        var dependencyMapFoldersToAdd = (preview.DependencyMapFoldersToAdd ?? [])
            .Where(value => !preset.MapFolders.Any(existing => string.Equals(existing, value, StringComparison.OrdinalIgnoreCase)))
            .ToArray();

        return new WorkshopCatalogPreviewDto(
            item,
            workshopItemsToAdd,
            modIdsToAdd,
            mapFoldersToAdd,
            CollectionChildren: collectionChildren,
            DependencyChildren: dependencyChildren,
            DependencyWorkshopItemIdsToAdd: dependencyWorkshopItemsToAdd,
            DependencyModIdsToAdd: dependencyModIdsToAdd,
            DependencyMapFoldersToAdd: dependencyMapFoldersToAdd,
            ModNamesById: preview.ModNamesById);
    }

    private static bool IsWorkshopCatalogItemQueued(WorkshopPreset preset, WorkshopCatalogItemDto item) =>
        item.Kind is WorkshopCatalogItemKind.Collection
            ? item.CollectionChildWorkshopIds is { Count: > 0 } children &&
              children.All(id => preset.WorkshopItemIds.Any(value => string.Equals(value, id, StringComparison.OrdinalIgnoreCase)))
            : WorkshopPresetMergeHelper.IsQueued(preset, item.WorkshopId, item.ModIds, item.MapFolders);

    private static string FormatList(IReadOnlyList<string> values) =>
        values.Count == 0 ? "None" : string.Join(", ", values);

    private static string Truncate(string value, int maxLength) =>
        string.IsNullOrWhiteSpace(value) || value.Length <= maxLength
            ? value
            : $"{value[..maxLength].TrimEnd()}...";
