@page "/profiles/{ProfileId}/mods-maps"
@attribute [Authorize(Roles="Owner,Admin")]
@using PZServerLauncher.Contracts.Profiles
@using PZServerLauncher.Core.Profiles
@inject ProfileStore ProfileStore
@inject StructuredSettingsService StructuredSettingsService
@inject SettingsDraftStore SettingsDraftStore
@inject WorkshopPresetScannerService WorkshopPresetScannerService
@inject NamedWorkshopPresetStore NamedWorkshopPresetStore
@inject RuntimeStateStore RuntimeStateStore
@inject WorkshopCatalogService WorkshopCatalogService
@inject WorkshopBrowserSettingsStore WorkshopBrowserSettingsStore

<PageTitle>Mods &amp; Maps</PageTitle>

@if (_profile is null)
{
    <div class="home-shell">
        <div class="card">
            <p class="eyebrow">Profile Workspace</p>
            <h1>Profile not found</h1>
            <p class="muted-text">The selected profile could not be loaded.</p>
            <a class="nav-button" href="/profiles">Back to profiles</a>
        </div>
    </div>
}
else
{
    <ProfileWorkspaceShell Profile="@_profile"
                           ActivePage="mods-maps"
                           RuntimeStatus="@_runtimeStatus"
                           InstallDetected="@_installDetected"
                           CacheDetected="@_cacheDetected">
        <Actions>
            <a class="nav-button secondary-button" href="@OverviewHref">Overview</a>
            <a class="nav-button secondary-button" href="@SandboxHref">Sandbox</a>
            <a class="nav-button secondary-button" href="@AdvancedFilesHref">Advanced Files</a>
            <button class="nav-button" @onclick="ScanAsync" disabled="@_busy">Scan Workshop</button>
            <button class="nav-button secondary-button" @onclick="SaveDraftAsync" disabled="@(_busy || _requiresAdvancedFilesFallback || !_pageSupportsDrafts)">Save Draft</button>
            <button class="nav-button secondary-button" @onclick="DiscardDraftAsync" disabled="@(_busy || _requiresAdvancedFilesFallback || !_pageSupportsDrafts)">Discard Draft</button>
            <button class="nav-button secondary-button" @onclick="SaveAsync" disabled="@(_busy || _requiresAdvancedFilesFallback)">Save Live Preset</button>
            <button class="nav-button secondary-button" @onclick="ApplyScanResultAsync" disabled="@(_busy || _scanResult is null || _requiresAdvancedFilesFallback)">Apply Scan Result</button>
        </Actions>
        <ChildContent>
            <section class="workspace-panel hero-panel">
                <div class="workspace-panel__copy">
                    <p class="eyebrow">Mods &amp; Maps</p>
                    <h1>@_profile.DisplayName</h1>
                    <p class="muted-text">This is the operator console for workshop loadouts, mod order, and map order. Scan Workshop normalizes the lists against what is actually installed, then Save Live Preset writes the live Project Zomboid keys back out.</p>
                    <p class="muted-text">Named loadouts are for recovery and reuse. If the file is forced into raw fallback, open Advanced Files rather than pushing structured edits through an unsupported config.</p>
                </div>

                <div class="workspace-actions">
                    <span class="pill">@_profile.Branch</span>
                    <span class="pill">@(_installDetected ? "Install detected" : "Install missing")</span>
                    <span class="pill">@(_cacheDetected ? "Cache ready" : "Cache missing")</span>
                    <span class="pill">@(_namedPresets.Count == 0 ? "No saved loadouts" : $"{_namedPresets.Count} saved loadouts")</span>
                    <span class="pill">@(_scanResult is null ? "Scan idle" : "Scan normalized")</span>
                    <span class="pill">@(_hasChanges ? "Unsaved changes" : "In sync")</span>
                </div>
            </section>

            <section class="metric-grid metric-grid--host">
                <article class="metric-card">
                    <span class="metric-label">Workshop Items</span>
                    <strong class="metric-value">@_profile.WorkshopPreset.WorkshopItemIds.Count</strong>
                    <span class="metric-note">Ordered workshop IDs</span>
                </article>
                <article class="metric-card">
                    <span class="metric-label">Enabled Mods</span>
                    <strong class="metric-value">@_profile.WorkshopPreset.EnabledModIds.Count</strong>
                    <span class="metric-note">Enabled mod IDs in load order</span>
                </article>
                <article class="metric-card">
                    <span class="metric-label">Map Folders</span>
                    <strong class="metric-value">@_profile.WorkshopPreset.MapFolders.Count</strong>
                    <span class="metric-note">Map load order</span>
                </article>
                <article class="metric-card">
                    <span class="metric-label">Saved Loadouts</span>
                    <strong class="metric-value">@_namedPresets.Count</strong>
                    <span class="metric-note">@(_namedPresets.Count == 0 ? "No reusable loadouts yet." : "Reusable recovery points and loadouts.")</span>
                </article>
            </section>

            <div class="cards cards--wide">
                <section class="card">
                    <div class="card-heading">
                        <div>
                            <p class="eyebrow">Workshop Browser</p>
                            <h2>Search Mods Visually</h2>
                        </div>
                        <span class="pill">@BrowserStateSummary</span>
                    </div>

                    <p class="muted-text">Search the local Workshop cache by mod or collection name, or use Steam search when a Steam Web API user key is configured. Manual Workshop IDs still work even without a key.</p>

                    @if (_workshopBrowserSettings.HasSteamWebApiKeyConfigured)
                    {
                        <div class="status-banner status-banner--warm">
                            <strong>Steam API Key</strong>
                            <p>The Steam Web API user key is stored on the host. Remove it anytime to return to local cache and manual Workshop ID mode.</p>
                            <div class="file-toolbar">
                                <button class="nav-button secondary-button" @onclick="RemoveSteamWebApiKeyAsync" disabled="@_busy">Remove API Key</button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="settings-banner settings-banner--warning">
                            <strong>Steam API Key</strong>
                            <p>Save a Steam Web API user key here to enable Steam Workshop search. Local cache search and manual Workshop ID lookup stay available even without it.</p>
                            <div class="file-toolbar">
                                <input type="password" @bind="_steamWebApiKey" @bind:event="oninput" placeholder="Paste Steam Web API user key" />
                                <button class="nav-button secondary-button" @onclick="SaveSteamWebApiKeyAsync" disabled="@_busy">Save API Key</button>
                            </div>
                        </div>
                    }

                    <div class="file-toolbar">
                        <input @bind="_searchQuery" placeholder="Search by mod or collection name, or paste a Workshop ID / URL" />
                        <button class="nav-button secondary-button" @onclick="@(() => _searchFilter = WorkshopCatalogSearchFilter.All)" disabled="@(_busy || _searchFilter == WorkshopCatalogSearchFilter.All)">All</button>
                        <button class="nav-button secondary-button" @onclick="@(() => _searchFilter = WorkshopCatalogSearchFilter.Mods)" disabled="@(_busy || _searchFilter == WorkshopCatalogSearchFilter.Mods)">Mods</button>
                        <button class="nav-button secondary-button" @onclick="@(() => _searchFilter = WorkshopCatalogSearchFilter.Collections)" disabled="@(_busy || _searchFilter == WorkshopCatalogSearchFilter.Collections)">Collections</button>
                        <button class="nav-button secondary-button" @onclick="@(() => _searchMode = WorkshopCatalogSearchMode.Local)" disabled="@(_busy || _searchMode == WorkshopCatalogSearchMode.Local)">Local</button>
                        <button class="nav-button secondary-button" @onclick="@(() => _searchMode = WorkshopCatalogSearchMode.Steam)" disabled="@(_busy || _searchMode == WorkshopCatalogSearchMode.Steam)">Steam</button>
                        <button class="nav-button secondary-button" @onclick="@(() => _searchMode = WorkshopCatalogSearchMode.Both)" disabled="@(_busy || _searchMode == WorkshopCatalogSearchMode.Both)">Both</button>
                        <button class="nav-button" @onclick="SearchWorkshopCatalogAsync" disabled="@_busy">Search</button>
                    </div>

                    @if (!_workshopBrowserSettings.HasSteamWebApiKeyConfigured && _searchMode is WorkshopCatalogSearchMode.Steam or WorkshopCatalogSearchMode.Both)
                    {
                        <div class="settings-banner settings-banner--warning">
                            <strong>Steam search needs a Steam Web API user key.</strong>
                            <p>Without a key you can still search the local Workshop cache or paste a Workshop ID manually. To enable Steam search, get a key from <a href="https://steamcommunity.com/dev/apikey" target="_blank" rel="noreferrer">the Steam Web API key page</a>.</p>
                            <p>1. Sign in with the Steam account that will own the key.</p>
                            <p>2. Open the Steam Web API key page.</p>
                            <p>3. Register a key for a domain name.</p>
                            <p>4. Copy the generated key into the launcher.</p>
                        </div>
                    }
                    @if (_workshopSearchResult is null)
                    {
                        <div class="empty-state">
                            <p class="muted-text">Search the Workshop to browse mods with their image and description before adding them to the current queue.</p>
                        </div>
                    }
                    else
                    {
                        @if (_workshopSearchResult.Diagnostics.Count > 0)
                        {
                            <div class="status-banner status-banner--warm">
                                <strong>Search diagnostics</strong>
                                @foreach (var diagnostic in _workshopSearchResult.Diagnostics)
                                {
                                    <p>@diagnostic</p>
                                }
                            </div>
                        }

                        @if (_workshopSearchResult.Results.Count == 0)
                        {
                            <div class="empty-state">
                                <p class="muted-text">No Workshop results matched this search yet.</p>
                            </div>
                        }
                        else
                        {
                            <ul class="job-list">
                                @foreach (var item in _workshopSearchResult.Results)
                                {
                                    <li class="job-list__item">
                                        <div class="workspace-actions" style="align-items:flex-start;">
                                            @if (!string.IsNullOrWhiteSpace(item.PreviewImageUrl))
                                            {
                                                <img src="@item.PreviewImageUrl"
                                                     alt="@item.Title"
                                                     style="width:120px;height:68px;object-fit:cover;border-radius:12px;border:1px solid rgba(0,0,0,.08);" />
                                            }
                                            <div style="flex:1;min-width:0;">
                                                <div class="job-list__title">
                                                    <strong style="color:#1f1a14;">@item.Title</strong>
                                                    <span style="color:#6b5a4c;">@item.WorkshopId</span>
                                                </div>
                                                <div class="workspace-actions">
                                                    @if (item.Kind is WorkshopCatalogItemKind.Collection)
                                                    {
                                                        <span class="pill pill--strong">Collection</span>
                                                        <span class="pill">@item.CollectionItemCount child item(s)</span>
                                                    }
                                                    <span class="pill">@item.Source</span>
                                                    <span class="pill">@(item.IsInstalledLocally ? "Installed locally" : "Not installed")</span>
                                                    <span class="pill">@(item.IsQueued ? "Queued" : "Not queued")</span>
                                                </div>
                                                <p class="muted-text">@Truncate(item.Description, 220)</p>
                                                <div class="workspace-actions">
                                                    <button class="nav-button secondary-button" @onclick="() => OpenWorkshopPreviewAsync(item.WorkshopId)" disabled="@_busy">
                                                        @(item.Kind is WorkshopCatalogItemKind.Collection ? "Preview Collection" : "Preview")
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                    }
                </section>
            </div>

            @if (_isWorkshopPreviewModalOpen && _selectedWorkshopPreview is not null)
            {
                <div class="workspace-modal" @onclick="CloseWorkshopPreviewModal">
                    <div class="workspace-modal__card" @onclick:stopPropagation="true">
                        <div class="workspace-modal__header">
                            <div>
                                <p class="eyebrow">Workshop Preview</p>
                                <h2>@_selectedWorkshopPreview.Item.Title</h2>
                                <p class="muted-text">Workshop ID: @_selectedWorkshopPreview.Item.WorkshopId</p>
                            </div>
                            <button class="nav-button secondary-button" @onclick="CloseWorkshopPreviewModal">Close</button>
                        </div>

                        <div class="workspace-modal__body">
                            @if (!string.IsNullOrWhiteSpace(_selectedWorkshopPreview.Item.PreviewImageUrl))
                            {
                                <img class="workspace-media-preview"
                                     src="@_selectedWorkshopPreview.Item.PreviewImageUrl"
                                     alt="@_selectedWorkshopPreview.Item.Title" />
                            }

                            <div class="workspace-actions">
                                <span class="pill">@(_selectedWorkshopPreview.Item.Kind is WorkshopCatalogItemKind.Collection ? "Collection" : "Item")</span>
                                <span class="pill">@_selectedWorkshopPreview.Item.Source</span>
                                <span class="pill">@(_selectedWorkshopPreview.Item.IsInstalledLocally ? "Installed locally" : "Not installed")</span>
                                <span class="pill">@(_selectedWorkshopPreview.Item.IsQueued ? "Queued" : "Not queued")</span>
                                @if (_selectedWorkshopPreview.Item.Kind is WorkshopCatalogItemKind.Collection)
                                {
                                    <span class="pill">@_selectedWorkshopPreview.Item.CollectionItemCount child item(s)</span>
                                }
                            </div>

                            <p class="muted-text">@_selectedWorkshopPreview.Item.Description</p>

                            <div class="info-grid info-grid--compact">
                                <div class="info-item">
                                    <span class="info-label">Workshop IDs to add</span>
                                    <span class="info-value">@FormatList(_selectedWorkshopPreview.WorkshopItemIdsToAdd)</span>
                                </div>
                                <div class="info-item">
                                    <span class="info-label">Mod IDs to add</span>
                                    <span class="info-value">@FormatList(_selectedWorkshopPreview.ModIdsToAdd)</span>
                                </div>
                                <div class="info-item">
                                    <span class="info-label">Map folders to add</span>
                                    <span class="info-value">@FormatList(_selectedWorkshopPreview.MapFoldersToAdd)</span>
                                </div>
                                <div class="info-item">
                                    <span class="info-label">Collection size</span>
                                    <span class="info-value">@_selectedWorkshopPreview.Item.CollectionItemCount</span>
                                </div>
                            </div>

                            @if (_selectedWorkshopPreview.CollectionChildren is { Count: > 0 })
                            {
                                <div class="workspace-modal__section">
                                    <strong>Collection contents</strong>
                                    @foreach (var child in _selectedWorkshopPreview.CollectionChildren)
                                    {
                                        <p>@child.Title (@child.WorkshopId) | @(child.IsInstalledLocally ? "Installed" : "Not installed") | @(child.IsQueued ? "Queued" : "Not queued")</p>
                                    }
                                </div>
                            }
                        </div>

                        <div class="workspace-modal__actions">
                            <button class="nav-button secondary-button" @onclick="CloseWorkshopPreviewModal">Close</button>
                            <button class="nav-button" @onclick="ApplyWorkshopPreviewAsync" disabled="@(_busy || !PreviewHasChanges)">
                                @(_selectedWorkshopPreview.Item.Kind is WorkshopCatalogItemKind.Collection ? "Add Collection To Editor" : "Add To Editor")
                            </button>
                        </div>
                    </div>
                </div>
            }

            <div class="cards cards--wide">
                <section class="card">
                    <div class="card-heading">
                        <div>
                            <p class="eyebrow">Mods &amp; Maps</p>
                            <h2>Preset Editor</h2>
                        </div>
                        <span class="pill">@(_scanResult is null ? "No normalized scan" : "Normalized scan ready")</span>
                    </div>

                    <p class="muted-text">Edit the ordered enabled mod IDs and map folders directly. This page keeps the real Project Zomboid <code>Mods</code> and <code>Map</code> keys operator-friendly while the launcher resolves <code>WorkshopItems</code> behind the scenes when it writes the live server preset.</p>

                    @if (_requiresAdvancedFilesFallback)
                    {
                        <div class="settings-banner settings-banner--warning">
                            <strong>Structured Mods &amp; Maps editing is unavailable for this file.</strong>
                            <p>@(_fallbackReason ?? "Use Advanced Files for the raw Project Zomboid INI.")</p>
                            <a class="nav-button secondary-button" href="@AdvancedFilesHref">Open Advanced Files</a>
                        </div>
                    }

                    <div class="status-banner status-banner--warm">
                        <strong>Operator flow</strong>
                        <p>1. Scan Workshop to normalize local content and catch missing pieces.</p>
                        <p>2. Save Live Preset to write the live server loadout back to the profile.</p>
                        <p>3. Save a named loadout when you want a reusable recovery point or alternate mod set.</p>
                        <p>4. Use Advanced Files only when this file is too raw for structured editing.</p>
                    </div>

                    <div class="profile-section">
                        <div class="profile-section__header">
                            <h3>Enabled Mod IDs</h3>
                            <p class="muted-text">One mod ID per line, in the order the server should load them. Search by Workshop URL or ID above when you want the launcher to resolve the matching mod IDs for you.</p>
                        </div>
                        <textarea class="raw-editor" rows="8" @bind="EnabledModIdsText" @bind:event="oninput" disabled="@_busy"></textarea>
                    </div>

                    <div class="profile-section">
                        <div class="profile-section__header">
                            <h3>Map Folders</h3>
                            <p class="muted-text">One map folder per line. Keep the order aligned with the server's map load order.</p>
                        </div>
                        <textarea class="raw-editor" rows="6" @bind="MapFoldersText" @bind:event="oninput" disabled="@_busy"></textarea>
                    </div>

                    <div class="file-toolbar">
                        <span class="muted-text">Live preset hash: @_presetHash</span>
                        <span class="muted-text">@ScanStateSummary</span>
                    </div>
                </section>

                <section class="card">
                    <div class="card-heading">
                        <div>
                            <p class="eyebrow">Recovery</p>
                            <h2>Workspace Snapshot</h2>
                        </div>
                        <span class="pill">@RecoveryStateSummary</span>
                    </div>

                    <div class="info-grid">
                        <div class="info-item">
                            <span class="info-label">Runtime</span>
                            <span class="info-value">@(_runtimeStatus?.State.ToString() ?? "Unknown")</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Install</span>
                            <span class="info-value">@(_installDetected ? "Detected" : "Missing")</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Cache</span>
                            <span class="info-value">@(_cacheDetected ? "Detected" : "Missing")</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Scan result</span>
                            <span class="info-value">@(_scanResult is null ? "Not run yet" : "Normalized and ready")</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Recovery</span>
                            <span class="info-value">@RecoveryHintSummary</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Saved loadouts</span>
                            <span class="info-value">@(_namedPresets.Count == 0 ? "No saved loadouts" : $"{_namedPresets.Count} available")</span>
                        </div>
                    </div>

                    <div class="status-banner status-banner--warm">
                        <strong>Recovery posture</strong>
                        <p>@RecoveryGuidanceSummary</p>
                        <p>@LoadoutGuidanceSummary</p>
                    </div>

                    <div class="profile-section">
                        <div class="profile-section__header">
                            <h3>Saved Loadouts</h3>
                            <p class="muted-text">Capture the current editor state as a named recovery point, then load it back into the editor whenever you need to rebuild the live preset.</p>
                        </div>

                        <div class="file-toolbar">
                            <input @bind="_newPresetName" placeholder="Loadout name" />
                            <button class="nav-button secondary-button" @onclick="SaveNamedPresetAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_newPresetName))">Save Loadout</button>
                        </div>

                        @if (_namedPresets.Count == 0)
                        {
                            <div class="empty-state">
                                <p class="muted-text">No saved loadouts yet. Use the current editor state to create a recovery point before making a risky mod or map change.</p>
                            </div>
                        }
                        else
                        {
                            <ul class="job-list">
                                @foreach (var preset in _namedPresets)
                                {
                                    <li class="job-list__item">
                                        <div class="job-list__title">
                                            <strong>@preset.Name</strong>
                                            <span>@preset.UpdatedAtUtc.ToLocalTime().ToString("g")</span>
                                        </div>
                                        <div class="muted-text">@BuildPresetCompositionSummary(preset.Preset)</div>
                                        <div class="workspace-actions">
                                            <button class="nav-button secondary-button" @onclick="() => LoadNamedPreset(preset)" disabled="@_busy">Load To Editor</button>
                                            <button class="nav-button secondary-button" @onclick="() => DeleteNamedPresetAsync(preset)" disabled="@_busy">Delete</button>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </section>
            </div>

            <div class="cards cards--wide">
                <section class="card">
                    <div class="card-heading">
                        <div>
                            <p class="eyebrow">Scan Result</p>
                            <h2>Normalized Preset</h2>
                        </div>
                        <span class="pill">@ScanResultSummary</span>
                    </div>

                    @if (_scanResult is null)
                    {
                        <div class="empty-state">
                            <p class="muted-text">No normalized scan has been captured yet. Run Scan Workshop to compare the live editor state against local content and populate this summary.</p>
                        </div>
                    }
                    else
                    {
                        <div class="info-grid info-grid--compact">
                            <div class="info-item">
                                <span class="info-label">Enabled mods</span>
                                <span class="info-value">@_scanResult.Preset.EnabledModIds.Count</span>
                            </div>
                            <div class="info-item">
                                <span class="info-label">Map folders</span>
                                <span class="info-value">@_scanResult.Preset.MapFolders.Count</span>
                            </div>
                        </div>

                        <p class="muted-text">This normalized loadout is what you can push into the live preset with Apply Scan Result after the scanner has reconciled the selected mods and maps with local workshop content.</p>
                    }
                </section>

                <section class="card">
                    <div class="card-heading">
                        <div>
                            <p class="eyebrow">Diagnostics</p>
                            <h2>Scanner Feedback</h2>
                        </div>
                        <span class="pill">@DiagnosticsSummary</span>
                    </div>

                    @if (_scanDiagnostics.Count == 0)
                    {
                        <div class="empty-state">
                            <p class="muted-text">No scanner diagnostics yet. Run a scan to surface missing workshop items, duplicate entries, and map validation messages here.</p>
                        </div>
                    }
                    else
                    {
                        <ul class="stack-list">
                            @foreach (var diagnostic in _scanDiagnostics)
                            {
                                <li>@diagnostic</li>
                            }
                        </ul>
                    }
                </section>
            </div>

            <p class="status-line">@_statusMessage</p>
        </ChildContent>
    </ProfileWorkspaceShell>
}

@code {
    [Parameter]
    public string ProfileId { get; set; } = string.Empty;

    private PZServerLauncher.Core.Profiles.ServerProfile? _profile;
    private SettingsCatalogDto? _catalog;
    private SettingsPageDto? _page;
    private ServerRuntimeStatus? _runtimeStatus;
    private bool _busy;
    private string? _statusMessage;
    private bool _installDetected;
    private bool _cacheDetected;
    private string workshopItemIdsText = string.Empty;
    private string enabledModIdsText = string.Empty;
    private string mapFoldersText = string.Empty;
    private string _presetHash = string.Empty;
    private WorkshopScanResultDto? _scanResult;
    private IReadOnlyList<string> _scanDiagnostics = [];
    private IReadOnlyList<NamedWorkshopPresetDto> _namedPresets = [];
    private bool _hasChanges;
    private bool _suppressChangeTracking;
    private bool _requiresAdvancedFilesFallback;
    private string? _fallbackReason;
    private string _newPresetName = string.Empty;
    private bool _pageSupportsDrafts;
    private SteamWorkshopBrowserSettingsDto _workshopBrowserSettings = new(false);
    private WorkshopCatalogSearchResultDto? _workshopSearchResult;
    private WorkshopCatalogPreviewDto? _selectedWorkshopPreview;
    private bool _isWorkshopPreviewModalOpen;
    private string _searchQuery = string.Empty;
    private WorkshopCatalogSearchMode _searchMode = WorkshopCatalogSearchMode.Both;
    private WorkshopCatalogSearchFilter _searchFilter = WorkshopCatalogSearchFilter.All;
    private string _steamWebApiKey = string.Empty;

    protected override async Task OnParametersSetAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _profile = await ProfileStore.GetAsync(ProfileId);
        if (_profile is null)
        {
            return;
        }

        _runtimeStatus = RuntimeStateStore.GetOrDefault(ProfileId);
        _installDetected = Directory.Exists(_profile.InstallDirectory);
        _cacheDetected = Directory.Exists(_profile.CacheDirectory);
        _workshopBrowserSettings = await WorkshopBrowserSettingsStore.GetAsync();
        _statusMessage = null;
        _catalog = StructuredSettingsService.GetCatalog(_profile);
        _page = _catalog.Pages.FirstOrDefault(page => string.Equals(page.PageId, ProfileWorkspacePageIds.ModsAndMaps, StringComparison.OrdinalIgnoreCase));
        _pageSupportsDrafts = _page?.SupportsDrafts == true;
        var valueSet = StructuredSettingsService.GetPage(_profile, ProfileWorkspacePageIds.ModsAndMaps);
        _requiresAdvancedFilesFallback = valueSet.RequiresAdvancedFilesFallback;
        _fallbackReason = valueSet.FallbackReason;

        var preset = StructuredSettingsService.GetWorkshopPreset(_profile);
        _profile = _profile with { WorkshopPreset = preset };
        LoadPreset(preset);
        await LoadDraftIfAvailableAsync();
        _namedPresets = await NamedWorkshopPresetStore.ListAsync(ProfileId);
        _scanResult = null;
        _scanDiagnostics = [];
        _workshopSearchResult = null;
        _selectedWorkshopPreview = null;
        _isWorkshopPreviewModalOpen = false;
        _steamWebApiKey = string.Empty;
        if (string.IsNullOrWhiteSpace(_statusMessage))
        {
            _statusMessage = _requiresAdvancedFilesFallback
                ? _fallbackReason ?? "Structured Mods & Maps editing is unavailable. Use Advanced Files."
                : "Workshop preset loaded.";
        }
    }

    private async Task ScanAsync()
    {
        if (_profile is null)
        {
            return;
        }

        if (_requiresAdvancedFilesFallback)
        {
            _statusMessage = _fallbackReason ?? "Structured Mods & Maps editing is unavailable. Use Advanced Files.";
            return;
        }

        _busy = true;
        try
        {
            var preset = BuildPresetForWorkshopOperations();
            _scanResult = WorkshopPresetScannerService.Scan(_profile.InstallDirectory, preset);
            _scanDiagnostics = _scanResult.Diagnostics;
            _statusMessage = _scanDiagnostics.Count == 0
                ? "Workshop scan completed successfully."
                : "Workshop scan completed with diagnostics.";
        }
        finally
        {
            _busy = false;
        }
    }

