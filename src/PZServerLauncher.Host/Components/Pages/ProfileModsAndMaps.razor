@page "/profiles/{ProfileId}/mods-maps"
@attribute [Authorize(Roles="Owner,Admin")]
@inject ProfileStore ProfileStore
@inject StructuredSettingsService StructuredSettingsService
@inject WorkshopPresetScannerService WorkshopPresetScannerService
@inject RuntimeStateStore RuntimeStateStore

<PageTitle>Mods &amp; Maps</PageTitle>

@if (_profile is null)
{
    <div class="home-shell">
        <div class="card">
            <p class="eyebrow">Profile Workspace</p>
            <h1>Profile not found</h1>
            <p class="muted-text">The selected profile could not be loaded.</p>
            <a class="nav-button" href="/profiles">Back to profiles</a>
        </div>
    </div>
}
else
{
    <ProfileWorkspaceShell Profile="@_profile"
                           ActivePage="mods-maps"
                           RuntimeStatus="@_runtimeStatus"
                           InstallDetected="@_installDetected"
                           CacheDetected="@_cacheDetected">
        <Actions>
            <a class="nav-button secondary-button" href="@OverviewHref">Overview</a>
            <a class="nav-button secondary-button" href="@SandboxHref">Sandbox</a>
            <a class="nav-button secondary-button" href="@AdvancedFilesHref">Advanced Files</a>
            <button class="nav-button" @onclick="ScanAsync" disabled="@_busy">Scan Workshop</button>
            <button class="nav-button secondary-button" @onclick="SaveAsync" disabled="@(_busy || _requiresAdvancedFilesFallback)">Save Preset</button>
            <button class="nav-button secondary-button" @onclick="ApplyScanResultAsync" disabled="@(_busy || _scanResult is null || _requiresAdvancedFilesFallback)">Apply Scan Result</button>
        </Actions>
        <ChildContent>
            <section class="workspace-panel hero-panel">
                <div class="workspace-panel__copy">
                    <p class="eyebrow">Mods &amp; Maps</p>
                    <h1>@_profile.DisplayName</h1>
                    <p class="muted-text">Edit ordered workshop items, enabled mods, and map folders. Scan Workshop normalizes the lists against what is installed locally.</p>
                </div>

                <div class="workspace-actions">
                    <span class="pill">@_profile.Branch</span>
                    <span class="pill">@(_installDetected ? "Install detected" : "Install missing")</span>
                    <span class="pill">@(_cacheDetected ? "Cache ready" : "Cache missing")</span>
                    <span class="pill">@(_hasChanges ? "Unsaved changes" : "In sync")</span>
                </div>
            </section>

            <section class="metric-grid metric-grid--host">
                <article class="metric-card">
                    <span class="metric-label">Workshop Items</span>
                    <strong class="metric-value">@_profile.WorkshopPreset.WorkshopItemIds.Count</strong>
                    <span class="metric-note">Ordered workshop IDs</span>
                </article>
                <article class="metric-card">
                    <span class="metric-label">Enabled Mods</span>
                    <strong class="metric-value">@_profile.WorkshopPreset.EnabledModIds.Count</strong>
                    <span class="metric-note">Enabled mod IDs in load order</span>
                </article>
                <article class="metric-card">
                    <span class="metric-label">Map Folders</span>
                    <strong class="metric-value">@_profile.WorkshopPreset.MapFolders.Count</strong>
                    <span class="metric-note">Map load order</span>
                </article>
                <article class="metric-card">
                    <span class="metric-label">Scan Diagnostics</span>
                    <strong class="metric-value">@_scanDiagnostics.Count</strong>
                    <span class="metric-note">Local workshop validation messages</span>
                </article>
            </section>

            <div class="cards cards--wide">
                <section class="card">
                    <div class="card-heading">
                        <div>
                            <p class="eyebrow">Mods &amp; Maps</p>
                            <h2>Preset Editor</h2>
                        </div>
                        <span class="pill">@(_scanResult is null ? "No scan result" : "Scan ready")</span>
                    </div>

                    <p class="muted-text">Edit the ordered workshop item IDs, enabled mod IDs, and map folders directly. This page now keeps the real Project Zomboid <code>WorkshopItems</code>, <code>Mods</code>, and <code>Map</code> INI keys in sync with the launcher preset.</p>

                    @if (_requiresAdvancedFilesFallback)
                    {
                        <div class="settings-banner settings-banner--warning">
                            <strong>Structured Mods &amp; Maps editing is unavailable for this file.</strong>
                            <p>@(_fallbackReason ?? "Use Advanced Files for the raw Project Zomboid INI.")</p>
                            <a class="nav-button secondary-button" href="@AdvancedFilesHref">Open Advanced Files</a>
                        </div>
                    }

                    <div class="status-banner">
                        <strong>Current preset</strong>
                        <p>Workshop items: @_profile.WorkshopPreset.WorkshopItemIds.Count</p>
                        <p>Enabled mods: @_profile.WorkshopPreset.EnabledModIds.Count</p>
                        <p>Map folders: @_profile.WorkshopPreset.MapFolders.Count</p>
                        <p>Saved state: @(_hasChanges ? "Unsaved changes" : "In sync")</p>
                    </div>

                    <div class="profile-section">
                        <div class="profile-section__header">
                            <h3>Workshop Item IDs</h3>
                            <p class="muted-text">One workshop URL or numeric ID per line. The scanner will normalize URLs to numeric IDs.</p>
                        </div>
                        <textarea class="raw-editor" rows="8" @bind="WorkshopItemIdsText" @bind:event="oninput" disabled="@_busy"></textarea>
                    </div>

                    <div class="profile-section">
                        <div class="profile-section__header">
                            <h3>Enabled Mod IDs</h3>
                            <p class="muted-text">One mod ID per line, in the order the server should load them.</p>
                        </div>
                        <textarea class="raw-editor" rows="8" @bind="EnabledModIdsText" @bind:event="oninput" disabled="@_busy"></textarea>
                    </div>

                    <div class="profile-section">
                        <div class="profile-section__header">
                            <h3>Map Folders</h3>
                            <p class="muted-text">One map folder per line. Keep the order aligned with the server's map load order.</p>
                        </div>
                        <textarea class="raw-editor" rows="6" @bind="MapFoldersText" @bind:event="oninput" disabled="@_busy"></textarea>
                    </div>

                    <div class="file-toolbar">
                        <span class="muted-text">Preset hash: @_presetHash</span>
                        <span class="muted-text">Scan diagnostics: @_scanDiagnostics.Count</span>
                    </div>
                </section>

                <section class="card">
                    <div class="card-heading">
                        <div>
                            <p class="eyebrow">Status</p>
                            <h2>Workspace Snapshot</h2>
                        </div>
                    </div>

                    <div class="info-grid">
                        <div class="info-item">
                            <span class="info-label">Runtime</span>
                            <span class="info-value">@(_runtimeStatus?.State.ToString() ?? "Unknown")</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Install</span>
                            <span class="info-value">@(_installDetected ? "Detected" : "Missing")</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Cache</span>
                            <span class="info-value">@(_cacheDetected ? "Detected" : "Missing")</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Scan result</span>
                            <span class="info-value">@(_scanResult is null ? "Not run yet" : "Ready")</span>
                        </div>
                    </div>

                    <div class="status-banner status-banner--warm">
                        <strong>Workflow guidance</strong>
                        <p>Use Advanced Files only for raw file editing fallback. Workshop and map lists are managed here.</p>
                    </div>

                    @if (_scanResult is not null)
                    {
                        <div class="inner-card card">
                            <div class="card-heading">
                                <div>
                                    <p class="eyebrow">Scan Result</p>
                                    <h3>Normalized Preset</h3>
                                </div>
                            </div>
                            <p>Workshop items: @_scanResult.Preset.WorkshopItemIds.Count</p>
                            <p>Enabled mods: @_scanResult.Preset.EnabledModIds.Count</p>
                            <p>Map folders: @_scanResult.Preset.MapFolders.Count</p>
                        </div>
                    }
                </section>
            </div>

            @if (_scanDiagnostics.Count > 0)
            {
                <section class="card">
                    <div class="card-heading">
                        <div>
                            <p class="eyebrow">Diagnostics</p>
                            <h2>Scanner Feedback</h2>
                        </div>
                    </div>
                    <ul class="stack-list">
                        @foreach (var diagnostic in _scanDiagnostics)
                        {
                            <li>@diagnostic</li>
                        }
                    </ul>
                </section>
            }

            <p class="status-line">@_statusMessage</p>
        </ChildContent>
    </ProfileWorkspaceShell>
}

@code {
    [Parameter]
    public string ProfileId { get; set; } = string.Empty;

    private PZServerLauncher.Core.Profiles.ServerProfile? _profile;
    private ServerRuntimeStatus? _runtimeStatus;
    private bool _busy;
    private string? _statusMessage;
    private bool _installDetected;
    private bool _cacheDetected;
    private string workshopItemIdsText = string.Empty;
    private string enabledModIdsText = string.Empty;
    private string mapFoldersText = string.Empty;
    private string _presetHash = string.Empty;
    private WorkshopScanResultDto? _scanResult;
    private IReadOnlyList<string> _scanDiagnostics = [];
    private bool _hasChanges;
    private bool _suppressChangeTracking;
    private bool _requiresAdvancedFilesFallback;
    private string? _fallbackReason;

    protected override async Task OnParametersSetAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _profile = await ProfileStore.GetAsync(ProfileId);
        if (_profile is null)
        {
            return;
        }

        _runtimeStatus = RuntimeStateStore.GetOrDefault(ProfileId);
        _installDetected = Directory.Exists(_profile.InstallDirectory);
        _cacheDetected = Directory.Exists(_profile.CacheDirectory);
        var valueSet = StructuredSettingsService.GetPage(_profile, ProfileWorkspacePageIds.ModsAndMaps);
        _requiresAdvancedFilesFallback = valueSet.RequiresAdvancedFilesFallback;
        _fallbackReason = valueSet.FallbackReason;

        var preset = StructuredSettingsService.GetWorkshopPreset(_profile);
        _profile = _profile with { WorkshopPreset = preset };
        LoadPreset(preset);
        _scanResult = null;
        _scanDiagnostics = [];
        _statusMessage = _requiresAdvancedFilesFallback
            ? _fallbackReason ?? "Structured Mods & Maps editing is unavailable. Use Advanced Files."
            : "Workshop preset loaded.";
    }

    private async Task ScanAsync()
    {
        if (_profile is null)
        {
            return;
        }

        if (_requiresAdvancedFilesFallback)
        {
            _statusMessage = _fallbackReason ?? "Structured Mods & Maps editing is unavailable. Use Advanced Files.";
            return;
        }

        _busy = true;
        try
        {
            var preset = BuildPresetFromEditor();
            _scanResult = WorkshopPresetScannerService.Scan(_profile.InstallDirectory, preset);
            _scanDiagnostics = _scanResult.Diagnostics;
            _statusMessage = _scanDiagnostics.Count == 0
                ? "Workshop scan completed successfully."
                : "Workshop scan completed with diagnostics.";
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SaveAsync()
    {
        if (_profile is null)
        {
            return;
        }

        if (_requiresAdvancedFilesFallback)
        {
            _statusMessage = _fallbackReason ?? "Structured Mods & Maps editing is unavailable. Use Advanced Files.";
            return;
        }

        _busy = true;
        try
        {
            var normalizedPreset = await StructuredSettingsService.SaveWorkshopPresetAsync(_profile, BuildPresetFromEditor());
            _scanResult = WorkshopPresetScannerService.Scan(_profile.InstallDirectory, normalizedPreset);
            _scanDiagnostics = _scanResult.Diagnostics;

            _profile = await ProfileStore.GetAsync(ProfileId);
            if (_profile is not null)
            {
                _profile = _profile with { WorkshopPreset = normalizedPreset };
            }

            LoadPreset(normalizedPreset);
            _statusMessage = _scanDiagnostics.Count == 0
                ? "Workshop preset saved."
                : "Workshop preset saved with diagnostics.";
        }
        catch (Exception ex)
        {
            _statusMessage = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task ApplyScanResultAsync()
    {
        if (_profile is null || _scanResult is null)
        {
            return;
        }

        if (_requiresAdvancedFilesFallback)
        {
            _statusMessage = _fallbackReason ?? "Structured Mods & Maps editing is unavailable. Use Advanced Files.";
            return;
        }

        _busy = true;
        try
        {
            var normalizedPreset = await StructuredSettingsService.SaveWorkshopPresetAsync(_profile, _scanResult.Preset);
            _profile = await ProfileStore.GetAsync(ProfileId);
            if (_profile is not null)
            {
                _profile = _profile with { WorkshopPreset = normalizedPreset };
            }

            LoadPreset(normalizedPreset);
            _statusMessage = _scanDiagnostics.Count == 0
                ? "Scanned workshop preset applied."
                : "Scanned workshop preset applied with diagnostics.";
        }
        catch (Exception ex)
        {
            _statusMessage = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void LoadPreset(PZServerLauncher.Core.Profiles.WorkshopPreset preset)
    {
        _suppressChangeTracking = true;
        try
        {
            WorkshopItemIdsText = string.Join(Environment.NewLine, preset.WorkshopItemIds);
            EnabledModIdsText = string.Join(Environment.NewLine, preset.EnabledModIds);
            MapFoldersText = string.Join(Environment.NewLine, preset.MapFolders);
        }
        finally
        {
            _suppressChangeTracking = false;
        }

        _presetHash = BuildPresetHash(BuildPresetFromEditor());
        _hasChanges = false;
    }

    private PZServerLauncher.Core.Profiles.WorkshopPreset BuildPresetFromEditor() =>
        new()
        {
            WorkshopItemIds = ParseLines(WorkshopItemIdsText),
            EnabledModIds = ParseLines(EnabledModIdsText),
            MapFolders = ParseLines(MapFoldersText),
        };

    private static IReadOnlyList<string> ParseLines(string text)
    {
        if (string.IsNullOrWhiteSpace(text))
        {
            return [];
        }

        return text
            .ReplaceLineEndings("\n")
            .Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .SelectMany(line => line.Split(';', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries))
            .Select(value => value.Trim())
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private static string BuildPresetHash(PZServerLauncher.Core.Profiles.WorkshopPreset preset)
    {
        var source = string.Join("|",
            string.Join(",", preset.WorkshopItemIds),
            string.Join(",", preset.EnabledModIds),
            string.Join(",", preset.MapFolders));
        return Convert.ToHexString(System.Security.Cryptography.SHA256.HashData(System.Text.Encoding.UTF8.GetBytes(source)));
    }

    private string OverviewHref => $"/profiles/{Uri.EscapeDataString(ProfileId)}/overview";

    private string SandboxHref => $"/profiles/{Uri.EscapeDataString(ProfileId)}/sandbox";

    private string AdvancedFilesHref => $"/profiles/{Uri.EscapeDataString(ProfileId)}/advanced-files";

    private string WorkshopItemIdsText
    {
        get => workshopItemIdsText;
        set
        {
            workshopItemIdsText = value;
            MarkChanged();
        }
    }

    private string EnabledModIdsText
    {
        get => enabledModIdsText;
        set
        {
            enabledModIdsText = value;
            MarkChanged();
        }
    }

    private string MapFoldersText
    {
        get => mapFoldersText;
        set
        {
            mapFoldersText = value;
            MarkChanged();
        }
    }

    private void MarkChanged()
    {
        if (_busy || _suppressChangeTracking)
        {
            return;
        }

        _hasChanges = true;
        _presetHash = BuildPresetHash(BuildPresetFromEditor());
        _statusMessage = "Workshop preset changed locally.";
    }
}
