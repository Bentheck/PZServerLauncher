@page "/host"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using PZServerLauncher.Host.Services
@inject HostSettingsStore HostSettingsStore

<PageTitle>Host</PageTitle>

<div class="home-shell">
    <section class="workspace-panel hero-panel">
        <div class="workspace-panel__copy">
            <p class="eyebrow">Workspace</p>
            <h1>Host</h1>
            <p class="muted-text">This is the control plane for the local launcher host: startup policy, loopback control, remote exposure, and owner bootstrap readiness all converge here.</p>
        </div>

        @if (_settings is not null)
        {
            <div class="workspace-actions">
                <span class="pill">Loopback @_settings.LoopbackPort</span>
                <span class="pill">@(_settings.StartHostWithWindows ? "Windows startup on" : "Windows startup off")</span>
                <span class="pill">@(_settings.RemoteAccess.IsEnabled ? "Remote access enabled" : "Loopback-only")</span>
                <span class="pill">@(_settings.OwnerBootstrap.IsConfigured ? "Owner bootstrap complete" : "Owner bootstrap pending")</span>
            </div>
        }
    </section>

    @if (_settings is null)
    {
        <section class="card">
            <p>Loading host settings...</p>
        </section>
    }
    else
    {
        <section class="metric-grid metric-grid--host">
            <article class="metric-card">
                <span class="metric-label">Loopback Port</span>
                <strong class="metric-value">@_settings.LoopbackPort</strong>
                <span class="metric-note">Private control channel used by the desktop app</span>
            </article>
            <article class="metric-card">
                <span class="metric-label">Startup</span>
                <strong class="metric-value">@(_settings.StartHostWithWindows ? "On" : "Off")</strong>
                <span class="metric-note">Whether the host comes up automatically at sign-in</span>
            </article>
            <article class="metric-card">
                <span class="metric-label">Remote Access</span>
                <strong class="metric-value">@(_settings.RemoteAccess.IsEnabled ? "Enabled" : "Disabled")</strong>
                <span class="metric-note">@(_settings.RemoteAccess.IsEnabled ? $"https://{(_settings.RemoteAccess.PublicHostname ?? _settings.RemoteAccess.BindAddress)}:{_settings.RemoteAccess.HttpsPort}" : "Not exposed beyond loopback")</span>
            </article>
            <article class="metric-card">
                <span class="metric-label">Owner Bootstrap</span>
                <strong class="metric-value">@(_settings.OwnerBootstrap.IsConfigured ? "Configured" : "Pending")</strong>
                <span class="metric-note">@(_settings.OwnerBootstrap.OwnerUserName ?? "No owner assigned yet")</span>
            </article>
        </section>

        <div class="cards cards--wide">
            <section class="card">
                <div class="card-heading">
                    <div>
                        <p class="eyebrow">Startup</p>
                        <h2>Host Control Plane</h2>
                    </div>
                </div>

                <div class="info-grid">
                    <div class="info-item">
                        <span class="info-label">Loopback port</span>
                        <span class="info-value">@_settings.LoopbackPort</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Windows start</span>
                        <span class="info-value">@(_settings.StartHostWithWindows ? "On" : "Off")</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Remote access</span>
                        <span class="info-value">@(_settings.RemoteAccess.IsEnabled ? "Enabled" : "Disabled")</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Remote endpoint</span>
                        <span class="info-value">@(_settings.RemoteAccess.IsEnabled ? $"https://{(_settings.RemoteAccess.PublicHostname ?? _settings.RemoteAccess.BindAddress)}:{_settings.RemoteAccess.HttpsPort}" : "Loopback-only")</span>
                    </div>
                </div>

                <div class="status-banner">
                    <strong>Operator note</strong>
                    <p>@(_settings.StartHostWithWindows ? "The host is configured like a persistent control service. Use this when the machine should behave like a dedicated server controller." : "The host stays manual until you opt in, which is a safer default while you are still setting up profiles and remote access.")</p>
                </div>
            </section>

            <section class="card">
                <div class="card-heading">
                    <div>
                        <p class="eyebrow">Owner Bootstrap</p>
                        <h2>Security Setup</h2>
                    </div>
                </div>

                <div class="status-banner">
                    <strong>Owner account</strong>
                    <p>@(_settings.OwnerBootstrap.OwnerUserName ?? "Not set")</p>
                </div>

                <div class="info-grid info-grid--compact">
                    <div class="info-item">
                        <span class="info-label">Status</span>
                        <span class="info-value">@(_settings.OwnerBootstrap.IsConfigured ? "Configured" : "Pending")</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Remote access ready</span>
                        <span class="info-value">@(_settings.OwnerBootstrap.IsConfigured ? "Can enable web admin" : "Needs bootstrap first")</span>
                    </div>
                </div>

                <div class="status-banner status-banner--warm">
                    <strong>Security posture</strong>
                    <p>@(_settings.OwnerBootstrap.IsConfigured ? "The owner account exists, so you can move on to 2FA and remote access hardening." : "Bootstrap the owner account first so web admin and remote exposure can be secured properly.")</p>
                </div>
            </section>

            <section class="card">
                <div class="card-heading">
                    <div>
                        <p class="eyebrow">Web Admin Readiness</p>
                        <h2>Remote Operator Surface</h2>
                    </div>
                </div>

                <p class="muted-text">Use Remote Access to expose the HTTPS endpoint and Users to manage roles for operators, admins, and viewers.</p>

                <div class="workspace-actions">
                    <a class="nav-button secondary-button" href="/remote">Remote Access</a>
                    <a class="nav-button secondary-button" href="/users">Users</a>
                </div>

                <div class="status-banner">
                    <strong>Recommended next step</strong>
                    <p>@(_settings.RemoteAccess.IsEnabled ? "Review the remote endpoint, then verify user roles and 2FA readiness before exposing the host more broadly." : "Open Remote Access to add certificate details and validate the endpoint before enabling public exposure.")</p>
                </div>
            </section>
        </div>

        <section class="card callout-card">
            <h2>Recommended Next Steps</h2>
            <ol>
                <li>Configure an authenticator app for your owner account under <a href="/Account/Manage/TwoFactorAuthentication">2FA</a>.</li>
                <li>Open <a href="/remote">Remote Access</a> and add your HTTPS certificate details.</li>
                <li>Create additional operators or viewers under <a href="/users">Users</a> if you want shared administration.</li>
            </ol>
        </section>
    }
</div>

@code {
    private PZServerLauncher.Core.Runtime.HostSettings? _settings;

    protected override async Task OnInitializedAsync()
    {
        _settings = await HostSettingsStore.GetAsync();
    }
}
