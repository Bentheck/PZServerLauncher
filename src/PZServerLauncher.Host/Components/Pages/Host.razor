@page "/host"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using PZServerLauncher.Contracts.Profiles
@using PZServerLauncher.Core.Profiles
@using PZServerLauncher.Core.Runtime
@using PZServerLauncher.Host.Services
@inject HostSettingsStore HostSettingsStore
@inject ProfileStore ProfileStore
@inject RuntimeStateStore RuntimeStateStore
@inject ServerBackupService BackupService

<PageTitle>Host</PageTitle>

<div class="home-shell">
    <section class="workspace-panel hero-panel">
        <div class="workspace-panel__copy">
            <p class="eyebrow">Workspace</p>
            <h1>Host</h1>
            <p class="muted-text">This is the control plane for the local launcher host: startup policy, loopback control, remote exposure, and owner bootstrap readiness all converge here.</p>
            <p class="muted-text">@(_summary?.OperatorSummary ?? "Load host posture to see the fleet briefing.")</p>
        </div>

        @if (_settings is not null)
        {
            <div class="workspace-actions">
                <span class="pill">@(_summary?.LifecycleHeadline ?? $"Loopback {_settings.LoopbackPort}")</span>
                <span class="pill">@(_summary?.ExposureHeadline ?? (_settings.RemoteAccess.IsEnabled ? "Remote access enabled" : "Loopback-only"))</span>
                <span class="pill">@(_summary?.SecurityHeadline ?? (_settings.OwnerBootstrap.IsConfigured ? "Owner bootstrap complete" : "Owner bootstrap pending"))</span>
            </div>
        }
    </section>

    @if (_settings is null)
    {
        <section class="card">
            <p>Loading host settings...</p>
        </section>
    }
    else
    {
        <section class="metric-grid metric-grid--host">
            <article class="metric-card">
                <span class="metric-label">Lifecycle</span>
                <strong class="metric-value">@(_summary?.LifecycleHeadline ?? "Lifecycle unavailable")</strong>
                <span class="metric-note">The host control plane and Windows startup posture for this machine.</span>
            </article>
            <article class="metric-card">
                <span class="metric-label">Fleet</span>
                <strong class="metric-value">@(_summary?.FleetHeadline ?? "Fleet unavailable")</strong>
                <span class="metric-note">Profiles currently under host supervision.</span>
            </article>
            <article class="metric-card">
                <span class="metric-label">Exposure</span>
                <strong class="metric-value">@(_summary?.ExposureHeadline ?? "Exposure unavailable")</strong>
                <span class="metric-note">How much of the host is intentionally reachable from outside the desktop.</span>
            </article>
            <article class="metric-card">
                <span class="metric-label">Security</span>
                <strong class="metric-value">@(_summary?.SecurityHeadline ?? "Security unavailable")</strong>
                <span class="metric-note">Owner bootstrap and access posture for the local host.</span>
            </article>
        </section>

        <section class="metric-grid metric-grid--host">
            <article class="metric-card">
                <span class="metric-label">Startup Roster</span>
                <strong class="metric-value">@(_summary?.StartupHeadline ?? "Startup roster unavailable")</strong>
                <span class="metric-note">What will come online automatically when the host starts.</span>
            </article>
            <article class="metric-card">
                <span class="metric-label">Recovery</span>
                <strong class="metric-value">@(_summary?.RecoveryHeadline ?? "Recovery unavailable")</strong>
                <span class="metric-note">The current archive posture and rollback readiness.</span>
            </article>
            <article class="metric-card">
                <span class="metric-label">Automation</span>
                <strong class="metric-value">@(_summary?.AutomationHeadline ?? "Automation unavailable")</strong>
                <span class="metric-note">Crash recovery and unattended restart posture.</span>
            </article>
            <article class="metric-card">
                <span class="metric-label">Risk</span>
                <strong class="metric-value">@(_summary?.RiskHeadline ?? "Risk unavailable")</strong>
                <span class="metric-note">The strongest operator warning on this page.</span>
            </article>
        </section>

        <section class="card">
            <div class="card-heading">
                <div>
                    <p class="eyebrow">Managed Profiles</p>
                    <h2>Host Supervision Roster</h2>
                </div>
            </div>

            @if (_profiles.Count == 0)
            {
                <div class="empty-state">
                    <p class="muted-text">No Project Zomboid profiles are loaded yet, so the host has nothing to supervise.</p>
                </div>
            }
            else
            {
                <p class="muted-text">@(_summary?.FleetHeadline ?? "Fleet posture unavailable.")</p>
                <p class="muted-text">@(_summary?.OperatorSummary ?? "Operator summary unavailable.")</p>

                <div class="field-grid">
                    @foreach (var profile in _profiles)
                    {
                        <div class="field-card">
                            <span class="field-label">@profile.DisplayName</span>
                            <span>@profile.Branch</span>
                            <span>@BuildRosterSummary(profile)</span>
                            <span>Start with host: @(profile.StartWithHost ? "On" : "Off")</span>
                            <span>Auto-restart: @(profile.AutoRestartOnCrash ? "On" : "Off")</span>
                            <span>Install root: @profile.InstallDirectory</span>
                            <span>Ports: @BuildPortSummary(profile)</span>
                        </div>
                    }
                </div>
            }
        </section>

        <div class="cards cards--wide">
            <section class="card">
                <div class="card-heading">
                    <div>
                        <p class="eyebrow">Host Control</p>
                        <h2>Control Plane</h2>
                    </div>
                </div>

                <div class="info-grid">
                    <div class="info-item">
                        <span class="info-label">Loopback Port</span>
                        <span class="info-value">@_settings.LoopbackPort</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Windows Startup</span>
                        <span class="info-value">@(_settings.StartHostWithWindows ? "On" : "Off")</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Remote Access</span>
                        <span class="info-value">@(_settings.RemoteAccess.IsEnabled ? "Enabled" : "Disabled")</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Remote Endpoint</span>
                        <span class="info-value">@(_settings.RemoteAccess.IsEnabled ? $"https://{(_settings.RemoteAccess.PublicHostname ?? _settings.RemoteAccess.BindAddress)}:{_settings.RemoteAccess.HttpsPort}" : "Loopback-only")</span>
                    </div>
                </div>

                <div class="status-banner">
                    <strong>Operator note</strong>
                    <p>@(_summary?.OperatorSummary ?? "Operator summary unavailable.")</p>
                </div>

                <div class="status-banner status-banner--warm">
                    <strong>Next step</strong>
                    <p>@(_summary?.NextStepSummary ?? "Next-step guidance unavailable.")</p>
                </div>
            </section>

            <section class="card">
                <div class="card-heading">
                    <div>
                        <p class="eyebrow">Security Setup</p>
                        <h2>Owner Bootstrap</h2>
                    </div>
                </div>

                <div class="status-banner">
                    <strong>Owner account</strong>
                    <p>@(_settings.OwnerBootstrap.OwnerUserName ?? "Not set")</p>
                </div>

                <div class="info-grid info-grid--compact">
                    <div class="info-item">
                        <span class="info-label">Status</span>
                        <span class="info-value">@(_settings.OwnerBootstrap.IsConfigured ? "Configured" : "Pending")</span>
                    </div>
                    <div class="info-item">
                        <span class="info-label">Remote Access Ready</span>
                        <span class="info-value">@(_settings.OwnerBootstrap.IsConfigured ? "Can enable web admin" : "Needs bootstrap first")</span>
                    </div>
                </div>

                <div class="status-banner status-banner--warm">
                    <strong>Security posture</strong>
                    <p>@(_summary?.SecurityHeadline ?? "Security posture unavailable.")</p>
                </div>
            </section>

            <section class="card">
                <div class="card-heading">
                    <div>
                        <p class="eyebrow">Web Admin Readiness</p>
                        <h2>Remote Operator Surface</h2>
                    </div>
                </div>

                <p class="muted-text">Use Remote Access to expose the HTTPS endpoint and Users to manage roles for operators, admins, and viewers.</p>

                <div class="workspace-actions">
                    <a class="nav-button secondary-button" href="/remote">Remote Access</a>
                    <a class="nav-button secondary-button" href="/users">Users</a>
                </div>

                <div class="status-banner">
                    <strong>Recommended next step</strong>
                    <p>@(_summary?.NextStepSummary ?? "Next-step guidance unavailable.")</p>
                </div>
            </section>
        </div>

        <section class="card callout-card">
            <div class="card-heading">
                <div>
                    <p class="eyebrow">Operator Checklist</p>
                    <h2>Host Rollout</h2>
                </div>
                <span class="pill">@($"{_summary?.Checklist.Count ?? 0} item(s)")</span>
            </div>

            <p class="muted-text">Use this checklist to decide whether the host should stay local-only, become a persistent controller, or expose the optional web surface.</p>

            <div class="users-table">
                <table>
                    <thead>
                        <tr>
                            <th>Status</th>
                            <th>Check</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _summary?.Checklist ?? [])
                        {
                            <tr>
                                <td>@item.StatusLabel</td>
                                <td>@item.Message</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>

@code {
    private PZServerLauncher.Core.Runtime.HostSettings? _settings;
    private IReadOnlyList<ServerProfile> _profiles = [];
    private ProjectZomboidHostOperatorSummary _summary = ProjectZomboidHostOperatorSummaryBuilder.Empty();

    protected override async Task OnInitializedAsync()
    {
        _settings = await HostSettingsStore.GetAsync();
        _profiles = await ProfileStore.ListAsync();
        _summary = BuildSummary();
    }

    private ProjectZomboidHostOperatorSummary BuildSummary()
    {
        var settings = _settings ?? new PZServerLauncher.Core.Runtime.HostSettings();
        return ProjectZomboidHostOperatorSummaryBuilder.Build(settings, BuildManagedProfiles());
    }

    private IReadOnlyCollection<ProjectZomboidHostManagedProfileSnapshot> BuildManagedProfiles()
    {
        return _profiles
            .OrderBy(profile => profile.DisplayName, StringComparer.OrdinalIgnoreCase)
            .Select(profile =>
            {
                var runtimeStatus = RuntimeStateStore.GetOrDefault(profile.ProfileId);
                var installDetected = Directory.Exists(profile.InstallDirectory) || Directory.Exists(Path.Combine(profile.InstallDirectory, "server"));
                var hasBackup = BackupService.ListBackups(profile.ProfileId).Count > 0;
                return new ProjectZomboidHostManagedProfileSnapshot(
                    profile.DisplayName,
                    profile.Branch.ToString(),
                    runtimeStatus.State.ToString(),
                    profile.StartWithHost,
                    profile.AutoRestartOnCrash,
                    hasBackup,
                    installDetected,
                    BuildPortSummary(profile));
            })
            .ToArray();
    }

    private static string BuildRosterSummary(ServerProfile profile)
    {
        var notes = new List<string>
        {
            profile.StartWithHost ? "Starts with host" : "Manual start",
            profile.AutoRestartOnCrash ? "Auto-restart" : "Manual recovery",
            profile.BackupPolicy.ScheduledBackupsEnabled ? "Scheduled backups" : "Manual backups",
        };

        return string.Join(" | ", notes);
    }

    private static string BuildPortSummary(ServerProfile profile) =>
        $"Game {profile.DefaultPort} | UDP {profile.UdpPort} | RCON {profile.RconPort}";
}
