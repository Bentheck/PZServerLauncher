@page "/remote"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Owner,Admin")]
@using PZServerLauncher.Contracts.Runtime
@using PZServerLauncher.Core.Runtime
@using PZServerLauncher.Host.Services
@inject AuditStore AuditStore
@inject HostSettingsStore HostSettingsStore
@inject UserManagementService UserManagementService

<PageTitle>Remote Access</PageTitle>

<div class="home-shell">
    <section class="workspace-panel hero-panel">
        <div class="workspace-panel__copy">
            <p class="eyebrow">Web Admin</p>
            <h1>Remote Access</h1>
            <p class="muted-text">Configure the optional HTTPS listener. Router forwarding is still manual in v1, but the host will validate your certificate and owner 2FA readiness before enabling remote access.</p>
        </div>

        @if (_currentRemoteAccess is not null)
        {
            <div class="workspace-actions">
                <span class="pill">@(_currentRemoteAccess.IsEnabled ? "Enabled" : "Disabled")</span>
                <span class="pill">@_currentRemoteAccess.HttpsPort</span>
                <span class="pill">@(_ownerAccountsWithTwoFactor > 0 ? "2FA ready" : "Needs 2FA")</span>
            </div>
        }
    </section>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <section class="card status-card status-line">
            <p>@_statusMessage</p>
        </section>
    }

    <section class="metric-grid metric-grid--host">
        <article class="metric-card">
            <span class="metric-label">Remote Listener</span>
            <strong class="metric-value">@(_currentRemoteAccess?.IsEnabled == true ? "Enabled" : "Disabled")</strong>
            <span class="metric-note">@(_currentRemoteAccess?.IsEnabled == true ? $"https://{(_currentRemoteAccess.PublicHostname ?? _currentRemoteAccess.BindAddress)}:{_currentRemoteAccess.HttpsPort}" : "Not exposed")</span>
        </article>
        <article class="metric-card">
            <span class="metric-label">Owner Accounts with 2FA</span>
            <strong class="metric-value">@_ownerAccountsWithTwoFactor</strong>
            <span class="metric-note">Required before web admin can be enabled</span>
        </article>
        <article class="metric-card">
            <span class="metric-label">Local 2FA Link</span>
            <strong class="metric-value">Ready</strong>
            <span class="metric-note">@_localTwoFactorPath</span>
        </article>
        <article class="metric-card">
            <span class="metric-label">Restart Requirement</span>
            <strong class="metric-value">Host restart</strong>
            <span class="metric-note">HTTPS binding changes apply after restart</span>
        </article>
    </section>

    <div class="cards cards--wide">
        <section class="card">
            <div class="card-heading">
                <div>
                    <p class="eyebrow">Remote Listener</p>
                    <h2>Exposure</h2>
                </div>
                <span class="pill">@(_currentRemoteAccess?.IsEnabled == true ? "Enabled" : "Disabled")</span>
            </div>

            <div class="info-grid">
                <div class="info-item">
                    <span class="info-label">Endpoint</span>
                    <span class="info-value">@(_currentRemoteAccess?.IsEnabled == true ? $"https://{(_currentRemoteAccess.PublicHostname ?? _currentRemoteAccess.BindAddress)}:{_currentRemoteAccess.HttpsPort}" : "Not exposed")</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Bind address</span>
                    <span class="info-value">@(_currentRemoteAccess?.BindAddress ?? "Not configured")</span>
                </div>
                <div class="info-item">
                    <span class="info-label">HTTPS port</span>
                    <span class="info-value">@(_currentRemoteAccess?.HttpsPort.ToString() ?? "Not configured")</span>
                </div>
                <div class="info-item">
                    <span class="info-label">Firewall intent</span>
                    <span class="info-value">@(_currentRemoteAccess?.CreateFirewallRule == true ? "Remembered" : "Not set")</span>
                </div>
            </div>

            <div class="status-banner">
                <strong>Loopback setup link</strong>
                <p><code>@_localTwoFactorPath</code></p>
            </div>
        </section>

        <section class="card">
            <div class="card-heading">
                <div>
                    <p class="eyebrow">Readiness</p>
                    <h2>Security Preconditions</h2>
                </div>
            </div>

            <div class="status-banner status-banner--warm">
                <strong>Owner account readiness</strong>
                <p>Owner accounts with 2FA: @_ownerAccountsWithTwoFactor</p>
            </div>

            <p class="muted-text">If this is 0, remote access cannot be enabled yet. Set up TOTP locally first at <a href="/Account/Manage/EnableAuthenticator">Enable Authenticator</a>.</p>
        </section>
    </div>

    <section class="card">
        <div class="card-heading">
            <div>
                <p class="eyebrow">Settings</p>
                <h2>HTTPS Listener Configuration</h2>
            </div>
        </div>

        <p class="muted-text">Saving these settings updates the host configuration. Restart the host afterwards to apply HTTPS binding changes.</p>

        <div class="admin-grid">
            <label class="checkbox-label">
                <input type="checkbox" @bind="_model.IsEnabled" />
                <span>Enable remote HTTPS access</span>
            </label>
            <label>
                <span>Bind IPv4 address</span>
                <input @bind="_model.BindAddress" />
            </label>
            <label>
                <span>HTTPS port</span>
                <input @bind="_model.HttpsPort" type="number" min="1" max="65535" />
            </label>
            <label>
                <span>Public hostname</span>
                <input @bind="_model.PublicHostname" />
            </label>
            <label>
                <span>PFX certificate path</span>
                <input @bind="_model.CertificatePath" />
            </label>
            <label>
                <span>PFX password</span>
                <input @bind="_model.CertificatePassword" type="password" />
            </label>
            <label class="checkbox-label">
                <input type="checkbox" @bind="_model.CreateFirewallRule" />
                <span>Remember firewall rule intent</span>
            </label>
        </div>

        <div class="workspace-actions">
            <button class="nav-button" type="button" @onclick="SaveAsync">Save Remote Settings</button>
            <a class="nav-button secondary-button" href="/users">Users</a>
        </div>
    </section>
</div>

@code {
    private readonly RemoteAccessInput _model = new();
    private RemoteAccessSettings? _currentRemoteAccess;
    private string _localTwoFactorPath = string.Empty;
    private int _ownerAccountsWithTwoFactor;
    private string? _statusMessage;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var settings = await HostSettingsStore.GetAsync();
        _currentRemoteAccess = settings.RemoteAccess;
        _localTwoFactorPath = $"http://127.0.0.1:{settings.LoopbackPort}/Account/Manage/EnableAuthenticator";
        _model.Load(settings.RemoteAccess);

        var users = await UserManagementService.ListAsync();
        _ownerAccountsWithTwoFactor = users.Count(user =>
            user.TwoFactorEnabled &&
            user.Roles.Contains(UserRole.Owner));
    }

    private async Task SaveAsync()
    {
        try
        {
            var dto = new RemoteAccessSettingsDto(
                _model.IsEnabled,
                _model.BindAddress,
                _model.HttpsPort,
                NullIfWhiteSpace(_model.PublicHostname),
                NullIfWhiteSpace(_model.CertificatePath),
                NullIfWhiteSpace(_model.CertificatePassword),
                _model.CreateFirewallRule);

            RemoteAccessSettingsValidator.Validate(dto);
            if (dto.IsEnabled)
            {
                await UserManagementService.EnsureRemoteAccessReadyAsync();
            }

            var current = await HostSettingsStore.GetAsync();
            await HostSettingsStore.UpdateAsync(current with
            {
                RemoteAccess = new RemoteAccessSettings
                {
                    IsEnabled = dto.IsEnabled,
                    BindAddress = dto.BindAddress,
                    HttpsPort = dto.HttpsPort,
                    PublicHostname = dto.PublicHostname,
                    CertificatePath = dto.CertificatePath,
                    CreateFirewallRule = dto.CreateFirewallRule,
                    RequiresHostRestart = true,
                },
            }, dto.CertificatePassword);
            await AuditStore.WriteAsync("remote.access.updated", "host", "web", "Updated remote access settings.", HttpContext.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value);

            _statusMessage = "Saved remote access settings. Restart the host to apply HTTPS binding changes.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _statusMessage = ex.Message;
        }
    }

    private static string? NullIfWhiteSpace(string value) =>
        string.IsNullOrWhiteSpace(value) ? null : value.Trim();

    private sealed class RemoteAccessInput
    {
        public bool IsEnabled { get; set; }

        public string BindAddress { get; set; } = "0.0.0.0";

        public int HttpsPort { get; set; } = 8443;

        public string PublicHostname { get; set; } = string.Empty;

        public string CertificatePath { get; set; } = string.Empty;

        public string CertificatePassword { get; set; } = string.Empty;

        public bool CreateFirewallRule { get; set; }

        public void Load(RemoteAccessSettings settings)
        {
            IsEnabled = settings.IsEnabled;
            BindAddress = settings.BindAddress;
            HttpsPort = settings.HttpsPort;
            PublicHostname = settings.PublicHostname ?? string.Empty;
            CertificatePath = settings.CertificatePath ?? string.Empty;
            CertificatePassword = string.Empty;
            CreateFirewallRule = settings.CreateFirewallRule;
        }
    }
}
