@page "/users"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Owner,Admin")]
@using PZServerLauncher.Contracts.Profiles
@using PZServerLauncher.Contracts.Runtime
@using PZServerLauncher.Core.Runtime
@using PZServerLauncher.Host.Services
@inject AuditStore AuditStore
@inject HostSettingsStore HostSettingsStore
@inject UserManagementService UserManagementService

<PageTitle>User Management</PageTitle>

@{
    var summary = Summary;
}

<div class="home-shell">
    <section class="workspace-panel hero-panel">
        <div class="workspace-panel__copy">
            <p class="eyebrow">Web Admin</p>
            <h1>User Management</h1>
            <p class="muted-text">Create local username accounts, shape role coverage, and verify which privileged users still need an authenticator app before the optional remote surface is trusted. This page mirrors the desktop guardrails so the same access rules stay visible everywhere.</p>
            <p class="muted-text">@summary.RosterHeadline</p>
            <p class="muted-text">@summary.SecurityHeadline</p>
        </div>

        <div class="workspace-actions">
            <span class="pill">@summary.OwnerHeadline</span>
            <span class="pill">@summary.RoleCoverageHeadline</span>
            <span class="pill">@BuildPendingTwoFactorSummary()</span>
            <span class="pill">@summary.CreateRoleHeadline</span>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <section class="card status-card status-line">
            <p>@_statusMessage</p>
        </section>
    }

    @if (!_ownerBootstrapConfigured)
    {
        <section class="card status-card">
            <strong>Desktop action required</strong>
            <p>Owner bootstrap is desktop-only. Open the desktop launcher and use Users > Create Owner Account.</p>
        </section>
    }

    <section class="metric-grid metric-grid--host">
        <article class="metric-card">
            <span class="metric-label">Users</span>
            <strong class="metric-value">@_users.Count</strong>
            <span class="metric-note">@summary.RosterHeadline</span>
        </article>
        <article class="metric-card">
            <span class="metric-label">Privileged Accounts</span>
            <strong class="metric-value">@_users.Count(user => string.Equals(user.RoleName, nameof(UserRole.Owner), StringComparison.Ordinal) || string.Equals(user.RoleName, nameof(UserRole.Admin), StringComparison.Ordinal))</strong>
            <span class="metric-note">@summary.SecurityHeadline</span>
        </article>
        <article class="metric-card">
            <span class="metric-label">2FA Enabled</span>
            <strong class="metric-value">@_users.Count(user => user.TwoFactorEnabled)</strong>
            <span class="metric-note">@summary.ReviewHeadline</span>
        </article>
        <article class="metric-card">
            <span class="metric-label">2FA Required</span>
            <strong class="metric-value">@_users.Count(user => user.RequiresTwoFactor)</strong>
            <span class="metric-note">@summary.CreateRoleGuardrailHeadline</span>
        </article>
    </section>

    <div class="cards cards--wide">
        <section class="card">
            <div class="card-heading">
                <div>
                    <p class="eyebrow">Security Posture</p>
                    <h2>Privileged Access</h2>
                </div>
            </div>

            <p class="muted-text">@summary.OperatorSummary</p>
            <p class="muted-text">@summary.NextStepSummary</p>
        </section>

        <section class="card">
            <div class="card-heading">
                <div>
                    <p class="eyebrow">Role Coverage</p>
                    <h2>Account Mix</h2>
                </div>
            </div>

            <p class="muted-text">@summary.RoleCoverageHeadline</p>
        </section>

        <section class="card">
            <div class="card-heading">
                <div>
                    <p class="eyebrow">Recommended Next Step</p>
                    <h2>Operator Guidance</h2>
                </div>
            </div>

            <p class="muted-text">@summary.ReviewHeadline</p>
            <p class="muted-text">@summary.CreateRoleHeadline</p>
            <p class="muted-text">@summary.CreateRoleGuardrailHeadline</p>
        </section>

        <section class="card">
            <div class="card-heading">
                <div>
                    <p class="eyebrow">Create Guardrails</p>
                    <h2>New Account Policy</h2>
                </div>
            </div>

            <p class="muted-text">@summary.CreateRoleHeadline</p>
            <p class="muted-text">@summary.CreateRoleGuardrailHeadline</p>
        </section>
    </div>

    <section class="card">
        <div class="card-heading">
            <div>
                <p class="eyebrow">Operator Checklist</p>
                <h2>Access Review</h2>
            </div>
            <span class="pill">@($"{summary.Checklist.Count} item(s)")</span>
        </div>

        <p class="muted-text">Use this checklist to decide whether the user roster is still owner-only, ready for shared administration, or still waiting on TOTP before the remote surface can be trusted.</p>

        @if (summary.Checklist.Count == 0)
        {
            <div class="empty-state">
                <p>No checklist items are available yet.</p>
            </div>
        }
        else
        {
            <div class="users-table">
                <table>
                    <thead>
                        <tr>
                            <th>Status</th>
                            <th>Check</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in summary.Checklist)
                        {
                            <tr>
                                <td>@item.StatusLabel</td>
                                <td>@item.Message</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="card">
        <div class="card-heading">
            <div>
                <p class="eyebrow">Create User</p>
                <h2>New Account</h2>
            </div>
            <span class="pill">Owner and Admin require TOTP</span>
        </div>

        <p class="muted-text">Owner and Admin accounts must configure TOTP before they can sign in to the web admin.</p>
        <p class="muted-text">Passwords stay local to this machine. If someone is locked out, an owner can assign a temporary password here and the user can change it after signing in.</p>
        <p class="muted-text">@summary.CreateRoleHeadline</p>
        <p class="muted-text">@summary.CreateRoleGuardrailHeadline</p>

        <div class="admin-grid">
            <label>
                <span>Username</span>
                <input @bind="_createUser.UserName" />
            </label>
            <label>
                <span>Temporary Password</span>
                <input @bind="_createUser.Password" type="password" />
            </label>
            <label>
                <span>Role</span>
                <select @bind="_createUser.RoleName">
                    @foreach (var roleName in ManagedRoleNames)
                    {
                        <option value="@roleName">@roleName</option>
                    }
                </select>
            </label>
        </div>

        <div class="workspace-actions">
            <button class="nav-button" type="button" @onclick="CreateAsync">Create User</button>
            <a class="nav-button secondary-button" href="/remote">Remote Access</a>
        </div>
    </section>

    <section class="card">
        <div class="card-heading">
            <div>
                <p class="eyebrow">Current Users</p>
                <h2>Account Registry</h2>
            </div>
            <span class="pill">@BuildPendingTwoFactorSummary()</span>
        </div>

        <p class="muted-text">This view assigns one application role per account and keeps the important guardrails visible while you edit.</p>
        <p class="muted-text">@summary.RosterHeadline</p>

        @if (_users.Count == 0)
        {
            <div class="empty-state">
                <p>No users found.</p>
            </div>
        }
        else
        {
            <div class="users-table">
                <table>
                    <thead>
                        <tr>
                            <th>Username</th>
                            <th>Role</th>
                            <th>Security</th>
                            <th>Password Reset</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _users)
                        {
                            <tr>
                                <td><input @bind="row.UserName" /></td>
                                <td>
                                    <select @bind="row.RoleName">
                                        @foreach (var roleName in ManagedRoleNames)
                                        {
                                            <option value="@roleName">@roleName</option>
                                        }
                                    </select>
                                    <div class="table-subtext">@BuildRowRoleSummary(row)</div>
                                </td>
                                <td>
                                    <div>@BuildRowSecuritySummary(row)</div>
                                    <div class="table-subtext">@((row.TwoFactorEnabled ? "TOTP is enabled." : row.RequiresTwoFactor ? "Finish TOTP before remote sign-in." : "This account can stay low risk."))</div>
                                </td>
                                <td>
                                    <input @bind="row.TemporaryPassword" type="password" placeholder="Temporary password" />
                                    <div class="table-subtext">Users can change it later from Account > Password.</div>
                                </td>
                                <td class="actions-cell">
                                    <button type="button"
                                            class="nav-button"
                                            @onclick="() => ResetPasswordAsync(row)"
                                            disabled="@(!CanResetPasswords || string.IsNullOrWhiteSpace(row.TemporaryPassword))">
                                        Reset Password
                                    </button>
                                    <button type="button" class="nav-button" @onclick="() => SaveAsync(row)">Save Changes</button>
                                    <button type="button" class="nav-button secondary-button" @onclick="() => DeleteAsync(row)">Remove Account</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>

@code {
    private static readonly string[] ManagedRoleNames =
    [
        nameof(UserRole.Owner),
        nameof(UserRole.Admin),
        nameof(UserRole.Operator),
        nameof(UserRole.Viewer),
    ];

    private readonly CreateUserInput _createUser = new();
    private readonly List<EditableUserRow> _users = [];
    private bool _ownerBootstrapConfigured;
    private string? _statusMessage;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private ProjectZomboidUserAccessSummary Summary =>
        ProjectZomboidUserAccessSummaryBuilder.Build(
            _ownerBootstrapConfigured,
            _users.Select(row => new UserAccountDto(
                row.UserId,
                row.UserName,
                [Enum.Parse<UserRole>(row.RoleName, ignoreCase: true)],
                row.TwoFactorEnabled)).ToArray(),
            _createUser.RoleName);

    private bool CanResetPasswords =>
        HttpContext.User.IsInRole(nameof(UserRole.Owner)) ||
        HttpContext.User.IsInRole(nameof(UserRole.LocalSystem));

    private async Task ReloadAsync()
    {
        var settings = await HostSettingsStore.GetAsync();
        _ownerBootstrapConfigured = settings.OwnerBootstrap.IsConfigured;
        var users = await UserManagementService.ListAsync();
        _users.Clear();
        _users.AddRange(users.Select(MapRow));
    }

    private async Task CreateAsync()
    {
        try
        {
            var created = await UserManagementService.CreateAsync(new CreateUserRequestDto(
                _createUser.UserName,
                _createUser.Password,
                [Enum.Parse<UserRole>(_createUser.RoleName, ignoreCase: true)]));
            await AuditStore.WriteAsync("user.created", created.UserId, "web", $"Created user {created.UserName}.", CurrentUserId);

            _statusMessage = $"Created user {_createUser.UserName}.";
            _createUser.Reset();
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _statusMessage = ex.Message;
        }
    }

    private async Task SaveAsync(EditableUserRow row)
    {
        try
        {
            await UserManagementService.UpdateAsync(
                row.UserId,
                new UpdateUserRequestDto(
                    row.UserName,
                    [Enum.Parse<UserRole>(row.RoleName, ignoreCase: true)]),
                actingUserId: CurrentUserId);
            await AuditStore.WriteAsync("user.updated", row.UserId, "web", $"Updated user {row.UserName}.", CurrentUserId);

            _statusMessage = $"Saved {row.UserName}.";
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _statusMessage = ex.Message;
        }
    }

    private async Task DeleteAsync(EditableUserRow row)
    {
        try
        {
            await UserManagementService.DeleteAsync(row.UserId, actingUserId: CurrentUserId);
            await AuditStore.WriteAsync("user.deleted", row.UserId, "web", $"Deleted user {row.UserName}.", CurrentUserId);
            _statusMessage = $"Deleted {row.UserName}.";
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _statusMessage = ex.Message;
        }
    }

    private async Task ResetPasswordAsync(EditableUserRow row)
    {
        if (!CanResetPasswords)
        {
            _statusMessage = "Only an owner can reset another user's password from the web admin.";
            return;
        }

        if (string.IsNullOrWhiteSpace(row.TemporaryPassword))
        {
            _statusMessage = "Enter a temporary password before resetting this account.";
            return;
        }

        try
        {
            await UserManagementService.ResetPasswordAsync(row.UserId, row.TemporaryPassword);
            await AuditStore.WriteAsync("user.password-reset", row.UserId, "web", $"Reset password for {row.UserName}.", CurrentUserId);
            row.TemporaryPassword = string.Empty;
            _statusMessage = $"Reset password for {row.UserName}.";
        }
        catch (Exception ex)
        {
            _statusMessage = ex.Message;
        }
    }

    private static EditableUserRow MapRow(UserAccountDto user)
    {
        var role = user.Roles.FirstOrDefault(role => role != UserRole.LocalSystem);
        return new EditableUserRow(
            user.UserId,
            user.UserName,
            role == default ? nameof(UserRole.Viewer) : role.ToString(),
            user.TwoFactorEnabled,
            user.Roles.Any(UserManagementService.RoleRequiresTwoFactor));
    }

    private string? CurrentUserId =>
        HttpContext.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

    private string BuildPendingTwoFactorSummary()
    {
        var pending = _users.Count(user => user.RequiresTwoFactor && !user.TwoFactorEnabled);
        return pending == 0
            ? "Privileged 2FA ready"
            : $"{pending} privileged user(s) need 2FA";
    }

    private static string BuildRowRoleSummary(EditableUserRow row) =>
        row.RoleName switch
        {
            nameof(UserRole.Owner) => "Owner keeps emergency recovery access.",
            nameof(UserRole.Admin) => "Admin can manage configuration and remote access.",
            nameof(UserRole.Operator) => "Operator can handle lifecycle and backups.",
            nameof(UserRole.Viewer) => "Viewer is read-only and lowest risk.",
            _ => "Custom role selection.",
        };

    private static string BuildRowSecuritySummary(EditableUserRow row) =>
        row.RequiresTwoFactor
            ? row.TwoFactorEnabled
                ? "Privileged account with TOTP enabled."
                : "Privileged account; finish TOTP before web sign-in."
            : row.TwoFactorEnabled
                ? "Lower-risk account with optional TOTP."
                : "Lower-risk account with no web-sign-in requirement.";

    private sealed class CreateUserInput
    {
        public string UserName { get; set; } = string.Empty;

        public string Password { get; set; } = string.Empty;

        public string RoleName { get; set; } = nameof(UserRole.Viewer);

        public void Reset()
        {
            UserName = string.Empty;
            Password = string.Empty;
            RoleName = nameof(UserRole.Viewer);
        }
    }

    private sealed class EditableUserRow(
        string userId,
        string userName,
        string roleName,
        bool twoFactorEnabled,
        bool requiresTwoFactor)
    {
        public string UserId { get; } = userId;

        public string UserName { get; set; } = userName;

        public string RoleName { get; set; } = roleName;

        public bool TwoFactorEnabled { get; } = twoFactorEnabled;

        public bool RequiresTwoFactor { get; } = requiresTwoFactor;

        public string TemporaryPassword { get; set; } = string.Empty;
    }
}
