@page "/users"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Owner,Admin")]
@using PZServerLauncher.Contracts.Runtime
@using PZServerLauncher.Core.Runtime
@using PZServerLauncher.Host.Services
@inject AuditStore AuditStore
@inject UserManagementService UserManagementService

<PageTitle>User Management</PageTitle>

<div class="home-shell">
    <section class="workspace-panel hero-panel">
        <div class="workspace-panel__copy">
            <p class="eyebrow">Web Admin</p>
            <h1>User Management</h1>
            <p class="muted-text">Create local accounts, shape role coverage, and verify which privileged users still need an authenticator app before the optional remote surface is trusted. This page mirrors the desktop guardrails so the same access rules stay visible everywhere.</p>
        </div>

        <div class="workspace-actions">
            <span class="pill">Users @_users.Count</span>
            <span class="pill">Owners @_users.Count(user => string.Equals(user.RoleName, nameof(UserRole.Owner), StringComparison.Ordinal))</span>
            <span class="pill">Admins @_users.Count(user => string.Equals(user.RoleName, nameof(UserRole.Admin), StringComparison.Ordinal))</span>
            <span class="pill">Operators @_users.Count(user => string.Equals(user.RoleName, nameof(UserRole.Operator), StringComparison.Ordinal))</span>
            <span class="pill">@BuildPendingTwoFactorSummary()</span>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <section class="card status-card status-line">
            <p>@_statusMessage</p>
        </section>
    }

    <section class="metric-grid metric-grid--host">
        <article class="metric-card">
            <span class="metric-label">Users</span>
            <strong class="metric-value">@_users.Count</strong>
            <span class="metric-note">Local accounts in the web admin</span>
        </article>
        <article class="metric-card">
            <span class="metric-label">Privileged Accounts</span>
            <strong class="metric-value">@_users.Count(user => string.Equals(user.RoleName, nameof(UserRole.Owner), StringComparison.Ordinal) || string.Equals(user.RoleName, nameof(UserRole.Admin), StringComparison.Ordinal))</strong>
            <span class="metric-note">Owners and admins with elevated access</span>
        </article>
        <article class="metric-card">
            <span class="metric-label">2FA Enabled</span>
            <strong class="metric-value">@_users.Count(user => user.TwoFactorEnabled)</strong>
            <span class="metric-note">Accounts protected by authenticator apps</span>
        </article>
        <article class="metric-card">
            <span class="metric-label">2FA Required</span>
            <strong class="metric-value">@_users.Count(user => user.RequiresTwoFactor)</strong>
            <span class="metric-note">Accounts that must finish setup before sign-in</span>
        </article>
    </section>

    <div class="cards cards--wide">
        <section class="card">
            <div class="card-heading">
                <div>
                    <p class="eyebrow">Security Posture</p>
                    <h2>Privileged Access</h2>
                </div>
            </div>

            <p class="muted-text">@BuildSecurityPostureSummary()</p>
            <p class="muted-text">@BuildOwnerGuardrailSummary()</p>
        </section>

        <section class="card">
            <div class="card-heading">
                <div>
                    <p class="eyebrow">Role Coverage</p>
                    <h2>Account Mix</h2>
                </div>
            </div>

            <p class="muted-text">@BuildRoleCoverageSummary()</p>
        </section>

        <section class="card">
            <div class="card-heading">
                <div>
                    <p class="eyebrow">Recommended Next Step</p>
                    <h2>Operator Guidance</h2>
                </div>
            </div>

            <p class="muted-text">@BuildUsersNextStepSummary()</p>
            <p class="muted-text">@BuildPendingChangeSummary()</p>
        </section>

        <section class="card">
            <div class="card-heading">
                <div>
                    <p class="eyebrow">Create Guardrails</p>
                    <h2>New Account Policy</h2>
                </div>
            </div>

            <p class="muted-text">@BuildCreateRoleSummary()</p>
            <p class="muted-text">@BuildCreateRoleGuardrailSummary()</p>
        </section>
    </div>

    <section class="card">
        <div class="card-heading">
            <div>
                <p class="eyebrow">Create User</p>
                <h2>New Account</h2>
            </div>
            <span class="pill">Owner and Admin require TOTP</span>
        </div>

        <p class="muted-text">Owner and Admin accounts must configure TOTP before they can sign in to the web admin.</p>
        <p class="muted-text">@BuildCreateRoleSummary()</p>
        <p class="muted-text">@BuildCreateRoleGuardrailSummary()</p>

        <div class="admin-grid">
            <label>
                <span>Username</span>
                <input @bind="_createUser.UserName" />
            </label>
            <label>
                <span>Email</span>
                <input @bind="_createUser.Email" />
            </label>
            <label>
                <span>Temporary Password</span>
                <input @bind="_createUser.Password" type="password" />
            </label>
            <label>
                <span>Role</span>
                <select @bind="_createUser.RoleName">
                    @foreach (var roleName in ManagedRoleNames)
                    {
                        <option value="@roleName">@roleName</option>
                    }
                </select>
            </label>
        </div>

        <div class="workspace-actions">
            <button class="nav-button" type="button" @onclick="CreateAsync">Create User</button>
            <a class="nav-button secondary-button" href="/remote">Remote Access</a>
        </div>
    </section>

    <section class="card">
        <div class="card-heading">
            <div>
                <p class="eyebrow">Current Users</p>
                <h2>Account Registry</h2>
            </div>
            <span class="pill">@BuildPendingTwoFactorSummary()</span>
        </div>

        <p class="muted-text">This view assigns one application role per account and keeps the important guardrails visible while you edit.</p>
        <p class="muted-text">@BuildRosterSummary()</p>

        @if (_users.Count == 0)
        {
            <div class="empty-state">
                <p>No users found.</p>
            </div>
        }
        else
        {
            <div class="users-table">
                <table>
                    <thead>
                        <tr>
                            <th>Username</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Security</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _users)
                        {
                            <tr>
                                <td><input @bind="row.UserName" /></td>
                                <td><input @bind="row.Email" /></td>
                                <td>
                                    <select @bind="row.RoleName">
                                        @foreach (var roleName in ManagedRoleNames)
                                        {
                                            <option value="@roleName">@roleName</option>
                                        }
                                    </select>
                                    <div class="table-subtext">@BuildRowRoleSummary(row)</div>
                                </td>
                                <td>
                                    <div>@BuildRowSecuritySummary(row)</div>
                                    <div class="table-subtext">@((row.TwoFactorEnabled ? "TOTP is enabled." : row.RequiresTwoFactor ? "Finish TOTP before remote sign-in." : "This account can stay low risk."))</div>
                                </td>
                                <td class="actions-cell">
                                    <button type="button" class="nav-button" @onclick="() => SaveAsync(row)">Save Changes</button>
                                    <button type="button" class="nav-button secondary-button" @onclick="() => DeleteAsync(row)">Remove Account</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>

@code {
    private static readonly string[] ManagedRoleNames =
    [
        nameof(UserRole.Owner),
        nameof(UserRole.Admin),
        nameof(UserRole.Operator),
        nameof(UserRole.Viewer),
    ];

    private readonly CreateUserInput _createUser = new();
    private readonly List<EditableUserRow> _users = [];
    private string? _statusMessage;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        var users = await UserManagementService.ListAsync();
        _users.Clear();
        _users.AddRange(users.Select(MapRow));
    }

    private async Task CreateAsync()
    {
        try
        {
            var created = await UserManagementService.CreateAsync(new CreateUserRequestDto(
                _createUser.UserName,
                _createUser.Email,
                _createUser.Password,
                [Enum.Parse<UserRole>(_createUser.RoleName, ignoreCase: true)]));
            await AuditStore.WriteAsync("user.created", created.UserId, "web", $"Created user {created.UserName}.", CurrentUserId);

            _statusMessage = $"Created user {_createUser.UserName}.";
            _createUser.Reset();
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _statusMessage = ex.Message;
        }
    }

    private async Task SaveAsync(EditableUserRow row)
    {
        try
        {
            await UserManagementService.UpdateAsync(
                row.UserId,
                new UpdateUserRequestDto(
                    row.UserName,
                    row.Email,
                    [Enum.Parse<UserRole>(row.RoleName, ignoreCase: true)]),
                actingUserId: CurrentUserId);
            await AuditStore.WriteAsync("user.updated", row.UserId, "web", $"Updated user {row.UserName}.", CurrentUserId);

            _statusMessage = $"Saved {row.UserName}.";
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _statusMessage = ex.Message;
        }
    }

    private async Task DeleteAsync(EditableUserRow row)
    {
        try
        {
            await UserManagementService.DeleteAsync(row.UserId, actingUserId: CurrentUserId);
            await AuditStore.WriteAsync("user.deleted", row.UserId, "web", $"Deleted user {row.UserName}.", CurrentUserId);
            _statusMessage = $"Deleted {row.UserName}.";
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _statusMessage = ex.Message;
        }
    }

    private static EditableUserRow MapRow(UserAccountDto user)
    {
        var role = user.Roles.FirstOrDefault(role => role != UserRole.LocalSystem);
        return new EditableUserRow(
            user.UserId,
            user.UserName,
            user.Email ?? string.Empty,
            role == default ? nameof(UserRole.Viewer) : role.ToString(),
            user.TwoFactorEnabled,
            user.Roles.Any(UserManagementService.RoleRequiresTwoFactor));
    }

    private string? CurrentUserId =>
        HttpContext.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

    private string BuildPendingTwoFactorSummary()
    {
        var pending = _users.Count(user => user.RequiresTwoFactor && !user.TwoFactorEnabled);
        return pending == 0
            ? "Privileged 2FA ready"
            : $"{pending} privileged user(s) need 2FA";
    }

    private string BuildRosterSummary()
    {
        if (_users.Count == 0)
        {
            return "No managed accounts exist yet. Keep the surface owner-only until you need more operators.";
        }

        return $"{_users.Count} account(s) total: {_users.Count(user => string.Equals(user.RoleName, nameof(UserRole.Owner), StringComparison.Ordinal))} owner, {_users.Count(user => string.Equals(user.RoleName, nameof(UserRole.Admin), StringComparison.Ordinal))} admin, {_users.Count(user => string.Equals(user.RoleName, nameof(UserRole.Operator), StringComparison.Ordinal))} operator, and {_users.Count(user => string.Equals(user.RoleName, nameof(UserRole.Viewer), StringComparison.Ordinal))} viewer.";
    }

    private string BuildSecurityPostureSummary()
    {
        if (_users.Count == 0)
        {
            return "No shared web-admin accounts exist yet. Keep the surface owner-only until you really need more operators.";
        }

        var pending = _users.Count(user => user.RequiresTwoFactor && !user.TwoFactorEnabled);
        return pending == 0
            ? "Every privileged account shown here has 2FA enabled."
            : $"{pending} privileged account(s) still need TOTP before web sign-in is safe.";
    }

    private string BuildOwnerGuardrailSummary()
    {
        var owners = _users.Count(user => string.Equals(user.RoleName, nameof(UserRole.Owner), StringComparison.Ordinal));
        if (owners == 0)
        {
            return "No owner accounts exist yet. That should only happen briefly while the first bootstrap is in progress.";
        }

        return owners == 1
            ? "One owner account protects the host. Keep it paired with TOTP and avoid adding a second owner unless you truly need it."
            : $"{owners} owner accounts exist. Keep at least one reserved for emergency recovery.";
    }

    private string BuildRoleCoverageSummary() =>
        $"{_users.Count(user => string.Equals(user.RoleName, nameof(UserRole.Owner), StringComparison.Ordinal))} owner | {_users.Count(user => string.Equals(user.RoleName, nameof(UserRole.Admin), StringComparison.Ordinal))} admin | {_users.Count(user => string.Equals(user.RoleName, nameof(UserRole.Operator), StringComparison.Ordinal))} operator | {_users.Count(user => string.Equals(user.RoleName, nameof(UserRole.Viewer), StringComparison.Ordinal))} viewer.";

    private string BuildUsersNextStepSummary()
    {
        if (_users.Count == 0)
        {
            return "Create the first operator or viewer account only if you truly need shared administration.";
        }

        return _users.Any(user => user.RequiresTwoFactor && !user.TwoFactorEnabled)
            ? "Finish TOTP enrollment for privileged users before you rely on remote web administration."
            : "Review whether every admin and operator still needs their current role, and keep elevated access as small as possible.";
    }

    private string BuildPendingChangeSummary()
    {
        var privilegedPending = _users.Count(user => user.RequiresTwoFactor && !user.TwoFactorEnabled);
        if (privilegedPending == 0)
        {
            return "No urgent account risk is visible right now.";
        }

        return $"{privilegedPending} privileged account(s) still need TOTP before remote access should be trusted.";
    }

    private static string BuildCreateRoleSummary(string roleName) =>
        roleName switch
        {
            nameof(UserRole.Owner) => "Owner is full control and should stay rare. It needs TOTP before the optional web admin will trust it.",
            nameof(UserRole.Admin) => "Admin can manage configuration and remote access, so keep the role narrow and pair it with TOTP.",
            nameof(UserRole.Operator) => "Operator can handle lifecycle, backups, and day-to-day maintenance without ownership transfer.",
            nameof(UserRole.Viewer) => "Viewer is read-only and is safest when someone only needs visibility into the host.",
            _ => "Custom role selection.",
        };

    private string BuildCreateRoleSummary() => BuildCreateRoleSummary(_createUser.RoleName);

    private string BuildCreateRoleGuardrailSummary() =>
        _createUser.RoleName is nameof(UserRole.Owner) or nameof(UserRole.Admin)
            ? "This is a privileged role. The account will require TOTP before web sign-in is considered safe."
            : "This role is intentionally lower risk and does not require TOTP by policy.";

    private static string BuildRowRoleSummary(EditableUserRow row) =>
        row.RoleName switch
        {
            nameof(UserRole.Owner) => "Owner keeps emergency recovery access.",
            nameof(UserRole.Admin) => "Admin can manage configuration and remote access.",
            nameof(UserRole.Operator) => "Operator can handle lifecycle and backups.",
            nameof(UserRole.Viewer) => "Viewer is read-only and lowest risk.",
            _ => "Custom role selection.",
        };

    private static string BuildRowSecuritySummary(EditableUserRow row) =>
        row.RequiresTwoFactor
            ? row.TwoFactorEnabled
                ? "Privileged account with TOTP enabled."
                : "Privileged account; finish TOTP before web sign-in."
            : row.TwoFactorEnabled
                ? "Lower-risk account with optional TOTP."
                : "Lower-risk account with no web-sign-in requirement.";

    private sealed class CreateUserInput
    {
        public string UserName { get; set; } = string.Empty;

        public string Email { get; set; } = string.Empty;

        public string Password { get; set; } = string.Empty;

        public string RoleName { get; set; } = nameof(UserRole.Viewer);

        public void Reset()
        {
            UserName = string.Empty;
            Email = string.Empty;
            Password = string.Empty;
            RoleName = nameof(UserRole.Viewer);
        }
    }

    private sealed class EditableUserRow(
        string userId,
        string userName,
        string email,
        string roleName,
        bool twoFactorEnabled,
        bool requiresTwoFactor)
    {
        public string UserId { get; } = userId;

        public string UserName { get; set; } = userName;

        public string Email { get; set; } = email;

        public string RoleName { get; set; } = roleName;

        public bool TwoFactorEnabled { get; } = twoFactorEnabled;

        public bool RequiresTwoFactor { get; } = requiresTwoFactor;
    }
}
