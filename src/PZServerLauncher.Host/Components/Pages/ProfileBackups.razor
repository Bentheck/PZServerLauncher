@page "/profiles/{ProfileId}/backups"
@attribute [Authorize]
@using System.Globalization
@using System.Text.RegularExpressions
@inject ProfileStore ProfileStore
@inject RuntimeStateStore RuntimeStateStore
@inject ServerBackupService BackupService
@inject ServerProcessSupervisor ProcessSupervisor
@inject AuditStore AuditStore
@using PZServerLauncher.Contracts.Profiles
@using PZServerLauncher.Core.Planning
@using PZServerLauncher.Core.Profiles
@using PZServerLauncher.Infrastructure.Planning

<PageTitle>Backups</PageTitle>

@if (_profile is null)
{
    <div class="home-shell">
        <div class="card">
            <p class="eyebrow">Profile Workspace</p>
            <h1>Profile not found</h1>
            <p class="muted-text">The selected profile could not be loaded.</p>
            <a class="nav-button" href="/profiles">Back to profiles</a>
        </div>
    </div>
}
else
{
    <ProfileWorkspaceShell Profile="@_profile"
                           ActivePage="backups"
                           RuntimeStatus="@_runtimeStatus"
                           InstallDetected="@_installDetected"
                           CacheDetected="@_cacheDetected">
        <Actions>
            <a class="nav-button secondary-button" href="@OverviewHref">Overview</a>
            <button class="nav-button" @onclick="CreateBackupAsync" disabled="@_busy">Create Backup</button>
            <button class="nav-button secondary-button" @onclick="RestoreSelectedAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_selectedBackup))">Restore Selected</button>
            <button class="nav-button secondary-button" @onclick="RestoreLatestAsync" disabled="@(_busy || string.IsNullOrWhiteSpace(_latestBackup))">Restore Latest</button>
            <button class="nav-button secondary-button" @onclick="ReloadAsync" disabled="@_busy">Reload</button>
        </Actions>
        <ChildContent>
            <section class="card">
                <div class="hero">
                    <div class="hero-copy">
                        <p class="eyebrow">Recovery Center</p>
                        <h1>@_profile.DisplayName</h1>
                        <p class="muted-text">Create manual snapshots, tune retention, and restore the right archive without digging through repeated recovery status.</p>
                    </div>
                    <div class="hero-pills">
                        <span class="pill">@_profile.Branch</span>
                        <span class="pill">@RecoveryPostureLabel</span>
                        <span class="pill">@BackupCountSummary</span>
                        <span class="pill pill--strong">@(_backupSummary?.LatestArchiveSummary ?? "Latest archive unavailable")</span>
                    </div>
                </div>
            </section>

            <div class="cards cards--wide">
                <section class="card">
                    <h2>Recovery Policy</h2>
                    <p class="muted-text">@(_backupSummary?.RetentionSummary ?? "Retention posture is unavailable.")</p>
                    <div class="field-grid">
                        <div class="field-card">
                            <span class="field-label">Manual Backups</span>
                            <span>@(_profile.BackupPolicy.KeepManualBackupsForever ? "Kept forever" : "Subject to retention policy")</span>
                        </div>
                        <div class="field-card">
                            <span class="field-label">Pre-Update</span>
                            <span>@(_profile.BackupPolicy.PreUpdateBackupEnabled ? $"Enabled, keep last {_profile.BackupPolicy.PreUpdateBackupRetentionCount}" : "Disabled")</span>
                        </div>
                        <div class="field-card">
                            <span class="field-label">Scheduled</span>
                            <span>@(_profile.BackupPolicy.ScheduledBackupsEnabled ? $"{ScheduledBackupPlanner.DescribeCadence(_profile.BackupPolicy)}, keep last {_profile.BackupPolicy.ScheduledBackupRetentionCount}" : "Disabled")</span>
                        </div>
                        <div class="field-card">
                            <span class="field-label">Latest Backup</span>
                            <span>@(_backupSummary?.LatestArchiveSummary ?? "Latest archive unavailable")</span>
                        </div>
                    </div>

                        <div class="profile-section">
                            <div class="admin-grid">
                                <label class="checkbox-label">
                                    <input type="checkbox" @bind="_scheduledBackupsEnabled" disabled="@_busy" />
                                    Enable scheduled backups
                                </label>
                                <label class="checkbox-label">
                                    <input type="checkbox" @bind="_preUpdateBackupEnabled" disabled="@_busy" />
                                    Create pre-update safety archives
                                </label>
                                <div>
                                    <span>Scheduled start time</span>
                                    <input placeholder="03:00" @bind="_scheduledStartLocalTime" disabled="@_busy" />
                                </div>
                                <div>
                                    <span>Repeat every (hours)</span>
                                    <input type="number" min="1" max="168" @bind="_scheduledIntervalHours" disabled="@_busy" />
                                </div>
                                <div>
                                    <span>Scheduled retention count</span>
                                    <input type="number" min="1" @bind="_scheduledRetentionCount" disabled="@_busy" />
                                </div>
                                <div>
                                    <span>Pre-update retention count</span>
                                    <input type="number" min="1" @bind="_preUpdateRetentionCount" disabled="@_busy" />
                                </div>
                                <label class="checkbox-label">
                                    <input type="checkbox" @bind="_keepManualBackupsForever" disabled="@_busy" />
                                    Keep manual backups forever
                                </label>
                            </div>
                        <div class="workspace-actions">
                            <button class="nav-button" @onclick="SavePolicyAsync" disabled="@_busy">Save Policy</button>
                            <button class="nav-button secondary-button" @onclick="ReloadAsync" disabled="@_busy">Reload</button>
                        </div>
                        <p class="muted-text">@PolicyEditorSummary</p>
                        <p class="muted-text">@ScheduledCadenceSummary</p>
                    </div>
                </section>

                <section class="card">
                    <h2>Restore Guidance</h2>
                    <p class="muted-text">@(_recoverySummary?.RestoreRiskHeadline ?? "Restore risk is unavailable.")</p>
                    <label class="checkbox-label">
                        <input type="checkbox" @bind="_restartAfterRestore" @bind:after="RefreshBackupSummary" disabled="@_busy" />
                        Restart server after restore
                    </label>
                    <p class="muted-text">@BuildRestoreModeSummary()</p>
                    <p class="muted-text">@BuildRestoreSafetyCopy()</p>
                    <p class="muted-text">@(_recoverySummary?.OperatorSummary ?? "Recovery guidance is unavailable.")</p>
                </section>
            </div>

            <div class="cards cards--wide">
                <section class="card">
                    <h2>Backup History</h2>
                    <p class="muted-text">Pick the archive you want to inspect or restore. The latest known-good archive stays highlighted so you can find the safest rollback point quickly.</p>

                    <div class="profile-section">
                        <div class="admin-grid">
                            <div>
                                <span>Available Backups</span>
                                @if (_backupEntries.Count == 0)
                                {
                                    <div class="settings-banner settings-banner--warning">
                                        <strong>No backups yet.</strong>
                                        <p>Create the first manual archive from this page or from Overview.</p>
                                    </div>
                                }
                                else
                                {
                                    <div class="stack-list">
                                        @foreach (var backup in _backupEntries)
                                        {
                                            <label class="field-card">
                                                <input type="radio"
                                                       name="selected-backup"
                                                       checked="@string.Equals(_selectedBackup, backup.FileName, StringComparison.Ordinal)"
                                                       @onchange="@(() => SelectBackup(backup.FileName))"
                                                       disabled="@_busy" />
                                                <span class="field-label">@backup.Title</span>
                                                <span>@backup.KindLabel | @backup.TimestampLabel</span>
                                                <span class="muted-text">@GetArchiveTriageLabel(backup)</span>
                                                <span class="muted-text">@backup.FileLabel</span>
                                            </label>
                                        }
                                    </div>
                                }
                            </div>

                            <div>
                                <span>Selected Backup</span>
                                <input value="@SelectedBackupHeadline" disabled />
                                <input value="@(_backupSummary?.SelectedArchiveSummary ?? "No recovery point is currently selected.")" disabled />
                                <input value="@(_selectedBackupEntry?.TimestampLabel ?? "Timestamp unavailable.")" disabled />
                                <input value="@SelectedBackupTriage" disabled />
                            </div>
                        </div>
                    </div>

                    @if (_backups.Count == 0)
                    {
                        <div class="settings-banner settings-banner--warning">
                            <strong>No backups exist yet.</strong>
                            <p>Create the first manual archive from this page or from Overview. Until then, there is no known-good restore point for this profile.</p>
                        </div>
                    }
                </section>

                <section class="card">
                    <h2>Recovery Briefing</h2>
                    <p class="muted-text">@(_recoverySummary?.SelectionSummary ?? "No recovery selection summary is available.")</p>
                    <p class="muted-text">@(_backupSummary?.ContinuitySummary ?? "Recovery continuity is unavailable.")</p>
                    <p class="muted-text">@LatestKnownGoodCallout</p>
                    <ul class="check-list">
                        @foreach (var item in _recoverySummary?.Checklist ?? Array.Empty<string>())
                        {
                            <li>@item</li>
                        }
                    </ul>
                </section>
            </div>

            <p class="muted-text">@_statusMessage</p>
        </ChildContent>
    </ProfileWorkspaceShell>
}

@code {
    [Parameter]
    public string ProfileId { get; set; } = string.Empty;

    private ServerProfile? _profile;
    private ServerRuntimeStatus? _runtimeStatus;
    private List<string> _backups = [];
    private bool _busy;
    private string? _statusMessage;
    private bool _installDetected;
    private bool _cacheDetected;
    private string? _selectedBackup;
    private List<BackupArchiveRow> _backupEntries = [];
    private BackupArchiveRow? _selectedBackupEntry;
    private bool _restartAfterRestore = true;
    private bool _scheduledBackupsEnabled;
    private string _scheduledRetentionCount = "10";
    private string _scheduledIntervalHours = BackupPolicy.DefaultScheduledBackupIntervalHours.ToString(CultureInfo.InvariantCulture);
    private string _scheduledStartLocalTime = BackupPolicy.DefaultScheduledBackupStartLocalTime;
    private bool _preUpdateBackupEnabled = true;
    private string _preUpdateRetentionCount = "5";
    private bool _keepManualBackupsForever = true;
    private ProjectZomboidBackupPostureSummary? _backupSummary;
    private ProjectZomboidRecoveryConsoleSummary? _recoverySummary;

    private static readonly Regex BackupPattern = new(
        "-(manual|preupdate|scheduled)-(\\d{8}-\\d{6})\\.zip$",
        RegexOptions.IgnoreCase | RegexOptions.CultureInvariant | RegexOptions.Compiled);

    private string? _latestBackup => _backups.FirstOrDefault();
    private string BackupCountSummary => _backupSummary is null
        ? "Archives unavailable"
        : $"{_backupSummary.TotalBackupCount} total | {_backupSummary.ManualBackupCount} manual | {_backupSummary.PreUpdateBackupCount} pre-update | {_backupSummary.ScheduledBackupCount} scheduled";
    private string SelectedBackupHeadline => _selectedBackupEntry?.Title ?? "No recovery point selected";
    private string RecoveryPostureLabel => _backups.Count == 0
        ? "No recovery point"
        : _restartAfterRestore
            ? "Restore-ready"
            : "Restore-safe";
    private string LatestKnownGoodCallout => _latestBackup is null
        ? "No latest known-good archive exists yet."
        : string.Equals(_selectedBackup, _latestBackup, StringComparison.Ordinal)
            ? $"The selected archive is the latest known-good restore point: {_selectedBackupEntry?.Title ?? _latestBackup}."
            : $"Latest known-good archive: {_backupEntries.FirstOrDefault(entry => string.Equals(entry.FileName, _latestBackup, StringComparison.Ordinal))?.Title ?? _latestBackup}.";
    private string SelectedBackupTriage => _selectedBackupEntry is null
        ? "No archive triage is available."
        : $"{_selectedBackupEntry.KindLabel} archive | {(_selectedBackupEntry.IsLatest ? "latest known-good" : "not latest")} | {_selectedBackupEntry.TimestampLabel}";
    private string PolicyEditorSummary => _profile is null
        ? "Select a profile to manage retention policy."
        : $"Scheduled backups {(_scheduledBackupsEnabled ? "enabled" : "disabled")} | pre-update safety {(_preUpdateBackupEnabled ? "enabled" : "disabled")} | manual backups {(_keepManualBackupsForever ? "kept forever" : "subject to retention")}.";
    private string ScheduledCadenceSummary => BuildScheduledCadenceSummary();

    protected override async Task OnParametersSetAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _profile = await ProfileStore.GetAsync(ProfileId);
        if (_profile is null)
        {
            return;
        }

        _runtimeStatus = RuntimeStateStore.GetOrDefault(ProfileId);
        _backups = BackupService.ListBackups(ProfileId).ToList();
        _backupEntries = _backups.Select((backup, index) => ParseBackupEntry(backup, index == 0)).ToList();
        ApplyPolicyEditor(_profile.BackupPolicy);
        if (_selectedBackup is null || !_backups.Contains(_selectedBackup, StringComparer.Ordinal))
        {
            _selectedBackup = _latestBackup;
        }
        _selectedBackupEntry = _backupEntries.FirstOrDefault(entry => string.Equals(entry.FileName, _selectedBackup, StringComparison.Ordinal));
        _installDetected = Directory.Exists(_profile.InstallDirectory);
        _cacheDetected = Directory.Exists(_profile.CacheDirectory);
        RefreshBackupSummary();
        _statusMessage = _backups.Count == 0
            ? "No backups exist yet. Create the first manual archive from this page."
            : $"Loaded {_backups.Count} backup archive(s) for {_profile.DisplayName}.";
    }

    private async Task CreateBackupAsync()
    {
        if (_profile is null)
        {
            return;
        }

        _busy = true;
        try
        {
            await BackupService.CreateBackupAsync(_profile.ProfileId, Core.Runtime.BackupTrigger.Manual, CancellationToken.None);
            _statusMessage = "Manual backup created.";
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _statusMessage = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SavePolicyAsync()
    {
        if (_profile is null)
        {
            return;
        }

        if (!int.TryParse(_scheduledRetentionCount, NumberStyles.Integer, CultureInfo.InvariantCulture, out var scheduledRetention) ||
            scheduledRetention < 1)
        {
            _statusMessage = "Scheduled retention count must be at least 1.";
            return;
        }

        if (!TryParseScheduledCadence(out var normalizedStartTime, out var intervalHours, out var cadenceValidationMessage))
        {
            _statusMessage = cadenceValidationMessage;
            return;
        }

        if (!int.TryParse(_preUpdateRetentionCount, NumberStyles.Integer, CultureInfo.InvariantCulture, out var preUpdateRetention) ||
            preUpdateRetention < 1)
        {
            _statusMessage = "Pre-update retention count must be at least 1.";
            return;
        }

        _busy = true;
        try
        {
            var updated = await ProfileStore.UpsertAsync(_profile with
            {
                BackupPolicy = new BackupPolicy
                {
                    ScheduledBackupsEnabled = _scheduledBackupsEnabled,
                    ScheduledBackupRetentionCount = scheduledRetention,
                    ScheduledBackupIntervalHours = intervalHours,
                    ScheduledBackupStartLocalTime = normalizedStartTime,
                    PreUpdateBackupEnabled = _preUpdateBackupEnabled,
                    PreUpdateBackupRetentionCount = preUpdateRetention,
                    KeepManualBackupsForever = _keepManualBackupsForever,
                },
                UpdatedAtUtc = DateTimeOffset.UtcNow,
            }, CancellationToken.None);

            await AuditStore.WriteAsync(
                "profile.backup-policy.updated",
                updated.ProfileId,
                "web",
                "Updated backup retention and recovery policy from web admin.",
                cancellationToken: CancellationToken.None);

            _profile = updated;
            ApplyPolicyEditor(updated.BackupPolicy);
            RefreshBackupSummary();
            _statusMessage = "Backup policy updated.";
        }
        catch (Exception ex)
        {
            _statusMessage = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task RestoreSelectedAsync()
    {
        if (_profile is null || string.IsNullOrWhiteSpace(_selectedBackup))
        {
            return;
        }

        await RestoreAsync(_selectedBackup);
    }

    private async Task RestoreLatestAsync()
    {
        if (_profile is null || string.IsNullOrWhiteSpace(_latestBackup))
        {
            return;
        }

        await RestoreAsync(_latestBackup);
    }

    private async Task RestoreAsync(string backupFileName)
    {
        if (_profile is null)
        {
            return;
        }

        _busy = true;
        try
        {
            var wasRunning = ProcessSupervisor.IsRunning(_profile.ProfileId);
            if (wasRunning)
            {
                await ProcessSupervisor.StopAsync(_profile.ProfileId, CancellationToken.None);
            }

            await BackupService.RestoreBackupAsync(_profile.ProfileId, backupFileName, CancellationToken.None);

            if (_restartAfterRestore)
            {
                await ProcessSupervisor.StartAsync(_profile, CancellationToken.None);
            }

            _statusMessage = _restartAfterRestore
                ? $"Restored {backupFileName} and restarted the server when possible."
                : $"Restored {backupFileName}.";
            await ReloadAsync();
        }
        catch (Exception ex)
        {
            _statusMessage = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void RefreshBackupSummary()
    {
        if (_profile is null)
        {
            _backupSummary = null;
            _selectedBackupEntry = null;
            return;
        }

        _selectedBackupEntry = _backupEntries.FirstOrDefault(entry => string.Equals(entry.FileName, _selectedBackup, StringComparison.Ordinal));
        _backupSummary = ProjectZomboidBackupPostureSummaryBuilder.Build(
            _profile,
            _backups,
            _selectedBackup,
            _runtimeStatus?.State.ToString() ?? "Stopped");
        _recoverySummary = ProjectZomboidRecoveryConsoleSummaryBuilder.Build(
            _backupSummary,
            _runtimeStatus?.State.ToString() ?? "Stopped",
            _installDetected,
            _cacheDetected,
            _restartAfterRestore,
            _selectedBackup,
            string.Equals(_selectedBackup, _latestBackup, StringComparison.Ordinal));
    }

    private void SelectBackup(string backupFileName)
    {
        _selectedBackup = backupFileName;
        RefreshBackupSummary();
    }

    private void ApplyPolicyEditor(BackupPolicy policy)
    {
        _scheduledBackupsEnabled = policy.ScheduledBackupsEnabled;
        _scheduledRetentionCount = policy.ScheduledBackupRetentionCount.ToString(CultureInfo.InvariantCulture);
        _scheduledIntervalHours = policy.ScheduledBackupIntervalHours.ToString(CultureInfo.InvariantCulture);
        _scheduledStartLocalTime = policy.ScheduledBackupStartLocalTime;
        _preUpdateBackupEnabled = policy.PreUpdateBackupEnabled;
        _preUpdateRetentionCount = policy.PreUpdateBackupRetentionCount.ToString(CultureInfo.InvariantCulture);
        _keepManualBackupsForever = policy.KeepManualBackupsForever;
    }

    private string BuildRestoreSafetyCopy()
    {
        var posture = _backupSummary?.RestoreSafetySummary ?? "Restore safety is unavailable.";
        return _restartAfterRestore
            ? $"{posture} The host will request a restart after recovery."
            : $"{posture} The server will stay offline afterward for inspection.";
    }

    private string BuildRestoreModeSummary() =>
        _restartAfterRestore
            ? "Restore mode: stop the server, unpack the archive, and request a restart."
            : "Restore mode: stop the server, unpack the archive, and leave it offline for inspection.";

    private bool TryParseScheduledCadence(out string normalizedStartTime, out int intervalHours, out string validationMessage)
    {
        normalizedStartTime = BackupPolicy.DefaultScheduledBackupStartLocalTime;
        intervalHours = BackupPolicy.DefaultScheduledBackupIntervalHours;
        validationMessage = string.Empty;

        if (!ScheduledBackupPlanner.TryParseStartLocalTime(_scheduledStartLocalTime, out var startTime))
        {
            validationMessage = "Scheduled backup start time must use 24-hour time like 03:00.";
            return false;
        }

        if (!int.TryParse(_scheduledIntervalHours, NumberStyles.Integer, CultureInfo.InvariantCulture, out intervalHours) ||
            !ScheduledBackupPlanner.IsValidIntervalHours(intervalHours))
        {
            validationMessage = "Scheduled backup interval must be a whole number between 1 and 168 hours.";
            return false;
        }

        normalizedStartTime = startTime.ToString("HH:mm", CultureInfo.InvariantCulture);
        return true;
    }

    private string BuildScheduledCadenceSummary()
    {
        if (_profile is null)
        {
            return "Select a profile to set scheduled backup timing.";
        }

        if (!_scheduledBackupsEnabled)
        {
            return "Scheduled backups are off. Turn them on to capture recurring restore points automatically.";
        }

        if (!TryParseScheduledCadence(out var normalizedStartTime, out var intervalHours, out _))
        {
            return "Set a 24-hour start time like 03:00 and an interval between 1 and 168 hours.";
        }

        var previewPolicy = _profile.BackupPolicy with
        {
            ScheduledBackupsEnabled = true,
            ScheduledBackupIntervalHours = intervalHours,
            ScheduledBackupStartLocalTime = normalizedStartTime,
        };

        var cadence = ScheduledBackupPlanner.DescribeCadence(previewPolicy);
        var nextRunUtc = ScheduledBackupPlanner.GetNextScheduledRunUtc(previewPolicy, DateTimeOffset.UtcNow);
        return nextRunUtc is null
            ? $"{char.ToUpperInvariant(cadence[0])}{cadence[1..]}."
            : $"{char.ToUpperInvariant(cadence[0])}{cadence[1..]}. Next scheduled archive: {nextRunUtc.Value.ToLocalTime():MMM d, yyyy 'at' h:mm tt}.";
    }

    private string OverviewHref => $"/profiles/{Uri.EscapeDataString(ProfileId)}/overview";

    private static string GetArchiveTriageLabel(BackupArchiveRow row)
    {
        var posture = row.IsLatest ? "latest known-good" : "alternate point";
        return $"{row.KindLabel} | {posture}";
    }

    private static BackupArchiveRow ParseBackupEntry(string backupFileName, bool isLatest)
    {
        var match = BackupPattern.Match(backupFileName);
        var (title, kindLabel) = match.Success
            ? match.Groups[1].Value.ToLowerInvariant() switch
            {
                "manual" => ("Manual Snapshot", "Manual"),
                "preupdate" => ("Pre-Update Safety Net", "Pre-Update"),
                "scheduled" => ("Scheduled Archive", "Scheduled"),
                _ => ("Recovery Archive", "Archive"),
            }
            : ("Recovery Archive", "Archive");

        var timestampLabel = "Timestamp unavailable.";
        if (match.Success &&
            DateTimeOffset.TryParseExact(
                match.Groups[2].Value,
                "yyyyMMdd-HHmmss",
                CultureInfo.InvariantCulture,
                DateTimeStyles.AssumeUniversal | DateTimeStyles.AdjustToUniversal,
                out var createdAtUtc))
        {
            timestampLabel = createdAtUtc.ToLocalTime().ToString("MMM d, yyyy 'at' h:mm tt", CultureInfo.CurrentCulture);
        }

        if (isLatest)
        {
            title = $"{title} (Latest)";
        }

        return new BackupArchiveRow(backupFileName, title, kindLabel, timestampLabel, backupFileName, isLatest);
    }

    private sealed record BackupArchiveRow(
        string FileName,
        string Title,
        string KindLabel,
        string TimestampLabel,
        string FileLabel,
        bool IsLatest);
}
