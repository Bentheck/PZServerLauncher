@page "/profiles/{ProfileId}/general"
@attribute [Authorize(Roles="Owner,Admin")]
@inject ProfileStore ProfileStore
@inject StructuredSettingsService StructuredSettingsService
@inject RuntimeStateStore RuntimeStateStore

<PageTitle>General</PageTitle>

@if (_profile is null)
{
    <div class="home-shell">
        <div class="card">
            <p class="eyebrow">Profile Workspace</p>
            <h1>Profile not found</h1>
            <p class="muted-text">The selected profile could not be loaded.</p>
            <a class="nav-button" href="/profiles">Back to profiles</a>
        </div>
    </div>
}
else
{
    <ProfileWorkspaceShell Profile="@_profile"
                           ActivePage="general"
                           RuntimeStatus="@_runtimeStatus"
                           InstallDetected="@_installDetected"
                           CacheDetected="@_cacheDetected">
        <Actions>
            <a class="nav-button secondary-button" href="@OverviewHref">Overview</a>
            <a class="nav-button secondary-button" href="@InstallHref">Install &amp; Update</a>
            <button class="nav-button" @onclick="SaveAsync" disabled="@_busy">Save General</button>
        </Actions>
        <ChildContent>
            <section class="workspace-panel hero-panel">
                <div class="workspace-panel__copy">
                    <p class="eyebrow">General</p>
                    <h1>@_profile.DisplayName</h1>
                    <p class="muted-text">This page now owns the Project Zomboid server browser identity, public listing behavior, spawn and loot lifecycle, respawn and cleanup rules, survival rules, safehouses, factions, trading, and the launcher runtime knobs that still belong to the host profile.</p>
                </div>

                <div class="workspace-actions">
                    <span class="pill">@_profile.Branch</span>
                    <span class="pill">@(_installDetected ? "Install detected" : "Install missing")</span>
                    <span class="pill">@(_cacheDetected ? "Cache ready" : "Cache missing")</span>
                    <span class="pill">@(_runtimeStatus?.State.ToString() ?? "Unknown runtime")</span>
                </div>
            </section>

            <section class="metric-grid metric-grid--host">
                <article class="metric-card">
                    <span class="metric-label">Public Listing</span>
                    <strong class="metric-value">@FormatBoolMetric(".server.public", "Public", "Private")</strong>
                    <span class="metric-note">@GetFieldValue(".server.public-name", _profile.DisplayName)</span>
                </article>
                <article class="metric-card">
                    <span class="metric-label">Player Slots</span>
                    <strong class="metric-value">@GetFieldValue(".server.max-players", "16")</strong>
                    <span class="metric-note">@FormatBoolMetric(".server.open", "Open signups", "Closed signups")</span>
                </article>
                <article class="metric-card">
                    <span class="metric-label">Runtime Memory</span>
                    <strong class="metric-value">@GetFieldValue(".runtime.memory", _profile.PreferredMemoryInGigabytes.ToString()) GB</strong>
                    <span class="metric-note">@FormatBoolMetric(".runtime.start-with-host", "Starts with host", "Manual host start")</span>
                </article>
                <article class="metric-card">
                    <span class="metric-label">Ports</span>
                    <strong class="metric-value">@GetFieldValue(".server.port", _profile.DefaultPort.ToString()) / @GetFieldValue(".server.rcon-port", _profile.RconPort.ToString())</strong>
                    <span class="metric-note">@_profile.ServerName namespace</span>
                </article>
            </section>

            <div class="cards cards--wide">
                <section class="card">
                    <div class="card-heading">
                        <div>
                            <p class="eyebrow">Structured Editor</p>
                            <h2>Server Browser &amp; Access</h2>
                        </div>
                        <span class="pill">Host-backed round-trip editing</span>
                    </div>

                    <p class="muted-text">These controls write actual Project Zomboid server INI values for public listing, player access, and world-facing behavior while leaving launcher-only runtime options in the profile.</p>

                    @if (_catalog is null || _page is null || _valueSet is null)
                    {
                        <div class="empty-state">
                            <p>Loading editor...</p>
                        </div>
                    }
                    else
                    {
                        @if (_valueSet.RequiresAdvancedFilesFallback)
                        {
                            <div class="settings-banner settings-banner--warning">
                                <strong>Structured editing is unavailable for this page.</strong>
                                <p>@(_valueSet.FallbackReason ?? "Use Advanced Files for the raw general server file.")</p>
                            </div>
                        }

                        @foreach (var sectionDef in _page.Sections)
                        {
                            <div class="profile-section">
                                <div class="profile-section__header">
                                    <h3>@sectionDef.Title</h3>
                                    <p class="muted-text">@DescribeGeneralSection(sectionDef.SectionId)</p>
                                </div>

                                <div class="field-grid">
                                    @foreach (var field in sectionDef.Fields)
                                    {
                                        <label class="field-card">
                                            <span class="field-label">@field.Label</span>
                                            @RenderField(field)
                                            @if (field.RequiresRestart)
                                            {
                                                <div class="field-meta">
                                                    <span class="field-pill">Restart required</span>
                                                </div>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(field.HelpText))
                                            {
                                                <small class="muted-text">@field.HelpText</small>
                                            }
                                            @if (_fieldErrors.TryGetValue(field.FieldId, out var errors))
                                            {
                                                @foreach (var error in errors)
                                                {
                                                    <span class="validation-message">@error</span>
                                                }
                                            }
                                        </label>
                                    }
                                </div>
                            </div>
                        }
                    }
                </section>

                <section class="card">
                    <div class="card-heading">
                        <div>
                            <p class="eyebrow">Workspace Snapshot</p>
                            <h2>Operator Context</h2>
                        </div>
                    </div>

                    <div class="info-grid">
                        <div class="info-item">
                            <span class="info-label">Server namespace</span>
                            <span class="info-value">@_profile.ServerName</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Runtime</span>
                            <span class="info-value">@(_runtimeStatus?.State.ToString() ?? "Unknown")</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Install</span>
                            <span class="info-value">@(_installDetected ? "Detected" : "Missing")</span>
                        </div>
                        <div class="info-item">
                            <span class="info-label">Cache</span>
                            <span class="info-value">@(_cacheDetected ? "Ready" : "Missing")</span>
                        </div>
                    </div>

                    <div class="status-banner status-banner--warm">
                        <strong>What this page owns</strong>
                        <p>Public identity, account openness, PvP/chat behavior, sleep and fire rules, safehouses, factions, trading, welcome message, and the primary gameplay-facing ports.</p>
                    </div>

                    @if (_pageValidation is not null)
                    {
                        <div class="card inner-card">
                            <div class="card-heading">
                                <div>
                                    <p class="eyebrow">Validation</p>
                                    <h3>Editor Feedback</h3>
                                </div>
                            </div>

                            @if (_pageValidation.PageErrors.Count == 0 && _pageValidation.FieldErrors.Count == 0)
                            {
                                <p class="muted-text">No validation errors.</p>
                            }
                            else
                            {
                                @if (_pageValidation.PageErrors.Count > 0)
                                {
                                    <ul class="stack-list">
                                        @foreach (var error in _pageValidation.PageErrors)
                                        {
                                            <li>@error</li>
                                        }
                                    </ul>
                                }

                                @if (_pageValidation.FieldErrors.Count > 0)
                                {
                                    <ul class="stack-list">
                                        @foreach (var entry in _pageValidation.FieldErrors)
                                        {
                                            @foreach (var error in entry.Value)
                                            {
                                                <li><strong>@entry.Key</strong> - @error</li>
                                            }
                                        }
                                    </ul>
                                }
                            }
                        </div>
                    }
                </section>
            </div>

            <p class="status-line">@_statusMessage</p>
        </ChildContent>
    </ProfileWorkspaceShell>
}

@code {
    [Parameter]
    public string ProfileId { get; set; } = string.Empty;

    private ServerProfile? _profile;
    private ServerRuntimeStatus? _runtimeStatus;
    private SettingsCatalogDto? _catalog;
    private SettingsPageDto? _page;
    private SettingsValueSetDto? _valueSet;
    private SettingsValidationResultDto? _pageValidation;
    private Dictionary<string, string?> _values = new(StringComparer.Ordinal);
    private Dictionary<string, IReadOnlyList<string>> _fieldErrors = new(StringComparer.Ordinal);
    private bool _busy;
    private string? _statusMessage;
    private bool _installDetected;
    private bool _cacheDetected;

    protected override async Task OnParametersSetAsync()
    {
        await ReloadAsync();
    }

    private async Task ReloadAsync()
    {
        _profile = await ProfileStore.GetAsync(ProfileId);
        if (_profile is null)
        {
            return;
        }

        _runtimeStatus = RuntimeStateStore.GetOrDefault(ProfileId);
        _catalog = StructuredSettingsService.GetCatalog(_profile);
        _page = _catalog.Pages.FirstOrDefault(page => string.Equals(page.PageId, "general", StringComparison.OrdinalIgnoreCase));
        _valueSet = StructuredSettingsService.GetPage(_profile, "general");
        _values = new Dictionary<string, string?>(_valueSet.Values, StringComparer.Ordinal);
        _fieldErrors = new Dictionary<string, IReadOnlyList<string>>(StringComparer.Ordinal);
        _pageValidation = null;
        _installDetected = Directory.Exists(_profile.InstallDirectory);
        _cacheDetected = Directory.Exists(_profile.CacheDirectory);
    }

    private async Task SaveAsync()
    {
        if (_profile is null)
        {
            return;
        }

        _busy = true;
        try
        {
            var result = await StructuredSettingsService.SaveAsync(_profile, "general", _values);
            _pageValidation = result.Validation;
            _fieldErrors = new Dictionary<string, IReadOnlyList<string>>(result.Validation.FieldErrors, StringComparer.Ordinal);
            _statusMessage = result.Validation.IsValid
                ? "General settings saved."
                : result.Validation.FallbackReason ?? "Validation failed.";

            if (result.Validation.IsValid && !result.Validation.RequiresAdvancedFilesFallback)
            {
                _profile = await ProfileStore.GetAsync(ProfileId);
                _valueSet = StructuredSettingsService.GetPage(_profile!, "general");
                _values = new Dictionary<string, string?>(_valueSet.Values, StringComparer.Ordinal);
            }
        }
        catch (Exception ex)
        {
            _statusMessage = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private RenderFragment RenderField(SettingsFieldDto field) => builder =>
    {
        var seq = 0;
        var value = _values.TryGetValue(field.FieldId, out var currentValue) ? currentValue ?? string.Empty : string.Empty;

        switch (field.Control)
        {
            case SettingsFieldControlKind.Checkbox:
                builder.OpenElement(seq++, "input");
                builder.AddAttribute(seq++, "type", "checkbox");
                builder.AddAttribute(seq++, "checked", bool.TryParse(value, out var parsed) && parsed);
                builder.AddAttribute(seq++, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this, args => SetValue(field.FieldId, args.Value?.ToString())));
                builder.CloseElement();
                break;
            case SettingsFieldControlKind.Numeric:
                builder.OpenElement(seq++, "input");
                builder.AddAttribute(seq++, "type", "number");
                builder.AddAttribute(seq++, "value", value);
                builder.AddAttribute(seq++, "oninput", EventCallback.Factory.Create<ChangeEventArgs>(this, args => SetValue(field.FieldId, args.Value?.ToString())));
                builder.CloseElement();
                break;
            case SettingsFieldControlKind.MultiLineText:
                builder.OpenElement(seq++, "textarea");
                builder.AddAttribute(seq++, "rows", "4");
                builder.AddAttribute(seq++, "value", value);
                builder.AddAttribute(seq++, "oninput", EventCallback.Factory.Create<ChangeEventArgs>(this, args => SetValue(field.FieldId, args.Value?.ToString())));
                builder.AddContent(seq++, value);
                builder.CloseElement();
                break;
            default:
                builder.OpenElement(seq++, "input");
                builder.AddAttribute(seq++, "type", "text");
                builder.AddAttribute(seq++, "value", value);
                builder.AddAttribute(seq++, "oninput", EventCallback.Factory.Create<ChangeEventArgs>(this, args => SetValue(field.FieldId, args.Value?.ToString())));
                builder.CloseElement();
                break;
        }
    };

    private void SetValue(string fieldId, string? value)
    {
        _values[fieldId] = value;
        _statusMessage = null;
    }

    private string GetFieldValue(string suffix, string? fallback = null)
    {
        var key = _values.Keys.FirstOrDefault(candidate => candidate.EndsWith(suffix, StringComparison.Ordinal));
        if (key is null)
        {
            return fallback ?? string.Empty;
        }

        var value = _values[key];
        return string.IsNullOrWhiteSpace(value) ? fallback ?? string.Empty : value;
    }

    private string FormatBoolMetric(string suffix, string trueLabel, string falseLabel)
    {
        var value = GetFieldValue(suffix);
        return bool.TryParse(value, out var parsed) && parsed ? trueLabel : falseLabel;
    }

    private static string DescribeGeneralSection(string sectionId) =>
        sectionId.EndsWith(".identity", StringComparison.Ordinal)
            ? "Visible name, description, and browser-facing access rules."
            : sectionId.EndsWith(".world-access", StringComparison.Ordinal)
                ? "Core server-side behavior that shapes how the world feels when players connect."
                : sectionId.EndsWith(".spawn-and-loot", StringComparison.Ordinal)
                    ? "Spawn kits, loot respawn cadence, and construction-based loot protection."
                : sectionId.EndsWith(".respawn-and-cleanup", StringComparison.Ordinal)
                    ? "Respawn behavior plus cleanup timers and item-removal lists for long-running worlds."
                : sectionId.EndsWith(".survival-rules", StringComparison.Ordinal)
                    ? "Sleep, fire, and death-announcement rules that shape multiplayer pacing."
                    : sectionId.EndsWith(".safehouses", StringComparison.Ordinal)
                        ? "Claiming, trespass, looting, and cleanup rules for player safehouses."
                        : sectionId.EndsWith(".factions-and-trade", StringComparison.Ordinal)
                            ? "Faction creation and direct player trading systems."
                : sectionId.EndsWith(".ports", StringComparison.Ordinal)
                    ? "Gameplay-facing ports plus launcher-managed runtime options."
                    : "Structured Project Zomboid general settings.";

    private string OverviewHref => $"/profiles/{Uri.EscapeDataString(ProfileId)}/overview";

    private string InstallHref => $"/profiles/{Uri.EscapeDataString(ProfileId)}/install-update";
}
