<Project>
  <PropertyGroup>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>latestMajor</LangVersion>
    <PZServerLauncherVersion>0.2.0</PZServerLauncherVersion>
    <Version>$(PZServerLauncherVersion)</Version>
    <PackageVersion>$(PZServerLauncherVersion)</PackageVersion>
    <InformationalVersion>$(PZServerLauncherVersion)</InformationalVersion>
  </PropertyGroup>
</Project>
